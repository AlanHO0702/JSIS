<script>
// Render field value in view mode.
function makeValueElement(field, rawVal) {
  const isCheckbox = Number(field?.ComboStyle ?? 0) === 1;
  if (isCheckbox) {
    const wrap = document.createElement('div');
    wrap.className = 'form-check m-0 d-inline-flex align-items-center';
    const chk = document.createElement('input');
    chk.type = 'checkbox';
    chk.className = 'form-check-input';
    chk.disabled = true;
    const val = rawVal == null ? '' : String(rawVal).toLowerCase();
    chk.checked = val === '1' || val === 'true' || val === 'y';
    wrap.appendChild(chk);
    return wrap;
  }
  const span = document.createElement('span');
  span.textContent = rawVal == null ? '' : rawVal;
  span.style.display = 'block';
  span.style.border = '1px solid #e5e7eb';
  span.style.background = '#f8fafc';
  span.style.padding = '1px 5px';
  span.style.borderRadius = '4px';
  span.style.minHeight = '14px';
  return span;
}

function normalizeEditColor(raw) {
  if (raw == null) return '';
  let s = String(raw).trim();
  if (!s) return '';
  if (s.toLowerCase().startsWith('cl')) s = s.substring(2);
  return s;
}

function applyEditColor(el, raw, important = false) {
  if (!el) return;
  const color = normalizeEditColor(raw);
  if (!color) return;
  if (important && typeof el.style?.setProperty === 'function') {
    el.style.setProperty('background-color', color, 'important');
  } else {
    el.style.backgroundColor = color;
  }
}

// ?梁嚗?鞈?颲剖摨扳?頧?銝??雿捆?函敶ｇ?銝餅??????堆?
function getLayoutRect(f) {
  const topPad = 6;
  const fieldGapX = 10;
  const sizeScale = 1.0;
  const n = (v, d = 0) => {
    const x = Number(v);
    return Number.isFinite(x) ? x : d;
  };

  const fTop = n(f.iFieldTop, 0) + topPad;
  const fLeft = n(f.iFieldLeft, 0);
  const rawFWidth = n(f.iFieldWidth, 0);
  const rawFHeight = n(f.iFieldHeight, 0);
  const fWidth = (rawFWidth > 0 ? rawFWidth : 160) * sizeScale;
  const fHeight = (rawFHeight > 0 ? rawFHeight : 22) * sizeScale;

  const hasLabel = !!String(f?.DisplayLabel ?? '').trim();
  const lTop = hasLabel ? (n(f.iLabTop, n(f.iFieldTop, 0)) + topPad) : fTop;
  const lLeft = hasLabel ? n(f.iLabLeft, 0) : fLeft;
  const rawLWidth = n(f.iLabWidth, 0);
  const rawLHeight = n(f.iLabHeight, 0);
  const lWidth = hasLabel ? ((rawLWidth > 0 ? rawLWidth : 90) * sizeScale) : 0;
  const lHeight = hasLabel ? ((rawLHeight > 0 ? rawLHeight : fHeight) * sizeScale) : 0;

  // Use field rect as the primary anchor; labels are rendered with relative offsets.
  // This matches dictionary coordinates more closely and avoids oversized field wrappers.
  const boxTop = fTop;
  const boxLeft = fLeft;
  const boxRight = fLeft + fWidth;
  const boxBottom = fTop + fHeight;

  const adjustedFieldLeft = hasLabel ? (fieldGapX * sizeScale) : 0;
  const adjustedFieldWidth = Math.max(40, fWidth - adjustedFieldLeft);

  return {
    boxTop,
    boxLeft,
    boxWidth: Math.max(8, boxRight - boxLeft),
    boxHeight: Math.max(8, boxBottom - boxTop),
    labTop: lTop - boxTop,
    labLeft: lLeft - boxLeft,
    labWidth: lWidth,
    labHeight: lHeight,
    fieldTop: fTop - boxTop,
    fieldLeft: (fLeft - boxLeft) + adjustedFieldLeft,
    fieldWidth: adjustedFieldWidth,
    fieldHeight: fHeight
  };
}
</script>

<script>
function getShowWhereValue(field) {
  const raw = field?.iShowWhere ?? field?.IShowWhere ?? field?.ishowWhere ?? field?.ISHOWWHERE ?? 1;
  const n = Number(raw);
  return Number.isFinite(n) ? n : 1;
}

function filterVisibleFields(dictArr, showWhere = 1) {
  const list = (Array.isArray(dictArr) ? dictArr : [])
    .filter(f => (f.Visible ?? 1) == 1)
    .filter(f => getShowWhereValue(f) === showWhere)
    .filter(f => {
      const nums = [f?.iFieldTop, f?.iFieldLeft, f?.iLabTop, f?.iLabLeft]
        .map(v => Number(v))
        .filter(v => Number.isFinite(v));
      if (nums.length === 0) return true;
      return nums.some(v => v > 0);
    })
    .sort((a,b) => (a.SerialNum ?? 9999) - (b.SerialNum ?? 9999));

  // Some dictionaries include duplicated layout rows for the same field
  // (e.g., copied panel/page design). Keep one entry per field name.
  const seen = new Map();
  for (const f of list) {
    const key = String(f?.FieldName || '').trim().toLowerCase();
    if (!key) continue;
    if (!seen.has(key)) {
      seen.set(key, f);
      continue;
    }
    const cur = seen.get(key);
    const curScore = (Number(cur?.iFieldTop) || 0) + (Number(cur?.iFieldLeft) || 0) + ((Number(cur?.SerialNum) || 0) / 1000);
    const nextScore = (Number(f?.iFieldTop) || 0) + (Number(f?.iFieldLeft) || 0) + ((Number(f?.SerialNum) || 0) / 1000);
    if (nextScore < curScore) seen.set(key, f);
  }
  return Array.from(seen.values()).sort((a,b) => (a.SerialNum ?? 9999) - (b.SerialNum ?? 9999));
}

const __lookupCache = new Map();
const __formRenderToken = Object.create(null);

function getLookupMeta(field) {
  const table = (field?.LookupTable || '').trim();
  const keyFieldRaw = (field?.LookupKeyField || '').trim();
  const result = (field?.LookupResultField || '').trim();
  if (!table || !result) return null;
  const parts = result.split(',').map(x => x.trim()).filter(Boolean);
  const keyField = keyFieldRaw || parts[0] || '';
  const nameField = parts.length >= 2 ? parts[1] : (parts[0] || '');
  if (!keyField || !nameField) return null;
  return {
    table,
    keyField,
    nameField
  };
}

function pickRowValueCI(row, fieldName) {
  if (!row || !fieldName) return '';
  const exact = row[fieldName];
  if (exact != null) return exact;
  const key = String(fieldName).toLowerCase();
  const hit = Object.keys(row).find(k => String(k).toLowerCase() === key);
  return hit ? row[hit] : '';
}

async function getLookupRows(table) {
  const key = (table || '').toLowerCase();
  if (!key) return [];
  if (__lookupCache.has(key)) return __lookupCache.get(key);
  try {
    const url = `/api/CommonTable/TopRows?table=${encodeURIComponent(table)}&top=5000`;
    const rows = await fetch(url).then(r => r.ok ? r.json() : []);
    const arr = Array.isArray(rows) ? rows : [];
    __lookupCache.set(key, arr);
    return arr;
  } catch {
    __lookupCache.set(key, []);
    return [];
  }
}

async function resolveLookupName(field, codeVal) {
  const meta = getLookupMeta(field);
  const code = codeVal == null ? '' : String(codeVal).trim();
  if (!meta || !code) return '';
  const rows = await getLookupRows(meta.table);
  const hit = rows.find(r => String(pickRowValueCI(r, meta.keyField) ?? '').trim() === code);
  return String(pickRowValueCI(hit, meta.nameField) ?? '').trim();
}

async function normalizeLookupCodeName(field, rawVal) {
  const meta = getLookupMeta(field);
  let code = rawVal == null ? '' : String(rawVal).trim();
  if (!meta || !code) return { code, name: '' };

  const rows = await getLookupRows(meta.table);
  const findByCode = (c) => rows.find(r => String(pickRowValueCI(r, meta.keyField) ?? '').trim() === c);

  let hit = findByCode(code);
  if (hit) return { code, name: String(pickRowValueCI(hit, meta.nameField) ?? '').trim() };

  const firstToken = code.split(/\s+/).filter(Boolean)[0] || '';
  if (firstToken && firstToken !== code) {
    hit = findByCode(firstToken);
    if (hit) return { code: firstToken, name: String(pickRowValueCI(hit, meta.nameField) ?? '').trim() };
    return { code: firstToken, name: code.slice(firstToken.length).trim() };
  }

  return { code, name: '' };
}

function makeLookupValueElement(code, name, codeWidth) {
  const wrap = document.createElement('div');
  wrap.className = 'mf-lk-view';
  if (Number.isFinite(Number(codeWidth)) && Number(codeWidth) > 0) {
    wrap.style.gridTemplateColumns = `${Number(codeWidth)}px minmax(60px, 1fr)`;
  }

  const left = document.createElement('span');
  left.className = 'mf-lk-code';
  left.textContent = code == null ? '' : String(code);

  const right = document.createElement('span');
  right.className = 'mf-lk-name';
  right.textContent = name == null ? '' : String(name);

  wrap.append(left, right);
  return wrap;
}

function getLookupCodeWidth(field, fieldWidth) {
  const w = Number(fieldWidth) || 0;
  const comboTextSizeRaw =
    field?.ComboTextSize ??
    field?.comboTextSize ??
    field?.combotextsize;
  const comboTextSize = parseInt(String(comboTextSizeRaw ?? '').trim(), 10);
  if (Number.isFinite(comboTextSize) && comboTextSize > 0) {
    if (w > 0) {
      // ComboTextSize: 代碼欄寬（像素）
      return Math.max(40, Math.min(comboTextSize, Math.max(40, w - 40)));
    }
    return Math.max(40, comboTextSize);
  }
  return Math.max(52, Math.min(96, Math.floor(w * 0.36)));
}

const __lookupOptionCache = new Map();
let __mfSuggestEl = null;
let __mfSuggestTarget = null;
let __mfSuggestOptions = [];
let __mfSuggestKeepUntil = 0;
let __mfSuggestBound = false;

function ensureMfSuggest() {
  if (__mfSuggestEl) return __mfSuggestEl;
  const el = document.createElement('div');
  el.className = 'mf-suggest';
  el.style.display = 'none';
  document.body.appendChild(el);
  __mfSuggestEl = el;
  return el;
}

function bindMfSuggestGlobal() {
  if (__mfSuggestBound) return;
  __mfSuggestBound = true;
  document.addEventListener('click', (e) => {
    if (!__mfSuggestTarget) return;
    const box = ensureMfSuggest();
    const trigger = __mfSuggestTarget?._lookupTrigger || null;
    if (e.target === __mfSuggestTarget || (trigger && (e.target === trigger || trigger.contains(e.target))) || box.contains(e.target)) return;
    hideMfSuggest();
  });
  ensureMfSuggest().addEventListener('mousedown', () => {
    __mfSuggestKeepUntil = Date.now() + 150;
  });
}

function getLookupNameEditor(inputEl) {
  return inputEl?._lookupNameEditor || null;
}

function setLookupNameDisplay(inputEl, text) {
  const nameEditor = getLookupNameEditor(inputEl);
  if (!nameEditor) return;
  const next = String(text || '');
  if (nameEditor instanceof HTMLInputElement || nameEditor instanceof HTMLTextAreaElement) {
    nameEditor.value = next;
  } else {
    nameEditor.textContent = next;
    nameEditor.title = next;
  }
}

function getLookupMetaFromInput(inputEl) {
  if (!inputEl) return null;
  const table = String(inputEl.dataset.lookupTable || '').trim();
  const keyField = String(inputEl.dataset.lookupKeyField || '').trim();
  const nameField = String(inputEl.dataset.lookupNameField || '').trim();
  if (!table || !keyField || !nameField) return null;
  return { table, keyField, nameField };
}

async function getLookupOptions(meta) {
  if (!meta) return [];
  const cacheKey = `${meta.table}|${meta.keyField}|${meta.nameField}`.toLowerCase();
  if (__lookupOptionCache.has(cacheKey)) return __lookupOptionCache.get(cacheKey);
  const rows = await getLookupRows(meta.table);
  const map = new Map();
  rows.forEach(r => {
    const code = String(pickRowValueCI(r, meta.keyField) ?? '').trim();
    if (!code) return;
    const label = String(pickRowValueCI(r, meta.nameField) ?? '').trim();
    if (!map.has(code)) map.set(code, { value: code, label: label || code });
  });
  const arr = Array.from(map.values());
  __lookupOptionCache.set(cacheKey, arr);
  return arr;
}

function positionMfSuggest(inputEl) {
  if (!inputEl) return;
  const box = ensureMfSuggest();
  const rect = inputEl.getBoundingClientRect();
  const nameEditor = getLookupNameEditor(inputEl);
  const nameWidth = nameEditor ? (nameEditor.getBoundingClientRect?.().width || 0) : 0;
  const fullWidth = rect.width + nameWidth;
  const minWidth = Math.max(220, fullWidth || rect.width);
  const maxWidth = Math.max(minWidth, window.innerWidth - 24);
  const width = Math.min(maxWidth, Math.max(rect.width, minWidth));
  let left = rect.left + window.scrollX;
  const maxLeft = window.scrollX + window.innerWidth - width - 12;
  if (left > maxLeft) left = Math.max(window.scrollX + 8, maxLeft);
  box.style.left = `${left}px`;
  box.style.top = `${rect.bottom + window.scrollY}px`;
  box.style.width = `${width}px`;
}

function hideMfSuggest() {
  if (Date.now() < __mfSuggestKeepUntil) return;
  const box = ensureMfSuggest();
  box.style.display = 'none';
  box.innerHTML = '';
  __mfSuggestTarget = null;
  __mfSuggestOptions = [];
}

function applyLookupSelection(inputEl, option) {
  if (!inputEl || !option) return;
  const code = String(option.value || '').trim();
  const label = String(option.label || '').trim();
  inputEl.value = code;
  setLookupNameDisplay(inputEl, label);
}

function renderMfSuggest(inputEl, options, forceAll = false) {
  const box = ensureMfSuggest();
  const q = forceAll ? '' : String(inputEl?.value || '').trim().toLowerCase();
  const currentRaw = String(inputEl?.value || '').trim().toLowerCase();
  const current = currentRaw.split(/\s*-\s*/)[0].trim();
  const list = q
    ? (options || []).filter(o =>
        String(o.value || '').toLowerCase().includes(q) ||
        String(o.label || '').toLowerCase().includes(q))
    : (options || []);

  box.innerHTML = '';
  if (!list.length) {
    hideMfSuggest();
    return;
  }

  list.slice(0, 200).forEach(o => {
    const item = document.createElement('div');
    item.className = 'mf-suggest-item';
    const code = String(o.value || '').trim();
    if (code && code.toLowerCase() === current) item.classList.add('is-selected');
    item.textContent = o.value ? `${o.value} - ${o.label}` : (o.label || '');
    item.addEventListener('mousedown', (e) => {
      e.preventDefault();
      applyLookupSelection(inputEl, o);
      hideMfSuggest();
    });
    box.appendChild(item);
  });
  if (!box.querySelector('.mf-suggest-item.is-selected')) {
    box.querySelector('.mf-suggest-item')?.classList.add('is-selected');
  }

  positionMfSuggest(inputEl);
  box.style.display = 'block';
}

async function showFormLookupSuggest(inputEl, forceAll = true) {
  const meta = getLookupMetaFromInput(inputEl);
  if (!meta || !inputEl) return;
  bindMfSuggestGlobal();
  const options = await getLookupOptions(meta);
  __mfSuggestTarget = inputEl;
  __mfSuggestOptions = options;
  renderMfSuggest(inputEl, options, forceAll);
}

function commitLookupInputValue(inputEl) {
  if (!inputEl) return;
  const options = __mfSuggestTarget === inputEl ? __mfSuggestOptions : [];
  const textRaw = String(inputEl.value || '').trim();
  if (!textRaw) {
    inputEl.value = '';
    setLookupNameDisplay(inputEl, '');
    return;
  }

  const exact = (options || []).find(o =>
    String(o.value || '').trim() === textRaw ||
    String(o.label || '').trim() === textRaw
  );
  if (exact) {
    applyLookupSelection(inputEl, exact);
    return;
  }

  const token = textRaw.split(/\s*-\s*/)[0].split(/\s+/).filter(Boolean)[0] || textRaw;
  const byCode = (options || []).find(o => String(o.value || '').trim() === token);
  if (byCode) {
    applyLookupSelection(inputEl, byCode);
    return;
  }

  inputEl.value = token;
  setLookupNameDisplay(inputEl, '');
}

function bindLookupSuggestInput(inputEl) {
  if (!inputEl || inputEl.dataset.lookupBound === '1') return;
  inputEl.dataset.lookupBound = '1';
  inputEl.addEventListener('focus', () => { showFormLookupSuggest(inputEl, true); });
  inputEl.addEventListener('input', () => {
    if (__mfSuggestTarget !== inputEl) {
      showFormLookupSuggest(inputEl, false);
      return;
    }
    renderMfSuggest(inputEl, __mfSuggestOptions, false);
  });
  inputEl.addEventListener('blur', () => {
    setTimeout(() => {
      const box = ensureMfSuggest();
      if (!box.matches(':hover')) hideMfSuggest();
      commitLookupInputValue(inputEl);
    }, 120);
  });
  inputEl.addEventListener('keydown', (e) => {
    if (e.key !== 'Backspace' && e.key !== 'Delete') return;
    const value = String(inputEl.value || '');
    if (!value) return;
    const start = typeof inputEl.selectionStart === 'number' ? inputEl.selectionStart : -1;
    const end = typeof inputEl.selectionEnd === 'number' ? inputEl.selectionEnd : -1;
    const allSelected = start === 0 && end === value.length;
    if (!allSelected) return;
    e.preventDefault();
    inputEl.value = '';
    setLookupNameDisplay(inputEl, '');
    if (__mfSuggestTarget === inputEl) renderMfSuggest(inputEl, __mfSuggestOptions, false);
  });
}

let __lookupDialogEl = null;
let __lookupDialogModal = null;
let __lookupDialogState = {
  inputEl: null,
  options: [],
  filtered: [],
  selectedCode: ''
};

function ensureLookupDialog() {
  if (__lookupDialogEl) return __lookupDialogEl;
  const host = document.createElement('div');
  host.className = 'modal fade ccs-lookup-dialog';
  host.tabIndex = -1;
  host.setAttribute('aria-hidden', 'true');
  host.innerHTML = `
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">名稱查詢</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="ccs-lk-filter">
            <input type="text" class="form-control form-control-sm" data-lk-filter="code" placeholder="代碼篩選">
            <input type="text" class="form-control form-control-sm" data-lk-filter="name" placeholder="名稱篩選">
          </div>
          <div class="ccs-lk-list-wrap">
            <table class="table table-sm mb-0 ccs-lk-table">
              <thead>
                <tr><th style="width:120px">代碼</th><th>名稱</th></tr>
              </thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary btn-sm" data-lk-action="ok">確定</button>
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
        </div>
      </div>
    </div>`;
  document.body.appendChild(host);
  __lookupDialogEl = host;
  __lookupDialogModal = bootstrap.Modal.getOrCreateInstance(host);

  const codeFilter = host.querySelector('[data-lk-filter="code"]');
  const nameFilter = host.querySelector('[data-lk-filter="name"]');
  const tbody = host.querySelector('tbody');
  const okBtn = host.querySelector('[data-lk-action="ok"]');

  const renderRows = () => {
    const codeQ = String(codeFilter?.value || '').trim().toLowerCase();
    const nameQ = String(nameFilter?.value || '').trim().toLowerCase();
    const all = Array.isArray(__lookupDialogState.options) ? __lookupDialogState.options : [];
    const filtered = all.filter(o => {
      const v = String(o.value || '').toLowerCase();
      const n = String(o.label || '').toLowerCase();
      if (codeQ && !v.includes(codeQ)) return false;
      if (nameQ && !n.includes(nameQ)) return false;
      return true;
    });
    __lookupDialogState.filtered = filtered;
    if (!tbody) return;
    tbody.innerHTML = filtered.map(o => {
      const code = String(o.value || '');
      const name = String(o.label || '');
      const sel = code === __lookupDialogState.selectedCode ? ' class="is-selected"' : '';
      return `<tr data-code="${code.replace(/"/g, '&quot;')}"${sel}><td>${code}</td><td>${name}</td></tr>`;
    }).join('');
    const selected = tbody.querySelector('tr.is-selected') || tbody.querySelector('tr');
    if (selected) {
      tbody.querySelectorAll('tr').forEach(tr => tr.classList.remove('is-selected'));
      selected.classList.add('is-selected');
      __lookupDialogState.selectedCode = selected.getAttribute('data-code') || '';
    }
  };

  const applySelected = () => {
    const inputEl = __lookupDialogState.inputEl;
    if (!inputEl) return;
    const selected = (__lookupDialogState.filtered || []).find(o => String(o.value || '') === __lookupDialogState.selectedCode);
    if (!selected) return;
    applyLookupSelection(inputEl, selected);
    __lookupDialogModal?.hide();
  };

  host.addEventListener('shown.bs.modal', () => {
    setTimeout(() => codeFilter?.focus(), 0);
  });

  codeFilter?.addEventListener('input', renderRows);
  nameFilter?.addEventListener('input', renderRows);
  okBtn?.addEventListener('click', applySelected);

  tbody?.addEventListener('click', (e) => {
    const tr = e.target.closest('tr[data-code]');
    if (!tr) return;
    tbody.querySelectorAll('tr').forEach(x => x.classList.remove('is-selected'));
    tr.classList.add('is-selected');
    __lookupDialogState.selectedCode = tr.getAttribute('data-code') || '';
  });

  tbody?.addEventListener('dblclick', (e) => {
    const tr = e.target.closest('tr[data-code]');
    if (!tr) return;
    __lookupDialogState.selectedCode = tr.getAttribute('data-code') || '';
    applySelected();
  });

  host.addEventListener('keydown', (e) => {
    const rows = Array.from(tbody?.querySelectorAll('tr[data-code]') || []);
    if (!rows.length) return;
    const cur = rows.findIndex(r => r.classList.contains('is-selected'));
    if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
      e.preventDefault();
      const next = e.key === 'ArrowDown'
        ? Math.min(rows.length - 1, Math.max(0, cur + 1))
        : Math.max(0, cur <= 0 ? 0 : cur - 1);
      rows.forEach(r => r.classList.remove('is-selected'));
      rows[next].classList.add('is-selected');
      __lookupDialogState.selectedCode = rows[next].getAttribute('data-code') || '';
      rows[next].scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter') {
      e.preventDefault();
      applySelected();
    }
  });

  host._renderRows = renderRows;
  return host;
}

async function openLookupDropdown(inputEl, forceAll = true) {
