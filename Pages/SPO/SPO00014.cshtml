@page "/SPO/SPO00014"
@using PcbErpApi.Models
@model PcbErpApi.Pages.SPO.SPO00014Model
@{
    Layout = "_InquiryTemplate";
    ViewData["Title"] = Model.PageTitle;
    ViewData["ShowInqHeader"] = false;
    ViewData["ShowInqRail"] = true;
    ViewData["InqRailTitle"] = "查詢";
    ViewData["InqRailWidth"] = "120px";
}

@section InqRail {
  <button type="submit" form="inqForm" class="inq-rail-btn" id="btnSPO15Query">查詢</button>
  <button type="button" class="inq-rail-btn" id="btnSPO15Excel">匯出Excel</button>
  <button type="button" class="inq-rail-btn" id="btnSPO15Switch">單據追蹤</button>
  <button type="button" class="inq-rail-btn" id="btnEditDict">編輯辭典</button>
  <button type="button" class="inq-rail-btn" id="btnClearInq">清除</button>
  <div class="inq-rail-status">
    <div>資料筆數：<span id="inqTotalCount">0</span></div>
    <div>目前位置：<span id="inqCurrentPos">0</span></div>
  </div>
}

@{
  string QVal(string name)
  {
      return Request.Query[name].ToString();
  }

  string QDateVal(string name)
  {
      var raw = Request.Query[name].ToString();
      if (DateTime.TryParse(raw, out var dt)) return dt.ToString("yyyy-MM-dd");
      return raw;
  }
}

@section InqQuery {
  <script>
    (() => {
      try {
        if (sessionStorage.getItem("__inqPendingBusy")) {
          document.documentElement.classList.add("inq-busy-pending");
        }
      } catch {}
    })();
  </script>
  <form id="inqForm" method="get" class="inq-form inq-form--auto-grid-enabled">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Cond_PaperNum" value=">=" />
    <input type="hidden" name="Cond_PaperNum2" value="<=" />
    <input type="hidden" name="Cond_CustomerId" value=">=" />
    <input type="hidden" name="Cond_CustomerId2" value="<=" />
    <input type="hidden" name="Cond_PartNum" value=">=" />
    <input type="hidden" name="Cond_PartNum2" value="<=" />
    <input type="hidden" name="Cond_PaperDate" value=">=" />
    <input type="hidden" name="Cond_PaperDate2" value="<=" />
    <input type="hidden" name="Cond_FinishedName" value="=" />
    <input type="hidden" name="Cond_SourNum" value="=" />
    <input type="hidden" name="Cond_ShortName" value="like" />

    <div class="inq-row">
      <label class="inq-label">起始退貨單號</label>
      <input type="text" name="PaperNum" class="form-control form-control-sm inq-input" value="@QVal("PaperNum")" />
      <label class="inq-label">截止退貨單號</label>
      <input type="text" name="PaperNum2" class="form-control form-control-sm inq-input" value="@QVal("PaperNum2")" />
      <label class="inq-label">退貨日期</label>
      <input type="date" name="PaperDate" class="form-control form-control-sm inq-input inq-date" value="@QDateVal("PaperDate")" />
      <label class="inq-to">至</label>
      <input type="date" name="PaperDate2" class="form-control form-control-sm inq-input inq-date" value="@QDateVal("PaperDate2")" />
    </div>

    <div class="inq-row">
      <label class="inq-label">起始客戶</label>
      <span class="inq-select">
        <input type="hidden" id="inq_CustomerId" name="CustomerId" class="inq-select-code-hidden" value="@QVal("CustomerId")" />
        <input type="text" class="form-control form-control-sm inq-input inq-lookup-display"
               value=""
               autocomplete="off"
               data-code-target="inq_CustomerId"
               data-lookup-table="SPOdV_MPSRejectInq"
               data-lookup-key="CustomerId"
               data-lookup-result="ShortName"
               data-selected="@QVal("CustomerId")" />
        <button type="button" class="inq-select-btn" aria-label="開啟清單">&#9662;</button>
      </span>
      <label class="inq-label">截止客戶</label>
      <span class="inq-select">
        <input type="hidden" id="inq_CustomerId2" name="CustomerId2" class="inq-select-code-hidden" value="@QVal("CustomerId2")" />
        <input type="text" class="form-control form-control-sm inq-input inq-lookup-display"
               value=""
               autocomplete="off"
               data-code-target="inq_CustomerId2"
               data-lookup-table="SPOdV_MPSRejectInq"
               data-lookup-key="CustomerId"
               data-lookup-result="ShortName"
               data-selected="@QVal("CustomerId2")" />
        <button type="button" class="inq-select-btn" aria-label="開啟清單">&#9662;</button>
      </span>
      <label class="inq-label">單據狀態</label>
      <input type="text" name="FinishedName" class="form-control form-control-sm inq-input" value="@QVal("FinishedName")" />
      <label class="inq-label">銷貨單號</label>
      <input type="text" name="SourNum" class="form-control form-control-sm inq-input" value="@QVal("SourNum")" />
    </div>

    <div class="inq-row">
      <label class="inq-label">起始品號</label>
      <input type="text" name="PartNum" class="form-control form-control-sm inq-input" value="@QVal("PartNum")" />
      <label class="inq-label">截止品號</label>
      <input type="text" name="PartNum2" class="form-control form-control-sm inq-input" value="@QVal("PartNum2")" />
      <label class="inq-label">客戶簡稱</label>
      <input type="text" name="ShortName" class="form-control form-control-sm inq-input" value="@QVal("ShortName")" />
      <label class="inq-label"></label>
      <input type="text" class="form-control form-control-sm inq-input inq-placeholder" tabindex="-1" aria-hidden="true" />
    </div>

    <input type="hidden" name="page" value="1" />
    @if (!string.IsNullOrWhiteSpace(Request.Query["sortBy"]))
    {
      <input type="hidden" name="sortBy" value="@Request.Query["sortBy"]" />
    }
    @if (!string.IsNullOrWhiteSpace(Request.Query["sortDir"]))
    {
      <input type="hidden" name="sortDir" value="@Request.Query["sortDir"]" />
    }
  </form>
}

<script>
  window._itemId = "SPO00014";
  window._dictTableName = "SPOdV_MPSRejectInq";
</script>
<script>
  (() => {
    let pendingMsg = "";
    try {
      pendingMsg = sessionStorage.getItem("__inqPendingBusy") || "";
      if (pendingMsg) sessionStorage.removeItem("__inqPendingBusy");
    } catch {}
    if (!pendingMsg) return;

    const docEl = document.documentElement;
    docEl.classList.add("inq-busy-pending");

    const overlay = document.createElement("div");
    overlay.id = "inqBusyPendingOverlay";
    overlay.className = "show";
    overlay.innerHTML = `<div class="inq-busy-card"><div class="spinner-border text-primary" role="status" aria-hidden="true"></div><div class="inq-busy-text">${pendingMsg}</div></div>`;

    const mount = () => {
      if (!overlay.isConnected) document.body.appendChild(overlay);
    };
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", mount, { once: true });
    } else {
      mount();
    }

    const clear = () => {
      docEl.classList.remove("inq-busy-pending");
      overlay.remove();
      if (typeof window.hideBusy === "function") window.hideBusy();
    };

    const isQueryLayoutReady = () => {
      const form = document.getElementById("inqForm");
      if (!(form instanceof HTMLElement)) return true;
      const rows = form.querySelectorAll(":scope > .inq-row");
      if (!rows.length || rows.length <= 1) return true;
      if (form.classList.contains("inq-form--auto-grid-active")) return true;
      return false;
    };

    const triggerQueryAlign = () => {
      try {
        window.dispatchEvent(new Event("resize"));
      } catch {}
    };

    const waitAndClear = (retry = 0) => {
      triggerQueryAlign();
      if (isQueryLayoutReady() || retry >= 120) {
        clear();
        return;
      }
      window.requestAnimationFrame(() => waitAndClear(retry + 1));
    };

    window.addEventListener("load", () => setTimeout(() => waitAndClear(), 120), { once: true });
    window.addEventListener("pageshow", () => setTimeout(() => waitAndClear(), 120), { once: true });
    setTimeout(clear, 9000);
  })();
</script>

@await Html.PartialAsync("~/Pages/Shared/_FieldDictModal.cshtml", new List<CURdTableField>(), ViewData)
<script src="~/js/fieldDictModal.js" asp-append-version="true"></script>

<div class="inq-table-wrap">
  <table class="table table-sm table-hover align-middle inq-table">
    <thead>
      <tr>
        @{
          var gFields = (Model.FieldDictList ?? new List<CURdTableField>())
            .Where(f => (f.Visible ?? 1) != 0)
            .Where(f => !string.IsNullOrWhiteSpace(f.FieldName))
            .OrderBy(f => f.SerialNum ?? int.MaxValue)
            .ToList();

          if (gFields.Count == 0)
          {
            var fallback = new[]
            {
              "PaperNum","PaperDate","CustomerId","ShortName","FinishedName","Item","PartNum","UOMQnty",
              "SourNum","SourItem","Treatment","Defects","ChangedName","ActionName","Qnty","PaperId"
            };
            gFields = fallback.Select(f => new CURdTableField { FieldName = f, DisplayLabel = f }).ToList();
          }

          string GLabel(CURdTableField f) => string.IsNullOrWhiteSpace(f.DisplayLabel) ? f.FieldName : f.DisplayLabel!;
        }
        @foreach (var f in gFields)
        {
          <th data-field="@f.FieldName">
            <span class="th-text">@GLabel(f)</span>
            <span class="col-resizer" draggable="false"></span>
          </th>
        }
      </tr>
    </thead>
    <tbody>
    @{
      var dict = (Model.FieldDictList ?? new List<CURdTableField>())
        .Where(f => !string.IsNullOrWhiteSpace(f.FieldName))
        .ToDictionary(f => f.FieldName!, StringComparer.OrdinalIgnoreCase);

      string FormatVal(Dictionary<string, object?> row, string fieldName)
      {
          if (!row.TryGetValue(fieldName, out var v)) return "";
          if (dict.TryGetValue(fieldName, out var f))
              return FormatHelper.FormatValue(v, f.DataType, f.FormatStr);
          return v?.ToString() ?? "";
      }
    }
    @if (Model.Items.Count == 0)
    {
      <tr>
        <td colspan="@(Math.Max(1, gFields.Count))" class="text-center text-muted py-2">沒有資料</td>
      </tr>
    }
    else
    {
      foreach (var row in Model.Items)
      {
        string Get(string name) => FormatVal(row, name);
        <tr data-paper-id="@Get("PaperId")" data-paper-num="@Get("PaperNum")">
          @foreach (var f in gFields)
          {
            <td>@Get(f.FieldName)</td>
          }
        </tr>
      }
    }
    </tbody>
  </table>
</div>

@if (Model.TotalPages > 1)
{
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-1 mt-2">
    <div class="d-flex align-items-center gap-1">
      <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber <= 1 ? "disabled" : "")"
         href="@(Model.PageNumber <= 1 ? "#" : BuildPageUrl(Model.PageNumber - 1))">上一頁</a>
      <span>Page: <strong>@Model.PageNumber</strong> / <span>@Model.TotalPages</span></span>
      <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")"
         href="@(Model.PageNumber >= Model.TotalPages ? "#" : BuildPageUrl(Model.PageNumber + 1))">下一頁</a>
    </div>
    <div class="text-muted">Total: @Model.TotalCount</div>
  </div>
}

@functions{
    string BuildPageUrl(int page)
    {
        var map = ViewContext.HttpContext.Request.Query.ToDictionary(k => k.Key, v => (string?)v.Value.ToString(), StringComparer.OrdinalIgnoreCase);
        map["page"] = page.ToString();
        map["pageSize"] = Model.PageSize.ToString();
        var qs = Microsoft.AspNetCore.Http.QueryString.Create(map).ToString();
        return qs;
    }
}

