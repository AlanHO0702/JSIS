@page
@model PcbErpApi.Pages.SysParams.IndexModel
@using System.Reflection
@{
    Layout = "_Layout";
    ViewData["Title"] = "系統參數設定";

    var fields = Model.TableFields;
    var dictTableName = Model.DictTableName;

    // 從辭典取欄寬(px)
    int ToColWidthPx(CURdTableField f, int pxPerChar = 10)
    {
        var raw = f.DisplaySize;
        if (raw != null && raw > 0) return raw.Value * pxPerChar;
        return 0;
    }

    object? GetValue(object item, string? name)
    {
        if (item == null || string.IsNullOrWhiteSpace(name)) return null;
        var prop = item.GetType().GetProperty(name, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
        return prop?.GetValue(item);
    }

    string FormatValue(object? val, CURdTableField f)
    {
        if (val == null) return "";
        return FormatHelper.FormatValue(val, f.DataType, f.FormatStr);
    }

    bool IsCheckbox(CURdTableField f)
    {
        return (f.ComboStyle ?? 0) == 1;
    }

    bool IsReadOnly(CURdTableField f)
    {
        return (f.ReadOnly ?? 0) == 1;
    }

    bool IsDateField(CURdTableField f)
    {
        var dt = (f.DataType ?? "").ToLowerInvariant();
        return dt.Contains("date") || dt.Contains("time");
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="sysparams-page">
  <!-- 左側系統別 -->
  <div class="left-panel">
    <div class="left-title">系統別</div>
    <ul class="list-group sys-list">
      @foreach (var sys in Model.SystemList)
      {
          var active = string.Equals(sys, Model.SelectedSystem, System.StringComparison.OrdinalIgnoreCase);
          <li class="list-group-item @(active ? "active" : "")">
              <a asp-page="/SysParams/Index"
                 asp-route-SelectedSystem="@sys"
                 class="sys-link">@sys</a>
          </li>
      }
    </ul>
  </div>

  <!-- 右側內容 -->
  <div class="right-panel">
    <div class="right-title d-flex align-items-center gap-2">
      <div>系統參數設定 - <span class="badge bg-secondary">@Model.SelectedSystem</span></div>
      <div class="ms-auto d-flex gap-2 align-items-center flex-wrap title-tools">
        <button id="btnAdd" class="btn btn-success btn-sm">新增</button>
        <button id="btnEdit" class="btn btn-outline-secondary btn-sm">編輯</button>
        <button id="btnDelete" class="btn btn-danger btn-sm d-none" disabled>刪除</button>
        <button id="btnSave" class="btn btn-primary btn-sm d-none">儲存</button>
        <button id="btnCancel" class="btn btn-secondary btn-sm d-none">取消</button>
        <div class="header-filter">
          <span class="filter-label">系統別</span>
          <input type="text" id="filterSystem" class="form-control form-control-sm filter-sys" value="@Model.SelectedSystem" placeholder="系統別" autocomplete="off" />
          <span class="filter-label">參數代碼</span>
          <input type="text" id="filterParamId" class="form-control form-control-sm" placeholder="輸入代碼" autocomplete="off" />
          <span class="filter-label">說明</span>
          <input type="text" id="filterNotes" class="form-control form-control-sm" placeholder="輸入說明" autocomplete="off" />
        </div>
      </div>
    </div>

    <div class="table-wrap">
      <table class="table table-bordered table-sm align-middle sys-table" id="tbl" data-dict-table="@dictTableName">
        <colgroup>
          @foreach (var f in fields)
          {
            var w = ToColWidthPx(f, 10);
            if (w > 0)
            { <col data-field="@f.FieldName" style="width:@($"{w}px");min-width:@($"{w}px");max-width:@($"{w}px")" /> }
            else
            { <col data-field="@f.FieldName" style="width:120px;min-width:120px;max-width:120px" /> }
          }
        </colgroup>
        <thead>
          <tr>
            @foreach (var f in fields)
            {
              <th class="text-nowrap" data-field="@f.FieldName" style="position:relative;">
                <span>@f.DisplayLabel</span>
                <span class="col-resizer" data-field="@f.FieldName"></span>
              </th>
            }
          </tr>
        </thead>
        <tbody>
          @if (Model.Rows.Count == 0)
          {
            <tr><td colspan="@(fields.Count)" class="text-center text-muted">（無資料）</td></tr>
          }
          else
          {
            @foreach (var r in Model.Rows)
            {
              <tr data-systemid="@r.SystemId" data-paramid="@r.ParamId">
                @foreach (var f in fields)
                {
                  var fieldName = f.FieldName ?? "";
                  var val = GetValue(r, fieldName);
                  var isChk = IsCheckbox(f);
                  var isRo = IsReadOnly(f);
                  var isDate = IsDateField(f);
                  var fldClass = $"fld-{fieldName}";

                  if (isChk)
                  {
                    var chkVal = val != null && (val.ToString() == "1" || val.ToString() == "True");
                    <td class="text-center">
                      <input type="checkbox" class="form-check-input @fldClass"
                            disabled @(chkVal ? "checked" : null)
                            data-orig="@(chkVal ? "1" : "0")"
                            data-field="@fieldName"
                            @(isRo ? "data-readonly=1" : "") />
                    </td>
                  }
                  else if (isDate)
                  {
                    <td class="text-nowrap" data-field="@fieldName">@FormatValue(val, f)</td>
                  }
                  else
                  {
                    var strVal = val?.ToString() ?? "";
                    <td>
                      <input class="form-control form-control-sm @fldClass"
                            value="@strVal" disabled data-orig="@strVal"
                            data-field="@fieldName"
                            @(isRo ? "data-readonly=1" : "")
                            data-title="@f.DisplayLabel（@r.ParamId）" />
                    </td>
                  }
                }
              </tr>
            }
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@* 說明/詳細說明：全文視窗 *@
<div class="modal fade" id="notesModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="notesModalTitle">說明</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
      </div>
      <div class="modal-body">
        <textarea id="notesModalText" class="form-control" rows="14"></textarea>
        <div id="notesHelp" class="form-text mt-1"></div>
      </div>
      <div class="modal-footer">
        <button id="btnCopyNotes" type="button" class="btn btn-outline-secondary">複製</button>
        <button id="btnApplyNotes" type="button" class="btn btn-primary">套用到欄位</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
      </div>
    </div>
  </div>
</div>

<style>
/* ===== Layout 基本框架 ===== */
.sysparams-page{
  display:flex;
  gap:16px;
  height:calc(100vh - 88px);
  padding:12px 16px;
  box-sizing:border-box;
}

/* ===== 左欄（3 碼） ===== */
.left-panel{ width:120px; min-width:120px; flex-shrink:0; display:flex; flex-direction:column; }
.left-title{ font-size:18px; font-weight:600; margin-bottom:8px; }
.sys-list{ flex:1 1 auto; overflow:auto; border:1px solid #dee2e6; border-radius:.375rem; }
.sys-list .list-group-item{ padding:0; background:#fff; color:#212529; border:none; border-bottom:1px solid #e9ecef; }
.sys-list .list-group-item:last-child{ border-bottom:none; }
.sys-link{ display:block; padding:6px 8px; text-decoration:none; color:#212529 !important; text-align:center; font-weight:600; }
.sys-list .list-group-item:not(.active) .sys-link:hover{ background:#f1f3f5; }
.sys-list .list-group-item.active{ background:#0d6efd; color:#fff; }
.sys-list .list-group-item.active .sys-link{ color:#fff !important; }

/* ===== 右欄 ===== */
.right-panel{ flex:1 1 auto; min-width:0; display:flex; flex-direction:column; }
.right-title{ font-size:20px; font-weight:600; margin-bottom:8px; display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
.title-tools{ row-gap:6px; }
.header-filter{
  display:flex; align-items:center; gap:6px;
  margin-left:8px; padding-left:8px;
  border-left:1px solid #dee2e6;
}
.header-filter .form-control{ width:170px; font-size:12px; }
.header-filter .filter-sys{ width:76px; text-align:center; font-weight:700; letter-spacing:.3px; }
.header-filter .filter-label{ font-size:12px; color:#495057; font-weight:600; white-space:nowrap; }

/* ===== 表格容器：可水平/垂直滾動，表頭 sticky ===== */
.table-wrap{
  flex:1 1 auto;
  overflow-x:auto;
  overflow-y:auto;
  border:1px solid #dee2e6;
  border-radius:.375rem;
  background:#fff;
  scrollbar-gutter:stable;
}

.sys-table thead th{ position:sticky; top:0; z-index:2; background:#f8f9fa; white-space:nowrap; }
.sys-table th, .sys-table td{ vertical-align:middle; }
.sys-table th{ padding:4px 8px !important; }
.sys-table td{ word-break:break-word; font-size:12.5px; padding:1px 6px !important; line-height:1.2; }
.sys-table td input.form-control { width: 100%; }
.sys-table tbody tr.row-hidden{ display:none; }

.sys-table tbody tr.tr-selected td{ background:#dce8ff !important; }
.editing tbody tr{ cursor:pointer; }
.editing tbody tr:hover td{ background:#eef3ff; }

.col-resizer{
  position:absolute; top:0; right:0; width:6px;
  cursor:col-resize; user-select:none; height:100%;
  z-index:3;
}

.sys-table input.form-control{
  border:none !important;
  border-radius:0 !important;
  background:transparent !important;
  box-shadow:none !important;
  outline:none !important;
  padding:0 2px !important;
  height:20px !important;
  min-height:20px !important;
  line-height:1.2 !important;
  color:#212529;
  font-size:12.5px !important;
}
.sys-table input[type="checkbox"]{
  width:14px !important;
  height:14px !important;
  min-width:14px !important;
  margin:0 auto !important;
}

/* 讓 disabled 的長文字欄也能雙擊 */
.sys-table input[disabled]{ pointer-events:none; }

/* 小螢幕 */
@@media (max-width: 992px){
  .left-panel{ width:100px; min-width:100px; }
  .header-filter{ margin-left:0; padding-left:0; border-left:none; width:100%; }
  .header-filter .form-control{ width:132px; }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
(() => {
  const tbl       = document.getElementById('tbl');
  const btnEdit   = document.getElementById('btnEdit');
  const btnSave   = document.getElementById('btnSave');
  const btnCancel = document.getElementById('btnCancel');
  const btnAdd    = document.getElementById('btnAdd');
  const btnDelete = document.getElementById('btnDelete');
  const selectedSystem = "@Model.SelectedSystem";
  const dictTableName = "@dictTableName";

  function clearRowSelection(){
    tbl.querySelectorAll("tbody tr.tr-selected").forEach(r => r.classList.remove("tr-selected"));
    btnDelete.disabled = true;
  }

  function setEditing(on){
    tbl.querySelectorAll("input.form-control, input.form-check-input").forEach(inp=>{
      // 唯讀欄位始終 disabled
      if (inp.dataset.readonly === "1") { inp.disabled = true; return; }
      inp.disabled = !on;
    });
    tbl.classList.toggle("editing", on);

    btnEdit.classList.toggle("d-none", on);
    btnSave.classList.toggle("d-none", !on);
    btnCancel.classList.toggle("d-none", !on);
    btnDelete.classList.toggle("d-none", !on);
    btnDelete.disabled = on ? !tbl.querySelector("tbody tr.tr-selected") : true;
  }

  btnEdit?.addEventListener("click", ()=> setEditing(true));

  btnCancel?.addEventListener("click", ()=>{
    tbl.querySelectorAll("input.form-control").forEach(inp=>{
      inp.value = inp.dataset.orig ?? "";
    });
    tbl.querySelectorAll("input.form-check-input").forEach(chk=>{
      chk.checked = (chk.dataset.orig ?? "0") === "1";
    });
    setEditing(false);
  });

  // 列點選高亮（瀏覽/編輯都生效）
  tbl.addEventListener("click", (e) => {
    const tr = e.target.closest("tbody tr[data-paramid]");
    if (!tr) return;

    const editing = tbl.classList.contains("editing");
    if ((e.ctrlKey || e.metaKey) && editing) {
      tr.classList.toggle("tr-selected");
    } else {
      tbl.querySelectorAll("tbody tr.tr-selected").forEach(r => r.classList.remove("tr-selected"));
      tr.classList.add("tr-selected");
    }

    if (editing) {
      btnDelete.disabled = !tbl.querySelector("tbody tr.tr-selected");
    }
  });

  // 刪除（以亮高列為準）
  btnDelete?.addEventListener("click", async ()=>{
    const picks = Array.from(tbl.querySelectorAll("tbody tr.tr-selected")).map(tr=>{
      return { tr, systemId: tr.dataset.systemid, paramId: tr.dataset.paramid };
    });
    if (!picks.length) return;

    const preview = picks.slice(0,8).map(p=>p.paramId).join(", ") + (picks.length>8?" ...":"");
    if (!confirm(`確定要刪除 ${picks.length} 筆參數？\n${preview}`)) return;

    try{
      const res = await fetch("/api/SysParamsApi/delete-rows", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify(picks.map(p=>({ systemId:p.systemId, paramId:p.paramId })))
      });
      const data = await res.json();
      if (!res.ok || data.success!==true) throw new Error(data.message || "刪除失敗");

      picks.forEach(p=> p.tr.remove());
      clearRowSelection();
      alert(`已刪除 ${data.count ?? picks.length} 筆。`);
    }catch(ex){
      alert(ex.message || ex);
    }
  });

  // ===== 儲存 =====
  btnSave?.addEventListener('click', async () => {
    const rows = [];
    tbl.querySelectorAll('tbody tr').forEach(tr => {
      const sys = tr.dataset.systemid, pid = tr.dataset.paramid;
      if (!sys || !pid) return;

      const payload = { systemId: sys, paramId: pid };
      let changed = false;

      // 收集所有欄位值
      tr.querySelectorAll('input[data-field]').forEach(inp => {
        const field = inp.dataset.field;
        if (!field) return;
        if (inp.type === 'checkbox') {
          const val = inp.checked ? 1 : 0;
          const orig = parseInt(inp.dataset.orig ?? '0');
          payload[field[0].toLowerCase() + field.slice(1)] = val;
          if (val !== orig) changed = true;
        } else {
          const val = inp.value ?? '';
          const orig = inp.dataset.orig ?? '';
          payload[field[0].toLowerCase() + field.slice(1)] = val;
          if (val !== orig) changed = true;
        }
      });

      if (changed) rows.push(payload);
    });

    if (rows.length === 0) {
      alert("沒有變更。");
      setEditing(false);
      return;
    }

    try {
      const res = await fetch('/api/SysParamsApi/update-rows', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(rows)
      });
      const data = await res.json();
      if (!res.ok || data.success !== true) throw new Error(data.message || '儲存失敗');

      // 更新 data-orig
      tbl.querySelectorAll('tbody tr').forEach(tr => {
        tr.querySelectorAll('input[data-field]').forEach(inp => {
          inp.dataset.orig = inp.type === 'checkbox'
            ? (inp.checked ? '1' : '0')
            : (inp.value ?? '');
        });
      });

      alert(`已儲存 ${data.count} 筆變更。`);
      setEditing(false);
      location.reload();
    } catch (ex) {
      alert(ex.message || ex);
    }
  });

  // ===== 新增 =====
  btnAdd?.addEventListener('click', async () => {
    const sys = selectedSystem?.trim();
    if (!sys) { alert('請先選擇左側系統別'); return; }

    const pid = prompt('參數代碼 (ParamId)？');
    if (!pid || !pid.trim()) { alert('ParamId 必填'); return; }

    const notes = prompt('說明（可空白）', '') ?? '';
    const value = prompt('參數值（可空白）', '') ?? '';

    const payload = {
      systemId: sys,
      paramId: pid.trim(),
      notes, value,
      paramType: 0, comboStyle: 0,
      isLock: 0, allowUserUpdate: 0,
      note2: ''
    };

    try {
      const res = await fetch('/api/SysParamsApi/create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!res.ok || data.success !== true) throw new Error(data.message || '新增失敗');

      alert('新增成功！將重新整理以顯示新資料。');
      location.reload();
    } catch (ex) {
      alert(ex.message || ex);
    }
  });

  // ===== 說明/詳細說明：雙擊開窗 =====
  const notesModal = new bootstrap.Modal(document.getElementById('notesModal'));
  const notesTitle = document.getElementById('notesModalTitle');
  const notesText = document.getElementById('notesModalText');
  const btnCopy = document.getElementById('btnCopyNotes');
  const btnApply = document.getElementById('btnApplyNotes');
  const notesHelp = document.getElementById('notesHelp');
  let currentInput = null;

  const isEditing = () => !btnSave.classList.contains('d-none');

  tbl.addEventListener('dblclick', (ev) => {
    const td = ev.target.closest('td');
    if (!td) return;
    const input = td.querySelector('input.form-control');
    if (!input) return;

    currentInput = input;
    const editable = isEditing();
    notesTitle.textContent = input.dataset.title || input.dataset.field || '內容';
    notesText.value = input.value || '';
    notesText.readOnly = !editable;
    btnApply.disabled = !editable;
    notesHelp.textContent = editable
      ? '可編輯內容後按「套用到欄位」，再按「儲存」寫回資料庫。'
      : '唯讀模式（若要修改，請先按「編輯」）。';
    notesModal.show();
  });

  btnCopy.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(notesText.value || '');
      btnCopy.textContent = '已複製';
      setTimeout(() => btnCopy.textContent = '複製', 1000);
    } catch { }
  });

  btnApply.addEventListener('click', () => {
    if (!currentInput) return;
    if (currentInput.disabled) return;
    currentInput.value = notesText.value ?? '';
    notesModal.hide();
  });

  // ===== 即時篩選 =====
  const filterSystem  = document.getElementById('filterSystem');
  const filterParamId = document.getElementById('filterParamId');
  const filterNotes   = document.getElementById('filterNotes');

  function filterRows() {
    const sys  = (filterSystem?.value || "").toLowerCase().trim();
    const pid  = (filterParamId?.value || "").toLowerCase().trim();
    const note = (filterNotes?.value || "").toLowerCase().trim();

    tbl.querySelectorAll("tbody tr[data-paramid]").forEach(tr => {
      const systemId = (tr.dataset.systemid || "").toLowerCase();
      const paramId  = (tr.dataset.paramid || "").toLowerCase();

      let notesVal = "";
      tr.querySelectorAll("input[data-field]").forEach(inp => {
        const f = (inp.dataset.field || "").toLowerCase();
        if (f === "notes" || f === "note" || f === "note2") {
          notesVal += " " + String(inp.value || inp.dataset.orig || "").toLowerCase();
        }
      });
      tr.querySelectorAll("td[data-field]").forEach(td => {
        const f = (td.getAttribute("data-field") || "").toLowerCase();
        if (f === "notes" || f === "note" || f === "note2") {
          notesVal += " " + String(td.textContent || "").toLowerCase();
        }
      });

      const match = (!sys || systemId.includes(sys))
        && (!pid || paramId.includes(pid))
        && (!note || notesVal.includes(note));

      tr.classList.toggle("row-hidden", !match);
    });
  }

  filterSystem?.addEventListener("input", filterRows);
  filterParamId?.addEventListener("input", filterRows);
  filterNotes?.addEventListener("input", filterRows);
  filterRows();

  // ===== 欄位寬度拖曳調整 =====
  const MIN_COL_WIDTH = 12;
  tbl.style.tableLayout = 'fixed';
  tbl.style.maxWidth = 'none';

  const colGroupCols = tbl.querySelectorAll('colgroup col[data-field]');
  const colMap = {};
  colGroupCols.forEach(col => {
    const field = col.getAttribute('data-field');
    if (field) colMap[field.toLowerCase()] = col;
  });

  const ths = Array.from(tbl.querySelectorAll('thead th[data-field]'));
  let dragState = null;

  const parsePx = (v) => {
    const n = parseFloat(String(v || '').replace('px', '').trim());
    return Number.isFinite(n) ? n : 0;
  };

  const isVisibleCol = (col) => {
    if (!col) return false;
    const s = (col.getAttribute('style') || '').toLowerCase();
    return !s.includes('display:none');
  };

  const setColFixedWidth = (col, width) => {
    if (!col) return;
    const w = Math.max(MIN_COL_WIDTH, Math.round(width));
    col.style.width = `${w}px`;
    col.style.minWidth = `${w}px`;
    col.style.maxWidth = `${w}px`;
  };

  const syncTableWidth = () => {
    let total = 0;
    Object.values(colMap).forEach(col => {
      if (!isVisibleCol(col)) return;
      const w = parsePx(col.style.width) || col.getBoundingClientRect().width || 0;
      total += Math.max(0, w);
    });
    if (total > 0) {
      const selColWidth = 0;
      const px = `${Math.ceil(total + selColWidth)}px`;
      tbl.style.width = px;
      tbl.style.minWidth = px;
    }
  };

  const lockInitialColumnWidths = () => {
    ths.forEach(th => {
      const field = (th.getAttribute('data-field') || '').toLowerCase();
      if (!field) return;
      const col = colMap[field];
      if (!col || !isVisibleCol(col)) return;
      const initWidth = parsePx(col.style.width) || th.getBoundingClientRect().width || MIN_COL_WIDTH;
      setColFixedWidth(col, initWidth);
      th.style.width = `${Math.round(initWidth)}px`;
      th.style.minWidth = `${Math.round(initWidth)}px`;
      th.style.maxWidth = `${Math.round(initWidth)}px`;
    });
    syncTableWidth();
  };

  lockInitialColumnWidths();
  requestAnimationFrame(lockInitialColumnWidths);
  setTimeout(lockInitialColumnWidths, 120);

  ths.forEach(th => {
    const field = th.getAttribute('data-field');
    const resizer = th.querySelector('.col-resizer');
    if (!field || !resizer) return;
    resizer.addEventListener('mousedown', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const col = colMap[field.toLowerCase()];
      const startX = e.clientX;
      const startWidth = parsePx(col?.style?.width) || col?.getBoundingClientRect().width || th.getBoundingClientRect().width;
      dragState = { field, startX, startWidth };
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
    });
  });

  document.addEventListener('mousemove', (e) => {
    if (!dragState) return;
    e.preventDefault();
    const delta = e.clientX - dragState.startX;
    const newW = Math.max(MIN_COL_WIDTH, dragState.startWidth + delta);
    const col = colMap[dragState.field.toLowerCase()];
    if (col) setColFixedWidth(col, newW);
    const th = ths.find(t => (t.getAttribute('data-field') || '').toLowerCase() === dragState.field.toLowerCase());
    if (th) {
      th.style.width = `${Math.round(newW)}px`;
      th.style.minWidth = `${Math.round(newW)}px`;
      th.style.maxWidth = `${Math.round(newW)}px`;
    }
    syncTableWidth();
  });

  document.addEventListener('mouseup', async () => {
    if (!dragState) return;
    const col = colMap[dragState.field.toLowerCase()];
    const th = ths.find(t => (t.getAttribute('data-field') || '').toLowerCase() === dragState.field.toLowerCase());
    const width = parsePx(col?.style?.width) || col?.getBoundingClientRect().width || th?.getBoundingClientRect().width || dragState.startWidth;
    dragState = null;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    syncTableWidth();

    // 自動儲存到辭典
    if (!dictTableName) return;
    try {
      await fetch('/api/DictSetupApi/FieldWidth/Save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tableName: dictTableName,
          fieldName: th?.getAttribute('data-field') || '',
          widthPx: Math.round(width)
        })
      });
    } catch (err) {
      console.warn('save width failed', err);
    }
  });
})();
</script>

@await Html.PartialAsync("~/Pages/Shared/_FieldDictModal.cshtml", Model.FieldDictList, ViewData)
<script>window._dictTableName = '@dictTableName';</script>
<script src="~/js/fieldDictModal.js" asp-append-version="true"></script>


