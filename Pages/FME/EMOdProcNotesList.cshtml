@page "/EMOdProcNotesList"
@model PcbErpApi.Pages.FME.EMOdProcNotesListModel
@{
    ViewData["Title"] = "製程常用備註表";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="procnotes-container">

    <!-- ══════════════════════════════════
         工具列 (對應 Delphi Panel1)
         btnInq / btnUpdate / btnBrowse / btnToExcel
         ══════════════════════════════════ -->
    <div class="toolbar-section">
        <div class="btn-group btn-group-sm me-2">
            <button type="button" class="btn btn-primary" id="btnInq" title="查詢">
                <i class="bi bi-search"></i> 查詢
            </button>
        </div>
        <div class="btn-group btn-group-sm me-2">
            <button type="button" class="btn btn-warning" id="btnUpdate" title="切換至編輯模式">
                <i class="bi bi-pencil"></i> 更新
            </button>
            <button type="button" class="btn btn-secondary" id="btnBrowse" title="切換至瀏覽模式">
                <i class="bi bi-eye"></i> 瀏覽
            </button>
        </div>
        <div class="btn-group btn-group-sm me-2">
            <button type="button" class="btn btn-outline-success" id="btnSaveNotes"
                    title="儲存備註" style="display:none;">
                <i class="bi bi-floppy"></i> 儲存備註
            </button>
        </div>
        <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-outline-secondary" id="btnToExcel" title="匯出Excel">
                <i class="bi bi-file-earmark-excel"></i> 匯出Excel
            </button>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span id="lblCurrentMode" class="badge bg-secondary">瀏覽</span>
        </div>
    </div>

    <!-- ══════════════════════════════════
         主表格區 (gridMaster1)
         資料來源: MASTER1 (CURdOCXTableSetUp → CURdTableName → RealTableName)
         欄位: ProcCode / ProcName
         ══════════════════════════════════ -->
    <div class="card mb-1" style="flex-shrink:0;">
        <div class="card-header py-1 d-flex justify-content-between align-items-center">
            <span>@Model.MasterTitle</span>
            <div class="d-flex align-items-center gap-2">
                <input type="text" id="masterFilter" class="form-control form-control-sm"
                       style="width:180px;" placeholder="篩選製程代號/名稱...">
                <span id="masterCount" class="badge bg-primary">0 筆</span>
            </div>
        </div>
        <div class="table-responsive master-wrap">
            <table class="table table-sm table-bordered table-hover mb-0" id="tblMaster">
                <thead class="table-light sticky-top">
                    <tr>
                        <th style="width:100px;">@Model.Field(Model.MasterFields, "ProcCode", "制代代碼")</th>
                        <th>@Model.Field(Model.MasterFields, "ProcName", "製程名稱")</th>
                    </tr>
                </thead>
                <tbody id="masterTbody"></tbody>
            </table>
            <div id="masterLoading" class="text-center py-3 text-muted" style="display:none;">
                <div class="spinner-border spinner-border-sm text-primary me-1"></div> 載入中...
            </div>
            <div id="masterEmpty" class="text-center py-3 text-muted" style="display:none;">
                <i class="bi bi-inbox fs-5 d-block"></i> 無資料
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════
         下方區域: 明細(左) + 備注Memo(右)
         對應 Delphi gridDetail1 (左) + DBMemo1 (右)
         ══════════════════════════════════ -->
    <div class="row g-1 detail-area" id="detailArea" style="flex:1; min-height:0;">

        <!-- 左側: 明細表格 (gridDetail1)
             資料: DETAIL1 (CURdOCXTableSetUp → CURdTableName → RealTableName) -->
        <div class="col-md-6 d-flex flex-column">
            <div class="card h-100">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <span>@Model.DetailTitle</span>
                    <div class="d-flex align-items-center gap-1">
                        <button type="button" class="btn btn-xs btn-outline-primary edit-only"
                                id="btnAddDetail" title="新增備注列" style="display:none;">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        <button type="button" class="btn btn-xs btn-outline-danger edit-only"
                                id="btnDeleteDetail" title="刪除選取列" style="display:none;" disabled>
                            <i class="bi bi-dash-lg"></i>
                        </button>
                        <span id="detailCount" class="badge bg-secondary">0 筆</span>
                    </div>
                </div>
                <div class="table-responsive detail-table-wrap">
                    <table class="table table-sm table-bordered table-hover mb-0" id="tblDetail">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:80px;">@Model.Field(Model.DetailFields, "ItemId", "代號")</th>
                                <th>@Model.Field(Model.DetailFields, "Notes", "備注內容")</th>
                            </tr>
                        </thead>
                        <tbody id="detailTbody"></tbody>
                    </table>
                    <div id="detailLoading" class="text-center py-2 text-muted" style="display:none;">
                        <div class="spinner-border spinner-border-sm text-primary me-1"></div> 載入中...
                    </div>
                    <div id="detailEmpty" class="text-center py-2 text-muted" style="display:none;">
                        <i class="bi bi-inbox d-block"></i> 此製程無備注資料
                    </div>
                </div>
            </div>
        </div>

        <!-- 右側: 備注 Memo (DBMemo1)
             DataField='Notes', DataSource=dsDetail1
             瀏覽時 ReadOnly=True，更新時 ReadOnly=False -->
        <div class="col-md-6 d-flex flex-column">
            <div class="card h-100">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <span>備注內容</span>
                    <small id="lblNotesKey" class="text-muted"></small>
                </div>
                <div class="card-body p-1 d-flex flex-column">
                    <textarea id="txtNotes"
                              class="form-control form-control-sm notes-textarea"
                              readonly
                              placeholder="請從左側選擇一筆備注..."></textarea>
                    <div id="notesBtnBar" class="mt-1 d-flex justify-content-end gap-1"
                         style="display:none;">
                        <button class="btn btn-sm btn-success" id="btnSaveInline" style="display:none;">
                            <i class="bi bi-floppy"></i> 儲存
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" id="btnCancelInline"
                                style="display:none;">取消</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ══════════════════════════════════
     Modal：新增備注列
     ══════════════════════════════════ -->
<div class="modal fade" id="modalAddDetail" tabindex="-1" aria-labelledby="modalAddDetailLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="modalAddDetailLabel">新增備注列</h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pb-2">
                <div class="mb-2">
                    <label class="form-label form-label-sm mb-1" id="lblAddDetailProcCode"></label>
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm mb-1" for="addDetailItemId">代號 <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-sm" id="addDetailItemId"
                           maxlength="20">
                    <div class="invalid-feedback" id="addDetailItemIdErr"></div>
                </div>
                <div class="mb-1">
                    <label class="form-label form-label-sm mb-1" for="addDetailNotes">備注內容</label>
                    <textarea class="form-control form-control-sm" id="addDetailNotes"
                              rows="4"></textarea>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnAddDetailConfirm">確定新增</button>
            </div>
        </div>
    </div>
</div>


@section Styles {
<style>
    .procnotes-container {
        padding: 5px 15px;
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 80px);
    }

    .toolbar-section {
        display: flex;
        align-items: center;
        padding: 4px 0;
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 5px;
        flex-shrink: 0;
        flex-wrap: wrap;
        gap: 3px;
    }

    /* 主表格固定高度，可捲動 */
    .master-wrap {
        max-height: 240px;
        overflow-y: auto;
    }

    /* 明細表格可捲動 */
    .detail-table-wrap {
        max-height: 300px;
        overflow-y: auto;
    }

    .detail-area {
        flex: 1;
        min-height: 0;
        overflow: hidden;
    }

    .card-header {
        background-color: #f8f9fa;
        font-size: 0.82rem;
        font-weight: 500;
    }

    .table th {
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
        padding: 0.2rem 0.4rem;
    }

    .table td {
        font-size: 0.75rem;
        vertical-align: middle;
        padding: 0.2rem 0.4rem;
    }

    .table tbody tr { cursor: pointer; }

    /* Bootstrap 5 透過 CSS 變數渲染 <td> 背景色，須覆寫變數才有效 */
    .table tbody tr:hover {
        --bs-table-bg-state: #e7f1ff;
    }
    /* 點選後維持 highlight（淺藍） */
    .table tbody tr.row-selected {
        --bs-table-color-state: inherit;
        --bs-table-bg-state: #cfe2ff;
    }
    /* 目前選中的主動列（深藍＋白字） */
    .table tbody tr.row-active {
        --bs-table-color-state: #fff;
        --bs-table-bg-state: #0d6efd;
    }
    .table tbody tr.row-active:hover {
        --bs-table-color-state: #fff;
        --bs-table-bg-state: #0b5ed7;
    }

    .sticky-top { position: sticky; top: 0; z-index: 1; }

    /* 備注 Memo */
    .notes-textarea {
        flex: 1;
        min-height: 250px;
        resize: none;
        font-size: 0.82rem;
        font-family: 'Noto Sans TC', sans-serif;
        line-height: 1.7;
    }

    .notes-textarea:not([readonly]) {
        border-color: #ffc107;
        background-color: #fffef0;
    }

    /* 比 btn-sm 更小的按鈕，用於 card header */
    .btn-xs {
        padding: 0.1rem 0.35rem;
        font-size: 0.72rem;
        line-height: 1.3;
        border-radius: 0.2rem;
    }

    .notes-preview {
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #555;
    }
</style>
}


@section Scripts {
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    // ══════════════════════════════════════════
    // 全域狀態
    // ══════════════════════════════════════════
    let isEditMode = false;
    let allMasterData = [];          // 全部主表資料 (for 篩選)
    let selectedProcCode = null;     // 目前選中的主表 ProcCode
    let selectedDetail = null;       // 目前選中的明細 {ProcCode, ItemId, Notes}
    let notesOriginal = '';

    $(document).ready(function () {
        loadMaster();
        bindEvents();
    });

    // ══════════════════════════════════════════
    // 事件綁定
    // ══════════════════════════════════════════
    function bindEvents() {
        $('#btnInq').click(loadMaster);
        $('#btnUpdate').click(enterEditMode);
        $('#btnBrowse').click(enterBrowseMode);
        $('#btnSaveNotes, #btnSaveInline').click(saveNotes);
        $('#btnCancelInline').click(cancelNotes);
        $('#btnToExcel').click(exportToExcel);

        // 主表篩選
        $('#masterFilter').on('input', function () {
            filterMaster($(this).val().trim().toLowerCase());
        });

        // 主表列點選
        $('#masterTbody').on('click', 'tr', function () {
            $('#masterTbody tr').removeClass('row-active');
            $(this).addClass('row-active');
            var procCode = $(this).data('proccode');
            var procName = $(this).data('procname');
            selectMaster(procCode, procName);
        });

        // 明細列點選
        $('#detailTbody').on('click', 'tr', function () {
            $('#detailTbody tr').removeClass('row-active');
            $(this).addClass('row-active');
            var itemId = $(this).data('itemid');
            var notes  = $(this).data('notes') || '';
            selectedDetail = {
                ProcCode: selectedProcCode,
                ItemId: itemId,
                Notes: notes
            };
            notesOriginal = notes;
            $('#txtNotes').val(notes).css('border-color', '');
            $('#lblNotesKey').text(selectedProcCode + ' / ' + itemId);
            // 有選明細列時才啟用刪除按鈕
            if (isEditMode) $('#btnDeleteDetail').prop('disabled', false);
        });

        // 新增備注列
        $('#btnAddDetail').click(function () {
            if (!selectedProcCode) { alert('請先選擇製程'); return; }
            $('#addDetailItemId').val('').removeClass('is-invalid');
            $('#addDetailNotes').val('');
            $('#addDetailItemIdErr').text('');
            $('#lblAddDetailProcCode').text('製程：' + selectedProcCode);
            var modal = new bootstrap.Modal(document.getElementById('modalAddDetail'));
            modal.show();
            setTimeout(function () { $('#addDetailItemId').focus(); }, 300);
        });

        // 確定新增
        $('#btnAddDetailConfirm').click(addDetail);
        $('#addDetailItemId').on('keydown', function (e) {
            if (e.key === 'Enter') addDetail();
        });

        // 刪除備注列
        $('#btnDeleteDetail').click(deleteDetail);
    }

    // ══════════════════════════════════════════
    // 主表載入
    // ══════════════════════════════════════════
    function loadMaster() {
        $('#masterLoading').show();
        $('#masterEmpty').hide();
        $('#masterTbody').empty();
        selectedProcCode = null;
        selectedDetail = null;
        $('#txtNotes').val('');
        // 清空明細但保持下方區塊可見
        $('#detailTbody').empty();
        $('#detailCount').text('0 筆');
        $('#lblNotesKey').text('');

        $.ajax({
            url: '/api/EMOdProcNotesList/master',
            type: 'GET',
            success: function (resp) {
                $('#masterLoading').hide();
                if (resp.success && resp.data && resp.data.length > 0) {
                    allMasterData = resp.data;
                    renderMaster(allMasterData);
                    $('#masterCount').text(allMasterData.length + ' 筆');
                } else {
                    $('#masterEmpty').show();
                    $('#masterCount').text('0 筆');
                }
            },
            error: function (xhr) {
                $('#masterLoading').hide();
                $('#masterEmpty').show();
                alert('載入製程清單失敗: ' + (xhr.responseJSON?.message || ''));
            }
        });
    }

    function renderMaster(data) {
        var tbody = $('#masterTbody');
        tbody.empty();
        data.forEach(function (row) {
            var tr = $('<tr>')
                .data('proccode', row.ProcCode)
                .data('procname', row.ProcName || '');
            tr.append(`<td>${esc(row.ProcCode || '')}</td>`);
            tr.append(`<td>${esc(row.ProcName || '')}</td>`);
            tbody.append(tr);
        });
    }

    function filterMaster(keyword) {
        if (!keyword) {
            renderMaster(allMasterData);
            $('#masterCount').text(allMasterData.length + ' 筆');
            return;
        }
        var filtered = allMasterData.filter(r =>
            (r.ProcCode || '').toLowerCase().includes(keyword) ||
            (r.ProcName || '').toLowerCase().includes(keyword)
        );
        renderMaster(filtered);
        $('#masterCount').text(filtered.length + ' / ' + allMasterData.length + ' 筆');
    }

    // ══════════════════════════════════════════
    // 選中主表列 → 載入明細
    // ══════════════════════════════════════════
    function selectMaster(procCode, procName) {
        selectedProcCode = procCode;
        selectedDetail = null;
        $('#txtNotes').val('').css('border-color', '');
        $('#lblNotesKey').text('');
        $('#btnDeleteDetail').prop('disabled', true);
        loadDetail(procCode);
    }

    function loadDetail(procCode) {
        $('#detailLoading').show();
        $('#detailEmpty').hide();
        $('#detailTbody').empty();

        $.ajax({
            url: '/api/EMOdProcNotesList/detail/' + encodeURIComponent(procCode),
            type: 'GET',
            success: function (resp) {
                $('#detailLoading').hide();
                if (resp.success && resp.data && resp.data.length > 0) {
                    renderDetail(resp.data);
                    $('#detailCount').text(resp.data.length + ' 筆');
                } else {
                    $('#detailEmpty').show();
                    $('#detailCount').text('0 筆');
                }
            },
            error: function (xhr) {
                $('#detailLoading').hide();
                $('#detailEmpty').show();
                alert('載入備注失敗: ' + (xhr.responseJSON?.message || ''));
            }
        });
    }

    function renderDetail(data) {
        var tbody = $('#detailTbody');
        tbody.empty();
        data.forEach(function (row) {
            var preview = (row.Notes || '').substring(0, 60)
                        + ((row.Notes || '').length > 60 ? '...' : '');
            var tr = $('<tr>')
                .data('itemid', row.ItemId)
                .data('notes', row.Notes || '');
            tr.append(`<td>${esc(row.ItemId || '')}</td>`);
            tr.append(`<td class="notes-preview">${preview ? esc(preview) : '<span class="text-muted fst-italic">（無內容）</span>'}</td>`);
            tbody.append(tr);
        });
    }

    // ══════════════════════════════════════════
    // 編輯模式切換 (對應 btnUpdate / btnBrowse)
    // ══════════════════════════════════════════
    function enterEditMode() {
        isEditMode = true;
        $('#txtNotes').prop('readonly', false);
        $('#lblCurrentMode').text('更新模式').removeClass('bg-secondary').addClass('bg-warning text-dark');
        $('#btnSaveNotes').show();
        $('#btnSaveInline, #btnCancelInline').show();
        $('#notesBtnBar').css('display', 'flex');
        // 新增/刪除按鈕只在更新模式才顯示
        $('#btnAddDetail').show();
        $('#btnDeleteDetail').show().prop('disabled', !selectedDetail);
    }

    function enterBrowseMode() {
        isEditMode = false;
        $('#txtNotes').prop('readonly', true).css('border-color', '');
        $('#lblCurrentMode').text('瀏覽').removeClass('bg-warning text-dark').addClass('bg-secondary');
        $('#btnSaveNotes').hide();
        $('#btnSaveInline, #btnCancelInline').hide();
        $('#notesBtnBar').hide();
        $('#btnAddDetail, #btnDeleteDetail').hide();
    }

    // ══════════════════════════════════════════
    // 新增備注列 (對應 Navigator nbInsert + nbPost)
    // ══════════════════════════════════════════
    function addDetail() {
        var itemId = $('#addDetailItemId').val().trim();
        if (!itemId) {
            $('#addDetailItemId').addClass('is-invalid');
            $('#addDetailItemIdErr').text('代號不可空白');
            return;
        }
        $('#addDetailItemId').removeClass('is-invalid');

        var notes = $('#addDetailNotes').val();
        $('#btnAddDetailConfirm').prop('disabled', true).text('新增中...');

        $.ajax({
            url: '/api/EMOdProcNotesList/detail',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                procCode: selectedProcCode,
                itemId:   itemId,
                notes:    notes
            }),
            success: function (resp) {
                $('#btnAddDetailConfirm').prop('disabled', false).text('確定新增');
                if (resp.success) {
                    bootstrap.Modal.getInstance(document.getElementById('modalAddDetail')).hide();
                    loadDetail(selectedProcCode);   // 重新載入明細列表
                } else {
                    $('#addDetailItemId').addClass('is-invalid');
                    $('#addDetailItemIdErr').text(resp.message || '新增失敗');
                }
            },
            error: function (xhr) {
                $('#btnAddDetailConfirm').prop('disabled', false).text('確定新增');
                var msg = xhr.responseJSON?.message || '新增失敗';
                $('#addDetailItemId').addClass('is-invalid');
                $('#addDetailItemIdErr').text(msg);
            }
        });
    }

    // ══════════════════════════════════════════
    // 刪除備注列 (對應 Navigator nbDelete)
    // ══════════════════════════════════════════
    function deleteDetail() {
        if (!selectedDetail) { alert('請先選擇要刪除的備注列'); return; }
        if (!confirm('確定刪除代號「' + selectedDetail.ItemId + '」的備注？\n此動作無法復原。')) return;

        $.ajax({
            url: '/api/EMOdProcNotesList/detail/'
                 + encodeURIComponent(selectedDetail.ProcCode) + '/'
                 + encodeURIComponent(selectedDetail.ItemId),
            type: 'DELETE',
            success: function (resp) {
                if (resp.success) {
                    // 從畫面上移除該列，清空 memo
                    $('#detailTbody tr.row-active').remove();
                    selectedDetail = null;
                    notesOriginal = '';
                    $('#txtNotes').val('').css('border-color', '');
                    $('#lblNotesKey').text('');
                    $('#btnDeleteDetail').prop('disabled', true);
                    // 更新筆數
                    var cnt = $('#detailTbody tr').length;
                    $('#detailCount').text(cnt + ' 筆');
                    if (cnt === 0) $('#detailEmpty').show();
                } else {
                    alert(resp.message || '刪除失敗');
                }
            },
            error: function (xhr) {
                alert('刪除失敗: ' + (xhr.responseJSON?.message || ''));
            }
        });
    }

    // ══════════════════════════════════════════
    // 儲存備注 (對應 Navigator nbPost / DBMemo1 儲存)
    // ══════════════════════════════════════════
    function saveNotes() {
        if (!selectedDetail) { alert('請先選擇一筆備注'); return; }
        var newNotes = $('#txtNotes').val();

        $.ajax({
            url: '/api/EMOdProcNotesList/notes',
            type: 'PUT',
            contentType: 'application/json',
            data: JSON.stringify({
                procCode: selectedDetail.ProcCode,
                itemId:   selectedDetail.ItemId,
                notes:    newNotes
            }),
            success: function (resp) {
                if (resp.success) {
                    selectedDetail.Notes = newNotes;
                    notesOriginal = newNotes;
                    $('#txtNotes').css('border-color', '');
                    var preview = newNotes.substring(0, 60) + (newNotes.length > 60 ? '...' : '');
                    $('#detailTbody tr.row-active')
                        .data('notes', newNotes)
                        .find('td:last')
                        .html(preview ? esc(preview) : '<span class="text-muted fst-italic">（無內容）</span>');
                } else {
                    alert(resp.message || '儲存失敗');
                }
            },
            error: function (xhr) {
                alert('儲存失敗: ' + (xhr.responseJSON?.message || ''));
            }
        });
    }

    function cancelNotes() {
        $('#txtNotes').val(notesOriginal).css('border-color', '');
    }

    // ══════════════════════════════════════════
    // 匯出 Excel (CSV)
    // ══════════════════════════════════════════
    function exportToExcel() {
        var rows = [['制代代碼', '製程名稱', '代號', '備注內容']];
        var procCode = selectedProcCode || '';
        var procName = '';
        if (procCode) {
            var masterRow = allMasterData.find(r => r.ProcCode === procCode);
            procName = masterRow ? (masterRow.ProcName || '') : '';
        }

        $('#detailTbody tr').each(function () {
            var itemId = $(this).data('itemid') || '';
            var notes  = $(this).data('notes') || '';
            rows.push([procCode, procName, itemId, notes]);
        });

        if (rows.length <= 1) { alert('請先選擇製程並確認有備注資料'); return; }

        var csv = rows.map(r => r.map(c => '"' + String(c).replace(/"/g, '""') + '"').join(',')).join('\n');
        var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = '製程常用備注_' + (procCode || 'all') + '.csv';
        a.click();
    }

    function esc(str) {
        return String(str)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
</script>
}
