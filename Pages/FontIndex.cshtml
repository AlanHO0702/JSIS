    function renderInteractiveFlowchart(systemId) {
        const container = document.getElementById('interactiveFlowchart');
        const emptyEl   = document.getElementById('interactiveFlowchartEmpty');
        if (!container) return;

        // 清除舊有節點與 SVG
        container.querySelectorAll('.flow-node, .flow-svg-overlay').forEach(el => el.remove());

        const config = systemFlowcharts[systemId];
        if (!config || !config.nodes || config.nodes.length === 0) {
            if (emptyEl) emptyEl.style.display = 'block';
            return;
        }
        if (emptyEl) emptyEl.style.display = 'none';

        const ns = 'http://www.w3.org/2000/svg';

        // 建立 SVG 連線層（viewBox 0 0 100 100，preserveAspectRatio none 確保坐標與節點 % 對齊）
        const svg = document.createElementNS(ns, 'svg');
        svg.setAttribute('class', 'flow-svg-overlay');
        svg.setAttribute('viewBox', '0 0 100 100');
        svg.setAttribute('preserveAspectRatio', 'none');

        // 定義箭頭 marker（solid / dashed 各一）
        const defs = document.createElementNS(ns, 'defs');
        [['arrow-solid','#555'], ['arrow-dashed','#888']].forEach(([id, fill]) => {
            const marker = document.createElementNS(ns, 'marker');
            marker.setAttribute('id', id);
            marker.setAttribute('markerUnits', 'userSpaceOnUse');
            marker.setAttribute('markerWidth', '2');
            marker.setAttribute('markerHeight', '2');
            marker.setAttribute('refX', '0');
            marker.setAttribute('refY', '1');
            marker.setAttribute('orient', 'auto');
            const poly = document.createElementNS(ns, 'polygon');
            poly.setAttribute('points', '0 0, 2 1, 0 2');
            poly.setAttribute('fill', fill);
            marker.appendChild(poly);
            defs.appendChild(marker);
        });
        svg.appendChild(defs);

        // 節點查找 Map
        const nodeMap = {};
        config.nodes.forEach(n => { nodeMap[n.id] = n; });

        // 計算連接點坐標（百分比空間）
        function getPort(node, port) {
            switch (port) {
                case 'top':    return { x: node.x + node.w / 2, y: node.y };
                case 'bottom': return { x: node.x + node.w / 2, y: node.y + node.h };
                case 'left':   return { x: node.x,              y: node.y + node.h / 2 };
                case 'right':  return { x: node.x + node.w,     y: node.y + node.h / 2 };
            }
        }

        // 路徑終點提前 ARROW_LEN，讓箭頭尾端在此，尖端落在節點邊界
        const ARROW_LEN = 2;
        function getPortTarget(node, port) {
            switch (port) {
                case 'top':    return { x: node.x + node.w / 2, y: node.y - ARROW_LEN };
                case 'bottom': return { x: node.x + node.w / 2, y: node.y + node.h + ARROW_LEN };
                case 'left':   return { x: node.x - ARROW_LEN,  y: node.y + node.h / 2 };
                case 'right':  return { x: node.x + node.w + ARROW_LEN, y: node.y + node.h / 2 };
            }
        }

        // 繪製連線 SVG path
        config.connections.forEach(conn => {
            const src = nodeMap[conn.from];
            const dst = nodeMap[conn.to];
            if (!src || !dst) return;

            const p1 = getPort(src, conn.fromPort);
            const p2 = getPortTarget(dst, conn.toPort);
            const dx = p2.x - p1.x;
            const dy = p2.y - p1.y;

            let d;
            const fp = conn.fromPort, tp = conn.toPort;

            if (conn.path === 'straight') {
                d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
            } else if (fp === 'bottom' && tp === 'top') {
                // 垂直：若 x 有偏差則 L 形
                if (Math.abs(dx) < 1) {
                    d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
                } else {
                    // 水平段盡量靠近目標節點上方，避免穿越中間節點
                    const pivot = Math.max(p1.y + 2, p2.y - 3);
                    d = `M${p1.x},${p1.y} L${p1.x},${pivot} L${p2.x},${pivot} L${p2.x},${p2.y}`;
                }
            } else if (fp === 'bottom' && (tp === 'left' || tp === 'right')) {
                // 向下再水平
                d = `M${p1.x},${p1.y} L${p1.x},${p2.y} L${p2.x},${p2.y}`;
            } else if ((fp === 'right' || fp === 'left') && tp === 'top') {
                // 先水平延伸至目標 x，再垂直向下
                d = `M${p1.x},${p1.y} L${p2.x},${p1.y} L${p2.x},${p2.y}`;
            } else if ((fp === 'right' || fp === 'left') && (tp === 'left' || tp === 'right')) {
                // 水平：若 y 有偏差則 L 形
                if (Math.abs(dy) < 1) {
                    d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
                } else {
                    const midX = (p1.x + p2.x) / 2;
                    d = `M${p1.x},${p1.y} L${midX},${p1.y} L${midX},${p2.y} L${p2.x},${p2.y}`;
                }
            } else {
                d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
            }

            const path = document.createElementNS(ns, 'path');
            path.setAttribute('d', d);
            path.setAttribute('fill', 'none');
            path.setAttribute('stroke', conn.style === 'dashed' ? '#888' : '#555');
            path.setAttribute('stroke-width', '1.0');
            if (conn.arrow !== false) {
                path.setAttribute('marker-end', `url(#arrow-${conn.style})`);
            }
            if (conn.style === 'dashed') path.setAttribute('stroke-dasharray', '2.5,1.5');
            svg.appendChild(path);
        });

        container.appendChild(svg);

        // 建立節點 HTML 元素
        config.nodes.forEach(node => {
            if (node.hidden) return;
            const el = document.createElement(node.link ? 'a' : 'div');
            el.className = `flow-node flow-node-${node.color}`;
            el.style.left   = `${node.x}%`;
            el.style.top    = `${node.y}%`;
            el.style.width  = `${node.w}%`;
            el.style.height = `${node.h}%`;
            el.innerHTML    = node.label.replace(/\n/g, '<br>');
            if (node.link) { el.href = node.link; el.target = '_blank'; }
            if (!node.link) el.title = '尚未設定連結';
            container.appendChild(el);
        });
    }

    function getSystemIdFromPowerType(ptRaw) {
        if (ptRaw === null || ptRaw === undefined) return null;
        const num = parseInt(ptRaw, 10);
        if (Number.isNaN(num)) return null;
        const map = {
            1: 1,  // 銷售客戶
            2: 2,  // 原物料廠商
            3: 3,  // 製程委外廠商
            4: 4,  // 製令委外廠商
            5: 5,  // 進出口廠商
            6: 6,  // 其它廠商
            7: 7,  // 經銷商
            9: 9,  // 臨時客戶
            103: 1 // 客戶授信額度 -> 視為銷售客戶
        };
        return map[num] ?? null;
    }

    function resolveCompanyLinkFromMeta(meta, itemId) {
        if (!meta) return null;
        const cls = String(meta.className ?? meta.ClassName ?? "").trim().toLowerCase();
        if (cls !== "ccsdcompanydll.dll") return null;
        const resolvedId = String(itemId ?? meta.itemId ?? meta.ItemId ?? "").trim();
        if (!resolvedId) return null;
        const pt = meta.powerType ?? meta.PowerType;
        const sysId = getSystemIdFromPowerType(pt);
        if (!sysId) return null;
        return `/CCS/${resolvedId}/${sysId}`;
    }

    const itemHintCache = new Map();

    function getTemplateNameFromMeta(meta, itemId) {
        const hard = pageMap[itemId];
        if (hard) return hard;

        const companyLink = resolveCompanyLinkFromMeta(meta, itemId);
        if (companyLink) return companyLink;

        const itemType = Number(meta?.itemType ?? meta?.ItemType);
        const outputType = Number(meta?.outputType ?? meta?.OutputType);

        const pickStr = (obj, keys) => {
            for (const k of keys) {
                if (obj && obj[k] !== undefined && obj[k] !== null) return obj[k];
            }
            return '';
        };
        const ocxRaw = pickStr(meta, [
            'ocxtemplete', 'Ocxtemplete', 'OCXTemplete', 'ocxTemplete', 'OCXTemplete',
            'ocxTemplate', 'OCXTemplate', 'ocxtemplate', 'OCXTEMPLATE',
            'OCX', 'ocx'
        ]);
        const ocx = String(ocxRaw).trim().toLowerCase();

        if (itemType === 6) {
            if (ocx.includes('jsdpaper3ldll')) return 'Paper3L';
            if (ocx.includes('jsdpaperorgdll')) return 'Paper';
            if (ocx.includes('jsdsinglegriddll')) return 'SingleGrid';
            if (ocx.includes('jsdgriddll')) return 'MultiGrid';
            if (ocx.includes('jsdmasdtldll')) return 'MasterDetail';
            if (ocx.includes('jsdmasmultidtldll')) return 'MasterMultiDetail';
        }

        if (itemType === 2 && outputType === 0) return 'Report(Direct)';
        if (itemType === 2 && (outputType === 6 || outputType === 7)) return 'Report(Generic)';

        return '未設定';
    }

    function getLocalHint(itemId, className, powerType) {
        const hard = pageMap[itemId];
        if (hard) return hard;
        const localMeta = { ClassName: className, PowerType: powerType };
        const companyLink = resolveCompanyLinkFromMeta(localMeta, itemId);
        return companyLink || null;
    }

    async function getItemHint(itemId, className, powerType) {
        const key = `${itemId}|${className ?? ''}|${powerType ?? ''}`;
        if (itemHintCache.has(key)) return itemHintCache.get(key);

        const local = getLocalHint(itemId, className, powerType);
        if (local) {
            itemHintCache.set(key, local);
            return local;
        }

        try {
            const res = await fetch(`/api/report/item-meta/${itemId}`);
            if (!res.ok) throw new Error('meta not found');
            const meta = await res.json();
            const hint = getTemplateNameFromMeta(meta, itemId);
            itemHintCache.set(key, hint);
            return hint;
        } catch {
            const hint = '未設定';
            itemHintCache.set(key, hint);
            return hint;
        }
    }

    async function loadHintOnHover(el, itemId, className, powerType) {
        if (!el) return;
        el.title = await getItemHint(itemId, className, powerType);
    }

