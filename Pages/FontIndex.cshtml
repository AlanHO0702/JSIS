    function renderInteractiveFlowchart(systemId) {
        currentFlowSystemId = systemId;
        const container = document.getElementById('interactiveFlowchart');
        const emptyEl   = document.getElementById('interactiveFlowchartEmpty');
        if (!container) return;

        // 清除舊有節點與 SVG
        container.querySelectorAll('.flow-node, .flow-svg-overlay, .flow-legend').forEach(el => el.remove());

        const config = systemFlowcharts[systemId];
        if (!config || !config.nodes || config.nodes.length === 0) {
            if (emptyEl) emptyEl.style.display = 'block';
            return;
        }
        if (emptyEl) emptyEl.style.display = 'none';

        const ns = 'http://www.w3.org/2000/svg';

        // 建立 SVG 連線層（viewBox 0 0 100 100，preserveAspectRatio none 確保坐標與節點 % 對齊）
        const svg = document.createElementNS(ns, 'svg');
        svg.setAttribute('class', 'flow-svg-overlay');
        svg.setAttribute('viewBox', '0 0 100 100');
        svg.setAttribute('preserveAspectRatio', 'none');

        // 定義箭頭 marker（solid / dashed 各一）
        const defs = document.createElementNS(ns, 'defs');
        ['arrow-solid', 'arrow-dashed'].forEach(id => {
            const marker = document.createElementNS(ns, 'marker');
            marker.setAttribute('id', id);
            marker.setAttribute('markerUnits', 'userSpaceOnUse');
            marker.setAttribute('markerWidth', '1.2');
            marker.setAttribute('markerHeight', '1.2');
            marker.setAttribute('refX', '0');
            marker.setAttribute('refY', '0.6');
            marker.setAttribute('orient', 'auto');
            const poly = document.createElementNS(ns, 'polygon');
            poly.setAttribute('points', '0 0, 1.2 0.6, 0 1.2');
            poly.setAttribute('fill', 'context-stroke');
            marker.appendChild(poly);
            defs.appendChild(marker);
        });
        svg.appendChild(defs);

        // 節點查找 Map
        const nodeMap = {};
        config.nodes.forEach(n => { nodeMap[n.id] = n; });
        // nodeId → 相連 path 元素（供 hover 高亮用）
        const pathMap = {};

        // 計算連接點坐標（百分比空間）
        function getPort(node, port) {
            switch (port) {
                case 'top':    return { x: node.x + node.w / 2, y: node.y };
                case 'bottom': return { x: node.x + node.w / 2, y: node.y + node.h };
                case 'left':   return { x: node.x,              y: node.y + node.h / 2 };
                case 'right':  return { x: node.x + node.w,     y: node.y + node.h / 2 };
            }
        }

        // 路徑終點提前 ARROW_LEN，讓箭頭尾端在此，尖端落在節點邊界
        const ARROW_LEN = 1.2;
        function getPortTarget(node, port) {
            switch (port) {
                case 'top':    return { x: node.x + node.w / 2, y: node.y - ARROW_LEN };
                case 'bottom': return { x: node.x + node.w / 2, y: node.y + node.h + ARROW_LEN };
                case 'left':   return { x: node.x - ARROW_LEN,  y: node.y + node.h / 2 };
                case 'right':  return { x: node.x + node.w + ARROW_LEN, y: node.y + node.h / 2 };
            }
        }

        // 繪製連線 SVG path（含端口覆寫 + 彎折偏移 + 點擊選取 + 彎折拖曳控點）
        _flowEdgePaths = {};
        config.connections.forEach(conn => {
            const src = nodeMap[conn.from];
            const dst = nodeMap[conn.to];
            if (!src || !dst) return;

            // 套用使用者儲存的端口覆寫與彎折偏移
            const ekey = conn.from + ':' + conn.to;
            const ov          = currentEdgePortOverrides[ekey];
            const fp          = (ov && ov.fromPort)    || conn.fromPort;
            const tp          = (ov && ov.toPort)      || conn.toPort;
            const pivotOffset = (ov && ov.pivotOffset) || 0;

            const rawP1 = getPort(src, fp);
            const rawP2 = conn.arrow !== false ? getPortTarget(dst, tp) : getPort(dst, tp);
            const offY = conn.offsetY || 0;
            const offX = conn.offsetX || 0;
            const p1 = { x: rawP1.x + offX + (conn.fromOffsetX || 0), y: rawP1.y + offY + (conn.fromOffsetY || 0) };
            const p2 = { x: rawP2.x + offX + (conn.toOffsetX   || 0), y: rawP2.y + offY + (conn.toOffsetY   || 0) };
            const dx = p2.x - p1.x;
            const dy = p2.y - p1.y;

            let d;
            let handleX = null, handleY = null, handleDir = null;

            if (conn.path === 'straight') {
                d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
            } else if (fp === 'bottom' && tp === 'top') {
                if (typeof conn.pivotY === 'number') {
                    const pv = conn.pivotY + offY + pivotOffset;
                    d = `M${p1.x},${p1.y} L${p1.x},${pv} L${p2.x},${pv} L${p2.x},${p2.y}`;
                    handleX = (p1.x + p2.x) / 2; handleY = pv; handleDir = 'y';
                } else if (Math.abs(dx) < 1) {
                    d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
                } else {
                    const pv = Math.max(p1.y + 2, p2.y - 3) + pivotOffset;
                    d = `M${p1.x},${p1.y} L${p1.x},${pv} L${p2.x},${pv} L${p2.x},${p2.y}`;
                    handleX = (p1.x + p2.x) / 2; handleY = pv; handleDir = 'y';
                }
            } else if (fp === 'bottom' && (tp === 'left' || tp === 'right')) {
                const midY = p2.y + pivotOffset;
                d = `M${p1.x},${p1.y} L${p1.x},${midY} L${p2.x},${midY}`;
                handleX = (p1.x + p2.x) / 2; handleY = midY; handleDir = 'y';
            } else if ((fp === 'right' || fp === 'left') && tp === 'top') {
                const midX = p2.x + pivotOffset;
                d = `M${p1.x},${p1.y} L${midX},${p1.y} L${midX},${p2.y}`;
                handleX = midX; handleY = (p1.y + p2.y) / 2; handleDir = 'x';
            } else if (fp === 'left' && tp === 'left') {
                const lx = Math.min(p1.x, p2.x) - 2 + pivotOffset;
                d = `M${p1.x},${p1.y} L${lx},${p1.y} L${lx},${p2.y} L${p2.x},${p2.y}`;
                handleX = lx; handleY = (p1.y + p2.y) / 2; handleDir = 'x';
            } else if ((fp === 'right' || fp === 'left') && (tp === 'left' || tp === 'right')) {
                if (Math.abs(dy) < 1) {
                    d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
                } else {
                    const mx = (p1.x + p2.x) / 2 + pivotOffset;
                    d = `M${p1.x},${p1.y} L${mx},${p1.y} L${mx},${p2.y} L${p2.x},${p2.y}`;
                    handleX = mx; handleY = (p1.y + p2.y) / 2; handleDir = 'x';
                }
            } else if ((fp === 'right' || fp === 'left') && tp === 'bottom') {
                const midX = p2.x + pivotOffset;
                d = `M${p1.x},${p1.y} L${midX},${p1.y} L${midX},${p2.y}`;
                handleX = midX; handleY = (p1.y + p2.y) / 2; handleDir = 'x';
            } else if (fp === 'top' && (tp === 'left' || tp === 'right')) {
                const midY = p2.y + pivotOffset;
                d = `M${p1.x},${p1.y} L${p1.x},${midY} L${p2.x},${midY}`;
                handleX = (p1.x + p2.x) / 2; handleY = midY; handleDir = 'y';
            } else if (fp === 'top' && tp === 'top') {
                const ly = Math.min(p1.y, p2.y) - 2 + pivotOffset;
                d = `M${p1.x},${p1.y} L${p1.x},${ly} L${p2.x},${ly} L${p2.x},${p2.y}`;
                handleX = (p1.x + p2.x) / 2; handleY = ly; handleDir = 'y';
            } else {
                d = `M${p1.x},${p1.y} L${p2.x},${p2.y}`;
            }

            // 不可見加寬點擊區域（讓連線更容易點到）
            const hitPath = document.createElementNS(ns, 'path');
            hitPath.setAttribute('d', d);
            hitPath.setAttribute('fill', 'none');
            hitPath.setAttribute('stroke', 'transparent');
            hitPath.setAttribute('stroke-width', '4');
            hitPath.style.pointerEvents = 'stroke';
            hitPath.style.cursor = 'pointer';
            svg.appendChild(hitPath);

            // 可見連線
            const path = document.createElementNS(ns, 'path');
            path.setAttribute('d', d);
            path.setAttribute('fill', 'none');
            path.setAttribute('stroke', conn.color ?? (conn.style === 'dashed' ? '#E2E8F0' : '#CBD5E1'));
            path.setAttribute('stroke-width', '0.4');
            path.setAttribute('stroke-linecap', 'round');
            path.setAttribute('stroke-linejoin', 'round');
            if (conn.arrow !== false) {
                path.setAttribute('marker-end', `url(#arrow-${conn.style})`);
            }
            if (conn.style === 'dashed') path.setAttribute('stroke-dasharray', '2.5,1.5');
            if (!pathMap[conn.from]) pathMap[conn.from] = [];
            if (!pathMap[conn.to])   pathMap[conn.to]   = [];
            pathMap[conn.from].push(path);
            pathMap[conn.to].push(path);
            svg.appendChild(path);

            // 彎折段拖曳控點（僅對有浮動中段的連線）
            let handleEl = null;
            if (handleDir !== null) {
                handleEl = document.createElementNS(ns, 'circle');
                handleEl.setAttribute('cx', handleX);
                handleEl.setAttribute('cy', handleY);
                handleEl.setAttribute('r', '1.5');
                handleEl.setAttribute('fill', '#ffffff');
                handleEl.setAttribute('stroke', '#94a3b8');
                handleEl.setAttribute('stroke-width', '0.4');
                handleEl.style.pointerEvents = 'none'; // 預設隱藏時不響應事件
                handleEl.style.cursor = handleDir === 'y' ? 'ns-resize' : 'ew-resize';
                handleEl.style.display = 'none';      // 點選連線後才顯示
                handleEl.addEventListener('click', function(ev) { ev.stopPropagation(); });
                (function(ek, dir, capOffset) {
                    handleEl.addEventListener('mousedown', function(ev) {
                        if (ev.button !== 0) return;
                        const cRect = container.getBoundingClientRect();
                        flowPivotDrag = {
                            ekey: ek, handleDir: dir,
                            startX: ev.clientX, startY: ev.clientY,
                            origOffset: capOffset,
                            cW: cRect.width, cH: cRect.height,
                            moved: false
                        };
                        ev.preventDefault();
                        ev.stopPropagation();
                    });
                    // 雙擊控點：歸零偏移，對齊回預設位置
                    handleEl.addEventListener('dblclick', function(ev) {
                        ev.stopPropagation();
                        ev.preventDefault();
                        const ov = currentEdgePortOverrides[ek];
                        if (ov) ov.pivotOffset = 0;
                        clearEdgeSelection();
                        renderInteractiveFlowchart(currentFlowSystemId);
                        clearTimeout(flowEdgeSaveTimer);
                        flowEdgeSaveTimer = setTimeout(function() { saveFlowEdges(currentFlowSystemId); }, 800);
                    });
                })(ekey, handleDir, pivotOffset);
                svg.appendChild(handleEl);
            }

            _flowEdgePaths[ekey] = { pathEl: path, hitPath, handleEl, conn, p1: { ...p1 }, p2: { ...p2 }, offY, handleDir, fp, tp };

            // 點擊連線本體：顯示端口選取圓點
            (function(ek, capFp, capTp, capPath, capSrc, capDst) {
                hitPath.addEventListener('click', function(ev) {
                    ev.stopPropagation();
                    selectEdge(ek, capFp, capTp, capPath, capSrc, capDst);
                });
            })(ekey, fp, tp, path, src, dst);
        });

        _flowSvgEl = svg;
        container.appendChild(svg);

        // 點擊空白區域取消端口選取
        container.onclick = function() { clearEdgeSelection(); };

        const legacyColorAlias = {
            green: 'use',
            green2: 'use',
            blue: 'in',
            orange: 'out'
        };

        // 建立節點 HTML 元素
        config.nodes.forEach(node => {
            if (node.hidden) return;
            const el = document.createElement(node.link ? 'a' : 'div');
            const colorKey = legacyColorAlias[node.color] || node.color;
            el.className = `flow-node flow-node-${colorKey}`;
            el.dataset.nodeid = node.id;
            el.style.left   = `${node.x}%`;
            el.style.top    = `${node.y}%`;
            el.style.width  = `${node.w}%`;
            el.style.height = `${node.h}%`;
            el.innerHTML    = node.label.replace(/\n/g, '<br>');
            if (node.link) { el.href = node.link; el.target = '_blank'; el.title = node.label.replace(/<[^>]*>/g,''); }
            // hover 高亮相連路徑
            const conPaths = pathMap[node.id] || [];
            if (conPaths.length > 0 || node.link) {
                el.addEventListener('mouseenter', () => {
                    conPaths.forEach(p => { p.style.stroke = '#3B82F6'; p.style.strokeWidth = '0.5'; });
                    el.classList.add('flow-hovered');
                });
                el.addEventListener('mouseleave', () => {
                    conPaths.forEach(p => { p.style.stroke = ''; p.style.strokeWidth = ''; });
                    el.classList.remove('flow-hovered');
                });
            }
            container.appendChild(el);
        });
        // 繪製圖例（若設定 legend）
        if (config.legend && config.legend.length > 0) {
            const leg = document.createElement('div');
            leg.className = 'flow-legend';
            leg.style.cssText = 'position:absolute;bottom:8px;left:0;right:0;display:flex;align-items:center;justify-content:center;gap:18px;padding:0 16px;font-size:0.72rem;color:#6B7280;z-index:3;pointer-events:none;';
            config.legend.forEach(item => {
                const s = document.createElement('span');
                s.style.cssText = 'display:inline-flex;align-items:center;gap:5px;';
                if (item.color) {
                    const dot = document.createElement('span');
                    dot.style.cssText = `width:9px;height:9px;border-radius:50%;background:${item.color};flex-shrink:0;`;
                    s.appendChild(dot);
                }
                if (item.icon) {
                    const ic = document.createElement('span');
                    ic.textContent = item.icon;
                    s.appendChild(ic);
                }
                s.appendChild(document.createTextNode(item.text));
                leg.appendChild(s);
            });
            container.appendChild(leg);
        }
    }

    function getSystemIdFromPowerType(ptRaw) {
        if (ptRaw === null || ptRaw === undefined) return null;
        const num = parseInt(ptRaw, 10);
        if (Number.isNaN(num)) return null;
        const map = {
            1: 1,  // 銷售客戶
            2: 2,  // 原物料廠商
            3: 3,  // 製程委外廠商
            4: 4,  // 製令委外廠商
            5: 5,  // 進出口廠商
            6: 6,  // 其它廠商
            7: 7,  // 經銷商
            9: 9,  // 臨時客戶
            103: 1 // 客戶授信額度 -> 視為銷售客戶
        };
        return map[num] ?? null;
    }

    function resolveCompanyLinkFromMeta(meta, itemId) {
        if (!meta) return null;
        const cls = String(meta.className ?? meta.ClassName ?? "").trim().toLowerCase();
        if (cls !== "ccsdcompanydll.dll") return null;
        const resolvedId = String(itemId ?? meta.itemId ?? meta.ItemId ?? "").trim();
        if (!resolvedId) return null;
        const pt = meta.powerType ?? meta.PowerType;
        const sysId = getSystemIdFromPowerType(pt);
        if (!sysId) return null;
        return `/CCS/${resolvedId}/${sysId}`;
    }

    const itemHintCache = new Map();

    function getTemplateNameFromMeta(meta, itemId) {
        const hard = pageMap[itemId];
        if (hard) return hard;

        const companyLink = resolveCompanyLinkFromMeta(meta, itemId);
        if (companyLink) return companyLink;

        const itemType = Number(meta?.itemType ?? meta?.ItemType);
        const outputType = Number(meta?.outputType ?? meta?.OutputType);

        const pickStr = (obj, keys) => {
            for (const k of keys) {
                if (obj && obj[k] !== undefined && obj[k] !== null) return obj[k];
            }
            return '';
        };
        const ocxRaw = pickStr(meta, [
            'ocxtemplete', 'Ocxtemplete', 'OCXTemplete', 'ocxTemplete', 'OCXTemplete',
            'ocxTemplate', 'OCXTemplate', 'ocxtemplate', 'OCXTEMPLATE',
            'OCX', 'ocx'
        ]);
        const ocx = String(ocxRaw).trim().toLowerCase();

        if (itemType === 6) {
            if (ocx.includes('jsdpaper3ldll')) return 'Paper3L';
            if (ocx.includes('jsdpaperorgdll')) return 'Paper';
            if (ocx.includes('jsdsinglegriddll')) return 'SingleGrid';
            if (ocx.includes('jsdgriddll')) return 'MultiGrid';
            if (ocx.includes('jsdmasdtldll')) return 'MasterDetail';
            if (ocx.includes('jsdmasmultidtldll')) return 'MasterMultiDetail';
        }

        if (itemType === 2 && outputType === 0) return 'Report(Direct)';
        if (itemType === 2 && (outputType === 6 || outputType === 7)) return 'Report(Generic)';

        return '未設定';
    }

    function getLocalHint(itemId, className, powerType) {
        const hard = pageMap[itemId];
        if (hard) return hard;
        const localMeta = { ClassName: className, PowerType: powerType };
        const companyLink = resolveCompanyLinkFromMeta(localMeta, itemId);
        return companyLink || null;
    }

    async function getItemHint(itemId, className, powerType) {
        const key = `${itemId}|${className ?? ''}|${powerType ?? ''}`;
        if (itemHintCache.has(key)) return itemHintCache.get(key);

        const local = getLocalHint(itemId, className, powerType);
        if (local) {
            itemHintCache.set(key, local);
            return local;
        }

        try {
            const res = await fetch(`/api/report/item-meta/${itemId}`);
            if (!res.ok) throw new Error('meta not found');
            const meta = await res.json();
            const hint = getTemplateNameFromMeta(meta, itemId);
            itemHintCache.set(key, hint);
            return hint;
        } catch {
            const hint = '未設定';
            itemHintCache.set(key, hint);
            return hint;
        }
    }

    async function loadHintOnHover(el, itemId, className, powerType) {
        if (!el) return;
        el.title = await getItemHint(itemId, className, powerType);
    }

    const selectedLevel1Id = "@Model.SelectedLevel1Id";

    async function resolveAndGo(itemId, itemName, superId, className, powerType) {
        console.debug('resolveAndGo click', { itemId, itemName, superId });
        const hard = pageMap[itemId];
        if (hard) { location.href = hard; return; }

        // 先嘗試本地 className/powerType 映射（我的最愛可帶進來）
        const localMeta = { ClassName: className, PowerType: powerType };
        const localLink = resolveCompanyLinkFromMeta(localMeta, itemId);
        if (localLink) { location.href = localLink; return; }

        try {
            const metaUrl = `/api/report/item-meta/${itemId}`;
            console.debug('fetch meta', metaUrl);
            const res = await fetch(metaUrl);
            if (!res.ok) throw new Error('not found');
            const meta = await res.json();

            // 若有從 my favorites 觸發，補齊並回存 class/power/superId，避免下次缺資料
            try {
                const favs = getFavorites();
                const idx = favs.findIndex(f => f.itemId === itemId);
                if (idx >= 0) {
                    const mClass = meta.ClassName ?? meta.className ?? '';
                    const mPower = meta.PowerType ?? meta.powerType ?? '';
                    const mSuper = meta.SuperId ?? meta.superId ?? superId ?? '';
                    favs[idx].className = mClass?.toString() ?? '';
                    favs[idx].powerType = mPower?.toString() ?? '';
                    favs[idx].superId = mSuper?.toString() ?? favs[idx].superId ?? '';
                    setFavorites(favs);
                }
            } catch (err) { console.warn('favorite meta backfill failed', err); }

            const companyLink = resolveCompanyLinkFromMeta(meta, itemId);
            if (companyLink) { location.href = companyLink; return; }

            const itemType = Number(meta.itemType ?? meta.ItemType);
            const outputType = Number(meta.outputType ?? meta.OutputType);
            const pickStr = (obj, keys) => {
                for (const k of keys) {
                    if (obj && obj[k] !== undefined && obj[k] !== null) return obj[k];
                }
                return '';
            };
            const ocxRaw = pickStr(meta, [
                'ocxtemplete','Ocxtemplete','OCXTemplete','ocxTemplete','OCXTemplete',
                'ocxTemplate','OCXTemplate','ocxtemplate','OCXTEMPLATE',
                'OCX','ocx'
            ]);
            const ocx = String(ocxRaw).trim().toLowerCase();
            let url = '';
            if (itemType === 2 && outputType === 0) url = `/Report/Direct/${itemId}`;
            else if (itemType === 2 && (outputType === 6 || outputType === 7)) url = `/Report/Generic/${itemId}`;
            else if (itemType === 6 && (ocx === 'jsdpaper3ldll.dll' || ocx.includes('jsdpaper3ldll'))) url = `/DynamicTemplate/Paper3L/${itemId}`;
            else if (itemType === 6 && (ocx === 'jsdpaperorgdll.dll' || ocx.includes('jsdpaperorgdll'))) url = `/DynamicTemplate/Paper/${itemId}`;
            else if (itemType === 6 && (ocx === 'jsdsinglegriddll.dll' || ocx.includes('jsdsinglegriddll'))) url = `/CUR/SingleGrid/${itemId}`;
            else if (itemType === 6 && (ocx === 'jsdgriddll.dll' || ocx.includes('jsdgriddll'))) url = `/CUR/MultiGrid/${itemId}`;
            else if (itemType === 6 && (ocx === 'jsdmasdtldll.dll' || ocx.includes('jsdmasdtldll'))) url = `/CUR/MasterDetail/${itemId}`;
            else if (itemType === 6 && (ocx === 'jsdmasmultidtldll.dll' || ocx.includes('jsdmasmultidtldll'))) url = `/CUR/MasterMultiDetail/${itemId}`;

            if (url) { location.href = url; return; }
            if (superId) { location.href = `?level1Id=${superId}`; return; }
        } catch (err) {
            console.warn('resolveAndGo meta error', err);
        }
        if (superId) {
            location.href = `?level1Id=${superId}`;
        } else {
            alert(`找不到對應的頁面: ${itemId}`);
        }
    }
    function showSystemGraph(systemId, systemName) {
        const panel = document.getElementById('systemGraphPanel');
        const titleBar = document.getElementById('systemGraphTitleBar');
        const functionListTitleBar = document.getElementById('functionListTitleBar');
        const img = document.getElementById('systemGraphImg');
        const empty = document.getElementById('systemGraphEmpty');
        const title = document.getElementById('systemGraphTitle');
        const open = document.getElementById('systemGraphOpen');
        const list = document.getElementById('level2-list');
        if (!panel || !img || !empty || !title || !open || !titleBar) return;

        const sid = (systemId || '').toString().trim();
        if (!sid) return;

        // 渲染互動流程圖（頁籤 1）
        renderInteractiveFlowchart(sid);
        loadSavedFlowData(sid);

        panel.style.display = 'block';

        // 給容器添加 show-graph 類來隱藏標題
        const card = panel.closest('.erp-card');
        if (card) card.classList.add('show-graph');

        // 顯示流程圖時，功能清單也要隱藏
        if (list) list.style.display = 'none';
        const emptyHint = document.getElementById('level2-empty-hint');
        if (emptyHint) emptyHint.style.display = 'none';

        const nameParam = (systemName || '').toString().trim();
        const url = `/api/SystemGraph/${encodeURIComponent(sid)}?name=${encodeURIComponent(nameParam)}&t=${Date.now()}`;
        open.href = url;
        open.style.display = 'none';
        img.style.display = 'none';
        empty.style.display = 'none';

        img.onload = () => {
            img.style.display = 'block';
            empty.style.display = 'none';
            // 圖片可點擊開新視窗
            img.style.cursor = 'pointer';
            img.onclick = () => window.open(url, '_blank');
        };
        img.onerror = () => {
            img.style.display = 'none';
            open.style.display = 'none';
            empty.style.display = 'block';
        };
        img.src = url;
    }

    window.toggleChildren = function (id, systemId, systemName) {
        const el = document.getElementById(id);
        if (el) {
            const isExpanding = el.style.display === "none";
            el.style.display = isExpanding ? "block" : "none";
            // 更新 chevron 圖示
            const link = el.closest('li')?.querySelector('.sidebar-mod0-link');
            if (link) {
                const chevron = link.querySelector('.sidebar-chevron-icon');
                if (chevron) {
                    chevron.classList.toggle('bi-chevron-right', !isExpanding);
                    chevron.classList.toggle('bi-chevron-down', isExpanding);
                }
            }
        }
        if (systemId) showSystemGraph(systemId, systemName);
    };

    // ── 互動流程圖：拖曳節點位置 + 端口選取 ──

    // 目前顯示的系統 ID
    let currentFlowSystemId = null;
    let flowDrag = null;
    let flowSaveTimer = null;

    // 連線端口覆寫（"{from}:{to}" → { fromPort, toPort, pivotOffset }）
    let currentEdgePortOverrides = {};
    let flowEdgeSaveTimer = null;
    let _flowEdgePaths = {};   // ekey → { pathEl, hitPath, handleEl, conn, p1, p2, offY, handleDir, fp, tp }
    let _flowSvgEl    = null;  // 目前 SVG 元素

    // 彎折段拖曳狀態
    let flowPivotDrag = null;

    // 端口選取狀態
    let selectedEdgeKey   = null;
    let _flowSelectedPath = null;
    let _flowPortDotEls   = [];

    // 計算節點端口位置（百分比坐標空間）
    function getNodePort(node, port) {
        switch (port) {
            case 'top':    return { x: node.x + node.w / 2, y: node.y };
            case 'bottom': return { x: node.x + node.w / 2, y: node.y + node.h };
            case 'left':   return { x: node.x,              y: node.y + node.h / 2 };
            case 'right':  return { x: node.x + node.w,     y: node.y + node.h / 2 };
        }
    }

    // 即時更新彎折段路徑與控點位置（拖曳中呼叫）
    function updatePivotPreview(ekey, newOffset) {
        const data = _flowEdgePaths[ekey];
        if (!data) return;
        const { pathEl, hitPath, handleEl, p1, p2, fp, tp, conn, offY } = data;
        const dx = p2.x - p1.x, dy = p2.y - p1.y;
        let d, hx = null, hy = null;

        if (fp === 'bottom' && tp === 'top') {
            if (typeof conn.pivotY === 'number') {
                const pv = conn.pivotY + offY + newOffset;
                d = `M${p1.x},${p1.y} L${p1.x},${pv} L${p2.x},${pv} L${p2.x},${p2.y}`;
                hx = (p1.x + p2.x) / 2; hy = pv;
            } else if (Math.abs(dx) >= 1) {
                const pv = Math.max(p1.y + 2, p2.y - 3) + newOffset;
                d = `M${p1.x},${p1.y} L${p1.x},${pv} L${p2.x},${pv} L${p2.x},${p2.y}`;
                hx = (p1.x + p2.x) / 2; hy = pv;
            }
        } else if (fp === 'bottom' && (tp === 'left' || tp === 'right')) {
            const midY = p2.y + newOffset;
            d = `M${p1.x},${p1.y} L${p1.x},${midY} L${p2.x},${midY}`;
            hx = (p1.x + p2.x) / 2; hy = midY;
        } else if ((fp === 'right' || fp === 'left') && tp === 'top') {
            const midX = p2.x + newOffset;
            d = `M${p1.x},${p1.y} L${midX},${p1.y} L${midX},${p2.y}`;
            hx = midX; hy = (p1.y + p2.y) / 2;
        } else if ((fp === 'right' || fp === 'left') && tp === 'bottom') {
            const midX = p2.x + newOffset;
            d = `M${p1.x},${p1.y} L${midX},${p1.y} L${midX},${p2.y}`;
            hx = midX; hy = (p1.y + p2.y) / 2;
        } else if (fp === 'top' && (tp === 'left' || tp === 'right')) {
            const midY = p2.y + newOffset;
            d = `M${p1.x},${p1.y} L${p1.x},${midY} L${p2.x},${midY}`;
            hx = (p1.x + p2.x) / 2; hy = midY;
        } else if (fp === 'left' && tp === 'left') {
            const lx = Math.min(p1.x, p2.x) - 2 + newOffset;
            d = `M${p1.x},${p1.y} L${lx},${p1.y} L${lx},${p2.y} L${p2.x},${p2.y}`;
            hx = lx; hy = (p1.y + p2.y) / 2;
        } else if ((fp === 'right' || fp === 'left') && (tp === 'left' || tp === 'right')) {
            if (Math.abs(dy) >= 1) {
                const mx = (p1.x + p2.x) / 2 + newOffset;
                d = `M${p1.x},${p1.y} L${mx},${p1.y} L${mx},${p2.y} L${p2.x},${p2.y}`;
                hx = mx; hy = (p1.y + p2.y) / 2;
            }
        } else if (fp === 'top' && tp === 'top') {
            const ly = Math.min(p1.y, p2.y) - 2 + newOffset;
            d = `M${p1.x},${p1.y} L${p1.x},${ly} L${p2.x},${ly} L${p2.x},${p2.y}`;
            hx = (p1.x + p2.x) / 2; hy = ly;
        }

        if (d) {
            pathEl.setAttribute('d', d);
            hitPath.setAttribute('d', d);
        }
        if (handleEl && hx !== null) {
            handleEl.setAttribute('cx', hx);
            handleEl.setAttribute('cy', hy);
        }
        const existing = currentEdgePortOverrides[ekey] || {};
        currentEdgePortOverrides[ekey] = Object.assign({}, existing, { pivotOffset: newOffset });
    }

    // 清除端口選取（移除高亮 + 隱藏控點 + 移除圓點）
    function clearEdgeSelection() {
        if (_flowSelectedPath) {
            _flowSelectedPath.style.stroke = '';
            _flowSelectedPath.style.strokeWidth = '';
            _flowSelectedPath = null;
        }
        // 隱藏彎折控點
        if (selectedEdgeKey && _flowEdgePaths[selectedEdgeKey]?.handleEl) {
            const hEl = _flowEdgePaths[selectedEdgeKey].handleEl;
            hEl.style.display = 'none';
            hEl.style.pointerEvents = 'none';
        }
        _flowPortDotEls.forEach(el => el.remove());
        _flowPortDotEls = [];
        selectedEdgeKey = null;
    }

    // 選取一條連線：高亮 + 顯示彎折控點 + 在兩個節點上顯示可點擊的端口圓點
    function selectEdge(ekey, fp, tp, pathEl, src, dst) {
        clearEdgeSelection();
        if (!_flowSvgEl) return;
        selectedEdgeKey   = ekey;
        _flowSelectedPath = pathEl;
        pathEl.style.stroke      = '#F59E0B';
        pathEl.style.strokeWidth = '0.8';

        // 顯示彎折拖曳控點
        const hEl = _flowEdgePaths[ekey]?.handleEl;
        if (hEl) { hEl.style.display = ''; hEl.style.pointerEvents = 'all'; }

        const PORTS = ['top', 'bottom', 'left', 'right'];
        const svgNs = 'http://www.w3.org/2000/svg';

        // 起點節點：橘色圓點 = 目前 fromPort；其餘灰色
        PORTS.forEach(function(port) {
            const pos  = getNodePort(src, port);
            const dot  = document.createElementNS(svgNs, 'circle');
            const isActive = port === fp;
            dot.setAttribute('cx', pos.x);
            dot.setAttribute('cy', pos.y);
            dot.setAttribute('r', isActive ? '2.2' : '1.8');
            dot.setAttribute('fill',         isActive ? '#F59E0B' : '#94a3b8');
            dot.setAttribute('stroke',       '#ffffff');
            dot.setAttribute('stroke-width', '0.5');
            dot.style.pointerEvents = 'all';
            dot.style.cursor        = 'pointer';
            dot.addEventListener('click', (function(p) {
                return function(ev) { ev.stopPropagation(); changeEdgePort(ekey, 'from', p); };
            })(port));
            _flowSvgEl.appendChild(dot);
            _flowPortDotEls.push(dot);
        });

        // 終點節點：藍色圓點 = 目前 toPort；其餘灰色
        PORTS.forEach(function(port) {
            const pos  = getNodePort(dst, port);
            const dot  = document.createElementNS(svgNs, 'circle');
            const isActive = port === tp;
            dot.setAttribute('cx', pos.x);
            dot.setAttribute('cy', pos.y);
            dot.setAttribute('r', isActive ? '2.2' : '1.8');
            dot.setAttribute('fill',         isActive ? '#3B82F6' : '#94a3b8');
            dot.setAttribute('stroke',       '#ffffff');
            dot.setAttribute('stroke-width', '0.5');
            dot.style.pointerEvents = 'all';
            dot.style.cursor        = 'pointer';
            dot.addEventListener('click', (function(p) {
                return function(ev) { ev.stopPropagation(); changeEdgePort(ekey, 'to', p); };
            })(port));
            _flowSvgEl.appendChild(dot);
            _flowPortDotEls.push(dot);
        });
    }

    // 改變某條連線的端口，重新渲染並儲存
    function changeEdgePort(ekey, which, newPort) {
        const cfg = systemFlowcharts[currentFlowSystemId];
        if (!cfg) return;
        const conn = cfg.connections.find(function(c) { return c.from + ':' + c.to === ekey; });
        if (!conn) return;
        const ov = currentEdgePortOverrides[ekey] || { fromPort: conn.fromPort, toPort: conn.toPort };
        if (which === 'from') ov.fromPort = newPort;
        else                  ov.toPort   = newPort;
        currentEdgePortOverrides[ekey] = ov;
        clearEdgeSelection();
        renderInteractiveFlowchart(currentFlowSystemId);
        clearTimeout(flowEdgeSaveTimer);
        flowEdgeSaveTimer = setTimeout(function() { saveFlowEdges(currentFlowSystemId); }, 800);
    }

    // 拖曳：mousemove（全域監聽，處理節點拖曳 + 彎折拖曳）
    document.addEventListener('mousemove', function (e) {
        if (flowDrag) {
            const { el, startX, startY, origX, origY, cW, cH, nodeId, systemId } = flowDrag;
            const dx = (e.clientX - startX) / cW * 100;
            const dy = (e.clientY - startY) / cH * 100;
            if (Math.abs(e.clientX - startX) > 3 || Math.abs(e.clientY - startY) > 3) {
                flowDrag.moved = true;
            }
            let newX = Math.max(0, origX + dx);
            let newY = Math.max(0, origY + dy);

            // 對齊吸附：與相連節點的中心差距在 1.5% 內自動對齊
            const cfg = systemFlowcharts[systemId];
            if (cfg && cfg.nodes) {
                const thisNode = cfg.nodes.find(function(n) { return n.id === nodeId; });
                if (thisNode) {
                    const cX = newX + thisNode.w / 2;
                    const cY = newY + thisNode.h / 2;
                    const SNAP = 1.5;
                    (cfg.connections || []).forEach(function(conn) {
                        const otherId = conn.from === nodeId ? conn.to : (conn.to === nodeId ? conn.from : null);
                        if (!otherId) return;
                        const other = cfg.nodes.find(function(n) { return n.id === otherId; });
                        if (!other) return;
                        const ov = currentEdgePortOverrides[conn.from + ':' + conn.to];
                        const fp = (ov && ov.fromPort) || conn.fromPort;
                        const tp = (ov && ov.toPort)   || conn.toPort;
                        // 垂直連線 → 吸附 X 中心
                        const isV = (fp === 'bottom' || fp === 'top') && (tp === 'top' || tp === 'bottom');
                        // 水平連線 → 吸附 Y 中心
                        const isH = (fp === 'left' || fp === 'right') && (tp === 'left' || tp === 'right');
                        const oCX = other.x + other.w / 2;
                        const oCY = other.y + other.h / 2;
                        if (isV && Math.abs(cX - oCX) < SNAP) newX = oCX - thisNode.w / 2;
                        if (isH && Math.abs(cY - oCY) < SNAP) newY = oCY - thisNode.h / 2;
                    });
                }
            }

            el.style.left = newX + '%';
            el.style.top  = newY + '%';
        }
        if (flowPivotDrag) {
            const { handleDir, startX, startY, origOffset, cW, cH } = flowPivotDrag;
            if (Math.abs(e.clientX - startX) > 2 || Math.abs(e.clientY - startY) > 2) flowPivotDrag.moved = true;
            let newOffset = handleDir === 'y'
                ? origOffset + (e.clientY - startY) / cH * 100
                : origOffset + (e.clientX - startX) / cW * 100;
            // 接近零時自動吸附（±0.8% 範圍內對齊回預設）
            if (Math.abs(newOffset) < 0.8) newOffset = 0;
            updatePivotPreview(flowPivotDrag.ekey, newOffset);
        }
    });

    // 拖曳結束：mouseup（節點 + 彎折）
    document.addEventListener('mouseup', function (e) {
        if (flowPivotDrag) {
            const { ekey, moved } = flowPivotDrag;
            flowPivotDrag = null;
            if (moved) {
                renderInteractiveFlowchart(currentFlowSystemId);
                clearTimeout(flowEdgeSaveTimer);
                flowEdgeSaveTimer = setTimeout(function() { saveFlowEdges(currentFlowSystemId); }, 800);
            }
        }
        if (!flowDrag) return;
        const { el, nodeId, systemId, moved } = flowDrag;
        flowDrag = null;
        el.style.zIndex = '';
        el.style.cursor = '';

        if (!moved) return;

        // 防止 <a> 標籤在拖曳後觸發跳頁
        el.addEventListener('click', function blocker(ev) {
            ev.preventDefault();
            ev.stopPropagation();
            el.removeEventListener('click', blocker, true);
        }, { capture: true, once: true });

        // 更新 in-memory config 節點位置
        const newX = parseFloat(el.style.left);
        const newY = parseFloat(el.style.top);
        const cfg = systemFlowcharts[systemId];
        if (cfg && cfg.nodes) {
            const node = cfg.nodes.find(n => n.id === nodeId);
            if (node) { node.x = newX; node.y = newY; }
        }

        // 重新渲染 SVG 連線（使箭頭跟著更新）
        renderInteractiveFlowchart(systemId);

        // 自動儲存（防抖 800ms）
        clearTimeout(flowSaveTimer);
        flowSaveTimer = setTimeout(() => saveFlowPositions(systemId), 800);
    });

    // 同時從資料庫載入節點位置 + 連線彎折偏移，僅重新渲染一次
    async function loadSavedFlowData(systemId) {
        try {
            const [posResp, edgeResp] = await Promise.all([
                fetch(`/api/SysFlowChart/${encodeURIComponent(systemId)}/positions`),
                fetch(`/api/SysFlowChart/${encodeURIComponent(systemId)}/edges`)
            ]);

            let changed = false;
            const cfg = systemFlowcharts[systemId];

            if (posResp.ok) {
                const saved = await posResp.json();
                if (cfg && cfg.nodes && Object.keys(saved).length > 0) {
                    cfg.nodes.forEach(node => {
                        const pos = saved[node.id];
                        if (pos !== undefined) { node.x = pos.x; node.y = pos.y; changed = true; }
                    });
                }
            }

            currentEdgePortOverrides = {};
            if (edgeResp.ok) {
                const saved = await edgeResp.json();
                if (Object.keys(saved).length > 0) {
                    Object.entries(saved).forEach(([k, v]) => {
                        if (v.fromPort || v.toPort || v.pivotOffset) {
                            currentEdgePortOverrides[k] = {
                                fromPort:    v.fromPort    || '',
                                toPort:      v.toPort      || '',
                                pivotOffset: v.pivotOffset || 0
                            };
                        }
                    });
                    changed = true;
                }
            }

            if (changed) renderInteractiveFlowchart(systemId);
        } catch (err) {
            console.warn('loadSavedFlowData 失敗:', err);
        }
    }

    // 儲存目前系統的連線端口覆寫到資料庫
    async function saveFlowEdges(systemId) {
        const edges = Object.entries(currentEdgePortOverrides)
            .map(([k, v]) => ({ edgeKey: k, fromPort: v.fromPort || '', toPort: v.toPort || '', pivotOffset: v.pivotOffset || 0 }));
        if (edges.length === 0) return;
        try {
            await fetch(`/api/SysFlowChart/${encodeURIComponent(systemId)}/edges`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(edges)
            });
        } catch (err) {
            console.warn('saveFlowEdges 失敗:', err);
        }
    }

    // 儲存目前系統所有節點位置到資料庫
    async function saveFlowPositions(systemId) {
        const cfg = systemFlowcharts[systemId];
        if (!cfg || !cfg.nodes) return;

        const positions = cfg.nodes
            .filter(n => !n.hidden)
            .map(n => ({ nodeId: n.id, x: n.x, y: n.y }));

        try {
            const resp = await fetch(`/api/SysFlowChart/${encodeURIComponent(systemId)}/positions`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(positions)
            });
        } catch (err) {
            console.warn('saveFlowPositions 失敗:', err);
        }
    }


    // 以事件委派方式在 flowchart container 上啟動拖曳（DOM 不需重綁）
    document.addEventListener('DOMContentLoaded', function () {
        const flowContainer = document.getElementById('interactiveFlowchart');
        if (!flowContainer) return;

        flowContainer.addEventListener('mousedown', function (e) {
            if (e.button !== 0) return;
            const nodeEl = e.target.closest('.flow-node');
            if (!nodeEl || !currentFlowSystemId) return;

            const cRect = flowContainer.getBoundingClientRect();
            flowDrag = {
                el: nodeEl,
                nodeId: nodeEl.dataset.nodeid,
                systemId: currentFlowSystemId,
                startX: e.clientX,
                startY: e.clientY,
                origX: parseFloat(nodeEl.style.left) || 0,
                origY: parseFloat(nodeEl.style.top)  || 0,
                cW: cRect.width,
                cH: cRect.height,
                moved: false
            };
            nodeEl.style.zIndex = '10';
            nodeEl.style.cursor = 'grabbing';
            e.preventDefault(); // 防止文字選取
        });
    });

