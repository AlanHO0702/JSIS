@page "/FontIndex"
@model PcbErpApi.Pages.FontIndexModel
@{
    var level0 = Model.Level0Items;
    var level1Map = Model.Level1Map;
    var level2List = Model.GetCurrentLevel2();
    Layout = "_Layout";
    ViewData["Title"] = "主選單";

    var pageMap = new Dictionary<string, string> {
        {"SPO00003", "/SPO/SPO00003"}, // 銷售訂單查詢
        {"SPO00009", "/SPO/SPO00009"}, // 銷貨單查詢
        {"SPO00013","/SPO/SPO00013" },  // 銷售價格表
        {"SPO00015", "/SPO/SPO00015"},
        {"SPO00014", "/SPO/SPO00014"},
        {"SPO00040", "/SPO/SPO00040"},// 銷售價格表(單一grid)
        {"MPH00052", "/MPH/MPH00052"},// 採購價格表(單一grid)
        {"MPH00015", "/MPH/MPH00015"},
        {"MPH00016", "/MPH/MPH00016"},
        {"MPH00017", "/MPH/MPH00017"},
        {"MPH00018", "/MPH/MPH00018"},
        {"MPH00019", "/MPH/MPH00019"},
        {"CUR00009", "/CUR/FlowDesigner"}, // 電子簽核流程設計
        {"CUR00012", "/CUR/CURdSysParams"},
        {"CURH0003", "/CUR/CURdV_SysProcess"},
        {"CUR00004", "/CUR/NoticeBoard"},
        {"MP000022", "/CCS/MP000022"},
        {"MT000004", "/MIN/MT000004"},
        {"MG000006", "/CPN/MGNdSetNum/MG000006"},
        {"MG000007", "/CPN/MGNdSetNum/MG000007"},
        {"MG000008", "/CPN/MG000008"},
        {"CPN00006", "/CPN/CPN00006"},
        {"MG000002", "/CPN/MG000002"},
        {"CPN00007", "/CPN/CPN00007"},
        {"CPN00009", "/CPN/MGNdSpecDemand"},
        {"FME00011", "/FME/FME00011"},
        {"EMO00004", "/EMOdProdInfo" },
        {"EMO00018", "/EMOdProdInfo?mode=view" },  // 工程資料查詢
        {"EMO00047", "/EMOdTmpBOM_SC" },            // 組合模型
        {"EMO00048", "/EMOdTmpRoute" },             // 途程主檔
        {"EMO00049", "/EMOdTmpPress" },             // 壓合疊構
        {"EMO00059", "/EMOdProdLayer" },            // 層別資料維護
        {"EMO00060", "/EMOdProdLayer?mode=view" },  // 層別資料查詢
        {"EMO00019", "/EMOdProdECNMain" },           // 工程變更審核
        {"ABE00004", "/ABE/ABEdBillInq"},
        {"AJN00009", "/AJN/AJNdJourInq"},
        {"AA000016", "/AJN/AJNdTransferAccData"},
        {"ATX00003", "/ATX/ATXdAccBas"},
        {"BT000013", "/ATX/ATXdTaxTune"},
        {"ATX00006", "/ATX/ATXdTaxTune2"},
        // LA 報價管理
        {"SQ000006", "/DynamicTemplate/Paper/SQ000006"}, // LA201 樣品報價單
        {"SQ000010", "/DynamicTemplate/Paper/SQ000010"}, // LA204 客戶聯絡單
        {"SPO00008", "/CUR/SingleGrid/SPO00008"}, // LA203 查詢(MPHdViewInq)

        {"ARM00004", "/APR/APRdPRInq?itemId=ARM00004"},
        {"APR00020", "/APR/APRdPRInq?itemId=APR00020"},
        {"FQC00002", "/FQC/FQCdQCType"}, // ME106 檢驗規範建立
        {"FQC00004", "/DynamicTemplate/Paper/FQC00004"}, // ME201 IQC品檢單
        {"FQC00017", "/DynamicTemplate/Paper/FQC00017"}, // ME202 IQC品檢單
        {"FQC00014", "/DynamicTemplate/Paper/FQC00014"}, // ME203 IQC品檢單
        {"FQC00057", "/CUR/MultiGrid/FQC00057"}, // ME110 報廢率基準_責任大站
        {"FQC00009", "/DynamicTemplate/Paper3L/FQC00009"}, // ME401 品檢報廢作業
        // 其它功能請自行加入...
    };

    Dictionary<int, int> systemMap = new()
    {
        {1, 1},   // 銷售客戶
        {2, 2},   // 原物料廠商
        {3, 3},   // 製程委外廠商
        {4, 4},   // 製令委外廠商
        {5, 5},   // 進出口廠商
        {6, 6},   // 其它廠商
        {7, 7},   // 經銷商
        {9, 9},   // 臨時客戶
        {103, 1}  // 客戶授信額度設定 -> 視為銷售客戶
    };

    int? ResolveCompanySystem(object? powerTypeObj)
    {
        try
        {
            if (powerTypeObj == null) return null;
            var valStr = powerTypeObj.ToString();
            if (string.IsNullOrWhiteSpace(valStr)) return null;
            if (!int.TryParse(valStr, out var pt)) return null;
            return systemMap.TryGetValue(pt, out var sys) ? sys : null;
        }
        catch { return null; }
    }

    string? ResolveCompanyLink(dynamic item)
    {
        try
        {
            var cls = (item?.ClassName ?? string.Empty).ToString().Trim();
            if (!cls.Equals("CCSdCompanyDLL.dll", StringComparison.OrdinalIgnoreCase))
                return null;
            var itemId = (item?.ItemId ?? string.Empty).ToString().Trim();
            if (string.IsNullOrWhiteSpace(itemId)) return null;
            var sysId = ResolveCompanySystem(item?.PowerType);
            if (!sysId.HasValue) return null;
            return $"/CCS/{itemId}/{sysId.Value}";
        }
        catch { return null; }
    }

    string ResolveItemHint(PcbErpApi.Models.CurdSysItem item)
    {
        if (pageMap.TryGetValue(item.ItemId, out var hardPath) && !string.IsNullOrWhiteSpace(hardPath))
            return hardPath;

        var companyLink = ResolveCompanyLink(item);
        if (!string.IsNullOrWhiteSpace(companyLink))
            return companyLink;

        var ocx = item.Ocxtemplete?.Trim().ToLowerInvariant() ?? "";

        if (item.ItemType == 6)
        {
            if (ocx.Contains("jsdpaper3ldll")) return "Paper3L";
            if (ocx.Contains("jsdpaperorgdll")) return "Paper";
            if (ocx.Contains("jsdsinglegriddll")) return "SingleGrid";
            if (ocx.Contains("jsdgriddll")) return "MultiGrid";
            if (ocx.Contains("jsdmasdtldll")) return "MasterDetail";
            if (ocx.Contains("jsdmasmultidtldll")) return "MasterMultiDetail";
        }

        if (item.ItemType == 2 && item.OutputType == 0) return "Report(Direct)";
        if (item.ItemType == 2 && (item.OutputType == 6 || item.OutputType == 7)) return "Report(Generic)";

        return "未設定";
    }

    var sysIconMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase) {
        {"CUR", "bi-gear-fill"},           // 系統管理
        {"CCS", "bi-people-fill"},         // 客戶廠商
        {"CPN", "bi-box-seam"},            // 料號主檔
        {"SQU", "bi-file-earmark-text"},   // 報價管理
        {"SPO", "bi-cart3"},               // 銷售管理
        {"EMO", "bi-cpu"},                 // 產品工程
        {"MGN", "bi-diagram-3"},           // 產品結構
        {"SBP", "bi-calendar2-week"},      // 生產管理
        {"FME", "bi-tools"},               // 製造執行
        {"FOS", "bi-arrow-repeat"},        // 製程委外
        {"FQC", "bi-shield-check"},        // 品質管理
        {"MPH", "bi-bag"},                 // 採購管理
        {"MIN", "bi-archive"},             // 庫存管理
        {"ARM", "bi-cash"},                // 應收帳款
        {"APR", "bi-credit-card-2-front"}, // 應付帳款
        {"ABE", "bi-receipt-cutoff"},      // 票據管理
        {"AJN", "bi-journal-bookmark"},    // 總帳管理
        {"ATX", "bi-newspaper"},           // 媒體申報
        {"AFA", "bi-building"},            // 固定資產
        {"ACA", "bi-graph-up"},            // 成本分析
        {"HPS", "bi-person-badge"},        // 人事管理
        {"HSA", "bi-wallet2"},             // 薪資管理
        {"CFW", "bi-pen-fill"},            // 電子簽核
    };
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
body {
    background: #f4f6fb;
    font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif;
    overflow-y: hidden;
    height: 100vh;
}
.erp-sidebar {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 10px #0001;
    padding: 8px 8px 8px 10px;
    height: calc(100vh - 70px);
    display: flex;
    flex-direction: column;
}
.erp-sidebar h4 {
    color: #333;
    font-weight: bold;
    margin-bottom: 2px;
    font-size: 1rem;
    letter-spacing: 2px;
    flex-shrink: 0;
    text-align: center;
}
.erp-nav-group {
    overflow-y: auto;
    overflow-x: hidden;
    flex: 1;
    padding: 2px 0;
}
.erp-nav-group > li {
    margin-bottom: 2px;
}
/* ── Level 0：模組標題列 ── */
.sidebar-mod0-link {
    display: flex;
    align-items: center;
    min-height: 34px;
    padding: 4px 8px 4px 11px; /* A) 預留 3px 左條空間 */
    background: #f1f5f9;
    color: #1e293b;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 6px;
    border-left: 3px solid transparent; /* A) 佔位，避免選取時跳動 */
    text-decoration: none;
    transition: background 0.13s, box-shadow 0.13s;
    cursor: pointer;
    user-select: none;
}
/* D) hover 加淡陰影，強化可點擊感 */
.sidebar-mod0-link:hover {
    background: #e8f0fb;
    color: #0f172a;
    box-shadow: 0 2px 6px rgba(59,130,246,0.10);
}
/* 系統 icon */
.sidebar-sys-icon {
    font-size: 0.95rem;
    margin-right: 7px;
    flex-shrink: 0;
    opacity: 0.75;
}
/* chevron */
.sidebar-chevron-icon {
    font-size: 0.9rem;
    color: #b0bec5 !important;
    margin-left: auto;
    flex-shrink: 0;
    transition: color 0.15s ease, transform 0.15s ease;
}
.sidebar-mod0-link:hover .sidebar-chevron-icon {
    color: #3b82f6 !important;
    transform: translateX(2px);
}
/* A) 目前所在模組：同規格 3px 藍條，padding 保持一致 */
.sidebar-mod0-link.mod0-selected {
    background: #eef5ff;
    border-left: 3px solid #3b82f6;
}
/* ── Level 1：子項目容器 ── */
.sidebar-sub-list {
    border-left: 2px solid #e8edf3;
    margin: 2px 0 8px 20px !important;
    padding: 0 0 2px 0 !important;
    list-style: none;
}
.sidebar-sub-list li {
    margin-bottom: 0;
}
/* Level 1 連結：固定高度 + hover */
.sidebar-sub-list a {
    display: flex;
    align-items: center;
    min-height: 33px;
    padding: 4px 8px 4px 12px; /* A) 與 mod0-selected 同 padding-left 基準 */
    color: #64748b;
    font-weight: 400;
    font-size: 0.825rem;
    border-left: 3px solid transparent; /* A) 佔位 */
    border-radius: 0 5px 5px 0;
    text-decoration: none;
    transition: background 0.1s, color 0.1s;
}
.sidebar-sub-list a:hover {
    background: #f4f8ff;
    color: #2563eb;
}
/* B) active 底色再淡，主提示靠色條 + 字重 */
.sidebar-sub-list a.active {
    background: #f0f6ff;
    color: #1d4ed8;
    font-weight: 600;
    border-left: 3px solid #3b82f6;
}
/* C) 代碼更灰更小，固定寬對齊 */
.sidebar-sub-code {
    font-family: 'Consolas', 'Courier New', monospace;
    font-size: 0.75rem;
    font-weight: 400;
    color: #9ba8b8;
    display: inline-block;
    min-width: 36px;
    margin-right: 5px;
    flex-shrink: 0;
}
.erp-nav-group .icon {
    font-size: 1.1rem;
    margin-right: 6px;
    color: #60a4e0;
}
.erp-card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 10px #0001;
    padding: 6px 16px 12px 16px;
    height: calc(100vh - 70px);
    display: flex;
    flex-direction: column;
}
.erp-list-title {
    font-weight: bold;
    color: #333;
    letter-spacing: 2px;
    font-size: 1rem;
    margin-bottom: 0.3rem;
    margin-top: 0.2rem;
    flex-shrink: 0;
    text-align: center;
}
.erp-list-group {
    overflow-y: auto;
    overflow-x: hidden;
    flex: 1;
}
.erp-list-group .list-group-item {
    border: none;
    padding: 2px 10px;
    font-size: 0.88rem;
    transition: background 0.1s;
    background: transparent;
    cursor: pointer;
    line-height: 1.2;
}
.erp-list-group .list-group-item:hover {
    background: #f0f8ff;
}
.erp-list-group .list-group-item a,
#favorite-list a {
    color: #333 !important;
    text-decoration: none !important;
    transition: color 0.15s, text-decoration 0.15s;
}
.erp-list-group .list-group-item a:hover,
#favorite-list a:hover {
    color: #155cb5 !important;
    text-decoration: underline !important;
}

.system-graph-frame{
    background: #f8fbff;
    border: 1px solid #e5eaf2;
    border-radius: 12px;
    padding: 10px;
}
#systemGraphImg{
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
}
/* 我的最愛區塊專用：去底線，hover再出現 */
#favorite-list a {
    color: #2766b5;
    text-decoration: none;
    transition: color 0.15s, text-decoration 0.15s;
}
#favorite-list a:hover {
    color: #155cb5;
    text-decoration: underline;
}
/* 拖曳相關樣式 */
.draggable-item {
    cursor: grab;
}
.draggable-item:active {
    cursor: grabbing;
}
.draggable-item.dragging {
    opacity: 0.5;
    background: #e3f0ff;
}
.favorite-drop-zone {
    transition: all 0.2s ease;
}
.favorite-drop-hint {
    color: #999;
    text-align: center;
    padding: 20px;
    font-size: 0.95rem;
    flex-shrink: 0;
}
.favorite-drop-zone.drag-over {
    background: #e7f1fd;
    border: 2px dashed #2766b5;
    border-radius: 8px;
}
#systemGraphPanel {
    flex-shrink: 0;
    margin-bottom: 12px;
}
/* 當顯示系統流程圖時，隱藏功能列表標題和分隔線 */
.erp-card.show-graph #functionListTitleBar {
    display: none !important;
}
.erp-card.show-graph #functionListDivider {
    display: none !important;
}
.erp-card.show-graph #functionListColumnHeader {
    display: none !important;
}
.system-graph-frame {
    background: #f8fbff;
    border: 1px solid #e5eaf2;
    border-radius: 12px;
    padding: 10px;
}
#systemGraphImg {
    width: 100%;
    max-height: calc((100vh - 70px) * 0.67);
    display: block;
    object-fit: fill;
}
/* 待辦事項統計樣式 */
.todo-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
}
.todo-stat-item {
    display: flex;
    align-items: center;
    padding: 4px 8px;
    background: #f8f9fa;
    border-radius: 8px;
    transition: all 0.2s;
    cursor: pointer;
    border: 1px solid transparent;
}
.todo-stat-item:hover {
    background: #fff;
    border-color: #e0e6ed;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transform: translateY(-1px);
}
.todo-icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 6px;
    flex-shrink: 0;
}
.todo-icon svg {
    width: 18px;
    height: 18px;
}
.todo-info {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.todo-label {
    font-size: 0.82rem;
    color: #666;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.todo-count {
    font-size: 0.95rem;
    font-weight: bold;
    color: #333;
    margin-left: 3px;
    flex-shrink: 0;
}
/* 縮小列表項目中的按鈕 */
.erp-list-group .btn-sm {
    padding: 2px 6px;
    font-size: 0.78rem;
    line-height: 1.4;
    min-height: 22px;
}
/* 快速啟動相關樣式 */
#quickStartTableBody tr {
    cursor: pointer;
    transition: background-color 0.15s ease;
}
#quickStartTableBody tr:hover {
    background-color: #e7f1fd !important;
}
.table-hover #quickStartTableBody tr.selected,
#quickStartTableBody tr.selected {
    background-color: #b8d9f7 !important;
}
.table-hover #quickStartTableBody tr.selected:hover,
#quickStartTableBody tr.selected:hover {
    background-color: #b8d9f7 !important;
}
/* 互動式流程圖按鈕節點 */
.flow-node {
    position: absolute;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1.5px solid;
    transition: box-shadow 0.18s, border-color 0.18s, transform 0.12s;
    text-align: center;
    line-height: 1.4;
    padding: 4px 6px;
    text-decoration: none;
    box-shadow: 0 1px 3px rgba(16,24,40,.07), 0 1px 2px rgba(16,24,40,.04);
    z-index: 2;
}
.flow-node[href]:hover,
.flow-node.flow-hovered {
    outline: 2px solid #3B82F6;
    outline-offset: 1px;
    transform: translateY(-1px);
    text-decoration: none;
}
/* ── 新扁平語義色系 ── */
/* 文件/單據：白底 + 1px 淺灰框 */
.flow-node-doc  { background:#FFFFFF; color:#374151; border-color:#E2E8F0; border-width:1px; }
.flow-node-doc[href]  { cursor:pointer; }
/* 倉別中心：淡藍底 + 1.5px 藍框 */
.flow-node-wh   { background:#EFF6FF; color:#1E40AF; border-color:#93C5FD; border-width:1.5px; font-size:0.85rem; font-weight:700; letter-spacing:0.02em; }
/* 出庫/關鍵動作：白底 + 1.5px 琥珀框 */
.flow-node-out  { background:#FFFBEB; color:#78350F; border-color:#FCD34D; border-width:1.5px; }
.flow-node-out[href]  { cursor:pointer; }
/* 入庫/進貨類：藍底 + 藍框 */
.flow-node-in   { background:#DBEAFE; color:#1D4ED8; border-color:#93C5FD; border-width:1.5px; }
.flow-node-in[href]  { cursor:pointer; }
/* 出庫/領用類：綠底 + 綠框 */
.flow-node-use  { background:#D1FAE5; color:#065F46; border-color:#6EE7B7; border-width:1.5px; }
.flow-node-use[href] { cursor:pointer; }
/* 倉庫核心：漸層色塊 */
.flow-node-wh-raw { background:linear-gradient(135deg,#3B82F6 0%,#6366F1 100%); color:#fff; border:none; box-shadow:0 4px 14px rgba(59,130,246,0.35); font-size:0.82rem; font-weight:700; flex-direction:column; gap:2px; }
.flow-node-wh-fin { background:linear-gradient(135deg,#10B981 0%,#059669 100%); color:#fff; border:none; box-shadow:0 4px 14px rgba(16,185,129,0.35); font-size:0.82rem; font-weight:700; flex-direction:column; gap:2px; }
/* 倉庫節點 emoji 圖示 */
.wh-icon { font-size:1.35em; line-height:1; }
/* 區段標題 */
.flow-node-label { background:transparent; color:#374151; border:none; box-shadow:none; font-size:1.06rem; font-weight:800; letter-spacing:0.04em; padding:0; justify-content:flex-start; align-items:flex-end; pointer-events:none; white-space:nowrap; }
/* ── 舊色系扁平化（相容其他流程圖） ── */
.flow-node-green  { background:#F0FDF4; color:#14532D; border-color:#86EFAC; }
.flow-node-green[href]  { cursor:pointer; }
.flow-node-green2 { background:#ECFDF5; color:#065F46; border-color:#6EE7B7; }
.flow-node-blue   { background:#EFF6FF; color:#1E40AF; border-color:#BFDBFE; }
.flow-node-orange { background:#FFF7ED; color:#7C2D12; border-color:#FED7AA; }
.flow-node-orange[href] { cursor:pointer; }
.flow-node-white  { background:#F8FAFC; color:#334155; border-color:#E2E8F0; }
.flow-node-red    { background:#FEF2F2; color:#7F1D1D; border-color:#FCA5A5; }
.flow-node-cyl    { background:#EFF6FF; color:#1E40AF; border-color:#BFDBFE; border-width:1.5px; border-radius:12px; font-weight:700; }
.flow-node:not([href]) { cursor: grab; }
.flow-node[href] { cursor: grab; }
.flow-svg-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 1;
}
</style>

<div class="container" style="padding: 0.5rem 0.75rem;">
    <div class="row gx-4">
        <!-- 左側系統模組 -->
        <div class="col-12 col-md-3 mb-4">
            <div class="erp-sidebar">
                <h4>系統模組</h4>
                <hr style="margin: 0 0 8px 0; border-top: 2px solid #555;">
                <ul class="erp-nav-group" style="list-style: none; padding-left: 0;">
                    @foreach (var mod0 in level0)
                    {
                        var level1Id = $"level1-{mod0.ItemId}";
                        var shouldExpand = level1Map.ContainsKey(mod0.ItemId) && level1Map[mod0.ItemId].Any(x => x.ItemId == Model.SelectedLevel1Id);
                        <li>
                            <a href="javascript:void(0)" onclick="toggleChildren('@level1Id','@mod0.ItemId','@mod0.ItemName')" class="sidebar-mod0-link @(shouldExpand ? "mod0-selected" : "")">
                                <span style="white-space:nowrap; flex:1; overflow:hidden; text-overflow:ellipsis;">
                                    <span style="font-family:'Consolas','Courier New',monospace;">@(!string.IsNullOrEmpty(mod0.SWebMenuId) ? mod0.SWebMenuId : mod0.ItemId)</span><span style="font-weight:400; margin-left:4px; color:#475569;">@mod0.ItemName</span>
                                </span>
                                <i class="bi @(shouldExpand ? "bi-chevron-down" : "bi-chevron-right") sidebar-chevron-icon"></i>
                            </a>
                            @if (level1Map.ContainsKey(mod0.ItemId))
                            {
                                <ul id="@level1Id" class="sidebar-sub-list" style="display: @(shouldExpand ? "block" : "none");">
                                    @foreach (var mod1 in level1Map[mod0.ItemId])
                                    {
                                        var isActiveMod1 = mod1.ItemId == Model.SelectedLevel1Id;
                                        <li>
                                            <a asp-page="/FontIndex" asp-route-level1Id="@mod1.ItemId" class="@(isActiveMod1 ? "active" : "")">
                                                @if (!string.IsNullOrEmpty(mod1.SWebMenuId)) {<span class="sidebar-sub-code">@mod1.SWebMenuId</span>}@mod1.ItemName
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- 中間：功能列表 + 待辦事項 -->
        <div class="col-12 col-md-5 mb-4" style="display:flex; flex-direction:column; height:calc(100vh - 70px);">
            <!-- 功能列表 -->
            <div class="erp-card mb-2" style="flex:1; min-height:0;">
                <div class="d-flex align-items-center justify-content-center mb-1" id="functionListTitleBar">
                    <h4 class="erp-list-title mb-0">功能列表</h4>
                    <div class="d-flex align-items-center" id="systemGraphTitleBar" style="display:none;">
                        <div id="systemGraphTitle" class="text-secondary fw-semibold me-2" style="font-size: 0.95rem;"></div>
                        <a id="systemGraphOpen" class="btn btn-sm btn-outline-primary" href="#" target="_blank" rel="noopener" style="display:none;">開新視窗</a>
                    </div>
                </div>
                <hr id="functionListDivider" style="margin: 0 0 0 0; border-top: 2px solid #555;">
                <div id="functionListColumnHeader" class="d-flex align-items-center" style="padding: 4px 8px; font-size: 0.82rem; font-weight: 600; color: #6c757d; border-bottom: 1px solid #dee2e6;">
                    <span style="display: inline-block; width: 90px; flex-shrink: 0;">功能代碼</span>
                    <span style="flex: 1;">功能名稱</span>
                </div>

                <div id="systemGraphPanel" class="mb-1" style="display:none;">
                    <ul class="nav nav-tabs mb-0" id="graphTabsList" style="font-size:0.82rem;">
                        <li class="nav-item">
                            <a class="nav-link active py-1 px-3" data-bs-toggle="tab" href="#tab-interactive">互動流程圖</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link py-1 px-3" data-bs-toggle="tab" href="#tab-image">流程圖圖片</a>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab-interactive">
                            <div id="interactiveFlowchart" style="position:relative; width:100%; overflow:hidden;
                                 background:#f5f8ff; border:1px solid #e5eaf2; border-top:none;
                                 border-radius:0 0 8px 8px; height:calc((100vh - 70px) * 0.68);">
                                <div id="interactiveFlowchartEmpty" style="display:none; padding:40px;
                                     text-align:center; color:#aaa; font-size:0.9rem;">
                                    尚無互動流程圖設定
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-image">
                            <div class="system-graph-frame" style="border-top:none; border-radius:0 0 8px 8px;">
                                <img id="systemGraphImg" alt="系統流程圖" style="display:none;" />
                                <div id="systemGraphEmpty" class="text-secondary small" style="display:none;">尚未提供流程圖</div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (level2List.Any())
                {
                   <ul id="level2-list" class="list-group erp-list-group">
                    @foreach (var item in level2List)
                    {
                        if (item.ItemType == 4)
                        {
                            <li class="list-group-item p-0" id="li-@item.ItemId">
                                <hr style="border: none; border-top: 2px dotted #000; margin: 4px 0; background: transparent; height: 0;" />
                            </li>
                        }
                        else
                        {
                            var ocx = item.Ocxtemplete?.Trim().ToLowerInvariant() ?? "";
                            var link = pageMap.ContainsKey(item.ItemId)
                             ? pageMap[item.ItemId]
                             : ResolveCompanyLink(item) // 公司/廠商主檔樣板
                             ?? (item.ItemType == 2 && item.OutputType == 0 ? $"/Report/Direct/{item.ItemId}"
                                : item.ItemType == 2 && (item.OutputType == 6 || item.OutputType == 7) ? $"/Report/Generic/{item.ItemId}"
                                : item.ItemType == 6 && ocx.Contains("jsdpaper3ldll") ? $"/DynamicTemplate/Paper3L/{item.ItemId}"
                                : item.ItemType == 6 && ocx.Contains("jsdpaperorgdll") ? $"/DynamicTemplate/Paper/{item.ItemId}"
                                : item.ItemType == 6 && ocx.Contains("jsdsinglegriddll") ? $"/CUR/SingleGrid/{item.ItemId}"
                                : item.ItemType == 6 && ocx.Contains("jsdgriddll") ? $"/CUR/MultiGrid/{item.ItemId}"
                                : item.ItemType == 6 && ocx.Contains("jsdmasdtldll") ? $"/CUR/MasterDetail/{item.ItemId}"
                                : item.ItemType == 6 && ocx.Contains("jsdmasmultidtldll") ? $"/CUR/MasterMultiDetail/{item.ItemId}"
                                : null);

                            var hint = ResolveItemHint(item);

                            <li class="list-group-item d-flex justify-content-between align-items-center draggable-item"
                                id="li-@item.ItemId"
                                draggable="true"
                                data-itemid="@item.ItemId"
                                data-itemname="@item.ItemName"
                                data-superid="@item.SuperId"
                                data-classname="@(item.ClassName ?? string.Empty)"
                                data-powertype="@(item.PowerType?.ToString() ?? string.Empty)"
                                data-itemtype="@item.ItemType"
                                data-swebmenuid="@(item.SWebMenuId ?? string.Empty)"
                                data-link="@(link ?? "")">

                            @{ var displayCode = !string.IsNullOrEmpty(item.SWebMenuId) ? item.SWebMenuId : item.ItemId; }
                            @if (!string.IsNullOrEmpty(link)) {
                                <a href="@link" title="@hint" style="flex:1; display: flex; align-items: center;">
                                    <span style="display: inline-block; width: 90px; flex-shrink: 0; font-family: 'Consolas', monospace; font-weight: 500;">@displayCode</span>
                                    <span style="flex: 1;">@item.ItemName</span>
                                </a>
                            } else {
                                <a href="javascript:void(0)" title="@hint" class="dyn-link" data-itemid="@item.ItemId" data-itemname="@item.ItemName" data-superid="@item.SuperId" style="flex:1; display: flex; align-items: center;" onclick="resolveAndGo('@item.ItemId','@item.ItemName','@item.SuperId')">
                                    <span style="display: inline-block; width: 90px; flex-shrink: 0; font-family: 'Consolas', monospace; font-weight: 500;">@displayCode</span>
                                    <span style="flex: 1;">@item.ItemName</span>
                                </a>
                            }
                                <button class="btn btn-outline-primary btn-sm" title="開啟新視窗" onclick="openInNewWindow('@item.ItemId','@item.ItemName','@item.SuperId','@(item.ClassName ?? string.Empty)','@(item.PowerType?.ToString() ?? string.Empty)')">⧉</button>
                            </li>
                        }
                    }
                    </ul>
                }
                else
                {
                    <p id="level2-empty-hint" class="text-secondary mt-4">請從左側展開模組並選擇子模組查看功能</p>
                }
            </div>

            <!-- 待辦事項 + 啟動程式 -->
            <div class="erp-card" style="height: calc((100vh - 70px) * 0.22 ); padding: 10px 8px 10px 8px;">
                <div class="todo-stats-grid">
                    <div class="todo-stat-item" onclick="goToPendingApprovals()">
                        <div class="todo-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="todo-info">
                            <div class="todo-label">簽核待審</div>
                            <div class="todo-count" id="todo-pending-sign">0</div>
                        </div>
                    </div>

                    <div class="todo-stat-item" onclick="goToMessages()">
                        <div class="todo-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="17" cy="7" r="3" fill="#ff4757"/>
                            </svg>
                        </div>
                        <div class="todo-info">
                            <div class="todo-label">訊息未讀</div>
                            <div class="todo-count" id="todo-messages">0</div>
                        </div>
                    </div>

                    <div class="todo-stat-item" onclick="goToWorkingList()">
                        <div class="todo-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="todo-info">
                            <div class="todo-label">未完成單據</div>
                            <div class="todo-count" id="todo-pending-docs">0</div>
                        </div>
                    </div>

                    <div class="todo-stat-item" onclick="goToPendingNotifications()">
                        <div class="todo-icon" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="18" cy="6" r="3" fill="#ff4757"/>
                            </svg>
                        </div>
                        <div class="todo-info">
                            <div class="todo-label">簽核通知</div>
                            <div class="todo-count" id="todo-notifications">0</div>
                        </div>
                    </div>

                    <div class="todo-stat-item" onclick="goToMessageSend()">
                        <div class="todo-icon" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M3 12l18-9-9 18-3-9-9-3z" stroke="#667eea" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="todo-info">
                            <div class="todo-label">訊息發送</div>
                        </div>
                    </div>

                    <div class="todo-stat-item" onclick="goToNoticeBoard()">
                        <div class="todo-icon" style="background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="#ff6b6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M9 15h2v2H9v-2z" fill="#ff6b6b"/>
                            </svg>
                        </div>
                        <div class="todo-info">
                            <div class="todo-label">佈告欄</div>
                            <div class="todo-count" id="todo-announcements">0</div>
                        </div>
                    </div>
                </div>
                <hr style="margin: 6px 0 6px 0; border-top: 1px solid #ddd;">
                <div class="d-flex align-items-center gap-2">
                    <input type="text" id="quickStartInput" class="form-control form-control-sm"
                           placeholder="功能代碼"
                           autocomplete="off"
                           style="font-size: 0.9rem; padding: 4px 8px; height: 32px; width: 100px; font-family: 'Consolas', monospace;">
                    <button type="button" id="quickStartNameBtn" class="btn btn-outline-secondary btn-sm"
                            style="flex: 1; font-size: 0.9rem; padding: 4px 8px; height: 32px; text-align: left; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    </button>
                    <button type="button" id="quickStartLaunchBtn" class="btn btn-outline-secondary btn-sm"
                            style="font-size: 0.85rem; padding: 4px 12px; height: 32px; white-space: nowrap;">
                        啟動程式
                    </button>
                </div>
            </div>
        </div>

        <!-- 右側我的最愛 -->
        <div class="col-12 col-md-4 mb-4">
            <div class="erp-card favorite-drop-zone" id="favorite-drop-zone" style="height: calc(100vh - 70px);">
                <h5 class="erp-list-title mb-0">★ 我的最愛</h5>
                <hr style="margin: 6px 0 0 0; border-top: 2px solid #555;">
                <div class="d-flex align-items-center" style="padding: 4px 4px; font-size: 0.82rem; font-weight: 600; color: #6c757d; border-bottom: 1px solid #dee2e6;">
                    <span style="display: inline-block; width: 90px; flex-shrink: 0;">功能代碼</span>
                    <span style="flex: 1;">功能名稱</span>
                </div>
                <div id="favorite-drop-hint" class="favorite-drop-hint">拖曳功能項目到此處加入我的最愛</div>
                <ul id="favorite-list" class="list-group erp-list-group"></ul>
            </div>
        </div>
    </div>
</div>

<!-- 名稱查詢 Modal -->
<div class="modal fade" id="quickStartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="width: 450px; max-width: 450px;">
        <div class="modal-content">
            <div class="modal-header" style="padding: 10px 16px;">
                <h5 class="modal-title" style="font-size: 1rem;">名稱查詢</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 4px 16px 4px; height: 500px; display: flex; flex-direction: column;">
                <!-- 即時篩選 -->
                <div class="d-flex" style="gap: 2px; margin-bottom: 4px;">
                    <div style="width: calc(35% - 1px);">
                        <input type="text" id="quickStartFilterInput" class="form-control form-control-sm"
                               placeholder="即時篩選"
                               autocomplete="off"
                               style="font-size: 0.9rem;">
                    </div>
                    <div style="width: calc(65% - 1px);">
                        <input type="text" id="quickStartFilterInput2" class="form-control form-control-sm"
                               placeholder="即時篩選"
                               autocomplete="off"
                               style="font-size: 0.9rem;">
                    </div>
                </div>

                <!-- 資料列表 -->
                <div id="quickStartListContainer" style="border: 1px solid #d1d5db; border-radius: 6px; flex: 1; overflow-y: auto; background: #fff; margin-bottom: 4px;">
                    <table class="table table-sm table-hover table-bordered mb-0" style="font-size: 0.85rem;">
                        <thead style="position: sticky; top: 0; background: #f8f9fa; z-index: 1;">
                            <tr>
                                <th style="width: 35%; padding: 6px 8px;">功能代碼</th>
                                <th style="width: 65%; padding: 6px 8px;">功能名稱</th>
                            </tr>
                        </thead>
                        <tbody id="quickStartTableBody">
                            <tr>
                                <td colspan="2" class="text-center text-muted" style="padding: 20px;">載入中...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer" style="padding: 10px 16px;">
                <button type="button" id="quickStartConfirmBtn" class="btn btn-primary btn-sm" style="font-size: 0.9rem;">確定</button>
                <button type="button" class="btn btn-danger btn-sm" data-bs-dismiss="modal" style="font-size: 0.9rem;">取消</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

<script>
    const pageMap = {
    "SPO00003": "/SPO/SPO00003",
    "SPO00009": "/SPO/SPO00009",
    "SPO00013": "/SPO/SPO00013",
    "SPO00015": "/SPO/SPO00015",
    "SPO00014": "/SPO/SPO00014",
    "SPO00040": "/SPO/SPO00040",
    "MPH00052": "/MPH/MPH00052",
    "MPH00015": "/MPH/MPH00015",
    "MPH00016": "/MPH/MPH00016",
    "MPH00017": "/MPH/MPH00017",
    "MPH00018": "/MPH/MPH00018",
    "MPH00019": "/MPH/MPH00019",
    "CUR00009": "/CUR/FlowDesigner", // 電子簽核流程設計
    "CUR00012": "/CUR/CURdSysParams",
    "CURH0003": "/CUR/CURdV_SysProcess",
    "CUR00004": "/CUR/NoticeBoard",
    "QC000209": "/FQCdProcInfo/Index",
    "MP000022": "/CCS/MP000022",
    "MT000004": "/MIN/MT000004",
    "MG000006": "/CPN/MGNdSetNum/MG000006",
    "MG000007": "/CPN/MGNdSetNum/MG000007",
    "MG000008": "/CPN/MG000008",
    "CPN00006": "/CPN/CPN00006",
    "MG000002": "/CPN/MG000002",
    "CPN00007": "/CPN/CPN00007",
    "CPN00009": "/CPN/MGNdSpecDemand",
    "FME00011": "/FME/FME00011",
    "EMO00004":  "/EMOdProdInfo",
    "EMO00018":  "/EMOdProdInfo?mode=view",  // 工程資料查詢
    "EMO00059":  "/EMOdProdLayer",            // 層別資料維護
    "EMO00060":  "/EMOdProdLayer?mode=view",  // 層別資料查詢
    "EMO00019":  "/EMOdProdECNMain",            // 工程變更審核
    "ABE00004": "/ABE/ABEdBillInq",
    "AJN00009": "/AJN/AJNdJourInq",
    "AA000016": "/AJN/AJNdTransferAccData",
    "ATX00003": "/ATX/ATXdAccBas",
    "BT000013": "/ATX/ATXdTaxTune",
    "ATX00006": "/ATX/ATXdTaxTune2",
    "ARM00004": "/APR/APRdPRInq?itemId=ARM00004",
    "APR00020": "/APR/APRdPRInq?itemId=APR00020",
    "FQC00002": "/FQC/FQCdQCType", // ME106 檢驗規範建立
    "FQC00004": "/DynamicTemplate/Paper/FQC00004", // ME201 IQC品檢單
    "FQC00017": "/DynamicTemplate/Paper/FQC00017", // ME202 IQC品檢單
    "FQC00014": "/DynamicTemplate/Paper/FQC00014", // ME203 IQC品檢單
    "FQC00057": "/CUR/MultiGrid/FQC00057", // ME110 報廢率基準_責任大站
    // 其它功能自行補上
    };

    // ==========================================
    // 互動式流程圖設定（各系統模組節點與連線）
    // ==========================================
    const systemFlowcharts = {
        // CUR 系統管理
        "CUR": {
            nodes: [
                // 區塊標題
                { id:"lbl_sys",  label:"系統管理", x:8,  y:3, w:34, h:8, color:"label", link:null },
                { id:"lbl_auth", label:"權限管理", x:58, y:3, w:34, h:8, color:"label", link:null },

                // 左：系統管理
                { id:"docSet",   label:"單據設定",    x:8,  y:16, w:34, h:9, color:"blue", link:"/CUR/MasterDetail/CUR00019" },
                { id:"sysParam", label:"系統參數",    x:8,  y:30, w:34, h:9, color:"blue", link:"/CUR/CURdSysParams" },
                { id:"sysMsg",   label:"主動訊息設定", x:8,  y:44, w:34, h:9, color:"blue", link:"/CUR/MasterDetail/CUR00003" },
                { id:"rptSub",   label:"報表訂閱",    x:8,  y:58, w:34, h:9, color:"blue", link:"/CUR/MasterMultiDetail/CURH0002" },

                // 右：權限管理
                { id:"userAuth", label:"使用者權限",  x:58, y:16, w:34, h:9, color:"blue", link:"/CUR/MasterDetail/CUR00006" },
                { id:"grpAuth",  label:"群組權限",    x:58, y:30, w:34, h:9, color:"blue", link:"/CUR/MasterMultiDetail/CUR00007" },
                { id:"authRpt",  label:"權限報表",    x:58, y:44, w:34, h:9, color:"blue", link:"/FontIndex?level1Id=CU000019" },

                // 隱藏節點：垂直分隔虛線
                { id:"divVTop", label:"", x:50, y:0,  w:0, h:0, color:"white", link:null, hidden:true },
                { id:"divVBot", label:"", x:50, y:98, w:0, h:0, color:"white", link:null, hidden:true }
            ],
            connections: [
                { from:"divVTop", fromPort:"bottom", to:"divVBot", toPort:"top", style:"dashed", color:"#1F2937", arrow:false, path:"straight" }
            ]
        },
        "SPO": {
            nodes: [
                // id, label, x(%), y(%), w(%), h(%), color, link(null=不可點擊)
                // 左列主流: x=21 w=32(中心37%)；客戶主檔稍靠左 x=2 w=32(中心18%)，連線可沿左側繞過預測訂單
