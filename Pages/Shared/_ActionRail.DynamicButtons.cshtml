@model dynamic
@using System.Linq

@{
    // 預期由頁面 model 提供：List<ItemCustButtonRow>
    var buttons = (IEnumerable<dynamic>)(Model?.CustomButtons ?? Enumerable.Empty<dynamic>());
}

@foreach (var b in buttons)
{
    var caption = (b?.Caption ?? b?.CustCaption ?? b?.ButtonName ?? "").ToString();
    if (string.IsNullOrWhiteSpace(caption)) { continue; }

    var hint = (b?.Hint ?? b?.CustHint ?? "").ToString();
    var btnName = (b?.ButtonName ?? "").ToString();

    var designType = (b?.DesignType ?? "").ToString();
    var searchTemplate = (b?.SearchTemplate ?? "").ToString();
    var spName = (b?.SpName ?? "").ToString();
    var execSpName = (b?.ExecSpName ?? "").ToString();
    var multiSelectDd = (b?.MultiSelectDD ?? "").ToString();
    var replaceExists = (b?.ReplaceExists ?? "").ToString();
    var dialogCaption = (b?.DialogCaption ?? "").ToString();
    var allowSelCount = (b?.AllowSelCount ?? "").ToString();
    var printRptName = (b?.PrintRptName ?? "").ToString();
    var needInEdit = (b?.bNeedInEdit ?? "").ToString();
    var ocxName = (b?.OCXName ?? "").ToString();

    <button type="button"
            class="fab"
            title="@hint"
            data-custom-btn="1"
            data-button-name="@btnName"
            data-design-type="@designType"
            data-ocx-name="@ocxName"
            data-search-template="@searchTemplate"
            data-sp-name="@spName"
            data-exec-sp-name="@execSpName"
            data-multi-select-dd="@multiSelectDd"
            data-replace-exists="@replaceExists"
            data-dialog-caption="@dialogCaption"
            data-allow-sel-count="@allowSelCount"
            data-print-rpt-name="@printRptName"
            data-b-need-in-edit="@needInEdit">
        @caption
    </button>
}

@await Html.PartialAsync("~/Pages/Shared/_PaperSearchModal.cshtml")

<div class="modal fade" id="condRunSpModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog cond-runsp-dialog">
    <div class="modal-content cond-runsp-modal">
      <div class="modal-header">
        <h5 class="modal-title">輸入條件</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form class="cond-runsp-form"></form>
      </div>
      <div class="modal-footer">
        <button class="btn btn-success crs-confirm">確定</button>
        <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="uomGetLotModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl uom-getlot-dialog">
    <div class="modal-content uom-getlot-modal">
      <div class="modal-header">
        <h5 class="modal-title">批號指定</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form class="uom-getlot-form">
          <div class="uom-getlot-top">
            <div class="uom-getlot-meta">
              <div class="ug-field">
                <label class="form-label ug-label">料號</label>
                <input class="form-control form-control-sm ug-partnum" type="text" readonly>
              </div>
              <div class="ug-field">
                <label class="form-label ug-label">需求數量</label>
                <input class="form-control form-control-sm ug-needqnty" type="text" readonly>
              </div>
              <div class="ug-actions">
                <button class="btn btn-outline-secondary btn-sm ug-search" type="button">重取</button>
                <button class="btn btn-outline-primary btn-sm ug-auto" type="button">自動</button>
              </div>
            </div>
            <div class="uom-getlot-filters">
              <div class="ug-field">
                <label class="form-label ug-label">倉別</label>
                <select class="form-select form-select-sm ug-stock"></select>
              </div>
              <div class="ug-field">
                <label class="form-label ug-label">庫位</label>
                <input class="form-control form-control-sm ug-pos" type="text">
              </div>
              <div class="ug-field">
                <label class="form-label ug-label">UOM</label>
                <input class="form-control form-control-sm ug-uom" type="text">
              </div>
              <div class="ug-field">
                <label class="form-label ug-label">長度</label>
                <input class="form-control form-control-sm ug-size" type="text">
              </div>
              <div class="ug-field">
                <label class="form-label ug-label">批號</label>
                <input class="form-control form-control-sm ug-lot" type="text">
              </div>
              <div class="ug-field ug-round">
                <div class="ug-round-box">
                  <input id="ugRoundUom" class="form-check-input ug-round-uom" type="checkbox">
                  <label class="form-label ug-round-label" for="ugRoundUom">Round To UOM</label>
                </div>
              </div>
            </div>
          </div>
        </form>
        <div class="uom-getlot-table-wrap">
          <table class="table table-sm table-striped mb-0 uom-getlot-table">
            <thead><tr></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
        <div class="uom-getlot-sum">
          <label class="form-label ug-label">領用基礎單位數量合計</label>
          <input class="form-control form-control-sm ug-sum" type="text" readonly>
        </div>
        <button class="btn btn-success ug-confirm">確定</button>
        <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

<style>
  #condRunSpModal .cond-runsp-dialog { --bs-modal-width: 520px; }
  #condRunSpModal .cond-runsp-modal { display: flex; flex-direction: column; }
  #condRunSpModal .modal-body { padding: 16px 18px; }
  #condRunSpModal .cond-runsp-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #condRunSpModal .crs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px 12px;
  }
  #condRunSpModal .crs-field {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #condRunSpModal .crs-label {
    white-space: nowrap;
    margin: 0;
    flex: 0 0 90px;
    text-align: right;
    font-size: var(--field-label-size);
  }
  #condRunSpModal .crs-control {
    flex: 1 1 auto;
    min-width: 0;
    font-size: var(--field-value-size);
  }

  #uomGetLotModal .uom-getlot-dialog { --bs-modal-width: 92vw; --bs-modal-margin: 10vh; }
  #uomGetLotModal .uom-getlot-modal { height: calc(82vh); display: flex; flex-direction: column; }
  #uomGetLotModal .modal-body { flex: 1 1 auto; display: flex; flex-direction: column; min-height: 0; overflow: hidden; padding: 16px; }
  #uomGetLotModal .modal-footer { display: flex; align-items: center; gap: 12px; }
  #uomGetLotModal .uom-getlot-top { display: flex; flex-direction: column; gap: 12px; margin-bottom: 12px; }
  #uomGetLotModal .uom-getlot-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 12px 16px; }
  #uomGetLotModal .uom-getlot-filters { display: grid; grid-template-columns: repeat(5, minmax(140px, 1fr)); gap: 10px 14px; align-items: end; }
  #uomGetLotModal .ug-field { display: flex; align-items: center; gap: 8px; min-width: 0; }
  #uomGetLotModal .ug-label { margin: 0; min-width: 72px; text-align: right; font-size: var(--field-label-size); }
  #uomGetLotModal .ug-round { margin-left: 0; }
  #uomGetLotModal .ug-round-box {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    gap: 8px;
    padding-left: 80px;
  }
  #uomGetLotModal .ug-round-label { margin: 0; text-align: left; min-width: 0; }
  #uomGetLotModal .ug-round .form-check-input { margin: 0; }
  #uomGetLotModal .ug-actions { display: flex; gap: 8px; margin-left: auto; }
  #uomGetLotModal .uom-getlot-table-wrap { flex: 1 1 auto; min-height: 0; overflow: auto; border: 1px solid #e5e7eb; border-radius: 8px; }
  #uomGetLotModal table { border-collapse: collapse; }
  #uomGetLotModal th, #uomGetLotModal td { border: 1px solid #dee2e6; vertical-align: middle; white-space: nowrap; }
  #uomGetLotModal thead th { position: sticky; top: 0; background: #f8fafc; z-index: 2; }
  #uomGetLotModal thead th { font-size: var(--field-label-size); }
  #uomGetLotModal tbody td,
  #uomGetLotModal .uom-getlot-table input {
    font-size: var(--field-value-size);
  }
  #uomGetLotModal .ug-sum { width: 140px; }
  #uomGetLotModal .uom-getlot-sum { display: flex; align-items: center; gap: 10px; margin-right: auto; }
  #uomGetLotModal .uom-getlot-table tbody tr { cursor: pointer; }
  #uomGetLotModal .uom-getlot-table tbody tr.ug-row-selected,
  #uomGetLotModal .uom-getlot-table tbody tr.ug-row-selected > td {
    background: #dbeafe !important;
  }

  @@media (max-width: 991.98px){
    #uomGetLotModal .uom-getlot-dialog { --bs-modal-width: 100vw; --bs-modal-margin: 0; }
    #uomGetLotModal .uom-getlot-modal { border-radius: 0; }
    #uomGetLotModal .uom-getlot-filters { grid-template-columns: repeat(2, minmax(140px, 1fr)); }
  }
</style>

<script>
(() => {
  const resolveCustomHandler = (btnName) => {
    const map = window.ActionRailCustomHandlers || {};
    const itemId = window._singleItemId || window._itemId || "";
    if (map[itemId] && typeof map[itemId][btnName] === "function") return map[itemId][btnName];
    if (typeof map[btnName] === "function") return map[btnName];
    return null;
  };

  const readPaperNum = () => {
    const v = (window._paperNum || "").toString().trim();
    if (v) return v;
    if (typeof window.getPaperNum === "function") {
      try { return (window.getPaperNum() || "").toString().trim(); } catch { /* ignore */ }
    }
    return "";
  };

  const isHeaderEditMode = () => {
    if (typeof window.__headerIsEdit === "boolean") return window.__headerIsEdit;
    const btn = document.getElementById("btnViewEditToggle");
    return !!btn && (btn.textContent || "").trim() === "保留";
  };

  const withJwtHeaders = (init = {}) => {
    const jwt = localStorage.getItem("jwtId");
    const headers = Object.assign({}, init.headers || {});
    if (jwt) headers["X-JWTID"] = jwt;
    return { ...init, headers };
  };

  const hasDateOnlyMask = (mask) => {
    const m = (mask || "").toString().toLowerCase();
    if (!m) return false;
    const isDate = m.includes("yyyy") && m.includes("mm") && m.includes("dd");
    const hasTime = m.includes("hh") || m.includes("ss") || m.includes("tt");
    return isDate && !hasTime;
  };

  const parseDateValue = (value) => {
    if (!value) return null;
    if (value instanceof Date && !isNaN(value)) return value;
    const s = String(value).trim();
    if (!s) return null;
    if (/^\d{4}-\d{2}-\d{2}/.test(s)) return new Date(s.slice(0, 10));
    if (/^\d{4}[/.]\d{1,2}[/.]\d{1,2}$/.test(s)) {
      const [y, m, d] = s.split(/[/.]/).map(Number);
      return new Date(y, (m || 1) - 1, d || 1);
    }
    if (/^\d{8}$/.test(s)) {
      const y = Number(s.slice(0, 4));
      const m = Number(s.slice(4, 6));
      const d = Number(s.slice(6, 8));
      return new Date(y, (m || 1) - 1, d || 1);
    }
    const dt = new Date(s);
    return isNaN(dt) ? null : dt;
  };

  const formatDateByMask = (value, mask) => {
    const dt = parseDateValue(value);
    if (!dt) return value;
    const sep = (mask || "").includes("/") ? "/" : ((mask || "").includes(".") ? "." : "-");
    const y = dt.getFullYear();
    const m = String(dt.getMonth() + 1).padStart(2, "0");
    const d = String(dt.getDate()).padStart(2, "0");
    return `${y}${sep}${m}${sep}${d}`;
  };

  const applyEditMask = (value, editMask) => {
    if (hasDateOnlyMask(editMask)) return formatDateByMask(value, editMask);
    return value;
  };

  const getParamEditMask = (p) => {
    const candidates = [
      p?.EditMask, p?.editMask,
      p?.ParamFormat, p?.paramFormat,
      p?.ParamFmt, p?.paramFmt,
      p?.FormatStr, p?.formatStr
    ];
    for (const c of candidates) {
      const v = (c ?? "").toString().trim();
      if (v) return v;
    }
    return "";
  };

  const isDateParam = (p) => {
    // 只依據 CURdOCXSearchParams.EditMask 是否含 yyyy/mm/dd 判斷
    return hasDateOnlyMask(getParamEditMask(p));
  };

  const condRunSp = (() => {
    const modalEl = document.getElementById("condRunSpModal");
    if (modalEl && modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }
    const formEl = modalEl?.querySelector(".cond-runsp-form");
    const btnConfirm = modalEl?.querySelector(".crs-confirm");
    const titleEl = modalEl?.querySelector(".modal-title");

    const state = {
      itemId: "",
      buttonName: "",
      paperNum: "",
      spName: "",
      execSpName: "",
      printRptName: "",
      searchParams: [],
      inputs: {}
    };

    const normalizeKey = (name) => (name || "").replace(/^@@+/, "").toLowerCase();

    const loadParamOptions = async (itemId, buttonName, paramName, superValue) => {
      const extra = superValue ? `&superValue=${encodeURIComponent(superValue)}` : "";
      const url = `/api/PaperSearch/ParamOptionsV2?itemId=${encodeURIComponent(itemId)}&buttonName=${encodeURIComponent(buttonName)}&paramName=${encodeURIComponent(paramName)}${extra}`;
      const res = await fetch(url, withJwtHeaders());
      if (!res.ok) throw new Error(await res.text());
      return await res.json();
    };

    const getHeaderFieldValue = (name) => {
      const key = (name || "").toString().trim();
      if (!key) return "";
      if (typeof window.readHeaderValue === "function") {
        const helperValue = (window.readHeaderValue(key) ?? "").toString().trim();
        if (helperValue !== "") return helperValue;
      }
      const form = document.getElementById("orderHeaderForm");
      let el = form?.querySelector(`[name="${CSS.escape(key)}"]`);
      if (!el && form) {
        const target = key.toLowerCase();
        const allNamed = form.querySelectorAll("[name]");
        for (const node of allNamed) {
          const n = (node.getAttribute("name") || "").toLowerCase();
          if (n === target) {
            el = node;
            break;
          }
        }
      }
      if (!el) return "";
      if (el.classList?.contains("lookup-dropdown")) {
        const hidden = el.closest("li")?.querySelector("input.lookup-key[name]");
        if (hidden) return (hidden.value || "").toString().trim();
      }
      if (el instanceof HTMLSelectElement) {
        return (el.value || "").toString().trim();
      }
      if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
        return (el.value || "").toString().trim();
      }
      return "";
    };

    const getRowFieldValue = (row, field) => {
      if (!row || !field) return "";
      const key = String(field).toLowerCase();
      const hit = Object.keys(row).find(k => String(k).toLowerCase() === key);
      const val = hit ? row[hit] : "";
      return val == null ? "" : String(val).trim();
    };

    const getDetailRowByIndex = (index) => {
      const tabs = window._multiTabTabs || window._debugTabsData || [];
      const tab = tabs[index];
      const tabId = tab?.Id || tab?.id;
      if (!tabId) return null;
      const selected = window._multiTabSelectedRows?.[tabId];
      if (selected) return selected;
      return null;
    };

    const getSubDetailRowByIndex = (index) => {
      return window._paper3lSubDetailSelectedRows?.[String(index + 1)] || null;
    };

    const getDefaultFromTableKind = (tableKind, fieldName) => {
      const kind = (tableKind || "").toString().trim().toLowerCase();
      if (!kind || !fieldName) return "";
      if (kind === "master1") return getHeaderFieldValue(fieldName);
      const m = kind.match(/^(detail|subdetail)(\d+)$/);
      if (!m) return "";
      const idx = Math.max(0, parseInt(m[2], 10) - 1);
      if (m[1] === "detail") {
        return getRowFieldValue(getDetailRowByIndex(idx), fieldName);
      }
      return getRowFieldValue(getSubDetailRowByIndex(idx), fieldName);
    };

    const getSuperValueCrs = (p) => {
      const rawSuperId = (p.SuperId || p.superId || "").toString().trim().replace(/^@@+/, "");
      const superKey = normalizeKey(rawSuperId);
      if (!superKey) return "";
      const superInput = formEl?.querySelector(`[data-param="${superKey}"]`);
      if (superInput && (superInput.value ?? "") !== "") return superInput.value ?? "";

      const headerVal = rawSuperId ? getHeaderFieldValue(rawSuperId) : "";
      if (headerVal) return headerVal;

      const superParam = (state.searchParams || []).find(sp => normalizeKey(sp.ParamName || sp.paramName) === superKey);
      if (!superParam) return "";
      const tk = superParam.TableKind ?? superParam.tableKind;
      const pv = superParam.ParamValue ?? superParam.paramValue;
      const fromKind = pv ? getDefaultFromTableKind(tk, pv) : "";
      return fromKind || (superParam.DefaultValue ?? superParam.defaultValue ?? "");
    };


    const buildForm = async (itemId, buttonName) => {
      if (!formEl) return;
      formEl.innerHTML = "";
      const visibleParams = (state.searchParams || []).filter(p => {
        return Number(p.iVisible ?? p.IVisible ?? 0) === 1;
      });
      window.__psBuildForm = { itemId, buttonName, visibleCount: visibleParams.length };
      console.debug("paperSearch buildForm", window.__psBuildForm);

      if (!visibleParams.length) {
        formEl.innerHTML = '<div class="text-muted small">（沒有可輸入的條件）</div>';
        return;
      }

      const grid = document.createElement("div");
      grid.className = "crs-grid";
      formEl.appendChild(grid);

      for (const p of visibleParams) {
        const name = normalizeKey(p.ParamName || p.paramName);
        if (!name) continue;

        const wrap = document.createElement("div");
        wrap.className = "crs-field";
        const label = document.createElement("label");
        label.className = "form-label crs-label";
        label.textContent = p.DisplayName || p.displayName || name;
        wrap.appendChild(label);

        const controlType = Number(p.ControlType ?? p.controlType ?? 0);
        const tableKind = p.TableKind ?? p.tableKind;
        const paramValue = p.ParamValue ?? p.paramValue;
        let headerDefault = "";
        if (paramValue) {
          headerDefault = getDefaultFromTableKind(tableKind, paramValue);
        }

        if (controlType === 1) {
          window.__psLastParam = { name, paramName: p.ParamName || p.paramName, controlType };
          console.debug("paperSearch param", window.__psLastParam);
          const select = document.createElement("select");
          select.className = "form-select form-select-sm crs-control";
          select.setAttribute("data-param", name);
          const emptyOpt = document.createElement("option");
          emptyOpt.value = "";
          emptyOpt.textContent = "";
          select.appendChild(emptyOpt);
          wrap.appendChild(select);
          try {
            const superValue = getSuperValueCrs(p);
            const options = await loadParamOptions(itemId, buttonName, p.ParamName || p.paramName, superValue);
            if (Array.isArray(options)) {
              options.forEach(opt => {
                const o = document.createElement("option");
                const val = opt.value ?? opt.Value ?? "";
                const text = opt.text ?? opt.Text ?? "";
                o.value = val;
                o.textContent = text ? `${val} ${text}`.trim() : val;
                if (text && text !== val) o.title = text;
                select.appendChild(o);
              });
            }
          } catch (err) {
            console.warn("load options failed", err);
          }
          const defVal = headerDefault || (p.DefaultValue ?? p.defaultValue);
          if (defVal != null && defVal !== "") {
            select.value = applyEditMask(defVal, getParamEditMask(p));
            if (!select.value) {
              const o = document.createElement("option");
              o.value = defVal;
              o.textContent = defVal;
              select.appendChild(o);
              select.value = defVal;
            }
          }
          select.addEventListener("keydown", (ev) => {
            if (ev.key === "Delete" || ev.key === "Backspace") {
              select.value = "";
            }
          });
          const superKey = normalizeKey(p.SuperId || p.superId);
          if (superKey) {
            const superInput = formEl?.querySelector(`[data-param="${superKey}"]`);
            if (superInput && !select.dataset.superBound) {
              select.dataset.superBound = "1";
              superInput.addEventListener("change", async () => {
                try {
                  const options = await loadParamOptions(itemId, buttonName, p.ParamName || p.paramName, superInput.value ?? "");
                  select.innerHTML = "";
                  const emptyOpt = document.createElement("option");
                  emptyOpt.value = "";
                  emptyOpt.textContent = "";
                  select.appendChild(emptyOpt);
                  if (Array.isArray(options)) {
                    options.forEach(opt => {
                      const o = document.createElement("option");
                      const val = opt.value ?? opt.Value ?? "";
                      const text = opt.text ?? opt.Text ?? "";
                      o.value = val;
                      o.textContent = text ? `${val} ${text}`.trim() : val;
                      if (text && text !== val) o.title = text;
                      select.appendChild(o);
                    });
                  }
                } catch (err) {
                  console.warn("load options failed", err);
                }
              });
            }
          }
        } else {
          const input = document.createElement("input");
          input.className = "form-control form-control-sm crs-control";
          const editMask = getParamEditMask(p);
          const isDate = isDateParam(p);
          input.type = isDate ? "date" : "text";
          input.setAttribute("data-param", name);
          if (isDate) input.setAttribute("data-edit-mask", editMask);
          const defVal = headerDefault || (p.DefaultValue ?? p.defaultValue);
          if (defVal != null && defVal !== "") {
            if (isDate) {
              const dt = parseDateValue(defVal);
              input.value = dt ? `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,"0")}-${String(dt.getDate()).padStart(2,"0")}` : defVal;
            } else {
              input.value = applyEditMask(defVal, editMask);
            }
          }
          const readOnly = Number(p.iReadOnly ?? p.IReadOnly ?? 0) === 1;
          if (readOnly) input.readOnly = true;
          wrap.appendChild(input);
        }

        grid.appendChild(wrap);
      }
    };

    const collectInputs = () => {
      const values = {};
      (state.searchParams || []).forEach(p => {
        const name = normalizeKey(p.ParamName || p.paramName);
        if (!name) return;
        const input = formEl?.querySelector(`[data-param="${name}"]`);
        if (input) {
          let val = input.value ?? "";
          const mask = input.getAttribute("data-edit-mask");
          if (mask && val) val = applyEditMask(val, mask);
          values[name] = val;
          return;
        }
        const tableKind = p.TableKind ?? p.tableKind;
        const paramValue = p.ParamValue ?? p.paramValue;
        const fromKind = paramValue ? getDefaultFromTableKind(tableKind, paramValue) : "";
        const defVal = fromKind || p.DefaultValue || p.defaultValue || p.ParamValue || p.paramValue;
        values[name] = defVal == null ? "" : defVal;
      });
      if (values.useid != null && String(values.useid).trim() === "") {
        values.useid = window.DEFAULT_USEID || window._useId || "A001";
      }
      state.inputs = values;
      return values;
    };

    const setConfirmLoading = (loading) => {
      if (!btnConfirm) return;
      btnConfirm.disabled = loading;
      btnConfirm.textContent = loading ? "執行中..." : "確定";
    };

    const normalizeReportName = (name) => {
      const s = (name || "").toString().trim();
      if (!s) return "";
      return s.toLowerCase().endsWith(".rpt") ? s.slice(0, -4) : s;
    };

    const autoPrintResult = async (inputParams) => {
      const spName = (state.spName || state.execSpName || "").toString().trim();
      const rptRaw = (state.printRptName || "").toString().trim();
      if (!spName || !rptRaw) return;

      const payload = {
        paperNum: state.paperNum || "",
        spName,
        reportName: normalizeReportName(rptRaw),
        params: { ...(inputParams || {}) }
      };

      const res = await fetch('/api/report/generate-url', withJwtHeaders({
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }));
      if (!res.ok) throw new Error(await res.text());

      const blob = await res.blob();
      const blobUrl = URL.createObjectURL(blob);
      const win = window.open('about:blank', '_blank');
      if (win) {
        win.location.href = blobUrl;
      } else {
        const a = document.createElement('a');
        a.href = blobUrl;
        a.target = '_blank';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
      }
      setTimeout(() => URL.revokeObjectURL(blobUrl), 60_000);
    };
    const runSp = async () => {
      setConfirmLoading(true);
      const inputs = collectInputs();
      const payload = {
        itemId: state.itemId,
        buttonName: state.buttonName,
        paperNum: state.paperNum,
        params: inputs
      };
      try {
        const res = await fetch("/api/PaperSearch/RunSpExec", withJwtHeaders({
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        }));
        const raw = await res.text();
        let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
        if (!res.ok || !data.ok) throw new Error(data.error || `HTTP ${res.status}`);
        if (modalEl) {
          try { bootstrap.Modal.getOrCreateInstance(modalEl).hide(); } catch {}
        }
        const _crsMsg = String(data.message ?? "").trim().replace(/^MESGE:\s*/i, "").trim();
        if (_crsMsg) await Swal.fire({ icon: 'info', title: _crsMsg, confirmButtonText: 'OK' });
        if ((state.printRptName || "").toString().trim() !== "") {
          try {
            await autoPrintResult(inputs);
          } catch (printErr) {
            await Swal.fire({ icon: 'error', title: '列印失敗', text: printErr?.message || String(printErr), confirmButtonText: 'OK' });
          }
        }
        if (typeof window.__refreshHeaderData === "function") {
          try { await window.__refreshHeaderData(); } catch {}
        }
        if (typeof window.__refreshMultiTab === "function") {
          try { await window.__refreshMultiTab(); } catch {}
        }
        if (typeof window.__paper3lSubDetailRefresh === "function") {
          try { await window.__paper3lSubDetailRefresh(); } catch {}
        }
      } catch (err) {
        await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
      } finally {
        setConfirmLoading(false);
      }
    };

    const open = async (ctx, meta) => {
      if (!modalEl) return;
      window.__paperSearchOpen = { ctx, meta };
      state.itemId = ctx.itemId || "";
      state.buttonName = ctx.buttonName || "";
      state.paperNum = ctx.paperNum || "";
      state.spName = meta.spName || "";
      state.execSpName = meta.execSpName || "";
      state.printRptName = meta.printRptName || "";

      const configUrl = `/api/PaperSearch/Config?itemId=${encodeURIComponent(state.itemId)}&buttonName=${encodeURIComponent(state.buttonName)}`;
      const res = await fetch(configUrl, withJwtHeaders());
      if (!res.ok) {
        await Swal.fire({ icon: 'error', title: '執行失敗', text: await res.text(), confirmButtonText: 'OK' });
        return;
      }
      const cfg = await res.json();
      state.searchParams = cfg.searchParams || cfg.SearchParams || [];

      const caption = meta.dialogCaption || cfg.dialogCaption || cfg.DialogCaption || ctx.caption || "輸入條件";
      if (titleEl) titleEl.textContent = caption;

      await buildForm(state.itemId, state.buttonName);
      if (window.bootstrap) {
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
      }
    };

    btnConfirm?.addEventListener("click", (e) => { e.preventDefault(); runSp(); });

    return { open };
  })();

  const uomGetLot = (() => {
    const modalEl = document.getElementById("uomGetLotModal");
    if (modalEl && modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }
    const table = modalEl?.querySelector(".uom-getlot-table");
    const headRow = table?.querySelector("thead tr");
    const body = table?.querySelector("tbody");
    const titleEl = modalEl?.querySelector(".modal-title");
    const partNumEl = modalEl?.querySelector(".ug-partnum");
    const needQntyEl = modalEl?.querySelector(".ug-needqnty");
    const roundEl = modalEl?.querySelector(".ug-round-uom");
    const stockEl = modalEl?.querySelector(".ug-stock");
    const posEl = modalEl?.querySelector(".ug-pos");
    const uomEl = modalEl?.querySelector(".ug-uom");
    const sizeEl = modalEl?.querySelector(".ug-size");
    const lotEl = modalEl?.querySelector(".ug-lot");
    const btnSearch = modalEl?.querySelector(".ug-search");
    const btnAuto = modalEl?.querySelector(".ug-auto");
    const btnConfirm = modalEl?.querySelector(".ug-confirm");
    const sumEl = modalEl?.querySelector(".ug-sum");

    const state = {
      itemId: "",
      buttonName: "",
      paperNum: "",
      paperId: "",
      detailItem: "",
      spId: 0,
      partNum: "",
      needQnty: "",
      dict: [],
      rows: [],
      stockLoaded: false
    };

    const normalizeKey = (name) => (name || "").toString().trim().toLowerCase();
    const getRowValue = (row, field) => {
      if (!row) return "";
      const key = normalizeKey(field);
      const hit = Object.keys(row).find(k => normalizeKey(k) === key);
      if (!hit) return "";
      const val = row[hit];
      return val == null ? "" : val;
    };

    const readActiveDetailRow = () => {
      const activeTab = document.querySelector(".multi-tab-detail .nav-link.active[data-tab-id]");
      if (activeTab) {
        const tabId = activeTab.dataset.tabId;
        const row = window._multiTabSelectedRows?.[tabId];
        if (row) return row;
        const pane = document.querySelector(`.multi-tab-detail .tab-pane.show.active`);
        const tr = pane?.querySelector("tbody tr.row-selected");
        if (tr) {
          const obj = {};
          tr.querySelectorAll("input.cell-edit[data-field]").forEach(inp => {
            const f = inp.dataset.field || "";
            if (!f) return;
            obj[f] = inp.value ?? "";
          });
          if (tr.dataset.paperNum && obj.PaperNum === undefined) obj.PaperNum = tr.dataset.paperNum;
          if (tr.dataset.item && obj.Item === undefined) obj.Item = tr.dataset.item;
          return obj;
        }
      }
      return null;
    };

    const getDetailItem = (row) => {
      if (!row) return "";
      const keys = ["Item", "item", "SeqNum", "seqnum", "ItemNo", "itemno", "ItemNum", "itemnum"];
      for (const k of keys) {
        if (row[k] != null && String(row[k]).trim() !== "") return String(row[k]).trim();
      }
      return "";
    };

    const toNumber = (v, fallback = 0) => {
      const n = Number(String(v ?? "").replace(/,/g, ""));
      return Number.isFinite(n) ? n : fallback;
    };

    const loadStockOptions = async () => {
      if (!stockEl || state.stockLoaded) return;
      const res = await fetch("/api/UomGetLot/StockOptions", withJwtHeaders());
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      const rows = data.rows || [];
      stockEl.innerHTML = '<option value=""></option>';
      rows.forEach(r => {
        const id = String(r.StockId ?? r.stockId ?? "").trim();
        const name = String(r.StockName ?? r.stockName ?? "").trim();
        const opt = document.createElement("option");
        opt.value = id;
        opt.textContent = name ? `${id} ${name}`.trim() : id;
        stockEl.appendChild(opt);
      });
      state.stockLoaded = true;
    };

    const loadDict = async () => {
      if (state.dict.length) return state.dict;
      const tables = ["MINdV_UOMGetLotQnty4Edit", "MINdUOMGetLotSearch"];
      for (const t of tables) {
        try {
          const url = `/api/TableFieldLayout/DictFields?table=${encodeURIComponent(t)}&lang=TW`;
          const res = await fetch(url, withJwtHeaders());
          if (!res.ok) continue;
          const rows = await res.json();
          if (Array.isArray(rows) && rows.length) {
            const hiddenFields = new Set(["partnum", "revision", "v", "spid", "select"]);
            state.dict = rows.filter(x => (x.Visible ?? x.visible) === 1 || (x.Visible ?? x.visible) === true)
              .map(c => ({
                FieldName: c.FieldName ?? c.fieldName,
                DisplayLabel: c.DisplayLabel ?? c.displayLabel ?? c.FieldName ?? c.fieldName,
                DisplaySize: c.DisplaySize ?? c.displaySize,
                DataType: c.DataType ?? c.dataType,
                FormatStr: c.FormatStr ?? c.formatStr
              }))
              .filter(c => {
                const field = (c.FieldName || "").toString().toLowerCase();
                const label = (c.DisplayLabel || "").toString().trim().toLowerCase();
                return !hiddenFields.has(field) && label !== "v";
              });
            break;
          }
        } catch { /* ignore */ }
      }
      return state.dict;
    };

    const buildFallbackDict = (rows) => {
      if (state.dict.length || !rows?.length) return;
      const cols = Object.keys(rows[0] || {});
      state.dict = cols.map(c => ({ FieldName: c, DisplayLabel: c, DisplaySize: 120, DataType: "" }));
    };

    const buildHeaders = () => {
      if (!headRow) return;
      headRow.innerHTML = "";
      const html = state.dict.map(c => {
        const w = Math.max(40, Number(c.DisplaySize ?? 120));
        return `<th data-field="${c.FieldName}" style="min-width:${w}px;width:${w}px;">${c.DisplayLabel ?? c.FieldName}</th>`;
      }).join("");
      headRow.insertAdjacentHTML("beforeend", html);
    };

    const fmtCell = (val, col) => {
      if (val == null) return "";
      const raw = String(val);
      if (!raw) return "";
      const dtType = (col.DataType || "").toString().toLowerCase();
      const fmt = (col.FormatStr || "").toString();
      if (dtType.includes("date") || (col.FieldName || "").toString().toLowerCase().includes("date")) {
        if (fmt) return formatDateByMask(raw, fmt);
        const d = parseDateValue(raw);
        return d ? `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}` : raw;
      }
      if (dtType.includes("number")) {
        const n = Number(String(val).replace(/,/g, ""));
        if (!Number.isNaN(n)) return n.toLocaleString();
      }
      return raw;
    };

    const renderRows = () => {
      if (!body) return;
      const cols = state.dict || [];
      const html = state.rows.map((row, idx) => {
        const tds = cols.map(c => {
          const field = c.FieldName;
          const v = getRowValue(row, field);
          const lc = normalizeKey(field);
          if (lc === "inuse") {
            const checked = String(v ?? "") === "1" || v === true;
            return `<td><input type="checkbox" data-field="${field}" ${checked ? "checked" : ""}></td>`;
          }
          if (lc === "transqnty" || lc === "transuomqnty") {
            const val = v == null ? "" : v;
            return `<td><input type="text" class="form-control form-control-sm ug-input" data-field="${field}" value="${val}"></td>`;
          }
          const cls = (c.DataType || "").toString().toLowerCase().includes("number") ? "text-end" : "";
          return `<td class="${cls}">${fmtCell(v, c)}</td>`;
        }).join("");
        return `<tr data-idx="${idx}">${tds}</tr>`;
      }).join("");
      body.innerHTML = html;
    };

    const refreshSum = async () => {
      if (!sumEl || state.spId <= 0) return;
      const res = await fetch(`/api/UomGetLot/Sum?spId=${encodeURIComponent(state.spId)}`, withJwtHeaders());
      if (!res.ok) return;
      const data = await res.json();
      sumEl.value = data.sumQnty ?? "";
    };

    const fetchRows = async () => {
      if (state.spId <= 0) return;
      const qs = new URLSearchParams({
        spId: String(state.spId),
        stockId: (stockEl?.value || "").trim(),
        posId: (posEl?.value || "").trim(),
        uom: (uomEl?.value || "").trim(),
        sizeLenth: (sizeEl?.value || "").trim(),
        lotNum: (lotEl?.value || "").trim()
      });
      const res = await fetch(`/api/UomGetLot/Rows?${qs.toString()}`, withJwtHeaders());
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      state.rows = data.rows || [];
      await loadDict();
      buildFallbackDict(state.rows);
      buildHeaders();
      // 套用欄位拖曳排序
      if (window.initColumnDragSort && headRow) {
        initColumnDragSort({ headerRow: headRow, tbody: table?.querySelector('tbody'), scrollWrap: table?.closest('.table-responsive') || table?.parentElement, tableName: '', onSaved: null });
      }
      renderRows();
      await refreshSum();
    };

    const saveRow = async (row, payload) => {
      if (!row || state.spId <= 0) return;
      const bodyPayload = {
        spId: state.spId,
        lotNum: getRowValue(row, "LotNum"),
        stockId: getRowValue(row, "StockId"),
        posId: getRowValue(row, "PosId"),
        ...payload
      };
      await fetch("/api/UomGetLot/SaveRow", withJwtHeaders({
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(bodyPayload)
      }));
    };

    const runCount = async (row) => {
      const needQnty = (needQntyEl?.value ?? state.needQnty ?? "").toString().trim();
      const payload = {
        spId: state.spId,
        lotNum: getRowValue(row, "LotNum"),
        needQnty,
        stockId: getRowValue(row, "StockId"),
        posId: getRowValue(row, "PosId"),
        roundToUom: roundEl?.checked ? 1 : 0
      };
      await fetch("/api/UomGetLot/Count", withJwtHeaders({
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      }));
    };

    const runAutoCount = async () => {
      const needQnty = (needQntyEl?.value ?? state.needQnty ?? "").toString().trim();
      const payload = {
        spId: state.spId,
        needQnty,
        stockId: (stockEl?.value || "").trim(),
        posId: (posEl?.value || "").trim(),
        uom: (uomEl?.value || "").trim(),
        sizeLenth: (sizeEl?.value || "").trim(),
        lotNum: (lotEl?.value || "").trim(),
        roundToUom: roundEl?.checked ? 1 : 0
      };
      await fetch("/api/UomGetLot/AutoCount", withJwtHeaders({
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      }));
    };

    const open = async (ctx, meta) => {
      if (!modalEl) return;
      const detailRow = readActiveDetailRow();
      const detailItem = getDetailItem(detailRow);
      if (!detailItem) {
        await Swal.fire({ icon: 'warning', title: '找不到目前選取的明細項次', confirmButtonText: 'OK' });
        return;
      }

      state.itemId = ctx.itemId || "";
      state.buttonName = ctx.buttonName || "";
      state.paperNum = ctx.paperNum || "";
      state.paperId = ctx.headerTable || "";
      state.detailItem = detailItem;

      const initRes = await fetch("/api/UomGetLot/Init", withJwtHeaders({
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          itemId: state.itemId,
          buttonName: state.buttonName,
          paperNum: state.paperNum,
          paperId: state.paperId,
          detailItem: state.detailItem
        })
      }));
      if (!initRes.ok) {
        await Swal.fire({ icon: 'error', title: '初始化失敗', text: await initRes.text(), confirmButtonText: 'OK' });
        return;
      }
      const initData = await initRes.json();
      if (!initData.ok) {
        await Swal.fire({ icon: 'error', title: '初始化失敗', text: initData.error || '', confirmButtonText: 'OK' });
        return;
      }
      state.spId = initData.spId || 0;
      state.partNum = initData.partNum || "";
      state.needQnty = initData.needQnty || "";
      const tranParams = Array.isArray(initData.tranParams) ? initData.tranParams : [];
      const tranMap = new Map(tranParams.map(p => [Number(p.seqNum), p.value ?? ""]));
      const tranItem = tranMap.get(1);
      if (tranItem) state.detailItem = String(tranItem);

      if (titleEl) titleEl.textContent = meta.dialogCaption || ctx.caption || "批號指定";
      if (partNumEl) partNumEl.value = state.partNum;
      if (needQntyEl) needQntyEl.value = state.needQnty;

      await loadStockOptions();

      if (stockEl) stockEl.value = "";
      if (posEl) posEl.value = "";
      if (uomEl) uomEl.value = "";
      if (sizeEl) sizeEl.value = "";
      if (lotEl) lotEl.value = "";
      if (roundEl) roundEl.checked = false;

      if (detailRow) {
        if (stockEl && !stockEl.value) stockEl.value = String(getRowValue(detailRow, "StockId") || "").trim();
        if (posEl && !posEl.value) posEl.value = String(getRowValue(detailRow, "PosId") || "").trim();
        if (uomEl && !uomEl.value) uomEl.value = String(getRowValue(detailRow, "UOM") || "").trim();
        if (sizeEl && !sizeEl.value) sizeEl.value = String(getRowValue(detailRow, "SizeLenth") || "").trim();
      }

      const tranStock = tranMap.get(2);
      if (stockEl && tranStock != null && String(tranStock).trim() !== "") stockEl.value = String(tranStock).trim();
      const tranPos = tranMap.get(3);
      if (posEl && tranPos != null && String(tranPos).trim() !== "") posEl.value = String(tranPos).trim();
      const tranUom = tranMap.get(4);
      if (uomEl && tranUom != null && String(tranUom).trim() !== "") uomEl.value = String(tranUom).trim();
      const tranRound = tranMap.get(5);
      if (roundEl && tranRound != null && String(tranRound).trim() !== "") {
        roundEl.checked = String(tranRound).trim() === "1";
      }
      const tranSize = tranMap.get(7);
      if (sizeEl && tranSize != null && String(tranSize).trim() !== "") sizeEl.value = String(tranSize).trim();
      const tranLot = tranMap.get(8);
      if (lotEl && tranLot != null && String(tranLot).trim() !== "") lotEl.value = String(tranLot).trim();

      await fetchRows();

      if (window.bootstrap) {
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
      }
    };

    body?.addEventListener("click", (ev) => {
      const tr = ev.target.closest("tr");
      if (!tr) return;
      body.querySelectorAll("tr.ug-row-selected").forEach(r => r.classList.remove("ug-row-selected"));
      tr.classList.add("ug-row-selected");
    });

    body?.addEventListener("change", async (ev) => {
      const target = ev.target;
      const tr = target.closest("tr");
      if (!tr) return;
      const idx = Number(tr.dataset.idx);
      const row = state.rows[idx];
      if (!row) return;
      const field = target.dataset.field || "";
      const lc = normalizeKey(field);

      if (lc === "inuse") {
        const checked = target.checked;
        if (!checked) {
          await saveRow(row, { inUse: 0, transQnty: 0, transUomQnty: 0 });
          await fetchRows();
          return;
        }
        await saveRow(row, { inUse: 1 });
        await runCount(row);
        await fetchRows();
        return;
      }

      if (lc === "transqnty" || lc === "transuomqnty") {
        const ratio = toNumber(getRowValue(row, "Ratio"), 0);
        let transQnty = toNumber(lc === "transqnty" ? target.value : "");
        let transUom = toNumber(lc === "transuomqnty" ? target.value : "");
        if (ratio > 0) {
          if (lc === "transqnty") {
            transUom = transQnty / ratio;
          } else {
            transQnty = transUom * ratio;
          }
        }
        const transQntyInput = tr.querySelector('input[data-field="TransQnty"], input[data-field="transqnty"]');
        const transUomInput = tr.querySelector('input[data-field="TransUOMQnty"], input[data-field="transuomqnty"]');
        if (transQntyInput) transQntyInput.value = transQnty ? String(transQnty) : "0";
        if (transUomInput) transUomInput.value = transUom ? String(transUom) : "0";
        await saveRow(row, { inUse: 1, transQnty, transUomQnty: transUom });
        await fetchRows();
      }
    });

    btnSearch?.addEventListener("click", () => {
      fetchRows().catch(async err => { await Swal.fire({ icon: 'error', title: '查詢失敗', text: err?.message || String(err), confirmButtonText: 'OK' }); });
    });

    btnAuto?.addEventListener("click", async () => {
      try {
        await runAutoCount();
        await fetchRows();
      } catch (err) {
        await Swal.fire({ icon: 'error', title: '自動計算失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
      }
    });

    btnConfirm?.addEventListener("click", async (e) => {
      e.preventDefault();
      if (state.spId <= 0) return;
      try {
        const res = await fetch("/api/UomGetLot/Confirm", withJwtHeaders({
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            paperNum: state.paperNum,
            paperId: state.paperId,
            detailItem: state.detailItem,
            spId: state.spId
          })
        }));
        if (!res.ok) throw new Error(await res.text());
        const data = await res.json();
        if (!data.ok) throw new Error(data.error || "執行失敗");
        if (modalEl) {
          try { bootstrap.Modal.getOrCreateInstance(modalEl).hide(); } catch {}
        }
        if (typeof window.__refreshHeaderData === "function") {
          try { await window.__refreshHeaderData(); } catch {}
        }
        if (typeof window.__refreshMultiTab === "function") {
          try { await window.__refreshMultiTab(); } catch {}
        }
        if (typeof window.__paper3lSubDetailRefresh === "function") {
          try { await window.__paper3lSubDetailRefresh(); } catch {}
        }
      } catch (err) {
        await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
      }
    });

    return { open };
  })();

  const buildCustomButtonContext = (btn, ctxOverride = null) => {
    const designType = parseInt(btn.dataset.designType || "0", 10);
    const searchTemplate = (btn.dataset.searchTemplate || "").toLowerCase();
    const meta = {
      designType,
      searchTemplate,
      ocxName: (btn.dataset.ocxName || "").toLowerCase(),
      spName: btn.dataset.spName || "",
      execSpName: btn.dataset.execSpName || "",
      multiSelectDd: btn.dataset.multiSelectDd || "",
      replaceExists: btn.dataset.replaceExists || "",
      dialogCaption: btn.dataset.dialogCaption || "",
      allowSelCount: btn.dataset.allowSelCount || "",
      printRptName: btn.dataset.printRptName || ""
    };
    const ctx = {
      buttonName: btn.getAttribute('data-button-name') || '',
      itemId: (ctxOverride?.itemId ?? window._itemId ?? '@(Model?.ItemId ?? "")').toString(),
      paperNum: (ctxOverride?.paperNum ?? readPaperNum()).toString(),
      headerTable: (ctxOverride?.headerTable ?? window._headerTableName ?? '@(Model?.HeaderTableName ?? "")').toString(),
      dictTableName: (ctxOverride?.dictTableName ?? window._dictTableName ?? '').toString(),
      caption: (btn.textContent || '').trim()
    };
    return { meta, ctx };
  };

  const runCustomButton = async (btn, ctxOverride = null) => {
    if (!btn) return;
    const needInEdit = (btn.dataset.bNeedInEdit || "").toString();
    if (needInEdit === "1" && !isHeaderEditMode()) {
      await Swal.fire({ icon: 'warning', title: '此按鈕僅能在編輯模式使用', text: '請先點「修改」切換到編輯模式。', confirmButtonText: 'OK' });
      return;
    }

    // 按自訂按鈕前，若有未儲存的變更，先自動儲存
    if (window.__unsavedChanges && typeof window.saveHeaderForm === 'function') {
      try {
        const saveResult = await window.saveHeaderForm();
        if (!saveResult || !saveResult.ok) return; // 儲存失敗，不開啟自訂按鈕
      } catch (err) {
        console.error('自訂按鈕前自動儲存失敗', err);
        await Swal.fire({ icon: 'error', title: '儲存失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
        return;
      }
    }

    const { meta, ctx } = buildCustomButtonContext(btn, ctxOverride);
    if (!ctx.buttonName) return;

    const handler = resolveCustomHandler(ctx.buttonName);
    const designType = meta.designType;
    const searchTemplate = meta.searchTemplate;

    if (handler) {
      try {
        await handler(ctx);
      } catch (err) {
        console.error("action-rail custom button handler error", err);
        await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
      }
      return;
    }

    if (designType === 1) {
      if (searchTemplate === "jsdpapersearchdll.dll") {
        try {
          await paperSearch.open(ctx, meta);
        } catch (err) {
          console.error("paper search template error", err);
          await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
        }
        return;
      }

      if (searchTemplate === "jsdcondrunspdll.dll") {
        try {
          await condRunSp.open(ctx, meta);
        } catch (err) {
          console.error("cond-run-sp template error", err);
          await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
        }
        return;
      }

      try {
        await window.paperSearch.open(ctx, meta);
      } catch (err) {
        console.error("paper search template error", err);
        await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
      }
    }

    if (designType === 0) {
      if (meta.ocxName === "hpsdchargecalcexcel.dll") {
        try {
          const resp = await fetch('/api/StoredProc/execByButtonExcel', withJwtHeaders({
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemId: ctx.itemId, buttonName: ctx.buttonName, paperNum: ctx.paperNum })
          }));
          if (!resp.ok) {
            let msg = `HTTP ${resp.status}`;
            try { const j = await resp.json(); msg = j.error || msg; } catch {}
            await Swal.fire({ icon: 'error', title: '執行失敗', text: msg, confirmButtonText: 'OK' });
            return;
          }
          const blob = await resp.blob();
          const cd = resp.headers.get('Content-Disposition') || '';
          const match = cd.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/);
          const fileName = match ? match[1].replace(/['"]/g, '') : 'export.xlsx';
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url; a.download = fileName; a.click();
          URL.revokeObjectURL(url);
        } catch (err) {
          console.error("execByButtonExcel error", err);
          await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
        }
        return;
      }
      await Swal.fire({ icon: 'warning', title: '尚未實作', text: `此按鈕（${ctx.buttonName}）設計方式為自寫（DesignType=0），尚未實作自訂處理程序。`, confirmButtonText: 'OK' });
      return;
    }

    // 無自訂 handler → 嘗試依 DB 設定呼叫 SP (DesignType=3)
    try {
      const masterRow = (typeof window._getMasterRow === 'function') ? window._getMasterRow() : null;
      // 取得目前選中的 detail row（從 MultiTabDetail 的選取狀態）
      const detailRow = (() => {
        const sel = window._multiTabSelectedRows;
        if (!sel) return null;
        // 優先取得目前 active tab 的選中列
        const activeTab = document.querySelector('.multi-tab-detail .nav-link.active');
        const activeTabId = activeTab?.dataset?.tabId;
        if (activeTabId && sel[activeTabId]) return sel[activeTabId];
        // fallback: 取第一個有選中列的 tab
        const firstKey = Object.keys(sel).find(k => sel[k]);
        return firstKey ? sel[firstKey] : null;
      })();
      const args = {};
      if (masterRow) args.masterRow = masterRow;
      if (detailRow) args.detailRow = detailRow;
      const currentUserId = (window._userId || localStorage.getItem("erpLoginUserId") || localStorage.getItem("userId") || "").toString().trim();
      const currentUseId = (window._useId || localStorage.getItem("erpUseId") || localStorage.getItem("useId") || window.DEFAULT_USEID || "").toString().trim();
      if (currentUserId) args.userId = currentUserId;
      if (currentUseId) args.useId = currentUseId;
      const resp = await fetch('/api/StoredProc/execByButton', withJwtHeaders({
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          itemId: ctx.itemId,
          buttonName: ctx.buttonName,
          paperNum: ctx.paperNum,
          args: Object.keys(args).length > 0 ? args : undefined
        })
      }));
      const raw = await resp.text();
      let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
      if (resp.ok && data.ok) {
        const _execMsg = String(data.message ?? "").trim().replace(/^MESGE:\s*/i, "").trim();
        if (_execMsg) await Swal.fire({ icon: 'info', title: _execMsg, confirmButtonText: 'OK' });
        if (typeof window.__refreshHeaderData === "function") {
          try { await window.__refreshHeaderData(); } catch {}
        }
        if (typeof window.__refreshMultiTab === "function") {
          try { await window.__refreshMultiTab(); } catch {}
        }
        if (typeof window.__paper3lSubDetailRefresh === "function") {
          try { await window.__paper3lSubDetailRefresh(); } catch {}
        }
        return;
      }
      await Swal.fire({ icon: 'error', title: '執行失敗', text: data.error || `HTTP ${resp.status}`, confirmButtonText: 'OK' });
    } catch (err) {
      console.error("action-rail execByButton error", err);
      await Swal.fire({ icon: 'error', title: '執行失敗', text: err?.message || String(err), confirmButtonText: 'OK' });
    }
  };

  const wireActionRailButtons = () => {
    document.querySelectorAll('.action-rail [data-custom-btn="1"]').forEach(btn => {
      if (btn.dataset.cbBound === "1") return;
      btn.dataset.cbBound = "1";

      btn.addEventListener('click', async (e) => {
        e.preventDefault(); e.stopPropagation();
        await runCustomButton(btn);
      });
    });
  };

  window.ActionRailRunButton = runCustomButton;
  wireActionRailButtons();
})();
</script>
