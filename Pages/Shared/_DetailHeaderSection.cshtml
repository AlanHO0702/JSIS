(function wireSubDetailToolbar() {
  const btnAdd = document.getElementById('btnSubDetailAdd');
  const btnDel = document.getElementById('btnSubDetailDelete');
  if (!btnAdd && !btnDel) return;
  btnAdd?.classList.remove('d-none');
  btnDel?.classList.remove('d-none');
  const root = document.querySelector('.mmd-wrapper');

  const pickApi = () => {
    const domId = root?.id;
    if (domId && window._mmdApi?.[domId]) return window._mmdApi[domId];
    const keys = Object.keys(window._mmdApi || {});
    return keys.length ? window._mmdApi[keys[0]] : null;
  };

  const warn = (msg) => {
    if (window.Swal?.fire) Swal.fire({ icon: 'info', title: msg });
    else alert(msg);
  };

  const clickMultiTabAction = (kind) => {
    const selector = kind === 'add' ? '.btn-add-row' : '.btn-delete-row';
    const activePane = document.querySelector('.multi-tab-detail .tab-pane.active');
    const scope = activePane || document.querySelector('.multi-tab-detail');
    if (!scope) return { ok: false, reason: 'no-multitab' };
    const btn = scope.querySelector(selector) || document.querySelector(`.multi-tab-detail ${selector}`);
    if (!btn) return { ok: false, reason: 'no-button' };
    btn.click();
    return { ok: true };
  };

  const getActiveMultiTabCtx = () => {
    const activePane = document.querySelector('.multi-tab-detail .tab-pane.active');
    if (!activePane) return null;
    const navBtn = document.querySelector('.multi-tab-detail .nav-link.active[data-api-url]');
    const apiUrl = navBtn?.dataset?.apiUrl || '';
    const tbody = activePane.querySelector('tbody');
    let selectedRow = tbody?.querySelector('tr.row-selected') || null;
    if (!selectedRow) {
      const focusTr = document.activeElement?.closest?.('.multi-tab-detail tbody tr');
      if (focusTr && tbody?.contains(focusTr)) selectedRow = focusTr;
    }
    return { activePane, apiUrl, tbody, selectedRow };
  };

  const detailDefaultsCache = {};

  const escAttr = (v) => String(v ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');

  const getDetailDefaults = async (table) => {
    const key = (table || '').toString().toLowerCase();
    if (!key) return {};
    if (detailDefaultsCache[key]) return detailDefaultsCache[key];
    const url = `/api/OrderHeaderApi/DetailDefaults?table=${encodeURIComponent(table)}`;
    const res = await fetch(url);
    if (!res.ok) return {};
    const data = await res.json();
    const defs = data?.defaults || {};
    detailDefaultsCache[key] = defs;
    return defs;
  };

  function isMultiTabBlankRow(tr, fields) {
    if (!tr) return false;
    const inputs = Array.from(tr.querySelectorAll('.cell-edit[data-field]'));
    if (!inputs.length) return false;
    let hasValue = false;
    inputs.forEach(inp => {
      const f = (inp.dataset.field || '').toString().toLowerCase();
      if (f === 'papernum' || f === 'item') return;
      const val = (inp.value ?? '').toString().trim();
      if (val === '') return;
      if (/^[-–—]+$/.test(val)) return;
      const num = Number(val);
      if (Number.isFinite(num) && num === 0) return;
      hasValue = true;
    });
    return !hasValue;
  }

  const addMultiTabBlankRow = async () => {
    if (!getHeaderEditState()) return { ok: false, reason: 'not-editing' };
    const ctx = getActiveMultiTabCtx();
    if (!ctx || !ctx.tbody) return { ok: false, reason: 'no-multitab' };
    const { activePane, tbody } = ctx;
    const table = activePane.querySelector('table.erp-table');
    const headerCells = Array.from(table?.querySelectorAll('thead th') || []);
    const fields = headerCells
      .map(th => (th.dataset.field || '').toString())
      .filter(Boolean);
    if (!fields.length) return { ok: false, reason: 'no-fields' };
    // 從現有 td 讀對齊（th 永遠是 align-left，對齊是由 td 的 getAlignClass 決定）
    const refRow = Array.from(tbody.querySelectorAll('tr')).find(tr =>
      tr.dataset.state !== 'added' && tr.dataset.state !== 'empty'
    ) || tbody.querySelector('tr');
    const alignMap = new Map(headerCells.map(th => {
      const key = (th.dataset.field || '').toString().toLowerCase();
      const f = th.dataset.field || '';
      const refTd = refRow?.querySelector(`td[data-field="${CSS.escape(f)}"]`);
      const alignClass = refTd
        ? (refTd.classList.contains('align-right') ? 'align-right' : 'align-left')
        : 'align-left';
      return [key, alignClass];
    }));

    const dictTable = activePane?.querySelector?.('.table-container')?.dataset?.dictTable || '';
    const safeTable = (dictTable || '').toString().replace(/^dbo\./i, '').trim();
    const readOnlyMap = safeTable && window._detailFieldReadOnlyMap
      ? (window._detailFieldReadOnlyMap[safeTable.toLowerCase()] || {})
      : {};

    const pn = (getPaperNum() || '').trim();
    const isEditing = getHeaderEditState() || !!document.querySelector('.multi-tab-detail .cell-edit:not(.d-none)');
    const viewClass = isEditing ? 'cell-view d-none' : 'cell-view';
    const editClass = isEditing ? 'cell-edit' : 'cell-edit d-none';

    // ★ 在 await 前先同步判斷是否有空白列可重用，避免非同步競爭
    // data-state="empty" 是系統自動產生的佔位列，優先重用
    // 也檢查「內容為空白」的列（不重用填了資料的 added 列）
    const reusableRow = Array.from(tbody.querySelectorAll('tr')).find(tr =>
      tr.dataset.state === 'empty' || isMultiTabBlankRow(tr, fields)
    );
    if (reusableRow) {
      let maxItem = 0;
      tbody.querySelectorAll('tr').forEach(tr => {
        const n = parseInt(tr.dataset.item || '', 10);
        if (!isNaN(n) && n > maxItem) maxItem = n;
      });
      const reusedItem = maxItem + 1;
      tbody.querySelectorAll('tr.row-selected').forEach(r => r.classList.remove('row-selected'));
      reusableRow.classList.add('row-selected');
      reusableRow.dataset.state = 'added';
      if (!reusableRow.dataset.paperNum) reusableRow.dataset.paperNum = pn;
      reusableRow.dataset.item = String(reusedItem);
      // 填入項次欄位值
      const reusedItemInp = reusableRow.querySelector('input.cell-edit[data-field="Item"], input.cell-edit[data-field="item"]');
      if (reusedItemInp) { reusedItemInp.value = String(reusedItem); reusedItemInp.dataset.init = String(reusedItem); }
      const reusedItemView = reusableRow.querySelector('td[data-field="Item"] .cell-view, td[data-field="item"] .cell-view');
      if (reusedItemView) reusedItemView.textContent = String(reusedItem);
      reusableRow.querySelectorAll('.cell-view').forEach(el => el.classList.add('d-none'));
      reusableRow.querySelectorAll('.cell-edit').forEach(el => el.classList.remove('d-none'));
      reusableRow.querySelector('.cell-edit')?.focus();
      if (typeof window.__updateToolbarCounts === 'function') window.__updateToolbarCounts();
      window.__unsavedChanges = true;
      updateSaveCheckButtons();
      return { ok: true, reused: true };
    }

    // 沒有可重用列，才 await defaults 建新列
    const defaults = safeTable ? await getDetailDefaults(safeTable) : {};

    // await 後再確認一次（防止競爭），同樣只重用空白列（含 data-state="empty" 佔位列）
    const pendingAfterAwait = Array.from(tbody.querySelectorAll('tr')).find(tr =>
      tr.dataset.state === 'empty' || isMultiTabBlankRow(tr, fields)
    );
    if (pendingAfterAwait) {
      let maxItem2 = 0;
      tbody.querySelectorAll('tr').forEach(tr => {
        const n = parseInt(tr.dataset.item || '', 10);
        if (!isNaN(n) && n > maxItem2) maxItem2 = n;
      });
      const pendingItem = maxItem2 + 1;
      pendingAfterAwait.dataset.item = String(pendingItem);
      if (!pendingAfterAwait.dataset.paperNum) pendingAfterAwait.dataset.paperNum = pn;
      const pendingItemInp = pendingAfterAwait.querySelector('input.cell-edit[data-field="Item"], input.cell-edit[data-field="item"]');
      if (pendingItemInp) { pendingItemInp.value = String(pendingItem); pendingItemInp.dataset.init = String(pendingItem); }
      const pendingItemView = pendingAfterAwait.querySelector('td[data-field="Item"] .cell-view, td[data-field="item"] .cell-view');
      if (pendingItemView) pendingItemView.textContent = String(pendingItem);
      tbody.querySelectorAll('tr.row-selected').forEach(r => r.classList.remove('row-selected'));
      pendingAfterAwait.classList.add('row-selected');
      pendingAfterAwait.dataset.state = 'added';
      pendingAfterAwait.querySelectorAll('.cell-view').forEach(el => el.classList.add('d-none'));
      pendingAfterAwait.querySelectorAll('.cell-edit').forEach(el => el.classList.remove('d-none'));
      pendingAfterAwait.querySelector('.cell-edit')?.focus();
      if (typeof window.__updateToolbarCounts === 'function') window.__updateToolbarCounts();
      window.__unsavedChanges = true;
      updateSaveCheckButtons();
      return { ok: true, reused: true };
    }

    let maxItem = 0;
    tbody.querySelectorAll('tr').forEach(tr => {
      const n = parseInt(tr.dataset.item || '', 10);
      if (!isNaN(n) && n > maxItem) maxItem = n;
    });
    const newItem = maxItem + 1;

    // ★ 取得當前分頁的 lookup 欄位資訊，讓新增行也能雙擊下拉選單
    const tabContainer = activePane.querySelector('.table-container[data-tab-id]');
    const currentTabId = tabContainer?.dataset?.tabId || '';
    const lookupFields = new Set((window._multiTabLookupFields?.[currentTabId] || []).map(f => f.toLowerCase()));
    const lookupMetaMap = window._multiTabLookupMeta?.[currentTabId] || {};

    let html = `<tr data-paper-num="${pn}" data-item="${newItem}" data-state="added" class="row-selected">`;
      fields.forEach(field => {
        const fieldKey = (field || '').toString().toLowerCase();
        const isReadOnly = !!readOnlyMap[fieldKey];
        const roClass = isReadOnly ? ' readonly-cell' : '';
        const roAttr = isReadOnly ? ' data-readonly="1" readonly' : ' data-readonly="0"';
        const defVal = fieldKey === 'item'
          ? newItem
          : (defaults && Object.prototype.hasOwnProperty.call(defaults, field)) ? defaults[field] : '';
        const value = defVal == null ? '' : String(defVal);
        const safeValue = escAttr(value);
        const alignClass = alignMap.get(fieldKey) || 'align-left';
        // ★ 若此欄位有 lookup 下拉，加上 lookup 相關屬性
        const isLookup = lookupFields.has(fieldKey);
        const lkMeta = isLookup ? lookupMetaMap[fieldKey] : null;
        const lookupCls = isLookup ? ' lookup-cell' : '';
        const lookupAttr = isLookup
          ? ` data-lookup-field="${escAttr(field)}" data-lookup-key-field="${escAttr(lkMeta?.key || '')}" data-lookup-result-field="${escAttr(lkMeta?.result || '')}"`
          : '';
        html += `<td data-field="${escAttr(field)}" class="${alignClass}${lookupCls}" data-readonly="${isReadOnly ? '1' : '0'}"${lookupAttr}>
          <span class="${viewClass}${roClass}" data-init-view="${safeValue}" data-readonly="${isReadOnly ? '1' : '0'}">${safeValue}</span>
          <input type="text" class="${editClass}${roClass}" data-field="${field}" data-init="${safeValue}" value="${safeValue}"${roAttr}>
        </td>`;
      });
    html += '</tr>';

    tbody.querySelectorAll('tr.row-selected').forEach(r => r.classList.remove('row-selected'));
    tbody.insertAdjacentHTML('beforeend', html);
    const newRow = tbody.querySelector('tr:last-child');
    if (newRow) {
      const firstInput = newRow.querySelector('input.cell-edit');
      if (firstInput) {
