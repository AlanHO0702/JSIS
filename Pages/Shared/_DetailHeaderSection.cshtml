// ============================
// 第一筆 / 上一筆 / 下一筆 / 最後一筆
// ============================
const NAV_BTN_FIRST = document.getElementById('btnFirst');
const NAV_BTN_PREV = document.getElementById('btnPrev');
const NAV_BTN_NEXT = document.getElementById('btnNext');
const NAV_BTN_LAST = document.getElementById('btnLast');
let navIds = [], navIndex = -1;
const headerCountEl = document.getElementById('toolbarHeaderCount');
const detailCountEl = document.getElementById('toolbarDetailCount');

function loadLastFilters() {
  try {
    const tn = (PAGE.headerTable || '').toString().trim().toLowerCase();
    const fk = tn ? `orderListQueryFilters:${tn}` : "orderListQueryFilters";
    const s1 = localStorage.getItem(fk);
    if (s1) return JSON.parse(s1);

    // legacy: only accept global filters if they were saved for the same table
    const legacyTable = (localStorage.getItem("orderListQueryTable") || '').toLowerCase();
    const s2 = legacyTable === tn ? localStorage.getItem("orderListQueryFilters") : null;
    return s2 ? JSON.parse(s2) : [];
  }
  catch { return []; }
}
function normalizeNavFilters(filters) {
  if (!Array.isArray(filters)) return [];
  return filters
    .filter(f => f && typeof f === 'object')
    .filter(f => {
      const field = (f.Field || '').toString().trim();
      const value = (f.Value ?? '').toString().trim();
      if (!field || !value) return false;
      const key = field.toLowerCase();
      return key !== 'page' && key !== 'pagesize';
    })
    .map(f => ({ ...f }));
}
function readNavKeyFromRow(row) {
  if (!row || typeof row !== 'object') return '';
  const keyField = (PAGE.keyField || 'PaperNum').toString().trim();
  if (!keyField) return '';

  const direct = row[keyField];
  if (direct != null && direct !== '') return String(direct).trim();

  const target = keyField.toLowerCase();
  const matchKey = Object.keys(row).find(k => (k || '').toString().toLowerCase() === target);
  if (!matchKey) return '';
  const val = row[matchKey];
  return val == null ? '' : String(val).trim();
}
function getDetailBasePath() { return location.pathname.replace(/\/[^\/]+$/, "/"); }
function gotoPaper(pn) { if (!pn) return; localStorage.setItem("lastViewedPaperNum", pn); location.href = getDetailBasePath() + pn; }
function updateNavButtons() {
  const hasFirst = navIndex > 0;
  const hasPrev = navIndex > 0;
  const hasNext = navIndex >= 0 && navIndex < navIds.length - 1;
  const hasLast = navIndex >= 0 && navIndex < navIds.length - 1;
  if (NAV_BTN_FIRST) {
    NAV_BTN_FIRST.disabled = !hasFirst;
    NAV_BTN_FIRST.onclick = () => hasFirst && gotoPaper(navIds[0]);
  }
  if (NAV_BTN_PREV) {
    NAV_BTN_PREV.disabled = !hasPrev;
    NAV_BTN_PREV.onclick = () => hasPrev && gotoPaper(navIds[navIndex - 1]);
  }
  if (NAV_BTN_NEXT) {
    NAV_BTN_NEXT.disabled = !hasNext;
    NAV_BTN_NEXT.onclick = () => hasNext && gotoPaper(navIds[navIndex + 1]);
  }
  if (NAV_BTN_LAST) {
    NAV_BTN_LAST.disabled = !hasLast;
    NAV_BTN_LAST.onclick = () => hasLast && gotoPaper(navIds[navIds.length - 1]);
  }
  updateToolbarCounts();
}
async function fetchIdListByPagedQuery(filters) {
  const baseFilters = normalizeNavFilters(filters);
  const fs = [...baseFilters, { Field: "page", Op: "", Value: "1" }, { Field: "pageSize", Op: "", Value: "1000" }];
  const res = await fetch('/api/PagedQuery/PagedQuery', withJwtHeaders({
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ table: PAGE.headerTable, filters: fs })
  }));
  if (!res.ok) throw new Error('PagedQuery/PagedQuery failed');
  const json = await res.json();
  const rows = Array.isArray(json.data) ? json.data : [];
  const ids = rows.map(readNavKeyFromRow).filter(Boolean);
  return Array.from(new Set(ids));
}
async function fetchIdListByDynamicTable(filters) {
  const baseFilters = normalizeNavFilters(filters);
  const itemId = (PAGE.itemId || window._itemId || window._singleItemId || '').toString().trim();
  const pageSize = 1000;
  let page = 1;
  const ids = [];
  const seen = new Set();
  let totalCount = 0;

  for (let guard = 0; guard < 500; guard++) {
    const fs = [...baseFilters,
      { Field: "page", Op: "", Value: String(page) },
      { Field: "pageSize", Op: "", Value: String(pageSize) }];

    const res = await fetch('/api/DynamicTable/PagedQuery', withJwtHeaders({
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ table: PAGE.headerTable, itemId, filters: fs })
    }));
    if (!res.ok) throw new Error('DynamicTable/PagedQuery failed');

    const json = await res.json();
    const rows = Array.isArray(json.data) ? json.data : [];
    const tc = Number(json.totalCount);
    if (Number.isFinite(tc) && tc > 0) totalCount = tc;

    for (const row of rows) {
      const id = readNavKeyFromRow(row);
      if (!id) continue;
      const hash = id.toLowerCase();
      if (seen.has(hash)) continue;
      seen.add(hash);
      ids.push(id);
    }

    if (rows.length < pageSize) break;
    if (totalCount > 0 && ids.length >= totalCount) break;
    page += 1;
  }

  return ids;
}
async function buildNavIds(filters) {
  let ids = [];
  try { ids = await fetchIdListByDynamicTable(filters); }
  catch { ids = []; }
  if ((!Array.isArray(ids) || ids.length === 0) && typeof fetchIdListByApi === 'function') {
    try { ids = await fetchIdListByApi(filters); } catch {}
  }
  if (!Array.isArray(ids) || ids.length === 0) {
    try { ids = await fetchIdListByPagedQuery(filters); } catch {}
  }
  return Array.isArray(ids) ? ids : [];
}
function getStoredNavIndex() {
  try {
    const tn = (PAGE.headerTable || '').toString().trim().toLowerCase();
    if (!tn) return -1;
    const n = parseInt(localStorage.getItem(`orderListQueryIndex:${tn}`) || '0', 10);
    return Number.isFinite(n) && n > 0 ? (n - 1) : -1;
  } catch {
    return -1;
  }
}
async function initRowNavigation() {
  try {
    const cur = (PAGE.paperNum || '').toString().trim().toLowerCase();
    const tn = (PAGE.headerTable || '').toString().trim().toLowerCase();
    let filters = normalizeNavFilters(loadLastFilters());
    let source = 'filter';

    // 1. 優先使用列表頁儲存的當前頁 ID 列表（與列表頁顯示完全一致）
    if (tn) {
      try {
        const listIdsJson = sessionStorage.getItem(`listNavIds:${tn}`);
        if (listIdsJson) {
          const listIds = JSON.parse(listIdsJson);
          if (Array.isArray(listIds) && listIds.length > 0) {
            const idx = listIds.findIndex(x => (x || '').toString().trim().toLowerCase() === cur);
            if (idx >= 0) {
              navIds = listIds.map(x => String(x).trim());
              navIndex = idx;
              source = 'listNavIds';
            }
          }
        }
      } catch {}
    }

    // 2. 若列表頁無 ID 或找不到當前單號，改用 filter 查詢
    if (source !== 'listNavIds') {
      navIds = await buildNavIds(filters);
      navIndex = navIds.findIndex(x => (x || '').toString().trim().toLowerCase() === cur);

      // 若 filter 的結果中找不到當前單號，用空 filter 重試
      // 注意：不清除 localStorage，讓「切換」仍能用原始 filter 顯示正確筆數
      if (navIndex < 0 && filters.length > 0) {
        navIds = await buildNavIds([]);
        navIndex = navIds.findIndex(x => (x || '').toString().trim().toLowerCase() === cur);
        if (navIndex >= 0) source = 'emptyFilter';
      }
    }

    if (!Array.isArray(navIds)) navIds = [];
    navIndex = navIds.findIndex(x => (x || '').toString().trim().toLowerCase() === cur);
    if (navIndex < 0 && navIds.length > 0) {
      const storedIdx = getStoredNavIndex();
      if (storedIdx >= 0 && storedIdx < navIds.length) navIndex = storedIdx;
    }
    window.__paperNavState = {
      table: PAGE.headerTable,
      currentPaperNum: PAGE.paperNum,
      filterCount: filters.length,
      navCount: navIds.length,
      navIndex,
      firstIds: navIds.slice(0, 10),
      source
    };
    updateNavButtons();

    // 3. 若來自列表頁的當前頁 ID 列表（有頁數限制），背景非同步載入完整 ID 清單
    //    使用 listNavFilters（renderTable 時儲存）而非 orderListQueryFilters（可能被汙染）
    if (source === 'listNavIds' && tn) {
      try {
        const _savedFiltersJson = sessionStorage.getItem(`listNavFilters:${tn}`);
        const _bgFilters = _savedFiltersJson
          ? normalizeNavFilters(JSON.parse(_savedFiltersJson))
          : filters;
        buildNavIds(_bgFilters).then(_allIds => {
          if (!Array.isArray(_allIds) || _allIds.length <= navIds.length) return;
          const _newIdx = _allIds.findIndex(x => (x || '').toString().trim().toLowerCase() === cur);
          if (_newIdx < 0) return;
          navIds = _allIds;
          navIndex = _newIdx;
          window.__paperNavState.navCount = navIds.length;
          window.__paperNavState.navIndex = navIndex;
          window.__paperNavState.source = 'listNavIds+fullFetch';
          updateNavButtons();
        }).catch(() => {});
      } catch {}
    }
  } catch {
    window.__paperNavState = {
      table: PAGE.headerTable,
      currentPaperNum: PAGE.paperNum,
      error: 'initRowNavigation_failed'
    };
    if (NAV_BTN_FIRST) NAV_BTN_FIRST.disabled = true;
    if (NAV_BTN_PREV) NAV_BTN_PREV.disabled = true;
    if (NAV_BTN_NEXT) NAV_BTN_NEXT.disabled = true;
    if (NAV_BTN_LAST) NAV_BTN_LAST.disabled = true;
  }
}
initRowNavigation();

function getActiveDetailRowStats() {
  const activePane = document.querySelector('.multi-tab-detail .tab-pane.show.active');
  if (!activePane) return { index: 0, total: 0 };
  const tbody = activePane.querySelector('tbody');
  if (!tbody) return { index: 0, total: 0 };
  const rows = Array.from(tbody.querySelectorAll('tr'))
    .filter(tr => (tr.dataset.state || '').toString().toLowerCase() !== 'empty');
  const total = rows.length;
  if (!total) return { index: 0, total: 0 };
  const selected = tbody.querySelector('tr.row-selected');
  const idx = selected ? rows.indexOf(selected) + 1 : 1;
  return { index: idx, total };
}

function updateToolbarCounts() {
  if (headerCountEl) {
    const total = navIds.length;
    if (total > 0 && navIndex >= 0) {
      const tn = (PAGE.headerTable || '').toString().trim().toLowerCase();
      try {
        const storedTotal = parseInt(localStorage.getItem(`orderListQueryTotal:${tn}`) || '0', 10);
        const storedPageStart = parseInt(localStorage.getItem(`orderListQueryPageStart:${tn}`) || '1', 10);
        // 若 navIds 是列表頁當前頁的子集（total < storedTotal），用全域位置顯示
        if (Number.isFinite(storedTotal) && storedTotal > total && storedPageStart > 0) {
          headerCountEl.textContent = `${storedPageStart + navIndex}/${storedTotal}`;
        } else {
          headerCountEl.textContent = `${navIndex + 1}/${total}`;
        }
      } catch {
        headerCountEl.textContent = `${navIndex + 1}/${total}`;
      }
    } else {
      const tn = (PAGE.headerTable || '').toString().trim().toLowerCase();
      let storedTotal = 0;
      let storedIndex = 0;
      try {
        storedTotal = parseInt(localStorage.getItem(`orderListQueryTotal:${tn}`) || '0', 10);
        storedIndex = parseInt(localStorage.getItem(`orderListQueryIndex:${tn}`) || '0', 10);
      } catch {}
      if (storedTotal > 0) {
        const idxText = storedIndex > 0 ? String(storedIndex) : '--';
        headerCountEl.textContent = `${idxText}/${storedTotal}`;
      } else {
        headerCountEl.textContent = '--/--';
      }
    }
  }
  if (detailCountEl) {
    const stats = getActiveDetailRowStats();
    detailCountEl.textContent = stats.total > 0 ? `${stats.index}/${stats.total}` : '--/--';
  }
}

window.__updateToolbarCounts = updateToolbarCounts;

