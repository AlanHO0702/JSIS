}

.action-rail{
  position: fixed;
  left: var(--fab-left);
  top: var(--action-rail-top);
  box-sizing: border-box;
  max-height: calc(100vh - (var(--action-rail-top) + 20px)); /* 限制最大高度，避免超出視窗 */
