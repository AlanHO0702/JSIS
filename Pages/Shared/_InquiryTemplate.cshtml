@model dynamic
@inject PcbErpApi.Services.IBreadcrumbService BreadcrumbService
@inject PcbErpApi.Data.PcbErpContext DbContext
@using Microsoft.EntityFrameworkCore
@{
    Layout = "_Layout";

    var title = (ViewData["Title"] as string) ?? (ViewData["PageTitle"] as string) ?? "";
    var railWidth = (ViewData["InqRailWidth"] as string) ?? "120px";
    var railTitle = (ViewData["InqRailTitle"] as string) ?? "";
    var actionPartial = ViewData["ActionRailPartial"] as string;
    var hasRailSection = IsSectionDefined("InqRail");
    var hasActionRail = !string.IsNullOrWhiteSpace(actionPartial)
        && !actionPartial.EndsWith("_ActionRail.Empty.cshtml", StringComparison.OrdinalIgnoreCase);
    var showHeader = (ViewData["ShowInqHeader"] as bool?) ?? true;
    var showRail = (ViewData["ShowInqRail"] as bool?) ?? (hasRailSection || hasActionRail);

    if (ViewData["Breadcrumbs"] == null)
    {
        var itemId = title.Split(' ').FirstOrDefault() ?? "";
        if (!string.IsNullOrWhiteSpace(itemId))
        {
            try
            {
                var sysItem = await DbContext.CurdSysItems.AsNoTracking()
                    .FirstOrDefaultAsync(x => x.ItemId == itemId);
                if (!string.IsNullOrWhiteSpace(sysItem?.SuperId))
                    ViewData["Breadcrumbs"] = await BreadcrumbService.BuildBreadcrumbsAsync(sysItem.SuperId);
            }
            catch { }
        }
    }
}

<style>
  .inq-shell {
    display: flex;
    gap: 12px;
    padding: 8px 12px 16px 12px;
    align-items: stretch;
  }
  .inq-rail {
    width: var(--inq-rail-width, 120px);
    flex: 0 0 var(--inq-rail-width, 120px);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .inq-rail-title {
    font-weight: 700;
    color: #1d3b6b;
    font-size: 0.9rem;
    padding: 4px 2px;
  }
  .inq-rail .fab,
  .inq-rail-btn {
    width: 100%;
    padding: 6px 8px;
    font-size: 0.9rem;
    font-weight: 600;
    background: #f8f9fb;
    color: #1f5fbf;
    border: 1px solid #cfd7e6;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(20, 40, 80, 0.12);
    cursor: pointer;
    text-align: center;
  }
  .inq-rail .fab:hover,
  .inq-rail-btn:hover {
    background: #e9f1ff;
    border-color: #9fbaf0;
  }
  .inq-main {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .inq-header {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 6px 8px;
    border: 1px solid #d8dee8;
    border-radius: 10px;
    background: var(--section-bg-toolbar, #f6f7f9);
  }
  .inq-title {
    font-weight: 700;
    color: #1d3b6b;
    letter-spacing: 1px;
    margin-right: 6px;
  }
  .inq-header .inq-toolbar {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .inq-count-box {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 30px;
    min-width: 74px;
    padding: 2px 8px;
    border-radius: 6px;
    font-weight: 700;
    line-height: 1.05;
    color: #fff;
    background: #1e4db7;
    user-select: none;
    font-size: 0.85rem;
  }
  .inq-section {
    border: 1px solid #d8dee8;
    border-radius: 10px;
    background: #fff;
    padding: 8px;
  }
  .inq-query .inq-form {
    gap: 2px;
  }
  .inq-query .inq-row {
    gap: 2px;
  }
  .inq-query .inq-label {
    min-width: 52px;
    font-size: 0.72rem;
  }
  .inq-query .inq-input {
    height: 22px;
    font-size: 0.72rem;
    padding: 0 4px;
  }
  .inq-query .compact-check .form-check-input {
    width: 11px;
    height: 11px;
  }
  .inq-query .inq-form.inq-form--auto-grid-active {
    width: max-content;
    min-width: 100%;
    overflow-x: auto;
  }
  .inq-query .inq-form.inq-form--auto-grid-active .inq-row {
    display: grid;
    grid-template-columns: var(--inq-auto-cols, max-content);
    column-gap: 2px;
    align-items: center;
    flex-wrap: nowrap;
  }
  .inq-query .inq-form.inq-form--auto-grid-active .inq-row > .inq-label {
    min-width: 0;
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .inq-query .inq-form.inq-form--auto-grid-active .inq-row > .inq-input,
  .inq-query .inq-form.inq-form--auto-grid-active .inq-row > .inq-select,
  .inq-query .inq-form.inq-form--auto-grid-active .inq-row > .compact-check {
    min-width: 0;
  }
  @@media (max-width: 992px) {
    .inq-shell {
      flex-direction: column;
    }
    .inq-rail {
      width: auto;
      flex: 0 0 auto;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .inq-rail .fab,
    .inq-rail-btn {
      width: auto;
      min-width: 96px;
    }
  }
</style>

<div class="inq-shell" style="--inq-rail-width:@railWidth;">
  @if (showRail)
  {
    <aside class="inq-rail">
      @if (!string.IsNullOrWhiteSpace(railTitle))
      {
        <div class="inq-rail-title">@railTitle</div>
      }
      @if (hasRailSection)
      {
        @RenderSection("InqRail", required: false)
      }
      @if (hasActionRail)
      {
        @await Html.PartialAsync(actionPartial!, (object)Model)
      }
    </aside>
  }

  <main class="inq-main">
    @if (showHeader)
    {
      if (IsSectionDefined("InqHeader"))
      {
        @RenderSection("InqHeader", required: false)
      }
      else
      {
        <div class="inq-header">
          @if (!string.IsNullOrWhiteSpace(title))
          {
            <div class="inq-title">@title</div>
          }
          <div id="singleGridCountBox" class="inq-count-box mode-view">
            <div id="singleGridMode" class="count-line">瀏覽模式</div>
            <div id="singleGridCount" class="count-line">0 / 0</div>
          </div>
          <div class="inq-toolbar">
            @RenderSection("InqHeaderActions", required: false)
          </div>
        </div>
      }
    }

    @if (IsSectionDefined("InqQuery"))
    {
      <section class="inq-section inq-query">
        @RenderSection("InqQuery", required: false)
      </section>
    }

    @if (IsSectionDefined("InqSummary"))
    {
      <section class="inq-section inq-summary">
        @RenderSection("InqSummary", required: false)
      </section>
    }

    <section class="inq-body">
      @RenderBody()
    </section>
  </main>
</div>

<script>
  (function () {
    const isTypingElement = (el) => {
      if (!el) return false;
      const tag = (el.tagName || "").toUpperCase();
      if (tag === "TEXTAREA" || tag === "SELECT") return true;
      if (tag === "INPUT") {
        const type = (el.type || "text").toLowerCase();
        return type !== "checkbox" && type !== "radio" && type !== "button";
      }
      return !!el.isContentEditable;
    };

    const bindCellNavigation = (table) => {
      if (!(table instanceof HTMLTableElement)) return;
      if (table.dataset.inqCellNav === "0") return;

      const tbody = table.tBodies && table.tBodies.length ? table.tBodies[0] : null;
      if (!tbody) return;

      let activeCell = null;

      const isDataRow = (tr) =>
        !!tr && !tr.classList.contains("vs-spacer") && !tr.querySelector("td[colspan]");

      const getDataRows = () =>
        Array.from(tbody.querySelectorAll("tr")).filter(isDataRow);

      const getVisibleCells = (tr) =>
        Array.from(tr.querySelectorAll("td"))
          .filter(td => td.colSpan <= 1 && td.offsetParent !== null && getComputedStyle(td).display !== "none");

      const clearActiveCell = () => {
        if (activeCell && activeCell.classList) activeCell.classList.remove("inq-active-cell");
        activeCell = null;
      };

      const setActiveCell = (td, focus) => {
        if (!td || td.tagName !== "TD" || td.colSpan > 1) {
          clearActiveCell();
          return;
        }
        if (activeCell && activeCell !== td) activeCell.classList.remove("inq-active-cell");
        activeCell = td;
        activeCell.classList.add("inq-active-cell");
        if (!activeCell.hasAttribute("tabindex")) activeCell.tabIndex = -1;
        if (focus) {
          try { activeCell.focus({ preventScroll: true }); } catch { activeCell.focus(); }
        }
        try { activeCell.scrollIntoView({ block: "nearest", inline: "nearest" }); } catch { }
      };

      const resolveArrowTarget = (fromTd, key) => {
        const fromTr = fromTd.closest("tr");
        if (!isDataRow(fromTr)) return null;
        const rows = getDataRows();
        const rowIdx = rows.indexOf(fromTr);
        if (rowIdx < 0) return null;

        const rowCells = getVisibleCells(fromTr);
        const cellIdx = rowCells.indexOf(fromTd);
        if (cellIdx < 0) return null;

        if (key === "ArrowLeft" || key === "ArrowRight") {
          const nextIdx = cellIdx + (key === "ArrowLeft" ? -1 : 1);
          if (nextIdx < 0 || nextIdx >= rowCells.length) return null;
          return rowCells[nextIdx];
        }

        const nextRowIdx = rowIdx + (key === "ArrowUp" ? -1 : 1);
        if (nextRowIdx < 0 || nextRowIdx >= rows.length) return null;
        const targetCells = getVisibleCells(rows[nextRowIdx]);
        if (!targetCells.length) return null;
        return targetCells[Math.min(cellIdx, targetCells.length - 1)];
      };

      tbody.addEventListener("click", (ev) => {
        const td = ev.target?.closest?.("td");
        if (!td || !tbody.contains(td) || td.colSpan > 1) return;
        if (!isDataRow(td.closest("tr"))) return;
        setActiveCell(td, false);
      });

      table.addEventListener("focusin", (ev) => {
        const td = ev.target?.closest?.("td");
        if (!td || !tbody.contains(td) || td.colSpan > 1) return;
        if (!isDataRow(td.closest("tr"))) return;
        setActiveCell(td, false);
      });

      table.addEventListener("keydown", (ev) => {
        if (!["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(ev.key)) return;
        if (isTypingElement(ev.target)) return;

        let source = activeCell;
        if (!source || !source.isConnected) {
          const selected = tbody.querySelector("tr.table-active");
          source = selected ? getVisibleCells(selected)[0] : null;
        }
        if (!source) return;

        const target = resolveArrowTarget(source, ev.key);
        if (!target) return;
        ev.preventDefault();
        setActiveCell(target, true);
        target.dispatchEvent(new MouseEvent("click", { bubbles: true }));
      });

      new MutationObserver(() => {
        if (activeCell && !activeCell.isConnected) activeCell = null;
      }).observe(tbody, { childList: true, subtree: true });
    };

    const alignQueryRows = () => {
      document.querySelectorAll(".inq-query .inq-form.inq-form--auto-grid-enabled").forEach((form) => {
        if (!(form instanceof HTMLElement)) return;
        form.classList.remove("inq-form--auto-grid-active");
        form.style.removeProperty("--inq-auto-cols");
        const rows = Array.from(form.querySelectorAll(":scope > .inq-row"));
        if (!rows.length) return;
        if (rows.length <= 1) return;

        const labelWidths = [];
        const fieldWidths = [];
        let maxPairs = 0;

        rows.forEach((row) => {
          const cells = Array.from(row.children).filter((el) => el instanceof HTMLElement);
          let pairIndex = 0;
          for (let i = 0; i < cells.length; i++) {
            const label = cells[i];
            if (!(label instanceof HTMLElement) || !label.classList.contains("inq-label")) continue;
            const field = cells[i + 1];
            if (!(field instanceof HTMLElement)) break;

            const lw = Math.ceil(label.getBoundingClientRect().width);
            const check = field.classList.contains("compact-check");
            const fw = check
              ? 20
              : Math.ceil(field.getBoundingClientRect().width);

            labelWidths[pairIndex] = Math.max(labelWidths[pairIndex] || 0, lw);
            fieldWidths[pairIndex] = Math.max(fieldWidths[pairIndex] || 0, fw);
            pairIndex += 1;
            i += 1;
          }
          maxPairs = Math.max(maxPairs, pairIndex);
        });

        if (!maxPairs) return;

        const cols = [];
        for (let i = 0; i < maxPairs; i++) {
          cols.push(`${Math.max(52, labelWidths[i] || 52)}px`);
          cols.push(`${Math.max(20, fieldWidths[i] || 20)}px`);
        }
        form.classList.add("inq-form--auto-grid-active");
        form.style.setProperty("--inq-auto-cols", cols.join(" "));
      });
    };

    const queueAlign = () => window.requestAnimationFrame(alignQueryRows);

    document.querySelectorAll(".inq-table").forEach(bindCellNavigation);
    queueAlign();
    window.addEventListener("resize", queueAlign);
  })();
</script>

