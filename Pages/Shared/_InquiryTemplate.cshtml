    text-align: center;
  }
  .inq-rail .fab:hover,
  .inq-rail-btn:hover {
    background: #e9f1ff;
    border-color: #9fbaf0;
  }
  .inq-rail-btn {
    padding: 4px 6px;
    font-size: 0.82rem;
    border-radius: 8px;
  }
  .inq-rail-status {
