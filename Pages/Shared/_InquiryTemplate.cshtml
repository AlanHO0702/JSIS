</style>

<!-- Loading 遮罩 -->
<div class="inq-loading-overlay" id="inqLoadingOverlay">
  <div class="inq-loading-spinner"></div>
  <div class="inq-loading-text">查詢中，請稍候...</div>
  <div class="inq-loading-elapsed" id="inqLoadingElapsed"></div>
  <div class="inq-loading-cancel" id="inqLoadingCancel">
    <button type="button" id="btnCancelQuery">取消查詢</button>
  </div>
</div>

<div class="inq-shell" style="--inq-rail-width:@railWidth;">
  @if (showRail)
  {
    <aside class="inq-rail">
      @if (!string.IsNullOrWhiteSpace(railTitle))
      {
        <div class="inq-rail-title">@railTitle</div>
      }
      @if (hasRailSection)
      {
        @RenderSection("InqRail", required: false)
      }
      @if (hasActionRail)
      {
        @await Html.PartialAsync(actionPartial!, (object)Model)
      }
    </aside>
  }

  <main class="inq-main">
    @if (showHeader)
    {
      if (IsSectionDefined("InqHeader"))
      {
        @RenderSection("InqHeader", required: false)
      }
      else
      {
        <div class="inq-header">
          @if (!string.IsNullOrWhiteSpace(title))
          {
            <div class="inq-title">@title</div>
          }
          <div id="singleGridCountBox" class="inq-count-box mode-view">
            <div id="singleGridMode" class="count-line">瀏覽模式</div>
            <div id="singleGridCount" class="count-line">0 / 0</div>
          </div>
          <div class="inq-toolbar">
            @RenderSection("InqHeaderActions", required: false)
          </div>
        </div>
      }
    }

    @if (IsSectionDefined("InqQuery"))
    {
      <section class="inq-section inq-query">
        @RenderSection("InqQuery", required: false)
      </section>
    }

    @if (IsSectionDefined("InqSummary"))
    {
      <section class="inq-section inq-summary">
        @RenderSection("InqSummary", required: false)
      </section>
    }

    <section class="inq-body">
      @RenderBody()
    </section>
  </main>
</div>

@{
    // 取得 GridDictFields 中的 bFooter / FormatStr，輸出給前端合計列使用
    var footerDict = new Dictionary<string, object>();
    try
    {
        var gridFields = (IEnumerable<dynamic>)Model.GridDictFields;
        if (gridFields != null)
        {
            foreach (var f in gridFields)
            {
                string fn = f.FieldName?.ToString() ?? "";
                if (string.IsNullOrWhiteSpace(fn)) continue;
                int footer = 0;
                try { footer = (int)(f.bFooter ?? 0); } catch { }
                if (footer == 1)
                {
                    footerDict[fn] = new { footer = 1, format = f.FormatStr?.ToString() ?? "" };
                }
            }
        }
    }
    catch { }
}

@await Html.PartialAsync("~/Pages/Shared/_FieldDictModal.cshtml", new List<CURdTableField>(), ViewData)
<script src="~/js/fieldDictModal.js" asp-append-version="true"></script>

@RenderSection("InqPageData", required: false)

<script>
  (function () {
    /* ========== 既有模板功能（所有使用此模板的頁面皆適用） ========== */

    const _inqFooterDict = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(footerDict));
    const shell = document.querySelector('.inq-shell');
    if (shell) {
      const setShellHeight = () => {
        const top = shell.getBoundingClientRect().top;
        shell.style.setProperty('--inq-shell-top', top + 'px');
        shell.style.height = 'calc(100vh - ' + top + 'px)';
      };
      setShellHeight();
      window.addEventListener('resize', setShellHeight);
    }

    const isTypingElement = (el) => {
      if (!el) return false;
      const tag = (el.tagName || "").toUpperCase();
      if (tag === "TEXTAREA" || tag === "SELECT") return true;
      if (tag === "INPUT") {
        const type = (el.type || "text").toLowerCase();
        return type !== "checkbox" && type !== "radio" && type !== "button";
      }
      return !!el.isContentEditable;
    };

    const bindCellNavigation = (table) => {
      if (!(table instanceof HTMLTableElement)) return;
      if (table.dataset.inqCellNav === "0") return;

      const tbody = table.tBodies && table.tBodies.length ? table.tBodies[0] : null;
      if (!tbody) return;

      let activeCell = null;

      const isDataRow = (tr) =>
        !!tr && !tr.classList.contains("vs-spacer") && !tr.querySelector("td[colspan]");

      const getDataRows = () =>
        Array.from(tbody.querySelectorAll("tr")).filter(isDataRow);

      const getVisibleCells = (tr) =>
        Array.from(tr.querySelectorAll("td"))
          .filter(td => td.colSpan <= 1 && td.offsetParent !== null && getComputedStyle(td).display !== "none");

      const clearActiveCell = () => {
        if (activeCell && activeCell.classList) activeCell.classList.remove("inq-active-cell");
        activeCell = null;
      };

      const setActiveCell = (td, focus) => {
        if (!td || td.tagName !== "TD" || td.colSpan > 1) {
          clearActiveCell();
          return;
        }
        if (activeCell && activeCell !== td) activeCell.classList.remove("inq-active-cell");
        activeCell = td;
        activeCell.classList.add("inq-active-cell");
        if (!activeCell.hasAttribute("tabindex")) activeCell.tabIndex = -1;
        if (focus) {
          try { activeCell.focus({ preventScroll: true }); } catch { activeCell.focus(); }
        }
        try { activeCell.scrollIntoView({ block: "nearest", inline: "nearest" }); } catch { }
      };

      const resolveArrowTarget = (fromTd, key) => {
        const fromTr = fromTd.closest("tr");
        if (!isDataRow(fromTr)) return null;
        const rows = getDataRows();
        const rowIdx = rows.indexOf(fromTr);
        if (rowIdx < 0) return null;

        const rowCells = getVisibleCells(fromTr);
        const cellIdx = rowCells.indexOf(fromTd);
        if (cellIdx < 0) return null;

        if (key === "ArrowLeft" || key === "ArrowRight") {
          const nextIdx = cellIdx + (key === "ArrowLeft" ? -1 : 1);
          if (nextIdx < 0 || nextIdx >= rowCells.length) return null;
          return rowCells[nextIdx];
        }

        const nextRowIdx = rowIdx + (key === "ArrowUp" ? -1 : 1);
        if (nextRowIdx < 0 || nextRowIdx >= rows.length) return null;
        const targetCells = getVisibleCells(rows[nextRowIdx]);
        if (!targetCells.length) return null;
        return targetCells[Math.min(cellIdx, targetCells.length - 1)];
      };

      tbody.addEventListener("click", (ev) => {
        const td = ev.target?.closest?.("td");
        if (!td || !tbody.contains(td) || td.colSpan > 1) return;
        if (!isDataRow(td.closest("tr"))) return;
        setActiveCell(td, false);
      });

      table.addEventListener("focusin", (ev) => {
        const td = ev.target?.closest?.("td");
        if (!td || !tbody.contains(td) || td.colSpan > 1) return;
        if (!isDataRow(td.closest("tr"))) return;
        setActiveCell(td, false);
      });

      table.addEventListener("keydown", (ev) => {
        if (!["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(ev.key)) return;
        if (isTypingElement(ev.target)) return;

        let source = activeCell;
        if (!source || !source.isConnected) {
          const selected = tbody.querySelector("tr.table-active");
          source = selected ? getVisibleCells(selected)[0] : null;
        }
        if (!source) return;

        const target = resolveArrowTarget(source, ev.key);
        if (!target) return;
        ev.preventDefault();
        setActiveCell(target, true);
        target.dispatchEvent(new MouseEvent("click", { bubbles: true }));
      });

      new MutationObserver(() => {
        if (activeCell && !activeCell.isConnected) activeCell = null;
      }).observe(tbody, { childList: true, subtree: true });
    };

    const alignQueryRows = () => {
      document.querySelectorAll(".inq-query .inq-form.inq-form--auto-grid-enabled").forEach((form) => {
        if (!(form instanceof HTMLElement)) return;
        form.classList.remove("inq-form--auto-grid-active");
        form.style.removeProperty("--inq-auto-cols");
        const rows = Array.from(form.querySelectorAll(":scope > .inq-row"));
        if (!rows.length) return;
        if (rows.length <= 1) return;

        const labelWidths = [];
        const fieldWidths = [];
        let maxPairs = 0;

        rows.forEach((row) => {
          const cells = Array.from(row.children).filter((el) => el instanceof HTMLElement);
          let pairIndex = 0;
          for (let i = 0; i < cells.length; i++) {
            const label = cells[i];
            if (!(label instanceof HTMLElement) || !label.classList.contains("inq-label")) continue;
            const field = cells[i + 1];
            if (!(field instanceof HTMLElement)) break;

            const lw = Math.ceil(label.getBoundingClientRect().width);
            const check = field.classList.contains("compact-check");
            const fw = check
              ? 20
              : Math.ceil(field.getBoundingClientRect().width);

            labelWidths[pairIndex] = Math.max(labelWidths[pairIndex] || 0, lw);
            fieldWidths[pairIndex] = Math.max(fieldWidths[pairIndex] || 0, fw);
            pairIndex += 1;
            i += 1;
          }
          maxPairs = Math.max(maxPairs, pairIndex);
        });

        if (!maxPairs) return;

        const cols = [];
        for (let i = 0; i < maxPairs; i++) {
          cols.push(`${Math.max(52, labelWidths[i] || 52)}px`);
          cols.push(`${Math.max(20, fieldWidths[i] || 20)}px`);
        }
        form.classList.add("inq-form--auto-grid-active");
        form.style.setProperty("--inq-auto-cols", cols.join(" "));
      });
    };

    const queueAlign = () => window.requestAnimationFrame(alignQueryRows);

    document.querySelectorAll(".inq-table").forEach(bindCellNavigation);
    queueAlign();
    window.addEventListener("resize", queueAlign);

    // --- 合計列 (bFooter) ---
    const buildInqFooter = (table) => {
      if (!(table instanceof HTMLTableElement)) return;
      if (!Object.keys(_inqFooterDict).length) return;

      const old = table.querySelector('tfoot.inq-footer');
      if (old) old.remove();

      const ths = Array.from(table.querySelectorAll('thead th'));
      const footerCols = ths.map(th => {
        const field = (th.dataset.field || '').trim();
        return _inqFooterDict[field] || null;
      });
      if (!footerCols.some(c => c)) return;

      const tbody = table.tBodies[0];
      if (!tbody) return;
      const dataRows = Array.from(tbody.querySelectorAll('tr'))
        .filter(r => !r.querySelector('td[colspan]'));
      if (!dataRows.length) return;

      const tfoot = document.createElement('tfoot');
      tfoot.className = 'inq-footer';
      const tr = document.createElement('tr');

      ths.forEach((th, idx) => {
        const td = document.createElement('td');
        const col = footerCols[idx];
        if (col) {
          let sum = 0;
          dataRows.forEach(row => {
            const cell = row.children[idx];
            if (!cell) return;
            const num = parseFloat((cell.textContent || '').replace(/,/g, ''));
            if (Number.isFinite(num)) sum += num;
          });
          const fmt = col.format || '';
          if (fmt.includes('.000')) td.textContent = sum.toFixed(3).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          else if (fmt.includes('.00')) td.textContent = sum.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          else td.textContent = Math.round(sum).toLocaleString();
          td.style.textAlign = 'right';
          td.style.fontWeight = '600';
          td.style.background = '#f0f4ff';
        }
        tr.appendChild(td);
      });

      tfoot.appendChild(tr);
      table.appendChild(tfoot);
    };

    document.querySelectorAll('.inq-body .inq-table').forEach(buildInqFooter);

    /* ========== 共用查詢頁功能（所有使用此模板的頁面皆適用） ========== */

    const cfg = window._inqPageData || {};
    const totalCount = cfg.totalCount || 0;
    const dictTableName = cfg.dictTableName || "";
    const paramTableName = cfg.paramTableName || "";
    const currentUserId = cfg.currentUserId || "";
    const currentUseId = cfg.currentUseId || "";
    const itemId = (cfg.itemId || "").trim();

    const fieldNames = Array.from(document.querySelectorAll('.inq-table thead th[data-field]'))
      .map(th => th.dataset.field || '');

    // --- Loading 遮罩控制 ---
    const overlay = document.getElementById("inqLoadingOverlay");
    const elapsedEl = document.getElementById("inqLoadingElapsed");
    const cancelWrap = document.getElementById("inqLoadingCancel");
    let loadingTimer = null;
    let loadingStart = 0;
    let isLoading = false;

    const showLoading = () => {
      if (!overlay) return;
      isLoading = true;
      loadingStart = Date.now();
      overlay.classList.add("active");
      if (elapsedEl) elapsedEl.style.display = "none";
      if (cancelWrap) cancelWrap.style.display = "none";
      loadingTimer = setInterval(() => {
        const sec = Math.round((Date.now() - loadingStart) / 1000);
        if (elapsedEl) {
          elapsedEl.textContent = "\u5DF2\u7B49\u5F85 " + sec + " \u79D2...";
          elapsedEl.style.display = "block";
        }
        if (sec >= 10 && cancelWrap) cancelWrap.style.display = "block";
      }, 1000);
    };

    const hideLoading = () => {
      isLoading = false;
      if (loadingTimer) { clearInterval(loadingTimer); loadingTimer = null; }
      if (overlay) overlay.classList.remove("active");
    };

    document.getElementById("btnCancelQuery")?.addEventListener("click", () => {
      window.stop();
      hideLoading();
    });

    // 處理瀏覽器返回 (bfcache) 時的遮罩殘留
    window.addEventListener("pageshow", (e) => { if (e.persisted) hideLoading(); });

    // --- 列選取 & 位置追蹤 ---
    const totalEl = document.getElementById("inqTotalCount");
    const posEl = document.getElementById("inqCurrentPos");
    if (totalEl) totalEl.textContent = String(totalCount);

    const dataRows = Array.from(document.querySelectorAll(".inq-table tbody tr"));
    let selectedRow = null;

    const setPos = (idx) => {
      if (!posEl) return;
      posEl.textContent = totalCount === 0 ? "0" : String(idx);
    };

    if (dataRows.length > 0 && totalCount > 0) {
      setPos(1);
      selectedRow = dataRows[0];
      dataRows[0].classList.add("table-active");
    }

    dataRows.forEach((tr, i) => {
      tr.addEventListener("click", () => {
        dataRows.forEach(r => r.classList.remove("table-active"));
        tr.classList.add("table-active");
        selectedRow = tr;
        setPos(i + 1);
      });
    });

    // 對外公開，供頁面專屬腳本使用（例如 AJN 的「來源追蹤」）
    window._inq = {
      get selectedRow() { return selectedRow; },
      currentUserId,
      currentUseId,
      showLoading,
      hideLoading
    };

    // --- 清除 ---
    document.getElementById("btnClearInq")?.addEventListener("click", () => {
      window.location.href = window.location.pathname;
    });

    // --- 排序 ---
    const parseSortValue = (text) => {
      if (text == null) return "";
      const t = String(text).trim();
      if (!t) return "";
      const d = t.match(/^(\d{4})[\/-](\d{2})[\/-](\d{2})$/);
      if (d) return new Date(d[1] + "-" + d[2] + "-" + d[3]).getTime();
      const n = t.replace(/,/g, "");
      if (!isNaN(n) && n !== "") return parseFloat(n);
      return t.toLowerCase();
    };

    const sortTableByColumn = (tbl, colIndex, asc) => {
      const tbody = tbl.querySelector("tbody");
      if (!tbody) return;
      const rows = Array.from(tbody.querySelectorAll("tr"))
        .filter(r => !r.querySelector("td[colspan]"));
      const dir = asc ? 1 : -1;
      rows.sort((a, b) => {
        const aText = a.children[colIndex]?.textContent ?? "";
        const bText = b.children[colIndex]?.textContent ?? "";
        const av = parseSortValue(aText);
        const bv = parseSortValue(bText);
        if (av < bv) return -1 * dir;
        if (av > bv) return 1 * dir;
        return 0;
      });
      rows.forEach(r => tbody.appendChild(r));
    };

    const table = document.querySelector(".inq-table");
    if (table) {
      const headers = Array.from(table.querySelectorAll("thead th"));
      headers.forEach((th, idx) => {
        th.addEventListener("click", (e) => {
          if (e.target && e.target.classList?.contains("col-resizer")) return;
          if (th.dataset.resizing === "1") return;
          const isAsc = !th.classList.contains("inq-sort-asc");
          headers.forEach(h => h.classList.remove("inq-sort-asc", "inq-sort-desc"));
          th.classList.add(isAsc ? "inq-sort-asc" : "inq-sort-desc");
          sortTableByColumn(table, idx, isAsc);
        });
      });
    }

    // --- 欄寬調整 & 持久化 ---
    function applyColumnWidth(tbl, ths, index, width) {
      const w = Math.max(20, Math.round(width));
      const th = ths[index];
      if (!th) return;
      th.style.width = w + "px";
      th.style.minWidth = w + "px";
      Array.from(tbl.querySelectorAll("tbody tr td:nth-child(" + (index + 1) + ")"))
        .forEach(td => {
          td.style.width = w + "px";
          td.style.minWidth = w + "px";
        });
    }

    function applySavedWidths(tbl, dictTable, fields) {
      const tn = (dictTable || "").trim();
      if (!tn) return;
      try {
        const raw = localStorage.getItem("colwidth:" + tn);
        if (!raw) return;
        const cols = JSON.parse(raw) || [];
        const ths = Array.from(tbl.querySelectorAll('thead th'));
        cols.forEach(c => {
          const f = (c.fieldName || '').toString();
          const w = Number(c.width);
          if (!f || !Number.isFinite(w)) return;
          const idx = fields.findIndex(x => x.toLowerCase() === f.toLowerCase());
          if (idx >= 0) applyColumnWidth(tbl, ths, idx, w);
        });
      } catch { }
    }

    function initColumnResize(tableEl, dictTable, fields) {
      if (!tableEl) return;
      const ths = Array.from(tableEl.querySelectorAll('thead th'));
      applySavedWidths(tableEl, dictTable, fields);

      let isResizing = false;
      let startX = 0;
      let startWidth = 0;
      let thIndex = -1;

      ths.forEach((th, idx) => {
        const handle = th.querySelector('.col-resizer');
        if (!handle) return;
        handle.addEventListener('mousedown', (e) => {
          e.preventDefault();
          isResizing = true;
          startX = e.pageX;
          startWidth = th.getBoundingClientRect().width;
          thIndex = idx;
          document.body.classList.add('resizing');
        });
      });

      document.addEventListener('mousemove', (e) => {
        if (!isResizing || thIndex < 0) return;
        const dx = e.pageX - startX;
        const newW = Math.max(20, startWidth + dx);
        applyColumnWidth(tableEl, ths, thIndex, newW);
      });

      document.addEventListener('mouseup', () => {
        if (!isResizing) return;
        isResizing = false;
        document.body.classList.remove('resizing');
        const tn = (dictTable || "").trim();
        if (tn) {
          const payload = ths.map(th => ({ fieldName: th.dataset.field, width: Math.round(th.getBoundingClientRect().width) }));
          try {
            localStorage.setItem("colwidth:" + tn, JSON.stringify(payload));
          } catch { }
        }
        thIndex = -1;
      });
    }

    initColumnResize(table, dictTableName, fieldNames);

    // --- 表單送出（含 Loading 遮罩 & 防重複送出） ---
    const inqForm = document.getElementById("inqForm");
    inqForm?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (isLoading) return;
      const fd = new FormData(inqForm);
      const params = new URLSearchParams();
      for (const [k, v] of fd.entries()) {
        const val = (v ?? "").toString().trim();
        if (!val) continue;
        params.append(k, val);
      }
      if (new URLSearchParams(window.location.search).has("debug")) {
        params.set("debug", "1");
      }
      const qs = params.toString();
      showLoading();
      window.location.href = qs
        ? (window.location.pathname + "?" + qs)
        : window.location.pathname;
    });

    // --- 匯出 Excel ---
    document.getElementById("btnExportExcel")?.addEventListener("click", () => {
      const url = new URL(window.location.href);
      url.searchParams.set("handler", "Export");
      window.location.href = url.toString();
    });

    // --- 單據 / 傳票追蹤 ---
    document.getElementById("btnPaperTrace")?.addEventListener("click", async () => {
      if (!selectedRow) return alert("\u8ACB\u5148\u9078\u64C7\u4E00\u7B46\u8CC7\u6599");
      const pid = selectedRow.getAttribute("data-paper-id");
      const pnum = selectedRow.getAttribute("data-paper-num");
      if (!pid || !pnum) return alert("\u627E\u4E0D\u5230\u55AE\u64DA\u8CC7\u8A0A");
      try {
        const res = await fetch("/api/Flow/ResolveItemIdByFromType", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ paperId: pid, paperNum: pnum, userId: currentUserId, useId: currentUseId })
        });
        if (res.ok) {
          const data = await res.json();
          const resolvedId = data.itemId || pid;
          window.open("/DynamicTemplate/Paper/" + encodeURIComponent(resolvedId) + "/" + encodeURIComponent(pnum), "_blank");
          return;
        }
      } catch {}
      window.open("/DynamicTemplate/Paper/" + encodeURIComponent(pid) + "/" + encodeURIComponent(pnum), "_blank");
    });

    // --- 儲存高度設定 ---
    document.getElementById("btnSaveHeight")?.addEventListener("click", async () => {
      const h = document.querySelector(".inq-body")?.clientHeight || 0;
      const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
      const res = await fetch("/api/MatInfoUtility/SaveBrowseHeight", {
        method: "POST",
        headers: { "Content-Type": "application/json", "RequestVerificationToken": token },
        body: JSON.stringify({ itemId: itemId, height: h })
      });
      if (!res.ok) return alert("\u5132\u5B58\u5931\u6557");
      alert("\u5DF2\u5132\u5B58\u9AD8\u5EA6\u8A2D\u5B9A");
    });

    // --- 重設參數 ---
    document.getElementById("btnResetParams")?.addEventListener("click", async () => {
      const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
      const res = await fetch("?handler=ResetParams", {
        method: "POST",
        headers: { "RequestVerificationToken": token }
      });
      if (!res.ok) return alert("\u91CD\u8A2D\u5931\u6557");
      alert("\u5DF2\u91CD\u8A2D\u53C3\u6578");
      window.location.reload();
    });

    // --- Lookup 查詢系統 ---
    const resolveCondValue = (name) => {
      if (!name) return "";
      const el = document.querySelector('[name="' + name + '"]');
      if (!el) return "";
      if (el.type === "checkbox") return el.checked ? "1" : "0";
      return el.value || "";
    };

    const parseItems = (raw) => {
      if (!raw) return [];
      return raw.split(/[;,]/).map(p => p.trim()).filter(Boolean).map(p => {
        const kv = p.split(/=|:/);
        if (kv.length >= 2) return { value: kv[0].trim(), label: kv.slice(1).join(":").trim() };
        return { value: p, label: p };
      });
    };

    const buildCondKey = (el) => {
      const tbl = el.dataset.lookupTable || "";
      const key = el.dataset.lookupKey || "";
      const result = el.dataset.lookupResult || "";
      const cond1Field = (el.dataset.cond1Field || "").trim();
      const cond1Source = (el.dataset.cond1Source || "").trim();
      const cond2Field = (el.dataset.cond2Field || "").trim();
      const cond2Source = (el.dataset.cond2Source || "").trim();
      const cond1ValueField = cond1Source || cond1Field;
      const cond2ValueField = cond2Source || cond2Field;
      const cond1Value = cond1ValueField ? resolveCondValue(cond1ValueField) : "";
      const cond2Value = cond2ValueField ? resolveCondValue(cond2ValueField) : "";
      const items = el.dataset.items || "";
      return [tbl, key, result, cond1Field, cond1Value, cond2Field, cond2Value, items].join("|");
    };

    const fetchLookupOptions = async (el) => {
      const items = parseItems(el.dataset.items || "");
      const tbl = el.dataset.lookupTable || "";
      const key = el.dataset.lookupKey || "";
      const result = el.dataset.lookupResult || "";
      const selected = el.dataset.selected || "";

      let options = [...items];

      if (tbl && key && result) {
        const cond1Field = (el.dataset.cond1Field || "").trim();
        const cond1Source = (el.dataset.cond1Source || "").trim();
        const cond2Field = (el.dataset.cond2Field || "").trim();
        const cond2Source = (el.dataset.cond2Source || "").trim();
        const cond1ValueField = cond1Source || cond1Field;
        const cond2ValueField = cond2Source || cond2Field;
        const cond1Value = cond1ValueField ? resolveCondValue(cond1ValueField) : "";
        const cond2Value = cond2ValueField ? resolveCondValue(cond2ValueField) : "";

        const url = "/api/TableFieldLayout/LookupData?table=" + encodeURIComponent(tbl) + "&key=" + encodeURIComponent(key) + "&result=" + encodeURIComponent(result)
          + (cond1Field && cond1Value ? "&cond1Field=" + encodeURIComponent(cond1Field) + "&cond1Value=" + encodeURIComponent(cond1Value) : "")
          + (cond2Field && cond2Value ? "&cond2Field=" + encodeURIComponent(cond2Field) + "&cond2Value=" + encodeURIComponent(cond2Value) : "");
        const res = await fetch(url);
        if (res.ok) {
          const data = await res.json();
          if (Array.isArray(data)) {
            const lookups = data.map(row => {
              const val = row?.key ?? "";
              const label = Object.keys(row || {}).filter(k => k.startsWith("result")).map(k => row[k]).join(" - ");
              return { value: String(val), label: label || String(val) };
            });
            options = options.concat(lookups);
          }
        }
      }

      const map = new Map();
      options.forEach(o => {
        if (!o.value) return;
        if (!map.has(o.value)) map.set(o.value, o);
      });

      if (selected && !map.has(selected)) map.set(selected, { value: selected, label: selected });

      return Array.from(map.values());
    };

    const getCodeInput = (el) => {
      const id = el?.dataset?.codeTarget;
      if (id) return document.getElementById(id);
      return el?.closest(".inq-select")?.querySelector(".inq-select-code-hidden");
    };

    const syncDisplayValue = (displayEl, options) => {
      if (!displayEl) return;
      const codeInput = getCodeInput(displayEl);
      const codeVal = (codeInput?.value || "").toString().trim();
      if (!codeVal) {
        displayEl.value = "";
        return;
      }
      const hit = (options || []).find(o => String(o.value).trim() === codeVal);
      displayEl.value = hit ? (hit.label || hit.value) : codeVal;
    };

    // --- 建議下拉元件 ---
    const suggest = document.createElement("div");
    suggest.className = "inq-suggest";
    suggest.style.display = "none";
    document.body.appendChild(suggest);
    let suggestTarget = null;
    let suggestOptions = [];
    let keepSuggestUntil = 0;

    const positionSuggest = (el) => {
      const rect = el.getBoundingClientRect();
      suggest.style.left = (rect.left + window.scrollX) + "px";
      suggest.style.top = (rect.bottom + window.scrollY) + "px";
      const width = Math.max(rect.width, 280);
      suggest.style.width = width + "px";
    };

    const hideSuggest = () => {
      if (Date.now() < keepSuggestUntil) return;
      suggest.style.display = "none";
      suggest.innerHTML = "";
      suggestTarget = null;
      suggestOptions = [];
    };

    const renderSuggest = (el, list) => {
      const q = (el.value || "").trim().toLowerCase();
      const filtered = q
        ? list.filter(o => (o.value || "").toLowerCase().includes(q) || (o.label || "").toLowerCase().includes(q))
        : list;

      suggest.innerHTML = "";
      if (filtered.length === 0) {
        hideSuggest();
        return;
      }

      filtered.slice(0, 200).forEach(o => {
        const itm = document.createElement("div");
        itm.className = "inq-suggest-item";
        itm.innerHTML = '<div class="inq-suggest-code">' + o.value + '</div><div class="inq-suggest-label">' + o.label + '</div>';
        itm.addEventListener("mousedown", (ev) => {
          ev.preventDefault();
          const codeInput = getCodeInput(el);
          if (codeInput) codeInput.value = o.value;
          el.value = o.label || o.value;
          hideSuggest();
        });
        suggest.appendChild(itm);
      });

      positionSuggest(el);
      suggest.style.display = "block";
    };

    const lookupCache = new Map();

    const showSuggest = async (el) => {
      const key = buildCondKey(el);
      if (!lookupCache.has(key)) {
        const opts = await fetchLookupOptions(el);
        lookupCache.set(key, opts);
      }
      suggestTarget = el;
      suggestOptions = lookupCache.get(key) || [];
      syncDisplayValue(el, suggestOptions);
      renderSuggest(el, suggestOptions);
    };

    document.querySelectorAll(".inq-select-btn").forEach(btn => {
      btn.addEventListener("mousedown", (ev) => {
        ev.preventDefault();
        keepSuggestUntil = Date.now() + 250;
        const input = btn.previousElementSibling;
        if (input) {
          input.focus();
          showSuggest(input);
        }
      });
    });

    document.addEventListener("click", (ev) => {
      if (!suggestTarget) return;
      if (ev.target === suggestTarget || suggest.contains(ev.target)) return;
      hideSuggest();
    });

    document.querySelectorAll(".inq-lookup-display[data-lookup-table], .inq-lookup-display[data-items]").forEach(el => {
      el.addEventListener("focus", () => showSuggest(el));
      el.addEventListener("input", () => {
        if (suggestTarget !== el) return showSuggest(el);
        renderSuggest(el, suggestOptions);
      });
      el.addEventListener("blur", () => {
        setTimeout(() => {
          if (!suggest.matches(":hover")) hideSuggest();
        }, 120);
        const codeInput = getCodeInput(el);
        if (!codeInput) return;
        const text = (el.value || "").trim();
        const key = buildCondKey(el);
        const opts = lookupCache.get(key) || [];
        if (!text) {
          codeInput.value = "";
          return;
        }
        const hit = opts.find(o => {
          const v = String(o.value ?? "").trim();
          const l = String(o.label ?? "").trim();
          return v === text || l === text;
        });
        if (hit) {
          codeInput.value = hit.value;
          el.value = hit.label || hit.value;
        } else {
          syncDisplayValue(el, opts);
        }
      });
    });

    // 頁面載入時還原 lookup 顯示值
    (async () => {
      const inputs = Array.from(document.querySelectorAll(".inq-lookup-display"));
      for (const el of inputs) {
        if (!(el instanceof HTMLInputElement)) continue;
        const key = buildCondKey(el);
        if (!lookupCache.has(key)) {
          const opts = await fetchLookupOptions(el);
          lookupCache.set(key, opts);
        }
        const opts = lookupCache.get(key) || [];
        syncDisplayValue(el, opts);
      }
    })();

    suggest.addEventListener("mousedown", () => {
      keepSuggestUntil = Date.now() + 250;
    });

    // --- 辭典編輯 ---
    (function initDictForInq() {
      const dictForQuery = paramTableName;
      const dictForGrid = dictTableName;
      let currentDict = dictForQuery;

      const setDict = (name) => {
        currentDict = name || currentDict;
        window._dictTableName = currentDict;
      };

      setDict(dictForQuery);

      const queryArea = document.getElementById("inqForm");
      const tbl = document.querySelector(".inq-table");

      queryArea?.addEventListener("focusin", () => setDict(dictForQuery));
      queryArea?.addEventListener("click", () => setDict(dictForQuery));
      tbl?.addEventListener("click", () => setDict(dictForGrid));

      const openFieldDict = () => {
        if (typeof window.initFieldDictModal === "function") {
          window.initFieldDictModal(currentDict, "fieldDictModal");
          const el = document.getElementById("fieldDictModal");
          if (el) {
            const md = bootstrap.Modal.getOrCreateInstance(el);
            md.show();
          }
        } else if (typeof window.loadFieldDict === "function") {
          window.loadFieldDict(currentDict);
        }
      };

      document.getElementById("btnEditDict")?.addEventListener("click", openFieldDict);

      document.addEventListener("keydown", (ev) => {
        if (ev.key !== "F3") return;
        const target = ev.target;
        const inText = target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA");
        if (inText) return;
        ev.preventDefault();
        openFieldDict();
      });
    })();
  })();
</script>
