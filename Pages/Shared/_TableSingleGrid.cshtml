<script>
  document.addEventListener("DOMContentLoaded", async () => {
    const editBtn = document.getElementById("btnEditToggle");
    const saveBtn = document.getElementById("btnSaveTable");
    const delBtn  = document.getElementById("btnDeleteRow");
    const exportBtn = document.getElementById("btnExportExcel");
    const sgFirst = document.getElementById("sgFirst");
    const sgPrev = document.getElementById("sgPrev");
    const sgNext = document.getElementById("sgNext");
    const sgLast = document.getElementById("sgLast");
    const sgAdd = document.getElementById("sgAdd");
    const sgDelete = document.getElementById("sgDelete");
    const sgSave = document.getElementById("sgSave");
    const sgCancel = document.getElementById("sgCancel");
    const wrapper = document.querySelector(".table-wrapper");
    const modeEl = document.getElementById("singleGridMode");
    const countEl = document.getElementById("singleGridCount");
    const countBox = document.getElementById("singleGridCountBox");
  const table   = document.getElementById("mainGrid");
  const ocxLookupMaps = @Html.Raw(JsonSerializer.Serialize(ocxLookupPayload));
  const partDefaultsRaw = @Html.Raw(JsonSerializer.Serialize(partDefaults));
  const partDefaultsMap = (() => {
    const src = partDefaultsRaw || {};
    const out = {};
    for (const [k, v] of Object.entries(src)) {
      const key = String(k || "").trim().toLowerCase();
      if (!key) continue;
      const uom = String(v?.uom ?? v?.Uom ?? "").trim();
      const qntyRaw = v?.qnty ?? v?.Qnty;
      const qnty = (qntyRaw === null || qntyRaw === undefined) ? "" : String(qntyRaw).trim();
      out[key] = { uom, qnty };
    }
    return out;
  })();

  function normalizeEditColor(raw) {
    if (!raw) return '';
    let s = String(raw).trim();
    if (s.toLowerCase().startsWith('cl')) s = s.substring(2);
    return s;
  }

  function syncCheckboxVisible(td, val) {
    const v = String(val ?? '');
    const checked = v === '1' || v.toLowerCase() === 'true';
    const chkView = td.querySelector('.sg-chk-view');
    const chkEdit = td.querySelector('.sg-chk-edit');
    if (chkView) chkView.checked = checked;
    if (chkEdit) chkEdit.checked = checked;
  }

  const customButtonsMeta = @Html.Raw(JsonSerializer.Serialize(customButtonMeta ?? new List<object>()));
  const disableEditColor = @disableEditColor.ToString().ToLowerInvariant();
  const disableAutoLoadAllRows = @disableAutoLoadAllRows.ToString().ToLowerInvariant();
  const enableLookupDropdown = @enableLookupDropdown.ToString().ToLowerInvariant();
  const enableDatePicker = @enableDatePicker.ToString().ToLowerInvariant();
  const enableSaveInEditWithoutDirty = @enableSaveInEditWithoutDirty.ToString().ToLowerInvariant();
  const fieldFormatMap = @Html.Raw(JsonSerializer.Serialize(
    dictFields.Select(f => new {
      FieldName = f.FieldName,
      DataType = f.DataType,
      FormatStr = f.FormatStr,
      ComboStyle = f.ComboStyle,
      EditColor = f.EditColor,
      LookupTable = f.LookupTable,
      LookupKeyField = f.LookupKeyField,
      LookupResultField = f.LookupResultField
    })
  ));
    const customButtonBar = null;
    const customButtonBarBottom = document.getElementById("customButtonBarBottom");
    const dictTableName = "@dictTableName";
    // 初始化時將 map key 全部轉小寫，確保後續比對不受大小寫影響
    // （C# Dictionary 用 OrdinalIgnoreCase，JS 物件屬性存取區分大小寫，需補齊）
    let lookupMaps = (() => {
      const src = ocxLookupMaps || {};
      const out = {};
      for (const [field, cfg] of Object.entries(src)) {
        if (cfg && cfg.map) {
          const normalizedMap = {};
          for (const [k, v] of Object.entries(cfg.map)) {
            normalizedMap[String(k).trim().toLowerCase()] = v;
          }
          out[field] = { ...cfg, map: normalizedMap };
        } else {
          out[field] = cfg;
        }
      }
      return out;
    })();
    // 標準 Lookup 對照表快取（LookupTable/LookupKeyField/LookupResultField）
    const _stdLookupCache = {};
    async function loadStandardLookups() {
      const fields = (Array.isArray(fieldFormatMap) ? fieldFormatMap : [])
        .filter(f => f.LookupTable && f.LookupKeyField && f.LookupResultField);
      for (const f of fields) {
        const fkey = (f.FieldName || '').toLowerCase();
        if (lookupMaps[fkey]) continue; // OCX lookup 優先，已存在則跳過
        const cacheKey = `${f.LookupTable}|${f.LookupKeyField}|${f.LookupResultField}`;
        if (!_stdLookupCache[cacheKey]) {
          try {
            const url = `/api/TableFieldLayout/LookupData`
              + `?table=${encodeURIComponent(f.LookupTable)}`
              + `&key=${encodeURIComponent(f.LookupKeyField)}`
              + `&result=${encodeURIComponent(f.LookupResultField)}`;
            const rows = await fetch(url).then(r => r.json()).catch(() => []);
            const map = {};
            (Array.isArray(rows) ? rows : []).forEach(r => {
              const k = String(r.key ?? '').trim().toLowerCase();
              map[k] = (r.result0 ?? '').toString().trim();
            });
            _stdLookupCache[cacheKey] = map;
          } catch { _stdLookupCache[cacheKey] = {}; }
        }
        lookupMaps[fkey] = { map: _stdLookupCache[cacheKey], keySelf: (f.LookupKeyField || '').toLowerCase(), keyField: (f.LookupKeyField || '').toLowerCase() };
      }
