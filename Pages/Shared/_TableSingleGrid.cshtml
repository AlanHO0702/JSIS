    const key = String(lookupKey ?? rawVal ?? "").trim().toLowerCase(); // 去除固定長度字串尾端空白後再比對
    if (key === "") return fallback ?? "";
    if (Object.prototype.hasOwnProperty.call(map, key)) {
      return map[key] ?? fallback ?? key;
