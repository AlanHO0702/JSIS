        if (!span || !inp) return;

        const isCheckbox = inp.type === "checkbox";
        const isReadonly = inp.dataset.readonly === "1";

        if (isEdit) {
          if (isCheckbox) {
            // checkbox: 不切換顯示/隱藏，直接啟用/禁用
