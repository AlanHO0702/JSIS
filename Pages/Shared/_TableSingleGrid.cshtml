    if (!enableLookupDropdown) return;

    const fieldLookupItems = {};
    Object.entries(lookupMaps || {}).forEach(([fieldKey, cfg]) => {
      const map = cfg?.map;
      if (!map || typeof map !== "object") return;
      const entries = Object.entries(map)
        .map(([k, v]) => ({ key: String(k ?? "").trim(), label: String(v ?? "").trim() }))
        .filter(x => x.key !== "");
      if (!entries.length) return;
      const fieldLower = String(fieldKey || "").toLowerCase();
      if (!fieldLookupItems[fieldLower]) {
        fieldLookupItems[fieldLower] = entries;
      }
      const keySelf = String(cfg?.keySelf || "").toLowerCase();
      if (keySelf && !fieldLookupItems[keySelf]) {
        fieldLookupItems[keySelf] = entries;
      }
    });

    table.querySelectorAll(".cell-edit").forEach(inp => {
      if (!(inp instanceof HTMLInputElement)) return;
      const lower = (inp.name || "").toLowerCase();
      const items = fieldLookupItems[lower];
      if (!items) return;
      if (inp.type === "checkbox" || inp.type === "hidden") return;
      if (inp.dataset.readonly === "1") return;
