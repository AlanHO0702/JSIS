  const positionSingleGridLookup = (list, anchor) => {
    if (!list || !anchor) return;
    const rect = anchor.getBoundingClientRect();
    const spaceBelow = window.innerHeight - rect.bottom;
    const maxHeight = Math.max(220, Math.min(420, spaceBelow - 8));
    const placeBelow = spaceBelow >= 140;
    list.style.position = "fixed";
    list.style.left = `${Math.max(6, rect.left)}px`;
    list.style.top = placeBelow ? `${rect.bottom}px` : `${Math.max(6, rect.top - maxHeight)}px`;
    list.style.minWidth = `${Math.max(320, rect.width + 120)}px`;
    list.style.maxHeight = `${maxHeight}px`;
