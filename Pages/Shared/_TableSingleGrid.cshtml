  };

  const applyCheckboxCells = () => {
    let convertCount = 0;
    table.querySelectorAll("tbody tr").forEach(tr => {
      tr.querySelectorAll("td").forEach(td => {
        const fieldName = td.dataset.field;
        if (!fieldName) return;

        // server-side 已渲染為 checkbox 格式（data-checkbox="1"），跳過避免重複
        if (td.dataset.checkbox) return;

        if (!isCheckboxField(fieldName)) return;

        const inp = td.querySelector(".cell-edit");
        if (!inp) return;

        // 如果已經是 checkbox，就跳過
        if (inp.type === "checkbox") return;

        convertCount++;

        // 以下是將 text input 轉換為 checkbox 的邏輯
        const isReadOnly = inp.dataset.readonly === "1";
        const rawValue = inp.value ?? "";
        const checked = rawValue === "1" || rawValue === "true" || rawValue.toLowerCase() === "y";

