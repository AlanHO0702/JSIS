      const key = String(item.dataset.key ?? "");
      input.value = key;
      input.dataset.lookupkey = key;

      const td = input.closest("td[data-field]");
      const span = td?.querySelector(".cell-view");
      if (span) {
        span.dataset.lookupkey = key;
        span.textContent = renderCellDisplay(input.name || td?.dataset?.field || "", key, key);
      }

      try {
        input.dispatchEvent(new Event("input", { bubbles: true }));
        input.dispatchEvent(new Event("change", { bubbles: true }));
