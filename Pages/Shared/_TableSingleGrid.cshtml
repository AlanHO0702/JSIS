  // 儲存
  const findDuplicateKeyConflict = (targetRows = null) => {
    if (!Array.isArray(KEY_FIELDS) || KEY_FIELDS.length === 0) return null;
    const rows = getBodyRows();
    if (!rows.length) return null;
    const targetSet = Array.isArray(targetRows) && targetRows.length ? new Set(targetRows) : null;
    const signatures = new Map();
    const pickKeyInput = (tr, keyName) =>
      Array.from(tr.querySelectorAll(".cell-edit")).find(inp => (inp.name || "").toLowerCase() === keyName) || null;

    for (const tr of rows) {
      const keyValues = [];
      const keyDisplay = [];
      let missing = false;
      for (const keyName of KEY_FIELDS) {
        const inp = pickKeyInput(tr, keyName);
        if (!inp) { missing = true; break; }
        const raw = (inp.value ?? "").toString().trim();
        if (raw === "") { missing = true; break; }
        keyValues.push(raw.toLowerCase());
        keyDisplay.push(`${inp.name || keyName}=${raw}`);
      }
      if (missing || keyValues.length === 0) continue;

      const signature = keyValues.join("\u001f");
      const prev = signatures.get(signature);
      if (prev) {
        if (targetSet && !targetSet.has(prev.tr) && !targetSet.has(tr)) continue;
        return {
          prevRowNo: rows.indexOf(prev.tr) + 1,
          currRowNo: rows.indexOf(tr) + 1,
          keyText: keyDisplay.join(", ")
        };
      }
      signatures.set(signature, { tr });
    }
    return null;
  };

    async function saveTableChanges(options = {}) {
      const opts = (options && typeof options === "object" && !(options instanceof Event)) ? options : {};
      const targetRows = Array.isArray(opts.targetRows) ? opts.targetRows.filter(Boolean) : null;
      const silentSuccess = !!opts.silentSuccess;
      const duplicate = findDuplicateKeyConflict(targetRows);
      if (duplicate) {
        Swal.fire({
          icon: 'warning',
          title: '\u9375\u503c\u91cd\u8907',
          text: `\u7b2c ${duplicate.prevRowNo} \u7b46\u8207\u7b2c ${duplicate.currRowNo} \u7b46\u4e3b\u9375\u91cd\u8907 (${duplicate.keyText})`
        });
        return false;
      }
      const changes = collectChanges(targetRows);
      if (changes.length === 0) {
        if (!silentSuccess) {
          Swal.fire({ icon: 'info', title: '無可儲存變更', timer: 1200, showConfirmButton: false });
        }
        return true;
      }

    const resp = await fetch('/api/CommonTable/SaveTableChanges', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        TableName: "@tableName",
        KeyFields: KEY_FIELDS,
        Data: changes
      })
    });

      const raw = await resp.clone().text();
      let payload = null;
      try { payload = raw ? JSON.parse(raw) : null; } catch { }
      const failedRows = Array.isArray(payload?.results)
        ? payload.results.filter(r => r && r.ok === false)
        : [];

      if (resp.ok && payload?.success !== false && failedRows.length === 0) {
      if (!silentSuccess) {
        Swal.fire({ icon: 'success', title: '儲存成功', timer: 1000, showConfirmButton: false });
      }

      changes.forEach(change => {
        const targetRow = findRowByKeys(change);
        if (!targetRow) return;

        for (const [field, newVal] of Object.entries(change)) {
          const cell = targetRow.querySelector(`td[data-field="${field}"]`);
          if (!cell) continue;
          const inp  = cell.querySelector(".cell-edit");
          const span = cell.querySelector(".cell-view");
          if (inp) {
            inp.defaultValue = newVal;
            inp.dataset.raw  = newVal;
          }
          if (cell.dataset.checkbox) {
            syncCheckboxVisible(cell, newVal);
          } else if (span) {
            span.textContent = renderCellDisplay(field, newVal, inp?.dataset.lookupkey ?? newVal);
          }
        }
      });
      setDirty(false);
      return true;
      } else {
        Swal.fire({ icon: 'error', title: '儲存失敗', text: await resp.text() });
        return false;
      }
    };
    if (saveBtn) {
      saveBtn.addEventListener("click", saveTableChanges);
    }

  // 依複合鍵找列
  async function deleteSelectedRow() {
    if (delBtn && delBtn.disabled) return; // 防止 disabled 按鈕被點擊
    const tr = window.SELECTED_ROW;
    if (!tr) {
      Swal.fire({ icon: 'warning', title: '\u8acb\u5148\u9078\u53d6\u4e00\u7b46\u8cc7\u6599' });
      return;
    }

    const keyValues = {};
    KEY_FIELDS.forEach(k => {
      const inp = Array.from(tr.querySelectorAll('.cell-edit')).find(i => (i.name || '').toLowerCase() === k);
      if (!inp) return;
      keyValues[inp.name] = inp.defaultValue ?? inp.value ?? "";
    });

    const missingKeys = KEY_FIELDS.filter(k => !Object.keys(keyValues).some(n => n.toLowerCase() === k));
    if (missingKeys.length) {
      Swal.fire({
        icon: 'error',
        title: '\u522a\u9664\u5931\u6557',
        text: `\u7f3a\u5c11\u4e3b\u9375/\u7d22\u5f15\u6b04\u4f4d: ${missingKeys.join(', ')}`
      });
      return;
    }

    const ok = await Swal.fire({
      icon: 'warning',
      title: '\u78ba\u5b9a\u8981\u522a\u9664\u9019\u4e00\u7b46\u55ce\uff1f',
      showCancelButton: true,
      confirmButtonText: '\u522a\u9664',
      cancelButtonText: '\u53d6\u6d88',
      confirmButtonColor: '#dc3545'
    });
    if (!ok.isConfirmed) return;

    const resp = await fetch('/api/CommonTable/SaveTableChanges', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        TableName: "@tableName",
        KeyFields: KEY_FIELDS,
        Data: [{ __delete: true, ...keyValues }]
      })
    });

    if (!resp.ok) {
      Swal.fire({ icon: 'error', title: '\u522a\u9664\u5931\u6557', text: await resp.text() });
      return;
    }

    let affected = null;
    try {
      const json = await resp.json();
      affected = json?.results?.[0]?.affected ?? null;
    } catch { }

      if (activeCell && tr.contains(activeCell)) clearActiveCell();
      tr.remove();
      window.SELECTED_ROW = null;
      if (totalCountAll > 0) totalCountAll -= 1;
      updateCountPanel(0);

    if (typeof affected === 'number' && affected > 1) {
      Swal.fire({
        icon: 'warning',
        title: '\u522a\u9664\u5b8c\u6210',
        text: `\u6ce8\u610f\uff1a\u5f71\u97ff\u884c\u6578 = ${affected}\uff0c\u5efa\u8b70\u91cd\u65b0\u67e5\u8a62\u78ba\u8a8d`
      });
    } else {
      Swal.fire({ icon: 'success', title: '\u522a\u9664\u5b8c\u6210', timer: 900, showConfirmButton: false });
    }
  }

  if (delBtn) {
    if (window.createGridController) {
      window.createGridController({ name: 'singleGridDelete', btnDelete: delBtn, onDelete: deleteSelectedRow });
    } else {
      delBtn.addEventListener('click', deleteSelectedRow);
    }
  }

  function selectRowByIndex(idx) {
    const rows = Array.from(table.querySelectorAll("tbody tr"));
    if (rows.length === 0) return;
    const target = rows[Math.max(0, Math.min(rows.length - 1, idx))];
    if (target) selectRow(target);
  }

  function selectRelativeRow(delta) {
    const rows = Array.from(table.querySelectorAll("tbody tr"));
    if (rows.length === 0) return;
    const currentIdx = window.SELECTED_ROW ? rows.indexOf(window.SELECTED_ROW) : -1;
    const nextIdx = currentIdx + delta;
    if (nextIdx < 0) {
      if (currentPage > 1 && typeof goPage === "function") {
        pendingSelect = "last";
        goPage(currentPage - 1);
      } else {
        selectRow(rows[0]);
      }
      return;
    }
    if (nextIdx >= rows.length) {
      if (currentPage < totalPages && typeof goPage === "function") {
        pendingSelect = "first";
        goPage(currentPage + 1);
      } else {
        selectRow(rows[rows.length - 1]);
      }
      return;
    }
    selectRow(rows[nextIdx]);
  }

  function jumpFirst() {
    const rows = Array.from(table.querySelectorAll("tbody tr"));
    if (rows.length === 0) return;
    if (currentPage > 1 && typeof goPage === "function") {
      pendingSelect = "first";
      goPage(1);
      return;
    }
    selectRow(rows[0]);
  }

  function jumpLast() {
    const rows = Array.from(table.querySelectorAll("tbody tr"));
    if (rows.length === 0) return;
    if (currentPage < totalPages && typeof goPage === "function") {
      pendingSelect = "last";
      goPage(totalPages);
      return;
    }
    selectRow(rows[rows.length - 1]);
  }

  sgFirst?.addEventListener("click", jumpFirst);
  sgPrev?.addEventListener("click", () => selectRelativeRow(-1));
  sgNext?.addEventListener("click", () => selectRelativeRow(1));
  sgLast?.addEventListener("click", jumpLast);
  sgAdd?.addEventListener("click", addRow);
  sgDelete?.addEventListener("click", deleteSelectedRow);
  sgSave?.addEventListener("click", saveTableChanges);
  sgCancel?.addEventListener("click", cancelEdit);

  function findRowByKeys(change) {
    const changeLC = {};
    for (const [ck, cv] of Object.entries(change)) changeLC[ck.toLowerCase()] = cv;
    const rows = Array.from(table.querySelectorAll("tbody tr"));
    return rows.find(tr => {
      return KEY_FIELDS.every(k => {
        const inp = Array.from(tr.querySelectorAll('.cell-edit')).find(i => i.name.toLowerCase() === k);
        if (!inp) return false;
        const changeVal = changeLC[k];
        if (changeVal == null) return false;
        return String(inp.value) === String(changeVal) || String(inp.defaultValue) === String(changeVal);
      });
    });
  }

  // 收集變更（只傳送鍵欄位 + 真正有變更的欄位）
  function collectChanges(targetRows = null) {
    const list = [];
    const tblName = "@tableName".toString().toLowerCase();
    const rows = Array.isArray(targetRows) && targetRows.length
      ? targetRows
      : Array.from(document.querySelectorAll("#mainGrid tbody tr"));
    rows.forEach(tr => {
      const changed = {};
      const keys = {};
      let hasDiff = false;

      tr.querySelectorAll(".cell-edit").forEach(inp => {
        const name = inp.name;
        if (!name) return;

        const oldVal = inp.dataset.raw ?? inp.defaultValue ?? "";
        const newVal = inp.value ?? "";
        const oldCmpVal = normalizeValueForCompare(name, oldVal);
        const newCmpVal = normalizeValueForCompare(name, newVal);
        const submitVal = normalizeValueForSubmit(name, newVal);
        const isReadonly = inp.dataset.readonly === "1";
        const isKey = KEY_FIELDS.includes(name.toLowerCase());

        // 鍵欄位一定要帶
        if (isKey) {
          keys[name] = newVal;
          return;
        }

        // 唯讀欄位跳過
        if (isReadonly) return;

        // 只收集有變更的欄位
        if (newCmpVal !== oldCmpVal) {
          hasDiff = true;
          changed[name] = submitVal;
        }
      });

      if (!hasDiff) return;

      // 合併鍵欄位 + 變更欄位
      if (tblName === "mphdpricetable" || tblName === "spodpricetable") {
        const hasUseId = Object.keys(keys).some(k => k.toLowerCase() === "useid");
        if (!hasUseId) {
          keys["UseId"] = getLoginUserId();
        }
      }
      list.push({ ...keys, ...changed });
    });
    return list;
  }

    // 在 erpGridNav 的 pointerdown (bubble) 之前（capture 階段）記錄切換前的列，
    // 供 click handler 做 auto-save 判斷（erpGridNav 的 pointerdown 會先更新 SELECTED_ROW）
    let _clickPrevRow = null;
    table.addEventListener("pointerdown", (ev) => {
      const tr = ev.target.closest("tbody tr");
      if (tr) _clickPrevRow = window.SELECTED_ROW || null;
    }, { capture: true });

    table.addEventListener("click", async (ev) => {
      const tr = ev.target.closest("tbody tr");
      if (!tr) return;
      const prevRow = _clickPrevRow;
      _clickPrevRow = null;
      // erpGridNav 的 pointerdown 可能已透過 onRowSelect 更新 SELECTED_ROW，
      // 此處用 prevRow 偵測真正的列切換，自行執行 auto-save
      if (prevRow && prevRow !== tr && isEdit && isDirty) {
        const ok = await saveTableChanges({ silentSuccess: true, targetRows: [prevRow] });
        if (!ok) return;
      }
      await selectRow(tr, { skipAutoSave: true });
      const td = ev.target.closest("td[data-field]");
      if (td) setActiveCell(td, { skipRowSelect: true });
    });
    table.addEventListener("focusin", (ev) => {
      const td = ev.target?.closest?.("td[data-field]");
      if (!td) return;
      setActiveCell(td, { focus: false });
    });
    const copyCellValue = (targetTd, sourceTd) => {
      if (!targetTd || !sourceTd) return false;
      if (targetTd.dataset.checkbox) {
        const targetChk = targetTd.querySelector(".sg-chk-edit");
        if (!targetChk || targetChk.disabled || targetChk.dataset.readonly === "1") return false;
        const sourceChk = sourceTd.querySelector(".sg-chk-edit");
        const sourceHidden = sourceTd.querySelector(".cell-edit");
        const nextChecked = sourceChk
          ? !!sourceChk.checked
          : String(sourceHidden?.value ?? "").trim() === "1";
        if (targetChk.checked === nextChecked) return false;
        targetChk.checked = nextChecked;
        targetChk.dispatchEvent(new Event("change", { bubbles: true }));
        return true;
      }

      const targetInput = targetTd.querySelector(".cell-edit");
      const sourceInput = sourceTd.querySelector(".cell-edit");
      if (!targetInput || !sourceInput) return false;
      if (targetInput.readOnly || targetInput.disabled || targetInput.dataset.readonly === "1") return false;
      const nextValue = sourceInput.value ?? "";
      if ((targetInput.value ?? "") === nextValue) return false;
      targetInput.value = nextValue;
      targetInput.dispatchEvent(new Event("input", { bubbles: true }));
      targetInput.dispatchEvent(new Event("change", { bubbles: true }));
      return true;
    };
    const copyRowFromPrevRow = (targetTd) => {
      if (!targetTd || !isEdit) return false;
      const targetRow = targetTd.closest("tr");
      if (!targetRow) return false;
      const rows = getBodyRows();
      const rowIndex = rows.indexOf(targetRow);
      if (rowIndex <= 0) return false;
      const sourceRow = rows[rowIndex - 1];
      let changed = false;
      targetRow.querySelectorAll("td[data-field]").forEach(td => {
        const fieldName = td.dataset.field || "";
        if (!fieldName) return;
        const sourceTd = getCellByField(sourceRow, fieldName);
        if (!sourceTd) return;
        if (copyCellValue(td, sourceTd)) changed = true;
      });
      return changed;
    };
    const copyCellFromPrevRow = (targetTd) => {
      if (!targetTd || !isEdit) return false;
      const targetRow = targetTd.closest("tr");
      if (!targetRow) return false;
      const fieldName = targetTd.dataset.field || "";
      if (!fieldName) return false;
      const rows = getBodyRows();
      const rowIndex = rows.indexOf(targetRow);
      if (rowIndex <= 0) return false;
      const sourceTd = getCellByField(rows[rowIndex - 1], fieldName);
      if (!sourceTd) return false;
      return copyCellValue(targetTd, sourceTd);
    };
    // F7/F8/方向鍵/Enter/Escape 由 erpGridNav 統一處理；此處只保留 Delete 清空格子
    table.addEventListener("keydown", (ev) => {
      if ((ev.key === "F4" || ev.key === "ArrowDown") && isEdit && enableLookupDropdown) {
        const input = ev.target instanceof HTMLInputElement ? ev.target : null;
        if (input && input.classList.contains("cell-edit") && input.classList.contains("sg-lookup-input")
          && !input.disabled && !input.readOnly && input.dataset.readonly !== "1") {
          ev.preventDefault();
          openSingleGridLookup(input, true);
          return;
        }
      }
      if (ev.key !== "Delete") return;
      const el = ev.target;
      if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) return;
      if (!el.classList.contains("cell-edit")) return;
      if (el.readOnly || el.disabled) return;
      ev.preventDefault();
      if (el instanceof HTMLSelectElement) {
        if (![...el.options].some(o => o.value === "")) {
          const empty = document.createElement("option");
          empty.value = "";
          empty.textContent = "";
          el.insertBefore(empty, el.firstChild);
        }
        el.value = "";
        el.dispatchEvent(new Event("input", { bubbles: true }));
        el.dispatchEvent(new Event("change", { bubbles: true }));
        return;
      }
      if (el instanceof HTMLInputElement && el.type === "checkbox") {
        el.checked = false;
        return;
      }
      el.value = "";
      el.dispatchEvent(new Event("input", { bubbles: true }));
      el.dispatchEvent(new Event("change", { bubbles: true }));
    });
    table.addEventListener("dblclick", (ev) => {
      if (isEdit) {
        if (!enableLookupDropdown) return;
        const td = ev.target.closest("td[data-field]");
        if (!td || td.dataset.checkbox) return;
        const inp = td.querySelector(".cell-edit:not(.d-none)");
        if (!(inp instanceof HTMLInputElement)) return;
        if (inp.type === "checkbox" || inp.type === "hidden") return;
        if (inp.dataset.readonly === "1" || inp.disabled || inp.readOnly) return;
        if (!Array.isArray(inp._sgLookupItems) || inp._sgLookupItems.length === 0) return;
        ev.preventDefault();
        ev.stopPropagation();
        openSingleGridLookup(inp, true);
        return;
      }
      const tr = ev.target.closest("tbody tr");
      if (!tr) return;
      const target = ev.target;
      if (target && target.closest && target.closest("input,textarea,select,button,a,label")) return;
      selectRow(tr);
      const handler = resolveCustomHandler("openDetail");
      if (typeof handler !== "function") return;
      ev.preventDefault();
      const ctx = {
        buttonName: "openDetail",
        itemId: window._singleItemId || "",
        tableName: window._singleRealTable || window._dictTableName || table?.dataset?.dictTable || "",
        meta: findButtonMeta("openDetail"),
        selectedRow: readRowData(window.SELECTED_ROW)
      };
      try {
        handler(ctx);
      } catch (err) {
        console.error("double-click openDetail failed", err);
        alert(`執行失敗: ${err?.message || err}`);
      }
    });

    await loadStandardLookups();
    applyLookupToTable();
    applyLookupDropdowns();
    applyCheckboxCells(); // 頁面載入時套用 checkbox 轉換
    setModePanel(isEdit);
    updateCountPanel(getSelectedRowIndex());
    buildCustomButtonsFromMeta();
    wireCustomButtons();

    // ── erpGridNav：鍵盤導航（F7/F8/Enter/Escape/方向鍵） ──
    if (typeof window.initErpGridNav === 'function') {
      const _navTbody = table.querySelector('tbody');
      if (_navTbody) {
        window.initErpGridNav(_navTbody, {
          keyFields : KEY_FIELDS,
          isEditMode: () => isEdit,
          addRow    : async () => {
            const tr = addRow({ append: true });
            return tr ? { ok: true } : { ok: false };
          },
          // Enter / F7 / F8 後自動存檔（列切換的 auto-save 由 click handler 的 selectRow 負責）
          autoSave  : async () => {
            if (!isDirty) return;
            await saveTableChanges({ silentSuccess: true, targetRows: [window.SELECTED_ROW].filter(Boolean) });
          },
          onRowSelect: (tr) => { if (tr) selectRow(tr, { skipAutoSave: true }); },
          gridLabel : 'singlegrid',
        });
      }
    }

  // 共用狀態變數
  let isSorting = false; // 防止重複請求（排序、分頁共用）
  let currentSortBy = '@(ViewData["SortBy"] as string ?? "")';
  let currentSortDir = '@(ViewData["SortDir"] as string ?? "")';

  // 分頁控制
    const pagerPrev = document.getElementById("pagerPrev");
    const pagerNext = document.getElementById("pagerNext");
    const pagerLast = document.getElementById("pagerLast");
    const pagerFirst = document.getElementById("pagerFirst");
    const pagerInfo = document.getElementById("pagerInfo");
    const pagerPageSize = document.getElementById("pagerPageSize");
    const pagerCurrentEl = document.getElementById("pagerCurrent");
    const pagerTotalEl = document.getElementById("pagerTotal");
    currentPage = parseInt(pagerCurrentEl?.textContent || String(currentPage), 10);
    totalPages = parseInt(pagerTotalEl?.textContent || String(totalPages), 10);
  const pagerGoInput = document.getElementById("pagerGoInput");
  const pagerGoBtn = document.getElementById("pagerGoBtn");
  const btnOpenQuery = document.getElementById("btnOpenQuery");
  const queryModalEl = document.getElementById("singleGridQueryModal");
  const queryForm = document.getElementById("searchForm");
  const btnQuerySubmit = document.getElementById("btnQuerySubmit");
  const fallbackQueryFields = @Html.Raw(JsonSerializer.Serialize(
    fields.Select(f => new {
      ColumnName = f.FieldName,
      ColumnCaption = f.DisplayLabel,
      DataType = f.DataType,
      DefaultEqual = "like"
    })
  ));

  // 更新分頁資訊
    function updatePager(newPage, newPageSize, newTotalCount) {
      currentPage = newPage;
      pageSize = newPageSize;
      totalPages = Math.max(1, Math.ceil(newTotalCount / newPageSize));
      totalCountAll = newTotalCount;

      // 更新 DOM
      if (pagerCurrentEl) pagerCurrentEl.textContent = currentPage;
      if (pagerTotalEl) pagerTotalEl.textContent = totalPages;
      if (pagerGoInput) {
        pagerGoInput.value = currentPage;
        pagerGoInput.max = totalPages;
      }
      if (pagerInfo) {
        pagerInfo.textContent = `第 ${currentPage} / ${totalPages} 頁，共 ${totalCountAll} 筆`;
      }

      // 更新按鈕狀態
      if (pagerFirst) pagerFirst.disabled = currentPage <= 1;
      if (pagerPrev) pagerPrev.disabled = currentPage <= 1;
      if (pagerNext) pagerNext.disabled = currentPage >= totalPages;
      if (pagerLast) pagerLast.disabled = currentPage >= totalPages;
      updateCountPanel(getSelectedRowIndex());
    }

  async function goPage(p, forcedPageSize = null, silentError = false) {

    if (!Number.isFinite(p) || p < 1) {
      return;
    }

    if (isSorting) {
      return;
    }

    isSorting = true;
    showLoading();

    try {
      const forcedSize = Number.isFinite(forcedPageSize) ? parseInt(forcedPageSize, 10) : NaN;
      const selectedSize = pagerPageSize ? parseInt(pagerPageSize.value, 10) : NaN;
      const newPageSize = Number.isFinite(forcedSize) && forcedSize > 0
        ? forcedSize
        : (Number.isFinite(selectedSize) && selectedSize > 0 ? selectedSize : Math.max(1, pageSize));

      // 呼叫 AJAX API
      const urlObj = new URL(window.location.href);
      urlObj.searchParams.set("handler", "Data");
      urlObj.searchParams.set("pageIndex", String(p));
      urlObj.searchParams.set("pageSize", String(newPageSize));
      if (currentSortBy) urlObj.searchParams.set("sortBy", currentSortBy);
      else urlObj.searchParams.delete("sortBy");
      if (currentSortDir) urlObj.searchParams.set("sortDir", currentSortDir);
      else urlObj.searchParams.delete("sortDir");
      const url = urlObj.toString();

      const response = await fetch(url);

      if (!response.ok) {
        throw new Error('HTTP error! status: ' + response.status);
      }

      const data = await response.json();

      if (!data.success) {
        throw new Error(data.error || 'Unknown error');
      }

      // 更新表格
      const fields = @Html.Raw(fieldsJson);
      const emptyMessage = getEmptyMessage(!!data.openNoRecord, !!data.hasQueryParams);
      updateTableBody(data.items, fields, emptyMessage);
      loadSavedColumnOrder();
      await loadStandardLookups();
      applyLookupToTable(); // 套用 lookup 顯示
      applyLookupDropdowns();

      // 更新分頁資訊
      updatePager(data.pageNumber, newPageSize, data.totalCount);
      return true;

    } catch (err) {
      if (!silentError) {
        console.error('[goPage] Page change failed:', err);
      } else {
        console.warn('[goPage] Auto load all rows skipped:', err?.message || err);
      }
      if (!silentError) {
        alert('換頁失敗：' + err.message);
      }
      return false;
    } finally {
      hideLoading();
      isSorting = false;
    
    }
  }

  async function loadAllRowsIfNeeded() {
    if (hasLoadedAllRows) return;
    if (!Number.isFinite(totalCountAll) || totalCountAll <= 0) return;
    if (pageSize >= totalCountAll && totalPages <= 1) return;

    hasLoadedAllRows = true;
    const loaded = await goPage(1, totalCountAll, true);
    if (loaded) return;

    // Fallback: 某些頁面沒有 handler=Data，改用整頁重載帶入全筆 pageSize。
    // 使用 hash 標記避免重載循環（hash 不會送到後端，不影響 SQL 查詢）。
    const currentUrl = new URL(window.location.href);
    if ((window.location.hash || "").includes("sgall=1")) return;
    const targetSize = String(Math.max(1, totalCountAll));
    const samePageIndex = currentUrl.searchParams.get("pageIndex") === "1";
    const samePageSize = currentUrl.searchParams.get("pageSize") === targetSize;
    if (samePageIndex && samePageSize) return;
    currentUrl.searchParams.set("pageIndex", "1");
    currentUrl.searchParams.set("pageSize", targetSize);
    currentUrl.hash = "sgall=1";
    window.location.replace(currentUrl.toString());
  }

  pagerFirst?.addEventListener("click", (e) => {
 
    e.preventDefault();
    goPage(1);
  });
  pagerPrev?.addEventListener("click", (e) => {
    e.preventDefault();
    if (!e.currentTarget.disabled) goPage(currentPage - 1);
  });
  pagerNext?.addEventListener("click", (e) => {
    e.preventDefault();
    if (!e.currentTarget.disabled) goPage(currentPage + 1);
  });
  pagerLast?.addEventListener("click", (e) => {
    e.preventDefault();
    if (!e.currentTarget.disabled) goPage(totalPages);
  });
  pagerPageSize?.addEventListener("change", () => {
    goPage(1);
  });
  pagerGoBtn?.addEventListener("click", () => {
    const v = parseInt(pagerGoInput?.value || "1", 10);
    if (Number.isFinite(v)) goPage(Math.min(Math.max(1, v), totalPages));
  });
  pagerGoInput?.addEventListener("keyup", (e) => {
    if (e.key === "Enter") pagerGoBtn?.click();
  });

  // 查詢 modal
  let queryFieldsLoaded = false;
  let inqMustLoaded = false;
  let inqMustList = [];
  async function loadQueryFields() {
    if (queryFieldsLoaded) return;
    const itemId = window._singleItemId || "";
    const table = window._singleRealTable || tableName;
    if (!itemId || !table) return;
    try {
      const res = await fetch(`/api/DictSetupApi/QueryFields?itemId=${encodeURIComponent(itemId)}&table=${encodeURIComponent(table)}&lang=TW`);
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      const list = Array.isArray(data) && data.length ? data : (fallbackQueryFields || []);
      buildQueryForm(list);
      queryFieldsLoaded = true;
    } catch (err) {
      console.warn("load query fields failed", err);
      if (fallbackQueryFields && fallbackQueryFields.length) {
        buildQueryForm(fallbackQueryFields);
        queryFieldsLoaded = true;
      }
    }
  }

  function buildEmptyRow(fields) {
    const tr = document.createElement("tr");
    tr.dataset.newRow = "1";
    fields.forEach(f => {
      const fieldName = f.FieldName;
      const isHidden = f.Visible == 0;
      const hiddenStyle = isHidden ? "display:none;" : "";
      const dt = (f.DataType || "").toString().toLowerCase();
      const isNumber = dt.includes('number') || dt.startsWith('decimal') || dt.startsWith('numeric')
        || dt.startsWith('money') || dt.startsWith('smallmoney') || dt.startsWith('float') || dt.startsWith('real')
        || dt.startsWith('int') || dt.startsWith('smallint') || dt.startsWith('tinyint') || dt.startsWith('bigint');
      const cellClass = isNumber ? 'cell-number' : 'cell-text';
      const isReadOnly = f.ReadOnly != null && f.ReadOnly != 0;
      const fmtMeta = fieldFormatMap?.find?.(x => (x.FieldName || '').toLowerCase() === (fieldName || '').toLowerCase());
      const isCheckboxCell = (fmtMeta?.ComboStyle ?? 0) === 1;
      const editColorRaw = (fmtMeta?.EditColor || '').trim();
      const bgStyle = (!disableEditColor && editColorRaw) ? 'background-color:' + normalizeEditColor(editColorRaw) + '!important;' : '';
      const tdStyle = bgStyle + hiddenStyle;

      const td = document.createElement("td");
      td.dataset.field = fieldName;
      td.setAttribute("style", tdStyle);
      td.tabIndex = -1;

      if (isCheckboxCell) {
        td.className = "text-nowrap text-center" + (isReadOnly ? " readonly-td" : "");
        td.dataset.checkbox = "1";
        td.innerHTML =
          '<input type="checkbox" class="sg-chk-view form-check-input" disabled />' +
          '<input type="hidden" class="cell-edit" name="' + fieldName + '" value="0" data-raw="0" data-readonly="' + (isReadOnly ? '1' : '0') + '" />' +
          '<input type="checkbox" class="sg-chk-edit form-check-input"' + (isReadOnly ? ' disabled data-readonly="1"' : ' data-readonly="0"') + ' />';
      } else {
        td.className = `text-nowrap ${cellClass}`;

        const span = document.createElement("span");
        span.className = "cell-view d-none";
        span.dataset.raw = "";
        span.dataset.lookupkey = "";
        span.textContent = "";

        const inp = document.createElement("input");
        inp.className = `form-control form-control-sm cell-edit ${isReadOnly ? "readonly-cell" : ""}`;
        if (enableDatePicker && isDateField(fieldName)) {
          inp.type = "date";
        }
        inp.name = fieldName;
        inp.value = "";
        inp.dataset.raw = "";
        inp.dataset.lookupkey = "";
        inp.dataset.readonly = isReadOnly ? "1" : "0";
        if (isReadOnly) inp.readOnly = true;

        td.appendChild(span);
        td.appendChild(inp);
      }

      tr.appendChild(td);
    });
    return tr;
  }

  function addRow(options = {}) {
    if (!isEdit) editBtn.click();
    const tbody = table.querySelector("tbody");
    if (!tbody) return;
    const append = !!options.append;
    const fields = @Html.Raw(fieldsJson);
    const placeholderRows = Array.from(tbody.querySelectorAll("tr.sg-empty-row"));
    if (placeholderRows.length > 0) {
      placeholderRows.forEach(r => r.remove());
    }
    if (tbody.children.length === 1) {
      const only = tbody.children[0];
      if (only.querySelector("td[colspan]")) tbody.innerHTML = "";
    }
      const tr = buildEmptyRow(fields);
      applyDefaultNewRowValues(tr);
      if (append) tbody.appendChild(tr);
      else tbody.insertBefore(tr, tbody.firstChild);
      selectRow(tr);
      tr.scrollIntoView({ block: "center" });
      applyLookupDropdowns();
      setDirty(true);
      return tr;
    }

  function getLoginUserId() {
    const v = (window._userId || localStorage.getItem('erpLoginUserId') || '').toString().trim();
    return v || 'admin';
  }

  function setCellValue(tr, fieldName, value, keepDefaultEmpty = false) {
    const inputs = Array.from(tr.querySelectorAll('.cell-edit'));
    const inp = inputs.find(i => (i.name || '').toLowerCase() === fieldName.toLowerCase());
    if (!inp) return;
    const val = value == null ? "" : String(value);
    inp.value = val;
    if (!keepDefaultEmpty) inp.defaultValue = val;
    const td = inp.closest("td");
    if (td && td.dataset.checkbox) {
      syncCheckboxVisible(td, val);
    } else {
      const span = td?.querySelector(".cell-view");
      if (span) span.textContent = renderCellDisplay(fieldName, val, inp?.dataset?.lookupkey ?? val);
    }
  }

  function getRowFieldValue(tr, fieldName) {
    if (!tr || !fieldName) return "";
    const lower = String(fieldName).toLowerCase();
    const inp = Array.from(tr.querySelectorAll(".cell-edit"))
      .find(i => (i.name || "").toLowerCase() === lower);
    if (!inp) return "";
    return String(inp.value ?? inp.dataset.raw ?? "").trim();
  }

  function applyPartDefaultsToRow(tr, partNum) {
    if (!tr) return { uom: false, qnty: false };
    const key = String(partNum || "").trim().toLowerCase();
    if (!key) return { uom: false, qnty: false };
    const def = partDefaultsMap[key];
    if (!def) return { uom: false, qnty: false };

    let uomApplied = false;
    let qntyApplied = false;
    if (def.uom) {
      setCellValue(tr, "UOM", def.uom);
      uomApplied = true;
    }
    if (def.qnty) {
      setCellValue(tr, "Qnty", def.qnty);
      qntyApplied = true;
    }
    return { uom: uomApplied, qnty: qntyApplied };
  }

  function getDefaultFieldValue(fieldName) {
    const lower = String(fieldName || "").toLowerCase();
    if (!lower) return "";
    const rows = Array.from(table.querySelectorAll("tbody tr"));
    const pickFromRow = (tr) => {
      if (!tr) return "";
      const inp = Array.from(tr.querySelectorAll(".cell-edit"))
        .find(i => (i.name || "").toLowerCase() === lower);
      const v = String(inp?.value ?? inp?.dataset?.raw ?? "").trim();
      return v;
    };

    const fromSelected = pickFromRow(window.SELECTED_ROW);
    if (fromSelected) return fromSelected;

    for (const tr of rows) {
      if (tr.dataset.newRow === "1") continue;
      const v = pickFromRow(tr);
      if (v) return v;
    }
    return "";
  }

  function applyDefaultNewRowValues(tr) {
    const tbl = "@tableName".toString().toLowerCase();
    if (tbl !== "mphdpricetable" && tbl !== "spodpricetable") return;

    setCellValue(tr, "Revision", 0);
    setCellValue(tr, "UseId", getLoginUserId());
    const isInVal = tbl === "spodpricetable" ? 0 : 1;
    setCellValue(tr, "IsIn", isInVal, true);
    setCellValue(tr, "Qnty", 1);
    const inheritedPartNum = getDefaultFieldValue("PartNum");
    const applied = applyPartDefaultsToRow(tr, inheritedPartNum);
    if (!applied.uom) {
      const defaultUom = getDefaultFieldValue("UOM");
      if (defaultUom) setCellValue(tr, "UOM", defaultUom);
    }
    if (!applied.qnty && !getRowFieldValue(tr, "Qnty")) {
      setCellValue(tr, "Qnty", 1);
    }
  }

  function cancelEdit() {
    if (!isEdit) return;
    table.querySelectorAll("tbody tr").forEach(tr => {
      if (tr.dataset.newRow === "1") {
        tr.remove();
        return;
      }
      tr.querySelectorAll(".cell-edit").forEach(inp => {
        const val = inp.dataset.raw ?? inp.defaultValue ?? "";
        inp.value = val;
        inp.dataset.raw = val;
        const td = inp.closest("td");
        if (td && td.dataset.checkbox) {
          syncCheckboxVisible(td, val);
        } else {
          const span = td?.querySelector(".cell-view");
          if (span) span.textContent = renderCellDisplay(inp.name, val, inp?.dataset?.lookupkey ?? val);
        }
      });
    });
    applyLookupToTable();
    isEdit = false;
      editBtn.innerHTML = '<i class="bi bi-pencil-square me-1"></i> 修改';
      wrapper.classList.remove("edit-mode");
      if (saveBtn) saveBtn.classList.add("d-none");
      setModePanel(false);
      setDirty(false);
    }

  async function loadInqMust() {
    if (inqMustLoaded) return;
    const table = window._singleRealTable || table?.dataset?.dictTable || window._dictTableName || "";
    if (!table) return;
    try {
      const res = await fetch(`/api/DictSetupApi/InqMust?paperId=${encodeURIComponent(table)}`);
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      inqMustList = Array.isArray(data) ? data : [];
      inqMustLoaded = true;
    } catch (err) {
      console.warn("load inq must failed", err);
    }
  }

  function buildQueryForm(fields) {
    if (!queryForm) return;
    queryForm.innerHTML = "";

    // 直接渲染所有查詢欄位
    fields.forEach(f => {
      const colName = f.columnName || f.ColumnName || "";
      if (!colName) return;
      const caption = f.columnCaption || f.ColumnCaption || colName;
      const defVal = f.defaultValue || f.DefaultValue || "";
      const defEq = (f.defaultEqual || f.DefaultEqual || "").toString().toLowerCase();
      const dtRaw = f.dataType ?? f.DataType;
      const dt = Number(dtRaw);

      const wrap = document.createElement("div");
      wrap.className = "col-md-4 col-sm-6";
      const label = document.createElement("label");
      label.className = "form-label text-muted";
      label.textContent = caption;
      const input = document.createElement("input");
      input.className = "form-control form-control-sm";
      input.name = colName;
      if (dt === 1) input.type = "date";
      else if (dt === 2) input.type = "number";
      else input.type = "text";
      if (defVal) input.value = defVal;
      if (defEq === "like") input.placeholder = "模糊查詢";

      wrap.appendChild(label);
      wrap.appendChild(input);
      queryForm.appendChild(wrap);
    });
  }

  btnOpenQuery?.addEventListener("click", async () => {
    // _QueryPanelPartial.cshtml 會在 modal shown 事件時自動建立查詢表單，不需要在這裡呼叫 loadQueryFields()
    if (queryModalEl && window.bootstrap) {
      const modal = bootstrap.Modal.getOrCreateInstance(queryModalEl);
      modal.show();
    }
  });

  // 清除查詢條件
  const btnClearQuery = document.getElementById("btnClearQuery");
  btnClearQuery?.addEventListener("click", () => {
    if (queryForm) {
      Array.from(queryForm.elements).forEach(el => {
        if (el.tagName === "INPUT") el.value = "";
      });
    }
  });

  const submitQueryForm = async () => {
    if (!queryForm) return;
    await loadInqMust();

    if (inqMustList.length > 0) {
      for (const rule of inqMustList) {
        const field = (rule.fieldMust || rule.FieldMust || "").toString();
        if (!field) continue;
        const input = queryForm.querySelector(`[data-field="${CSS.escape(field)}"]`);
        const value = input?.value?.toString().trim() ?? "";
        if (!value) {
          const msg = (rule.showError || rule.ShowError || "").toString();
          Swal.fire({ icon: 'error', title: msg || '請輸入必要查詢條件' });
          return;
        }
      }
    }

    // 建立新的 URL，只保留路徑部分
    const url = new URL(window.location.origin + window.location.pathname);

    // 設定分頁參數
    url.searchParams.set("pageIndex", "1");
    url.searchParams.set("pageSize", String(Math.max(1, totalCountAll || pageSize || 1)));
    url.searchParams.set("doQuery", "1");

    // 收集查詢欄位（排除 Cond_ 開頭的運算符欄位和系統欄位）
    Array.from(queryForm.elements).forEach(el => {
      if (!el.name || el.name.startsWith("Cond_") || el.name === "__RequestVerificationToken") return;
      const val = el.value?.toString().trim() ?? "";
      if (!val) return; // 空值不加入
      // 使用 data-field 屬性（純欄位名稱）而非 name（帶有 sortOrder 後綴）
      const fieldName = el.dataset.field || el.name;
      url.searchParams.set(fieldName, val);
    });

    window.location.href = url.toString();
  };

  btnQuerySubmit?.addEventListener("click", () => submitQueryForm());
  queryForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    submitQueryForm();
  });

  exportBtn?.addEventListener("click", () => {
    const url = new URL(window.location.href);
    url.searchParams.set("handler", "Export");
    window.location.href = url.toString();
  });


  // 欄寬拖拉
  const colGroupCols = Array.from(table.querySelectorAll("colgroup col"));
  const ths = Array.from(table.querySelectorAll("thead th"));
  const dictName = window._dictTableName || table.dataset.dictTable || dictTableName || table.dataset.table || table.dataset.dict || "";
  const tableName = dictName;
  const MIN_COL_WIDTH = 12;
  table.style.tableLayout = "fixed";
  table.style.maxWidth = "none";
  const colMap = {};
  colGroupCols.forEach(col => {
    const field = col.getAttribute("data-field");
    if (field) colMap[field.toLowerCase()] = col;
  });

  const parsePx = (v) => {
    const n = parseFloat(String(v || "").replace("px", "").trim());
    return Number.isFinite(n) ? n : 0;
  };

  const isVisibleCol = (col) => {
    if (!col) return false;
    const s = (col.getAttribute("style") || "").toLowerCase();
    return !s.includes("display:none");
  };

  const setColFixedWidth = (col, width) => {
    if (!col) return;
    const w = Math.max(MIN_COL_WIDTH, Math.round(width));
    col.style.width = `${w}px`;
    col.style.minWidth = `${w}px`;
    col.style.maxWidth = `${w}px`;
  };

  const syncTableWidthFromCols = () => {
    let total = 0;
    Object.values(colMap).forEach(col => {
      if (!isVisibleCol(col)) return;
      const w = parsePx(col.style.width) || col.getBoundingClientRect().width || 0;
      total += Math.max(0, w);
    });
    if (total > 0) {
      const px = `${Math.ceil(total)}px`;
      table.style.width = px;
      table.style.minWidth = px;
    }
  };

  const lockInitialColumnWidths = () => {
    ths.forEach(th => {
      const field = (th.getAttribute("data-field") || "").toLowerCase();
      if (!field) return;
      const col = colMap[field];
      if (!isVisibleCol(col)) return;
      const initWidth = parsePx(col.style.width) || th.getBoundingClientRect().width || MIN_COL_WIDTH;
      setColFixedWidth(col, initWidth);
      th.style.width = `${Math.round(initWidth)}px`;
      th.style.minWidth = `${Math.round(initWidth)}px`;
      th.style.maxWidth = `${Math.round(initWidth)}px`;
    });
    syncTableWidthFromCols();
  };

  lockInitialColumnWidths();
  requestAnimationFrame(lockInitialColumnWidths);
  setTimeout(lockInitialColumnWidths, 120);

  let dragState = null;
  ths.forEach(th => {
    const field = th.getAttribute("data-field");
    const resizer = th.querySelector(".col-resizer");
    if (!field || !resizer) return;
    resizer.addEventListener("mousedown", (e) => {
      e.preventDefault();
      const col = colMap[field.toLowerCase()];
      const startX = e.clientX;
      const startWidth = parsePx(col?.style?.width) || col?.getBoundingClientRect().width || th.getBoundingClientRect().width;
      dragState = { field, startX, startWidth };
      document.body.style.cursor = "col-resize";
    });
  });

  document.addEventListener("mousemove", (e) => {
    if (!dragState) return;
    const delta = e.clientX - dragState.startX;
    const newW = Math.max(MIN_COL_WIDTH, dragState.startWidth + delta);
    const col = colMap[dragState.field.toLowerCase()];
    if (col) {
      setColFixedWidth(col, newW);
    }
    // apply to header cell for visual feedback
    const th = ths.find(t => (t.getAttribute("data-field") || "").toLowerCase() === dragState.field.toLowerCase());
    if (th) {
      th.style.width = `${Math.round(newW)}px`;
      th.style.minWidth = `${Math.round(newW)}px`;
      th.style.maxWidth = `${Math.round(newW)}px`;
    }
    syncTableWidthFromCols();
  });

  document.addEventListener("mouseup", async () => {
    if (!dragState) return;
    const col = colMap[dragState.field.toLowerCase()];
    const th = ths.find(t => (t.getAttribute("data-field") || "").toLowerCase() === dragState.field.toLowerCase());
    const width = parsePx(col?.style?.width) || col?.getBoundingClientRect().width || th?.getBoundingClientRect().width || dragState.startWidth;
    dragState = null;
    document.body.style.cursor = "";
    syncTableWidthFromCols();
    if (!tableName) return;
    try {
      await fetch("/api/DictSetupApi/FieldWidth/Save", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          tableName: tableName,
          fieldName: th?.getAttribute("data-field") || "",
          widthPx: Math.round(width)
        })
      });
    } catch (err) {
      console.warn("save width failed", err);
    }
  });

  // ===== AJAX 排序功能 =====
  const headers = document.querySelectorAll(".sortable-header .header-label");
  const sortTableBody = document.querySelector("#mainGrid tbody");
  const tableWrapper = document.querySelector(".table-fix-wrapper");

  // Loading overlay
  const loadingOverlay = document.createElement('div');
  loadingOverlay.className = 'table-loading-overlay';
  loadingOverlay.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>';
  loadingOverlay.style.cssText = 'position:absolute;inset:0;display:flex;opacity:0;pointer-events:none;align-items:center;justify-content:center;background:rgba(247,250,255,0.96);backdrop-filter:blur(0.5px);transition:opacity .14s ease;z-index:1000;';
  tableWrapper?.appendChild(loadingOverlay);

  // 顯示 Loading
  function showLoading() {
    if (loadingOverlay) {
      if (tableWrapper) tableWrapper.classList.add('sg-busy');
      loadingOverlay.style.opacity = '1';
      loadingOverlay.style.pointerEvents = 'auto';
    }
  }

  // 隱藏 Loading
  function hideLoading() {
    if (loadingOverlay) {
      loadingOverlay.style.opacity = '0';
      loadingOverlay.style.pointerEvents = 'none';
      if (tableWrapper) tableWrapper.classList.remove('sg-busy');
    }
  }

  // 更新排序圖示
  function updateSortIcons(fieldName, sortDir) {
    document.querySelectorAll('.sort-icon').forEach(icon => icon.textContent = '');
    const th = document.querySelector(`.sortable-header[data-field="${fieldName}"]`);
    if (th) {
      const icon = th.querySelector('.sort-icon');
      if (icon) icon.textContent = sortDir === 'desc' ? '▼' : '▲';
    }
  }

  // 更新表格內容
  const getEmptyMessage = (openNoRecordFlag, hasQueryFlag) => {
    return (openNoRecordFlag && !hasQueryFlag) ? "（請先使用查詢功能）" : "（無資料）";
  };

  const trimZeroDecimal = (value) => {
    if (value === null || value === undefined) return "";
    const text = String(value);
    const idx = text.indexOf(".");
    if (idx < 0) return text;
    const head = text.slice(0, idx + 1);
    let tail = text.slice(idx + 1);
    tail = tail.replace(/0+$/, "");
    if (!tail) return head.slice(0, -1);
    return head + tail;
  };

  const getDecimalScale = (dataType) => {
    if (!dataType) return null;
    const s = String(dataType).trim().toLowerCase();
    if (!s.startsWith("decimal") && !s.startsWith("numeric")) return null;
    const l = s.indexOf("(");
    const r = s.indexOf(")");
    if (l < 0 || r <= l) return 0;
    const inner = s.slice(l + 1, r);
    const parts = inner.split(",");
    if (parts.length === 2) {
      const n = parseInt(parts[1].trim(), 10);
      return Number.isFinite(n) ? Math.max(0, n) : 0;
    }
    return 0;
  };

  const isDecimalString = (value) => {
    if (value === null || value === undefined) return false;
    const text = String(value).trim();
    if (!text) return false;
    return /^[+-]?\d+\.\d+$/.test(text);
  };

  const isFieldVisibleForEmpty = (f) => {
    const v = f?.Visible;
    if (v === null || v === undefined || v === "") return true;
    if (typeof v === "boolean") return v;
    const n = Number(v);
    if (Number.isFinite(n)) return n !== 0;
    const s = String(v).trim().toLowerCase();
    if (s === "false" || s === "0" || s === "n") return false;
    return true;
  };

  const buildEmptyGridRowsHtml = (fields, rowCount = 12) => {
    const cols = Array.isArray(fields) ? fields : [];
    const rows = Math.max(1, Number(rowCount) || 1);
    let html = "";
    for (let i = 0; i < rows; i++) {
      html += '<tr class="sg-empty-row">';
      cols.forEach(f => {
        const hidden = !isFieldVisibleForEmpty(f);
        const fieldName = (f?.FieldName ?? '').toString();
        const dt = (f?.DataType || '').toString().toLowerCase();
        const isNumber = dt.includes('number') || dt.startsWith('decimal') || dt.startsWith('numeric')
          || dt.startsWith('money') || dt.startsWith('smallmoney') || dt.startsWith('float') || dt.startsWith('real')
          || dt.startsWith('int') || dt.startsWith('smallint') || dt.startsWith('tinyint') || dt.startsWith('bigint');
        const cellClass = isNumber ? 'cell-number' : 'cell-text';
        const readOnly = !(f?.ReadOnly == null || f?.ReadOnly == 0 || f?.ReadOnly === false || String(f?.ReadOnly) === '');
        const tdClass = 'text-nowrap ' + cellClass + (readOnly ? ' readonly-td' : '');
        const roClass = readOnly ? ' readonly-cell' : '';
        const roAttr = readOnly ? ' readonly' : '';
        html += '<td class="' + tdClass + '" data-field="' + fieldName + '" tabindex="-1"'
          + (hidden ? ' style="display:none;"' : '')
          + '><span class="cell-view' + roClass + '" data-raw="" data-lookupkey="">&nbsp;</span>'
          + '<input class="form-control form-control-sm cell-edit d-none' + roClass + '" type="text"'
          + ' name="' + fieldName + '" value="" data-raw="" data-lookupkey="" data-readonly="' + (readOnly ? '1' : '0') + '"' + roAttr + ' />'
          + '</td>';
      });
      html += "</tr>";
    }
    return html;
  };

  function updateTableBody(items, fields, emptyMessage) {
    const tbody = sortTableBody || document.querySelector("#mainGrid tbody");
    if (!tbody) return;

    if (!items || items.length === 0) {
      tbody.innerHTML = buildEmptyGridRowsHtml(fields, 1);
      window.SELECTED_ROW = null;
      clearActiveCell();
      updateCountPanel(0);
      return;
    }

    const ocxLookupPayload = @Html.Raw(JsonSerializer.Serialize(ocxLookupPayload));

    tbody.innerHTML = items.map(item => {
      return '<tr>' + fields.map(f => {
        const fieldName = f.FieldName;
        const rawVal = item[fieldName] ?? item[fieldName?.toLowerCase()] ?? '';
        const isHidden = f.Visible == 0;
        const hiddenStyle = isHidden ? 'display:none;' : '';
        const isReadOnly = f.ReadOnly != null && f.ReadOnly != 0;
        const dt = (f.DataType || '').toString().toLowerCase();
        const isNumber = dt.includes('number') || dt.startsWith('decimal') || dt.startsWith('numeric')
          || dt.startsWith('money') || dt.startsWith('smallmoney') || dt.startsWith('float') || dt.startsWith('real')
          || dt.startsWith('int') || dt.startsWith('smallint') || dt.startsWith('tinyint') || dt.startsWith('bigint');
        const cellClass = isNumber ? 'cell-number' : 'cell-text';

        // 計算 lookupKey（與初始渲染邏輯一致）
        let lookupKey = rawVal;
        const ocxLookup = ocxLookupPayload[fieldName?.toLowerCase()];
        if (ocxLookup) {
          const keyFieldName = ocxLookup.keyField;
          const keySelfName = ocxLookup.keySelf;

          let keyFieldVal = '';
          let keySelfVal = '';

          if (keyFieldName) {
            const kfVal = item[keyFieldName] ?? item[keyFieldName?.toLowerCase()];
            keyFieldVal = (kfVal !== null && kfVal !== undefined) ? String(kfVal) : '';
          }
          if (keySelfName) {
            const ksVal = item[keySelfName] ?? item[keySelfName?.toLowerCase()];
            keySelfVal = (ksVal !== null && ksVal !== undefined) ? String(ksVal) : '';
          }

          // 優先使用 keyFieldVal，其次 keySelfVal，最後才用 rawVal
          // 這樣可以確保 lookup 欄位（如 StatusName）能用對應的 key 欄位（如 Status）的值
          if (keyFieldVal !== '') {
            lookupKey = keyFieldVal;
          } else if (keySelfVal !== '') {
            lookupKey = keySelfVal;
          } else if (lookupKey === '' && rawVal !== null && rawVal !== undefined) {
            lookupKey = String(rawVal);
          }
        }

        // 標準 Lookup key（非實體欄位用）：若 lookupKey 仍為空，從 LookupKeyField 取同列值
        if (!lookupKey) {
          const fmeta = (Array.isArray(fieldFormatMap) ? fieldFormatMap : [])
            .find(x => (x.FieldName || '').toLowerCase() === (fieldName || '').toLowerCase());
          if (fmeta?.LookupKeyField) {
            const kfVal = item[fmeta.LookupKeyField] ?? item[(fmeta.LookupKeyField || '').toLowerCase()];
            if (kfVal !== null && kfVal !== undefined) lookupKey = String(kfVal);
          }
        }

        // 簡單格式化
        let displayVal = rawVal;
        const dateFormatMode = window._singleGridDateFormat || '';
        const formatDateValue = (val, dateOnly) => {
          const date = new Date(val);
          if (isNaN(date)) {
            if (dateOnly) {
              const m = String(val).match(/(\d{4})[/-](\d{1,2})[/-](\d{1,2})/);
              if (m) {
                const y = m[1];
                const mm = String(m[2]).padStart(2, '0');
                const dd = String(m[3]).padStart(2, '0');
                return `${y}/${mm}/${dd}`;
              }
            }
            return String(val);
          }
          const y = date.getFullYear();
          const m = String(date.getMonth() + 1).padStart(2, '0');
          const d = String(date.getDate()).padStart(2, '0');
          if (dateOnly || dateFormatMode === 'date') return `${y}/${m}/${d}`;
          const hh = String(date.getHours()).padStart(2, '0');
          const mm = String(date.getMinutes()).padStart(2, '0');
          const ss = String(date.getSeconds()).padStart(2, '0');
          return `${y}/${m}/${d} ${hh}:${mm}:${ss}`;
        };

        if (rawVal instanceof Date || (typeof rawVal === 'string' && rawVal.match(/^\d{4}-\d{2}-\d{2}/))) {
          const fmtMeta = fieldFormatMap?.find?.(x => (x.FieldName || "").toLowerCase() === (fieldName || "").toLowerCase());
          const fmt = (fmtMeta?.FormatStr || "").toString();
          const fmtLower = fmt.toLowerCase();
          const hasTime = fmtLower.includes("hh") || fmtLower.includes("nn") || fmtLower.includes("ss");
          if (fmt) displayVal = formatDateValue(rawVal, !hasTime);
          else if (dateFormatMode) displayVal = formatDateValue(rawVal, true);
          else {
            const date = new Date(rawVal);
            if (!isNaN(date)) {
              displayVal = date.toLocaleDateString('zh-TW') + ' ' + date.toLocaleTimeString('zh-TW', {hour: '2-digit', minute: '2-digit'});
            }
          }
        } else if (typeof rawVal === 'number') {
          const scale = getDecimalScale(dt);
          displayVal = scale !== null ? trimZeroDecimal(rawVal.toLocaleString('zh-TW', { maximumFractionDigits: 8 })) : trimZeroDecimal(rawVal.toLocaleString('zh-TW'));
        } else if (typeof rawVal === 'string' && (isNumber || isDecimalString(rawVal) || getDecimalScale(dt) !== null)) {
          displayVal = trimZeroDecimal(rawVal);
        }

        // 安全處理值，避免 0 被視為 falsy
        const dateInputEnabled = enableDatePicker && isDateField(fieldName);
        const editRawVal = dateInputEnabled ? toDateInputValue(rawVal) : ((rawVal !== null && rawVal !== undefined) ? String(rawVal) : '');
        const safeRawVal = (rawVal !== null && rawVal !== undefined) ? String(rawVal) : '';
        const safeLookupKey = (lookupKey !== null && lookupKey !== undefined) ? String(lookupKey) : '';
        const safeDisplayVal = (displayVal !== null && displayVal !== undefined) ? String(displayVal) : '';

        // 辭典底色與勾選框
        const fmtMeta = fieldFormatMap?.find?.(x => (x.FieldName || '').toLowerCase() === (fieldName || '').toLowerCase());
        const editColorRaw = (fmtMeta?.EditColor || '').trim();
        const bgStyle = (!disableEditColor && editColorRaw) ? 'background-color:' + normalizeEditColor(editColorRaw) + '!important;' : '';
        const tdStyle = bgStyle + hiddenStyle;
        const isCheckboxCell = (fmtMeta?.ComboStyle ?? 0) === 1;

        if (isCheckboxCell) {
          const checked = safeRawVal === '1' || safeRawVal.toLowerCase() === 'true';
          const initVal = checked ? '1' : '0';
          const chkAttr = checked ? 'checked' : '';
          const roAttr = isReadOnly ? 'disabled data-readonly="1"' : 'data-readonly="0"';
          return '<td class="text-nowrap text-center' + (isReadOnly ? ' readonly-td' : '') + '" data-field="' + fieldName + '" data-checkbox="1" style="' + tdStyle + '" tabindex="-1">' +
            '<input type="checkbox" class="sg-chk-view form-check-input" ' + chkAttr + ' disabled />' +
            '<input type="hidden" class="cell-edit" name="' + fieldName + '" value="' + initVal + '" data-raw="' + initVal + '" data-readonly="' + (isReadOnly ? '1' : '0') + '" />' +
            '<input type="checkbox" class="sg-chk-edit form-check-input" ' + chkAttr + ' ' + roAttr + ' />' +
            '</td>';
        }

        // 產生與初始渲染一致的結構，包含 data-field, cell-view, cell-edit
        const tdClass = 'text-nowrap ' + cellClass + (isReadOnly ? ' readonly-td' : '');
        return '<td class="' + tdClass + '" data-field="' + fieldName + '" style="' + tdStyle + '" tabindex="-1">' +
          '<span class="cell-view' + (isReadOnly ? ' readonly-cell' : '') + '" data-raw="' + safeRawVal + '" data-lookupkey="' + safeLookupKey + '">' + safeDisplayVal + '</span>' +
          '<input class="form-control form-control-sm cell-edit d-none ' + (isReadOnly ? 'readonly-cell' : '') + '" ' +
          'type="' + (dateInputEnabled ? 'date' : 'text') + '" ' +
          'name="' + fieldName + '" ' +
          'value="' + editRawVal + '" ' +
          'data-raw="' + editRawVal + '" ' +
          'data-lookupkey="' + safeLookupKey + '" ' +
          'data-readonly="' + (isReadOnly ? '1' : '0') + '" ' +
          (isReadOnly ? 'readonly' : '') + ' />' +
          '</td>';
      }).join('') + '</tr>';
    }).join('');

    // 套用 checkbox 轉換（根據 ComboStyle）
    applyCheckboxCells();

    window.SELECTED_ROW = null;
    clearActiveCell();
    updateCountPanel(0);
    if (pendingSelect) {
      const rows = Array.from(tbody.querySelectorAll("tr"));
      if (rows.length > 0) {
        const idx = pendingSelect === "last" ? rows.length - 1 : 0;
        selectRow(rows[idx]);
      }
      pendingSelect = "";
    }
  }

  // 將函式暴露到 window，供外部 JS（如 singlegrid/*.js）呼叫
  window._sgUpdateTableBody = updateTableBody;
  window._sgApplyLookup = applyLookupToTable;
  window._sgTableFields = @Html.Raw(fieldsJson);

  let suppressSortClickUntil = 0;
  let draggingHeaderField = "";

  const getFieldKey = (el) => (el?.getAttribute("data-field") || "").toLowerCase();
  const getHeaderCells = () => Array.from(table.querySelectorAll("thead th[data-field]"));
  const COL_ORDER_KEY = tableName ? `singlegrid:colOrder:${String(tableName).toLowerCase()}` : "";
  const clearHeaderDragMarks = () => {
    getHeaderCells().forEach(h => h.classList.remove("col-dragging", "col-drag-over-left", "col-drag-over-right"));
  };

  const moveColumnByField = (dragFieldKey, targetFieldKey, placeAfter) => {
    const headerRow = table.querySelector("thead tr");
    const colGroup = table.querySelector("colgroup");
    if (!headerRow || !colGroup) return false;

    const headerCells = Array.from(headerRow.querySelectorAll("th[data-field]"));
    const fromTh = headerCells.find(th => getFieldKey(th) === dragFieldKey);
    const toTh = headerCells.find(th => getFieldKey(th) === targetFieldKey);
    if (!fromTh || !toTh || fromTh === toTh) return false;
    headerRow.insertBefore(fromTh, placeAfter ? toTh.nextSibling : toTh);

    const cols = Array.from(colGroup.querySelectorAll("col[data-field]"));
    const fromCol = cols.find(c => getFieldKey(c) === dragFieldKey);
    const toCol = cols.find(c => getFieldKey(c) === targetFieldKey);
    if (fromCol && toCol && fromCol !== toCol) {
      colGroup.insertBefore(fromCol, placeAfter ? toCol.nextSibling : toCol);
    }

    table.querySelectorAll("tbody tr").forEach(tr => {
      const cells = Array.from(tr.querySelectorAll("td[data-field]"));
      const fromTd = cells.find(td => getFieldKey(td) === dragFieldKey);
      const toTd = cells.find(td => getFieldKey(td) === targetFieldKey);
      if (!fromTd || !toTd || fromTd === toTd) return;
      tr.insertBefore(fromTd, placeAfter ? toTd.nextSibling : toTd);
    });

    syncTableWidthFromCols();
    return true;
  };

  const getCurrentColumnOrder = () =>
    getHeaderCells()
      .map(th => th.getAttribute("data-field") || "")
      .filter(Boolean);

  const saveColumnOrder = () => {
    if (!COL_ORDER_KEY) return;
    try {
      localStorage.setItem(COL_ORDER_KEY, JSON.stringify(getCurrentColumnOrder()));
    } catch { }
  };

  const applyColumnOrder = (order) => {
    if (!Array.isArray(order) || order.length === 0) return false;
    const headerRow = table.querySelector("thead tr");
    const colGroup = table.querySelector("colgroup");
    if (!headerRow || !colGroup) return false;

    const headerMap = new Map(Array.from(headerRow.querySelectorAll("th[data-field]"))
      .map(th => [String(th.getAttribute("data-field") || "").toLowerCase(), th]));
    const colMapLive = new Map(Array.from(colGroup.querySelectorAll("col[data-field]"))
      .map(col => [String(col.getAttribute("data-field") || "").toLowerCase(), col]));

    const orderedKeys = order.map(x => String(x || "").toLowerCase()).filter(k => headerMap.has(k));
    const remainingKeys = Array.from(headerMap.keys()).filter(k => !orderedKeys.includes(k));
    const finalKeys = [...orderedKeys, ...remainingKeys];
    if (!finalKeys.length) return false;

    finalKeys.forEach(k => {
      const th = headerMap.get(k);
      if (th) headerRow.appendChild(th);
    });
    finalKeys.forEach(k => {
      const col = colMapLive.get(k);
      if (col) colGroup.appendChild(col);
    });
    table.querySelectorAll("tbody tr").forEach(tr => {
      const tdMap = new Map(Array.from(tr.querySelectorAll("td[data-field]"))
        .map(td => [String(td.getAttribute("data-field") || "").toLowerCase(), td]));
      finalKeys.forEach(k => {
        const td = tdMap.get(k);
        if (td) tr.appendChild(td);
      });
    });
    syncTableWidthFromCols();
    return true;
  };

  const loadSavedColumnOrder = () => {
    if (!COL_ORDER_KEY) return;
    try {
      const raw = localStorage.getItem(COL_ORDER_KEY);
      if (!raw) return;
      const order = JSON.parse(raw);
      applyColumnOrder(order);
    } catch { }
  };

  const bindHeaderDragReorder = () => {
    getHeaderCells().forEach(th => {
      if (th.dataset.dragBound === "1") return;
      th.dataset.dragBound = "1";
      th.setAttribute("draggable", "true");

      th.addEventListener("dragstart", (e) => {
        if (e.target?.closest?.(".col-resizer")) {
          e.preventDefault();
          return;
        }
        const field = getFieldKey(th);
        if (!field) return;
        draggingHeaderField = field;
        clearHeaderDragMarks();
        th.classList.add("col-dragging");
        if (e.dataTransfer) {
          e.dataTransfer.effectAllowed = "move";
          try { e.dataTransfer.setData("text/plain", field); } catch { }
        }
      });

      th.addEventListener("dragover", (e) => {
        if (!draggingHeaderField) return;
        const targetField = getFieldKey(th);
        if (!targetField || targetField === draggingHeaderField) return;
        e.preventDefault();
        const rect = th.getBoundingClientRect();
        const placeAfter = e.clientX >= rect.left + rect.width / 2;
        th.classList.toggle("col-drag-over-left", !placeAfter);
        th.classList.toggle("col-drag-over-right", placeAfter);
        if (e.dataTransfer) e.dataTransfer.dropEffect = "move";
      });

      th.addEventListener("dragleave", () => {
        th.classList.remove("col-drag-over-left", "col-drag-over-right");
      });

      th.addEventListener("drop", (e) => {
        if (!draggingHeaderField) return;
        e.preventDefault();
        const targetField = getFieldKey(th);
        if (!targetField || targetField === draggingHeaderField) {
          clearHeaderDragMarks();
          suppressSortClickUntil = Date.now() + 260;
          return;
        }
        const rect = th.getBoundingClientRect();
        const placeAfter = e.clientX >= rect.left + rect.width / 2;
        moveColumnByField(draggingHeaderField, targetField, placeAfter);
        saveColumnOrder();
        clearHeaderDragMarks();
        suppressSortClickUntil = Date.now() + 260;
      });

      th.addEventListener("dragend", () => {
        draggingHeaderField = "";
        clearHeaderDragMarks();
        suppressSortClickUntil = Date.now() + 220;
      });
    });
  };

  // AJAX 排序處理
  async function handleSort(fieldName) {
    if (isSorting) return;

    const fields = @Html.Raw(fieldsJson);
    const ocxLookupPayload = @Html.Raw(JsonSerializer.Serialize(ocxLookupPayload));

    // 計算實際要排序的欄位名稱
    let actualFieldName = fieldName;
    const fieldDef = fields.find(f => f.FieldName === fieldName);

    // 判斷是否為非實體欄位：DataType 為空或 null 表示非實體欄位
    const isVirtualField = fieldDef && (!fieldDef.DataType || fieldDef.DataType === '');

    // 檢查是否為非實體欄位
    if (isVirtualField) {
      // 嘗試從 OCXLookup 找到對應的 KeyField
      const lookupInfo = ocxLookupPayload[fieldName.toLowerCase()];
      if (lookupInfo && lookupInfo.keyField) {
        // 使用 lookup 的 keyField 作為實際排序欄位
        actualFieldName = lookupInfo.keyField;
      } else if (fieldName.endsWith('Name')) {
        // 嘗試去掉 Name 後綴找到對應的實體欄位
        const baseFieldName = fieldName.substring(0, fieldName.length - 4);
        const baseField = fields.find(f => f.FieldName === baseFieldName && f.DataType);
        if (baseField) {
          actualFieldName = baseFieldName;
        }
      }

      // 如果還是找不到對應的實體欄位，則無法排序
      if (actualFieldName === fieldName) {
        Swal.fire({ icon: 'info', title: '此欄位不支援排序', text: '找不到對應的實體欄位', timer: 2000, showConfirmButton: false });
        return;
      }
    }

    isSorting = true;
    showLoading();

    try {
      const fallbackSortByReload = () => {
        const navUrl = new URL(window.location.href);
        navUrl.searchParams.delete("handler");
        navUrl.searchParams.delete("_sgall");
        navUrl.searchParams.set("sortBy", actualFieldName);
        navUrl.searchParams.set("sortDir", newSortDir);
        navUrl.searchParams.set("pageIndex", "1");
        navUrl.searchParams.set("pageSize", String(Math.max(1, pageSize || totalCountAll || 1)));
        navUrl.hash = "";
        window.location.href = navUrl.toString();
      };

      // 決定新的排序方向（使用實際欄位名稱比較）
      let newSortDir = 'asc';
      if (currentSortBy === actualFieldName) {
        newSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
      }

      // 呼叫 AJAX API
      const urlObj = new URL(window.location.href);
      urlObj.searchParams.set("handler", "Data");
      urlObj.searchParams.set("sortBy", actualFieldName);
      urlObj.searchParams.set("sortDir", newSortDir);
      urlObj.searchParams.set("pageIndex", "1");
      urlObj.searchParams.set("pageSize", String(Math.max(1, pageSize || totalCountAll || 1)));
      const url = urlObj.toString();
      const response = await fetch(url);

      if (!response.ok) {
        throw new Error('HTTP error! status: ' + response.status);
      }

      const contentType = (response.headers.get("content-type") || "").toLowerCase();
      let data = null;
      if (contentType.includes("application/json")) {
        data = await response.json();
      } else {
        const text = await response.text();
        try {
          data = JSON.parse(text);
        } catch {
          fallbackSortByReload();
          return;
        }
      }

      if (!data || !data.success) {
        throw new Error(data.error || 'Unknown error');
      }

      // 更新表格
      const emptyMessage = getEmptyMessage(!!data.openNoRecord, !!data.hasQueryParams);
      updateTableBody(data.items, fields, emptyMessage);
      loadSavedColumnOrder();
      await loadStandardLookups();
      applyLookupToTable(); // 套用 lookup 顯示
      applyLookupDropdowns();

      // 更新排序狀態（使用實際傳送的欄位名稱）
      currentSortBy = actualFieldName;
      currentSortDir = newSortDir;
      updateSortIcons(fieldName, newSortDir);

    } catch (err) {
      console.error('Sort failed:', err);
      Swal.fire({ icon: 'error', title: '排序失敗', text: err.message });
    } finally {
      hideLoading();
      isSorting = false;
    }
  }

  bindHeaderDragReorder();
  loadSavedColumnOrder();

  // 綁定點擊排序
  headers.forEach(headerLabel => {
    headerLabel.addEventListener("click", (e) => {
      e.stopPropagation(); // 防止觸發 col-resizer
      if (Date.now() < suppressSortClickUntil) return;
      const th = headerLabel.closest("th");
      const fieldName = th?.getAttribute("data-field");
      if (fieldName) handleSort(fieldName);
    });
  });

  if (!disableAutoLoadAllRows) {
    loadAllRowsIfNeeded();
  }

});
</script>

@if (ViewData["QueryFieldModalsRendered"] == null)
{
    @await Html.PartialAsync("~/Pages/Shared/_QueryFieldModals.cshtml")
}
