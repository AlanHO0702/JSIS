        return;
      }
      const wrapperRect = wrapper.getBoundingClientRect();
      const rowRect = tr.getBoundingClientRect();
      const header = table?.querySelector("thead");
      const headerRect = header ? header.getBoundingClientRect() : null;
      const headerHeight = headerRect ? headerRect.height : 0;
      const margin = 6;
      const rowTop = rowRect.top - wrapperRect.top + wrapper.scrollTop;
      const rowBottom = rowTop + rowRect.height;
      const viewTop = wrapper.scrollTop + headerHeight + margin;
      const viewBottom = wrapper.scrollTop + wrapper.clientHeight - margin;
      if (rowTop < viewTop) {
        wrapper.scrollTop = Math.max(0, rowTop - headerHeight - margin);
      } else if (rowBottom > viewBottom) {
        wrapper.scrollTop = Math.max(0, rowBottom - wrapper.clientHeight + margin);
