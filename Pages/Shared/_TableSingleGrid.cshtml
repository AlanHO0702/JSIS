    positionSingleGridLookup(list, input);
    document.addEventListener("mousedown", onSingleGridLookupDocDown, true);
    document.addEventListener("pointerdown", onSingleGridLookupDocDown, true);
    document.addEventListener("click", onSingleGridLookupDocDown, true);
    document.addEventListener("focusin", onSingleGridLookupFocusIn, true);
    document.addEventListener("keydown", onSingleGridLookupKeydown, true);
    window.addEventListener("resize", onSingleGridLookupResize, true);
