@model dynamic
@using System.Text.Json
@{
    var fieldsJson = JsonSerializer.Serialize(Model ?? new List<object>());
}

<form id="searchForm" method="post" class="modal-content query-modal-content">
    <div class="modal-header">
        <h5 class="modal-title">查詢條件</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="container-fluid">
            <div class="row g-1 query-field-grid"></div>
        </div>
    </div>
    <div class="modal-footer query-footer">
        <div class="query-footer-left">
            <button id="btnQueryFieldSelect" class="btn btn-outline-secondary btn-sm" type="button">進階</button>
            <button id="btnQueryDefault" class="btn btn-outline-secondary btn-sm" type="button">預設</button>
        </div>
        <div class="query-footer-right">
            <button type="submit" class="btn btn-primary">查詢</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
        </div>
    </div>
</form>

<!-- 查詢條件 Lookup 篩選 Modal -->
<div class="modal fade" id="queryLookupModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="false" style="pointer-events:none;">
  <div class="modal-dialog modal-dialog-scrollable" style="max-width:420px; pointer-events:all;">
    <div class="modal-content" style="font-size:0.78rem;">
      <div class="modal-header py-1 px-2">
        <span class="modal-title fw-bold" id="queryLookupModalTitle" style="font-size:0.8rem;">名稱查詢</span>
        <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal" style="font-size:0.6rem;"></button>
      </div>
      <div class="modal-body p-1">
        <div class="d-flex gap-1 mb-1">
          <input type="text" class="form-control form-control-sm" id="queryLookupSearchCode" placeholder="代碼篩選" style="font-size:0.75rem;">
          <input type="text" class="form-control form-control-sm" id="queryLookupSearchName" placeholder="名稱篩選" style="font-size:0.75rem;">
        </div>
        <div style="max-height:280px; overflow-y:auto;">
          <table class="table table-sm table-hover mb-0" style="font-size:0.75rem;">
            <thead class="table-light sticky-top">
              <tr>
                <th style="width:38%; padding:2px 6px;">代碼</th>
                <th style="padding:2px 6px;">名稱</th>
              </tr>
            </thead>
            <tbody id="queryLookupBody"></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer py-1 px-2">
        <button type="button" class="btn btn-primary btn-sm py-0 px-2" id="queryLookupConfirm" style="font-size:0.75rem;">確定</button>
        <button type="button" class="btn btn-secondary btn-sm py-0 px-2" data-bs-dismiss="modal" style="font-size:0.75rem;">取消</button>
      </div>
    </div>
  </div>
</div>

<style>
    .query-modal-content .modal-header { cursor: move; user-select: none; padding: 6px 12px; }
    .query-modal-content .modal-header :is(button, input, select, textarea, a) { cursor: default; }
    /* 視窗寬度：讓包含查詢面板的 modal-dialog 變寬 */
    .modal-dialog:has(.query-modal-content) { max-width: 980px; }
    .query-modal-content .query-op { flex: 0 0 72px; min-width: 72px; max-width: 72px; }
    .query-modal-content .query-input { flex: 0 0 160px; min-width: 160px; max-width: 160px; }
    .query-modal-content .query-lookup-wrap { flex: 0 0 160px; min-width: 160px; max-width: 160px; display: flex; align-items: stretch; }
    .query-modal-content .modal-body { padding: 10px 16px; height: 64vh; overflow-y: auto; }
    .query-modal-content .modal-header { display: flex; align-items: center; gap: 10px; }
    .query-modal-content .modal-title { margin: 0; }
    .query-modal-content .query-footer { display: flex; align-items: center; justify-content: space-between; }
    .query-modal-content .query-footer-left { display: flex; gap: 6px; }
    .query-modal-content .query-footer-right { display: flex; gap: 8px; }
    .query-field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 24px; row-gap: 2px; }
    .query-field-grid > .query-item { box-sizing: border-box; }
    .query-field-grid .query-item { display: flex; }
    .query-field-grid .query-row { display: flex; align-items: center; gap: 6px; }
    .query-field-grid .col-md-6:nth-child(2n) .query-row { justify-content: flex-end; }
    .query-field-grid .col-md-6:nth-child(2n+1) .query-row { justify-content: flex-start; }
    .query-field-grid .query-label {
        flex: 0 0 96px;
        text-align: right;
        font-size: var(--field-label-size);
        line-height: 1.2;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    @@media (max-width: 991.98px) {
        .query-field-grid { grid-template-columns: 1fr; }
    }
    .query-field-grid .query-input,
    .query-field-grid .query-op {
        height: 26px;
        padding-top: 2px;
        padding-bottom: 2px;
        font-size: var(--field-value-size);
    }
    .query-date-wrap {
        position: relative;
        flex: 0 0 160px;
        min-width: 160px;
        max-width: 160px;
    }
    .query-date-wrap .query-input {
        padding-right: 28px;
    }
    .query-date-btn {
        position: absolute;
        right: 4px;
        top: 50%;
        transform: translateY(-50%);
        border: 0;
        background: transparent;
        padding: 0;
        width: 18px;
        height: 18px;
        cursor: pointer;
    }
    .query-date-btn::before {
        content: "";
        display: block;
        width: 6px;
        height: 6px;
        margin: 0 auto;
        border-right: 1.5px solid #6b7280;
        border-bottom: 1.5px solid #6b7280;
        transform: rotate(45deg) translateY(-1px);
    }
    .query-date-btn:disabled {
        opacity: .5;
        cursor: not-allowed;
    }
    .query-date-picker-proxy {
        position: absolute;
        opacity: 0;
        pointer-events: none;
        width: 1px;
        height: 1px;
    }
    /* --- 查詢 Lookup：完全自給自足，不依賴 _DetailHeaderSection.cshtml --- */
    .query-lookup-wrap {
        display: flex; align-items: stretch; box-sizing: border-box;
    }
    .query-lookup-wrap .lookup-code-wrap {
        position: relative;
        width: 82px !important; min-width: 60px !important; max-width: 82px !important;
        align-self: stretch; display: flex; align-items: stretch; flex: 0 0 auto;
    }
    .query-lookup-wrap .lookup-code-wrap input {
        flex: 1 1 auto !important; width: 100% !important;
        height: 26px !important; padding-top: 2px !important; padding-bottom: 2px !important;
        font-size: var(--field-value-size) !important; padding-right: 22px !important;
        box-sizing: border-box !important;
    }
    .query-lookup-wrap .lookup-toggle {
        position: absolute; right: 4px; top: 50%; transform: translateY(-50%);
        width: 18px; height: 18px; border: 0; background: transparent; cursor: pointer; z-index: 6;
        flex-shrink: 0;
    }
    .query-lookup-wrap .lookup-toggle::before {
        content: "";
        display: block;
        width: 6px;
        height: 6px;
        margin: 0 auto;
        border-right: 1.5px solid #6b7280;
        border-bottom: 1.5px solid #6b7280;
        transform: rotate(45deg) translateY(-1px);
    }
    .query-lookup-wrap .lookup-name-btn {
        flex: 1 1 auto; min-width: 0; align-self: stretch;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        padding: 0 6px;
        background: var(--bs-body-bg, #fff);
        border: 1px solid #ced4da; border-left: none;
        border-radius: 0 4px 4px 0;
        font-size: var(--field-value-size); line-height: 26px;
        cursor: pointer; color: var(--bs-body-color, #495057);
        box-sizing: border-box; display: block; text-align: left;
    }
    .query-lookup-wrap .lookup-name-btn:hover { background: #f8f9fa; }
    /* 行內下拉清單 */
    .query-lookup-panel {
        display: none; position: absolute; top: 100%; left: 0; z-index: 9999;
        background: #fff; border: 1px solid #b9c7de; border-radius: 0 0 6px 6px;
        box-shadow: 0 4px 12px rgba(0,0,0,.15); max-height: 180px; overflow-y: auto;
        min-width: 100%; width: max-content; max-width: 280px;
    }
    .query-lookup-panel.open { display: block; }
    .query-lookup-panel-item {
        padding: 2px 8px; cursor: pointer; font-size: var(--field-value-size); white-space: nowrap;
    }
    .query-lookup-panel-item:hover, .query-lookup-panel-item.active { background: #2d5fa8; color: #fff; }
</style>

<script>
(() => {
    const formEl = document.getElementById("searchForm");
    const gridEl = formEl?.querySelector(".query-field-grid");
    if (!formEl || !gridEl) return;
    const busyFetch = (input, init, msg) => {
        if (typeof window.busyFetch === "function") return window.busyFetch(input, init, msg);
        return fetch(input, init);
    };
    const modalEl = formEl.closest(".modal");
    if (modalEl && modalEl.parentElement !== document.body) {
        document.body.appendChild(modalEl);
    }
    // queryLookupModal 需獨立掛在 body，避免巢狀在 searchModal 裡導致 Bootstrap 互相干擾
    const qlModalDom = document.getElementById('queryLookupModal');
    if (qlModalDom && qlModalDom.parentElement !== document.body) {
        document.body.appendChild(qlModalDom);
    }

    const fallbackFields = @Html.Raw(fieldsJson);
    let cachedFields = null;
    let cachedEquals = null;
    let building = false;

    const normalizeKey = (v) => (v || "").toString().trim().replace(/^@@+/, "").toLowerCase();

    const getItemId = () => (window._itemId || window._singleItemId || "").toString().trim();
    const getTable = () => {
        // 單身頁優先用 PAGE.headerTable（主表），確保查詢面板欄位與 sub-ToolbarHandler 搜尋的表一致
        if (typeof PAGE !== "undefined" && PAGE.headerTable) return PAGE.headerTable;
        return (window._dictTableName || window._tableName || "").toString().trim();
    };

    const getUserId = () => (localStorage.getItem("erpLoginUserId") || window._userId || "").toString().trim();
    const getUseId = () => (localStorage.getItem("erpLoginBUId") || window.DEFAULT_USEID || window._useId || "A001").toString().trim();

    const applyDefaultByType = (field) => {
        const defType = Number(field.defaultType ?? field.DefaultType ?? 0);
        if (defType === 2) return getUserId();
        if (defType === 3) return getUseId();
        const raw = field.defaultValue ?? field.DefaultValue;
        return raw ?? "";
    };

    const looksLikeSqlDefault = (val) => {
        if (typeof val !== "string") return false;
        return /\bselect\b/i.test(val);
    };

    const isDatePlaceholder = (val) => {
        if (val == null) return false;
        const s = String(val).trim();
        const lower = s.toLowerCase();
        // 瑼Ｘ撣貉????雿泵?澆?嚗??思葉????
        return lower === "yyyy/mm/dd" ||
               lower === "yyyy-mm-dd" ||
               lower === "yyyy/月/dd" ||
               /^yyyy[\/-]mm[\/-]dd$/i.test(s) ||
               /^yyyy[\/-]月[\/-]dd$/i.test(s);
    };

    const applyEditMask = (value, field) => {
        if (typeof window.normalizeForDateInput === "function") {
            const fake = { type: "date", dataset: { field: field.columnName || field.ColumnName || "" } };
            return window.normalizeForDateInput(fake, value);
        }
        return value;
    };

    const normalizeDateValue = (val) => {
        if (val == null) return "";
        const s = String(val).trim();
        if (!s) return "";
        if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
        if (/^\d{4}\/\d{1,2}\/\d{1,2}$/.test(s)) {
            const [y, m, d] = s.split("/");
            return `${y}-${m.padStart(2, "0")}-${d.padStart(2, "0")}`;
        }
        const m = s.match(/^(\d{4})[\/-](\d{1,2})[\/-](\d{1,2})(?:\s+(上午|下午))?(?:\s+(\d{1,2}):(\d{2})(?::(\d{2}))?)?/);
        if (m) {
            const y = m[1];
            const mo = m[2].padStart(2, "0");
            const d = m[3].padStart(2, "0");
            let hour = m[5] ? Number(m[5]) : 0;
            const ap = m[4];
            if (ap === "下午" && hour < 12) hour += 12;
            if (ap === "上午" && hour === 12) hour = 0;
            return `${y}-${mo}-${d}`;
        }
        const parsed = new Date(s);
        if (!Number.isNaN(parsed.getTime())) {
            const year = parsed.getFullYear();
            if (!Number.isInteger(year) || year < 1 || year > 9999) return "";
            const y = String(year).padStart(4, "0");
            const mo = String(parsed.getMonth() + 1).padStart(2, "0");
            const d = String(parsed.getDate()).padStart(2, "0");
            return `${y}-${mo}-${d}`;
        }
        return "";
    };

    const toDisplayDate = (ymd) => {
        const m = String(ymd ?? "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!m) return "";
        return `${m[1]}/${m[2]}/${m[3]}`;
    };

    const fetchEquals = async () => {
        if (cachedEquals) return cachedEquals;
        try {
            const res = await busyFetch("/api/DictSetupApi/QueryEquals", null, "載入查詢條件…");
            if (!res.ok) throw new Error(await res.text());
            const list = await res.json();
            cachedEquals = Array.isArray(list) ? list : [];
        } catch {
            cachedEquals = [
                { value: "=", text: "=" },
                { value: ">=", text: ">=" },
                { value: "<=", text: "<=" },
                { value: "like", text: "like" }
            ];
        }
        return cachedEquals;
    };

    const mergeResolvedDefaults = (selected, resolved) => {
        if (!Array.isArray(selected) || !Array.isArray(resolved)) return selected;
        const map = new Map();
        resolved.forEach(r => {
            const key = normalizeKey(r?.columnName ?? r?.ColumnName ?? "");
            if (key) map.set(key, r);
        });

        // 瑼Ｘ?芯?甈??閬銵?SQL 雿???瑁?蝯?銝?
        const sqlFields = selected.filter(item => {
            const defType = Number(item.defaultType ?? item.DefaultType ?? 0);
            const defVal = item?.defaultValue ?? item?.DefaultValue ?? "";
            return defType === 1 && looksLikeSqlDefault(defVal);
        });

        const missingFields = sqlFields.filter(item => {
            const key = normalizeKey(item?.columnName ?? item?.ColumnName ?? "");
            return key && !map.has(key);
        });
        if (missingFields.length > 0) {
            console.warn(`[QueryPanel] 隞乩? ${missingFields.length} ??雿?閬銵?SQL 雿?瑁?蝯?銝剜銝:`, missingFields.map(f => f.columnName || f.ColumnName));
        }

        selected.forEach(item => {
            const key = normalizeKey(item?.columnName ?? item?.ColumnName ?? "");
            if (!key || !map.has(key)) return;
            const hit = map.get(key);
            const defType = Number(item.defaultType ?? item.DefaultType ?? hit?.defaultType ?? hit?.DefaultType ?? 0);
            const resolvedVal = hit?.defaultValue ?? hit?.DefaultValue ?? "";
            const currentVal = item?.defaultValue ?? item?.DefaultValue ?? "";

            if (defType === 1 && resolvedVal !== "" && looksLikeSqlDefault(currentVal)) {
                item.defaultValue = resolvedVal;
                item.DefaultValue = resolvedVal;
            } else if (!currentVal && resolvedVal) {
                item.defaultValue = resolvedVal;
                item.DefaultValue = resolvedVal;
            }
        });
        return selected;
    };

    const loadQueryFields = async () => {
        if (cachedFields) {
            return cachedFields;
        }
        const itemId = getItemId();
        const table = getTable();
        if (!itemId || !table) {
            console.warn('[QueryPanel] 蝻箏? itemId ??table嚗蝙??fallback 甈?');
            cachedFields = Array.isArray(fallbackFields) ? fallbackFields : [];
            return cachedFields;
        }
        try {
            const url = `/api/DictSetupApi/PaperSelectedList?itemId=${encodeURIComponent(itemId)}&table=${encodeURIComponent(table)}&resolveDefault=1`;
            const res = await busyFetch(url, null, "載入查詢條件…");
            if (!res.ok) throw new Error(await res.text());
            const data = await res.json();
            let selected = Array.isArray(data?.selected) ? data.selected : (Array.isArray(fallbackFields) ? fallbackFields : []);
            console.log('[QueryPanel] API 回傳欄位:', selected.map(f => ({
                col: f.columnName || f.ColumnName,
                ct: f.controlType ?? f.ControlType,
                cmd: (f.commandText || f.CommandText || '').substring(0, 30) || '(empty)'
            })));
            // 憿舐內??3 ??雿? defaultType
            selected.slice(0, 3).forEach(item => {
            });
            const needResolve = selected.some(f => {
                const defType = Number(f?.defaultType ?? f?.DefaultType ?? 0);
                const defVal = f?.defaultValue ?? f?.DefaultValue ?? "";
                return defType === 1 && looksLikeSqlDefault(defVal);
            });
            if (needResolve) {
                try {
                    const res2 = await busyFetch(`/api/DictSetupApi/QueryFields?itemId=${encodeURIComponent(itemId)}&table=${encodeURIComponent(table)}&lang=TW`, null, "載入查詢預設值…");
                    if (res2.ok) {
                        const resolved = await res2.json();
                        selected = mergeResolvedDefaults(selected, resolved);
                    } else {
                        console.error('[QueryPanel] QueryFields API ???航炊:', res2.status);
                    }
                } catch (err) {
                    console.error('[QueryPanel] QueryFields API ?澆憭望?:', err);
                }
            }
            cachedFields = selected;
        } catch (err) {
            console.error('[QueryPanel] 頛查詢甈?憭望?:', err);
            cachedFields = Array.isArray(fallbackFields) ? fallbackFields : [];
        }
        return cachedFields;
    };

    const loadOptions = async (columnName, superValue) => {
        const itemId = getItemId();
        const table = getTable();
        if (!itemId || !table) return [];
        const extra = superValue ? `&superValue=${encodeURIComponent(superValue)}` : "";
        const url = `/api/DictSetupApi/QueryFieldOptions?itemId=${encodeURIComponent(itemId)}&table=${encodeURIComponent(table)}&column=${encodeURIComponent(columnName)}${extra}`;
        const res = await busyFetch(url, null, "載入選項…");
        if (!res.ok) return [];
        const data = await res.json();
        return Array.isArray(data) ? data : [];
    };

    const buildOptionList = (selectEl, options, defaultValue) => {
        selectEl.innerHTML = "";
        const emptyOpt = document.createElement("option");
        emptyOpt.value = "";
        emptyOpt.textContent = "";
        selectEl.appendChild(emptyOpt);

        if (Array.isArray(options)) {
            options.forEach(opt => {
                const o = document.createElement("option");
                const val = opt.value ?? opt.Value ?? "";
                const text = opt.text ?? opt.Text ?? "";
                o.value = val;
                o.textContent = text ? `${val} ${text}`.trim() : val;
                if (text && text !== val) o.title = text;
                selectEl.appendChild(o);
            });
        }

        if (defaultValue && !Array.from(selectEl.options).some(o => o.value === defaultValue)) {
            const o = document.createElement("option");
            o.value = defaultValue;
            o.textContent = defaultValue;
            selectEl.appendChild(o);
        }
        if (defaultValue != null) selectEl.value = defaultValue;
    };

    // ---- 查詢 Lookup Modal（單例，由所有 lookup 欄位共用）----
    let _qlTargetInput = null;
    let _qlSelectedKey = null;
    let _qlModalInst = null;

    const _qlModalEl = () => document.getElementById('queryLookupModal');

    const _qlGetItems = (inp) => inp._lookupItems || [];

    const _qlGetName = (items, key) => {
        if (!key) return "";
        const hit = items.find(i => i.key === key);
        return hit ? hit.label : key;
    };

    const _qlRenderRows = (items, filterCode, filterName, currentKey) => {
        const tbody = document.getElementById('queryLookupBody');
        if (!tbody) return;
        const lc = (filterCode || "").toLowerCase();
        const ln = (filterName || "").toLowerCase();
        tbody.innerHTML = "";
        items.forEach(item => {
            if (lc && !item.key.toLowerCase().includes(lc)) return;
            if (ln && !item.label.toLowerCase().includes(ln)) return;
            const tr = document.createElement('tr');
            tr.dataset.key = item.key;
            tr.style.cursor = 'pointer';
            if (item.key === currentKey) {
                tr.classList.add('table-primary');
                _qlSelectedKey = item.key;
            }
            const tdCode = document.createElement('td');
            tdCode.style.cssText = 'padding:2px 6px;';
            tdCode.textContent = item.key;
            // 名稱欄去掉 "代碼 " 前綴
            const tdName = document.createElement('td');
            tdName.style.cssText = 'padding:2px 6px;';
            const prefix = item.key + " ";
            tdName.textContent = item.label.startsWith(prefix) ? item.label.slice(prefix.length) : item.label;
            tr.appendChild(tdCode);
            tr.appendChild(tdName);
            tr.addEventListener('click', () => {
                tbody.querySelectorAll('tr').forEach(r => r.classList.remove('table-primary'));
                tr.classList.add('table-primary');
                _qlSelectedKey = item.key;
            });
            tr.addEventListener('dblclick', () => {
                _qlSelectedKey = item.key;
                _qlApply();
            });
            tbody.appendChild(tr);
        });
    };

    const _qlApply = () => {
        if (!_qlTargetInput || !_qlSelectedKey) return;
        const inp = _qlTargetInput;
        const items = _qlGetItems(inp);
        const name = _qlGetName(items, _qlSelectedKey);
        inp.value = _qlSelectedKey;
        const nameBtn = inp.closest('.query-lookup-wrap')?.querySelector('.lookup-name-btn');
        if (nameBtn) {
            const prefix = _qlSelectedKey + " ";
            nameBtn.textContent = name.startsWith(prefix) ? name.slice(prefix.length) : name;
        }
        inp.dispatchEvent(new Event('change', { bubbles: true }));
        _qlModalInst?.hide();
    };

    const _qlOpen = (codeInput, caption) => {
        _qlTargetInput = codeInput;
        _qlSelectedKey = null;
        const items = _qlGetItems(codeInput);
        const currentKey = codeInput.value || '';
        const titleEl = document.getElementById('queryLookupModalTitle');
        if (titleEl) titleEl.textContent = caption ? `${caption} 查詢` : '名稱查詢';
        const codeFilterEl = document.getElementById('queryLookupSearchCode');
        const nameFilterEl = document.getElementById('queryLookupSearchName');
        if (codeFilterEl) codeFilterEl.value = '';
        if (nameFilterEl) nameFilterEl.value = '';
        _qlRenderRows(items, '', '', currentKey);
        if (codeFilterEl) codeFilterEl.oninput = () => _qlRenderRows(items, codeFilterEl.value, nameFilterEl?.value || '', currentKey);
        if (nameFilterEl) nameFilterEl.oninput = () => _qlRenderRows(items, codeFilterEl?.value || '', nameFilterEl.value, currentKey);
        const confirmBtn = document.getElementById('queryLookupConfirm');
        if (confirmBtn) confirmBtn.onclick = _qlApply;
        _qlModalInst = bootstrap.Modal.getOrCreateInstance(_qlModalEl(), { backdrop: false, keyboard: true });
        _qlModalInst.show();
        setTimeout(() => { if (codeFilterEl) codeFilterEl.focus(); }, 300);
    };

    // ---- convertToLookup：把 codeInput 包成 Lookup 控件 ----
    const convertToLookup = (codeInput, colName, superId, initialOptions, caption) => {
        // 存選項在元素上（key = code, label = "code name" 或 "code"）
        codeInput._lookupItems = (initialOptions || []).map(o => {
            const key = (o.value ?? o.Value ?? "").toString();
            const text = (o.text ?? o.Text ?? "").toString();
            return { key, label: text ? `${key} ${text}` : key };
        });
        codeInput.dataset.isLookup = "1";

        // 外框（lookup-split-field 複用單頭結構）
        const wrap = document.createElement("div");
        wrap.className = "query-lookup-wrap";
        codeInput.parentNode.insertBefore(wrap, codeInput);

        // 代碼 wrap（同單頭 lookup-code-wrap）
        const codeWrap = document.createElement("div");
        codeWrap.className = "lookup-code-wrap";
        wrap.appendChild(codeWrap);

        // 把 codeInput 移進 codeWrap，套用同單頭的 class
        codeInput.className = "form-control lookup-dropdown lookup-code-input";
        codeWrap.appendChild(codeInput);

        // ▼ Toggle 按鈕（同單頭）
        const toggleBtn = document.createElement("button");
        toggleBtn.type = "button";
        toggleBtn.className = "lookup-toggle";
        toggleBtn.tabIndex = -1;
        toggleBtn.setAttribute("aria-label", "展開查詢");
        codeWrap.appendChild(toggleBtn);

        // 名稱按鈕（同單頭 lookup-name-btn）
        const nameBtn = document.createElement("button");
        nameBtn.type = "button";
        nameBtn.className = "lookup-name-btn";
        nameBtn.tabIndex = -1;
        nameBtn.title = "點擊搜尋";
        wrap.appendChild(nameBtn);

        // 行內下拉清單（附在 codeWrap 下方）
        const dropPanel = document.createElement("div");
        dropPanel.className = "query-lookup-panel";
        codeWrap.appendChild(dropPanel);

        // 輔助：取名稱顯示文字（去掉 "code " 前綴，只留名稱部分）
        const getNameOnly = (key, label) => {
            if (!label || !key) return label || "";
            const prefix = key + " ";
            return label.startsWith(prefix) ? label.slice(prefix.length) : label;
        };

        // 設定選取值
        const applyItem = (key, label) => {
            codeInput.value = key;
            nameBtn.textContent = getNameOnly(key, label);
            dropPanel.classList.remove("open");
            codeInput.dispatchEvent(new Event('change', { bubbles: true }));
        };

        // 設定初始名稱顯示
        const setNameFromCode = (code) => {
            const item = codeInput._lookupItems.find(i => i.key === code);
            nameBtn.textContent = item ? getNameOnly(code, item.label) : "";
        };
        if (codeInput.value) setNameFromCode(codeInput.value);

        // 渲染行內下拉清單
        const renderDropPanel = (filter) => {
            const lc = (filter || "").toLowerCase();
            const items = codeInput._lookupItems;
            const matched = lc ? items.filter(i =>
                i.key.toLowerCase().includes(lc) || i.label.toLowerCase().includes(lc)
            ) : items;
            dropPanel.innerHTML = "";
            matched.slice(0, 200).forEach(item => {
                const div = document.createElement("div");
                div.className = "query-lookup-panel-item" + (item.key === codeInput.value ? " active" : "");
                div.textContent = item.label;
                div.addEventListener("mousedown", e => { e.preventDefault(); applyItem(item.key, item.label); });
                dropPanel.appendChild(div);
            });
            dropPanel.classList.toggle("open", matched.length > 0);
        };

        // ▼ Toggle 按鈕 → 行內下拉
        toggleBtn.addEventListener('click', e => {
            e.stopPropagation();
            if (dropPanel.classList.contains("open")) {
                dropPanel.classList.remove("open");
                return;
            }
            renderDropPanel(codeInput.value);
        });

        // 代碼 input 輸入時過濾行內下拉
        codeInput.addEventListener('input', () => {
            if (codeInput._lookupItems.length) renderDropPanel(codeInput.value);
        });

        // 代碼 input blur 時同步名稱
        codeInput.addEventListener('blur', () => {
            setTimeout(() => { dropPanel.classList.remove("open"); }, 150);
            setNameFromCode(codeInput.value);
            codeInput.dispatchEvent(new Event('change', { bubbles: true }));
        });

        // Delete / Backspace 在空白時清除名稱
        codeInput.addEventListener('keydown', e => {
            if ((e.key === 'Delete' || e.key === 'Backspace') && codeInput.value === '') {
                nameBtn.textContent = '';
                dropPanel.classList.remove("open");
                codeInput.dispatchEvent(new Event('change', { bubbles: true }));
            } else if (e.key === 'Escape') {
                dropPanel.classList.remove("open");
            }
        });

        // 名稱按鈕點擊 → 開啟 Lookup Modal
        const openLookup = () => {
            dropPanel.classList.remove("open");
            if (!codeInput._lookupLoaded && superId) {
                const superValue = readSuperValue(superId);
                loadOptions(colName, superValue).then(opts => {
                    codeInput._lookupItems = opts.map(o => {
                        const key = (o.value ?? o.Value ?? "").toString();
                        const text = (o.text ?? o.Text ?? "").toString();
                        return { key, label: text ? `${key} ${text}` : key };
                    });
                    codeInput._lookupLoaded = true;
                    _qlOpen(codeInput, caption);
                });
            } else {
                _qlOpen(codeInput, caption);
            }
        };
        nameBtn.addEventListener('click', openLookup);

        // 點選外部關閉下拉
        document.addEventListener('pointerdown', e => {
            if (!wrap.contains(e.target)) dropPanel.classList.remove("open");
        }, { capture: true });

        // 暴露介面供 wireSuperChange 使用
        codeInput._lookup = {
            setOptions: (opts) => {
                codeInput._lookupItems = opts.map(o => {
                    const key = (o.value ?? o.Value ?? "").toString();
                    const text = (o.text ?? o.Text ?? "").toString();
                    return { key, label: text ? `${key} ${text}` : key };
                });
                codeInput._lookupLoaded = true;
                codeInput.value = "";
                nameBtn.textContent = "";
                dropPanel.classList.remove("open");
            }
        };
    };

    const buildField = async (field, equals, index) => {
        const colName = field.columnName || field.ColumnName || "";
        if (!colName) return;

        const sortOrder = field.sortOrder ?? field.SortOrder ?? index + 1;
        const key = `${colName}${sortOrder}`;
        const caption = field.columnCaption || field.ColumnCaption || colName;

        const wrap = document.createElement("div");
        wrap.className = "query-item";

        const row = document.createElement("div");
        row.className = "query-row";

        const label = document.createElement("label");
        label.className = "query-label text-muted";
        label.textContent = caption;

        const opSelect = document.createElement("select");
        opSelect.name = `Cond_${key}`;
        opSelect.className = "form-select query-op";
        opSelect.style.fontWeight = "bold";
        equals.forEach(eq => {
            const opt = document.createElement("option");
            opt.value = eq.value ?? eq.Value ?? eq;
            opt.textContent = eq.text ?? eq.Text ?? eq;
            opSelect.appendChild(opt);
        });

        const defEqRaw = (field.defaultEqual || field.DefaultEqual || "").toString();
        const defEq = defEqRaw.toLowerCase();
        if (defEq && !Array.from(opSelect.options).some(o => o.value.toLowerCase() === defEq)) {
            const opt = document.createElement("option");
            opt.value = defEqRaw;
            opt.textContent = defEqRaw;
            opSelect.appendChild(opt);
        }
        if (defEq) {
            const hit = Array.from(opSelect.options).find(o => o.value.toLowerCase() === defEq);
            if (hit) opSelect.value = hit.value;
        }

        const controlType = Number(field.controlType ?? field.ControlType ?? 0);
        const dataType = Number(field.dataType ?? field.DataType ?? 0);
        const commandText = (field.commandText || field.CommandText || "").toString();
        const superId = (field.superId || field.SuperId || "").toString();
        const readOnly = Number(field.iReadOnly ?? field.IReadOnly ?? field.readOnly ?? 0) === 1;

        const isDateQueryField = !(controlType === 1 || controlType === 2 || commandText) && dataType === 1;
        let input;
        let inputContainer = null;
        if (controlType === 1 || controlType === 2 || commandText) {
            // Lookup 欄位：用 text input（name 屬性讓表單收集代碼值）
            const inp = document.createElement("input");
            inp.type = "text";
            inp.className = "form-control query-input";
            inp.dataset.param = normalizeKey(colName);
            inp.dataset.column = colName;
            inp.autocomplete = "off";
            if (superId) inp.dataset.super = normalizeKey(superId);
            input = inp;
        } else {
            const inp = document.createElement("input");
            inp.className = "form-control query-input";
            inp.type = "text";
            inp.autocomplete = "off";
            if (isDateQueryField) {
                inp.inputMode = "numeric";
                const dateWrap = document.createElement("div");
                dateWrap.className = "query-date-wrap";

                const picker = document.createElement("input");
                picker.type = "date";
                picker.className = "query-date-picker-proxy";
                picker.min = "0001-01-01";
                picker.max = "9999-12-31";
                picker.step = "1";

                const dateBtn = document.createElement("button");
                dateBtn.type = "button";
                dateBtn.className = "query-date-btn";
                dateBtn.setAttribute("aria-label", "選擇日期");

                const syncPickerFromText = () => {
                    const normalized = normalizeDateValue(inp.value);
                    if (!inp.value) {
                        picker.value = "";
                        return;
                    }
                    if (!normalized) {
                        inp.value = "";
                        picker.value = "";
                        return;
                    }
                    inp.value = toDisplayDate(normalized);
                    picker.value = normalized;
                };

                inp.addEventListener("blur", syncPickerFromText);
                inp.addEventListener("change", syncPickerFromText);
                inp.addEventListener("click", (e) => {
                    // 單擊依游標位置選取 yyyy/mm/dd 對應區段
                    if ((e.detail ?? 0) !== 1) return;
                    const text = String(inp.value || "");
                    if (!/^\d{4}\/\d{2}\/\d{2}$/.test(text)) return;
                    const start = typeof inp.selectionStart === "number" ? inp.selectionStart : -1;
                    const end = typeof inp.selectionEnd === "number" ? inp.selectionEnd : -1;
                    if (start < 0 || end < 0 || start !== end) return;

                    let segStart = 0;
                    let segEnd = 4;
                    if (start > 4 && start <= 7) {
                        segStart = 5;
                        segEnd = 7;
                    } else if (start > 7) {
                        segStart = 8;
                        segEnd = 10;
                    }
                    try { inp.setSelectionRange(segStart, segEnd); } catch { }
                });
                inp.addEventListener("dblclick", () => {
                    try {
                        inp.focus();
                        inp.select();
                        inp.setSelectionRange(0, inp.value.length);
                    } catch { }
                });

                picker.addEventListener("change", () => {
                    if (!picker.value) {
                        inp.value = "";
                        return;
                    }
                    const normalized = normalizeDateValue(picker.value);
                    inp.value = normalized ? toDisplayDate(normalized) : "";
                    inp.dispatchEvent(new Event("change", { bubbles: true }));
                });

                dateBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    if (inp.readOnly) return;
                    const normalized = normalizeDateValue(inp.value);
                    picker.value = normalized || "";
                    if (typeof picker.showPicker === "function") picker.showPicker();
                    else picker.focus();
                });

                dateWrap.appendChild(inp);
                dateWrap.appendChild(dateBtn);
                dateWrap.appendChild(picker);
                inputContainer = dateWrap;
            }
            input = inp;
        }

        input.name = key;
        input.dataset.field = colName;
        input.dataset.key = key;
        input.dataset.column = colName;
        if (field.tableName || field.TableName) input.dataset.tableName = field.tableName || field.TableName;
        if (field.aliasName || field.AliasName) input.dataset.aliasName = field.aliasName || field.AliasName;
        if (readOnly) {
            input.readOnly = true;
            const dateBtn = inputContainer?.querySelector?.(".query-date-btn");
            if (dateBtn) dateBtn.disabled = true;
        }

        row.appendChild(label);
        row.appendChild(opSelect);
        row.appendChild(inputContainer || input);
        wrap.appendChild(row);
        gridEl.appendChild(wrap);

        const rawDefaultVal = applyDefaultByType(field);
        let defaultVal = applyEditMask(rawDefaultVal, field);
        if (isDateQueryField) {
            defaultVal = normalizeDateValue(defaultVal);
        }

        

        // 憒? defaultType=1嚗QL?誘嚗?預設?潮???SQL 摮葡嚗”蝷?SQL 瘝??瑁?嚗?閬‵??
        const defType = Number(field.defaultType ?? field.DefaultType ?? 0);
        if (defType === 1 && looksLikeSqlDefault(defaultVal)) {
            defaultVal = "";
        }

        // 憒??舀??雿泵嚗?蝛?
        if (isDateQueryField && isDatePlaceholder(defaultVal)) {
            defaultVal = "";
        }
        if (controlType === 1 || controlType === 2 || commandText) {
            const superValue = superId ? readSuperValue(superId) : "";
            const opts = await loadOptions(colName, superValue);
            if (defaultVal) input.value = defaultVal;
            convertToLookup(input, colName, superId, opts, caption);
        } else if (defaultVal) {
            input.value = isDateQueryField ? toDisplayDate(defaultVal) : defaultVal;
        } else if (isDateQueryField) {
            input.value = "";
        }
        if (isDateQueryField) {
            const picker = inputContainer?.querySelector?.(".query-date-picker-proxy");
            if (picker) picker.value = normalizeDateValue(input.value) || "";
        }
    };

    const readSuperValue = (superId) => {
        const key = normalizeKey(superId);
        if (!key) return "";
        const el = formEl.querySelector(`[data-param="${key}"]`);
        if (el && (el.value ?? "") !== "") return el.value ?? "";
        const byName = formEl.querySelector(`[name="${CSS.escape(key)}"]`);
        if (byName && (byName.value ?? "") !== "") return byName.value ?? "";
        return "";
    };

    const wireSuperChange = () => {
        const selects = Array.from(formEl.querySelectorAll("[data-super]"));
        const bySuper = new Map();
        selects.forEach(sel => {
            const key = sel.dataset.super || "";
            if (!key) return;
            if (!bySuper.has(key)) bySuper.set(key, []);
            bySuper.get(key).push(sel);
        });

        bySuper.forEach((children, superKey) => {
            const superEl = formEl.querySelector(`[data-param="${superKey}"]`) || formEl.querySelector(`[name="${CSS.escape(superKey)}"]`);
            if (!superEl) return;
            superEl.addEventListener("change", async () => {
                for (const child of children) {
                    const col = child.dataset.column || "";
                    const opts = await loadOptions(col, superEl.value || "");
                    if (child._lookup) {
                        child._lookup.setOptions(opts);
                    } else {
                        buildOptionList(child, opts, "");
                    }
                }
            });
        });
    };

    let buildPromise = null;

    const buildForm = async () => {
        if (building) {
            if (buildPromise) {
                await buildPromise;
            }
            return;
        }
        building = true;

        buildPromise = (async () => {
            gridEl.innerHTML = "";
            try {
                const [fields, equals] = await Promise.all([loadQueryFields(), fetchEquals()]);
                if (!Array.isArray(fields) || fields.length === 0) {
                    console.warn('[QueryPanel] 沒有查詢欄位，無法建立表單');
                    return;
                }
                // 只建立 iVisible !== 0 的欄位，與 server-side IVisible==1 過濾一致
                // 避免隱藏欄位的 DefaultValue 被 ToolbarHandler 收集成過濾條件
                const visibleFields = fields.filter(f => {
                    const iv = f.iVisible ?? f.IVisible;
                    return iv == null || Number(iv) !== 0;
                });
                for (let i = 0; i < visibleFields.length; i++) {
                    await buildField(visibleFields[i], equals, i);
                }
                wireSuperChange();
            } catch (err) {
                console.error('[QueryPanel] 建立查詢表單發生錯誤', err);
            }
        })();

        await buildPromise;
        building = false;
        buildPromise = null;
    };

    window.QueryFieldsManager = {
        refresh: async () => {
            cachedFields = null;
            await buildForm();
        },
        load: buildForm
    };

    if (modalEl) {
        modalEl.addEventListener("shown.bs.modal", () => {
            // 皜敹怠?嚗Ⅱ靽??啗??亥??蒂?瑁? SQL
            cachedFields = null;
            buildForm().catch(() => {});
        });
    }

    (function enableQueryModalDrag() {
        const content = document.querySelector('.query-modal-content');
        if (!content) return;

        const dialog = content.closest('.modal-dialog');
        const modal = content.closest('.modal');
        const header = content.querySelector('.modal-header');
        if (!dialog || !header) return;

        let dragging = false;
        let startX = 0, startY = 0, startLeft = 0, startTop = 0;

        const resetDialogStyle = () => {
            dialog.style.position = '';
            dialog.style.left = '';
            dialog.style.top = '';
            dialog.style.margin = '';
            dialog.style.transform = '';
        };

        const begin = (ev) => {
            const isMouse = ev.pointerType === 'mouse' || ev.pointerType === undefined;
            if (isMouse && ev.button !== 0) return;
            if (ev.target?.closest('button, input, select, textarea, a')) return;

            const rect = dialog.getBoundingClientRect();
            dialog.style.position = 'fixed';
            dialog.style.margin = '0';
            dialog.style.left = `${rect.left}px`;
            dialog.style.top = `${rect.top}px`;
            dialog.style.transform = 'none';

            startX = ev.clientX;
            startY = ev.clientY;
            startLeft = rect.left;
            startTop = rect.top;
            dragging = true;

            if (header.setPointerCapture && ev.pointerId !== undefined) {
                header.setPointerCapture(ev.pointerId);
            }
            ev.preventDefault();
        };

        const move = (ev) => {
            if (!dragging) return;
            const dx = ev.clientX - startX;
            const dy = ev.clientY - startY;

            const w = dialog.offsetWidth || dialog.getBoundingClientRect().width;
            const h = dialog.offsetHeight || dialog.getBoundingClientRect().height;

            let left = startLeft + dx;
            let top = startTop + dy;

            const keepVisibleX = 120;
            const keepVisibleY = 80;
            const minLeft = -(w - keepVisibleX);
            const maxLeft = window.innerWidth - keepVisibleX;
            const minTop = -(h - keepVisibleY);
            const maxTop = window.innerHeight - keepVisibleY;

            left = Math.min(Math.max(minLeft, left), maxLeft);
            top = Math.min(Math.max(minTop, top), maxTop);

            dialog.style.left = `${left}px`;
            dialog.style.top = `${top}px`;
        };

        const end = () => { dragging = false; };

        header.addEventListener('pointerdown', begin);
        header.addEventListener('pointermove', move);
        header.addEventListener('pointerup', end);
        header.addEventListener('pointercancel', end);

        if (modal) {
            modal.addEventListener('hidden.bs.modal', resetDialogStyle);
            modal.addEventListener('show.bs.modal', resetDialogStyle);
        }
    })();
})();
</script>
