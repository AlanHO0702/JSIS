<script>
// ============================================
// EMOdProdInfo Detail 專用工具列邏輯
// ============================================
(function initEMOdProdInfoDetailToolbar() {
  const tableName = window._headerTableName || 'EMOdProdInfo';
  const isViewOnly = @(Model.IsViewOnly ? "true" : "false");

  // 1. 定義禁用按鈕的函式（只設 disabled，樣式由 CSS 的 :disabled 處理）
  function disableButton(btnId) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.disabled = true;
  }

  // 覆蓋原按鈕事件的輔助函式
  function overrideButton(btnId, handler) {
    const btn = document.getElementById(btnId);
    if (!btn) return null;
    const newBtn = btn.cloneNode(true);
    btn.parentNode.replaceChild(newBtn, btn);
    newBtn.addEventListener('click', handler);
    return newBtn;
  }

  // 建立 PaperNum 格式
  function buildPaperNum() {
    const partNum = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "PartNum").Value ?? "")';
    const revision = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "Revision").Value ?? "")';
    return `${partNum}|${revision}`;
  }

  // ============================
  // 上一筆 / 下一筆 導航邏輯
  // ============================
  const NAV_BTN_FIRST = document.getElementById('btnFirst');
  const NAV_BTN_PREV  = document.getElementById('btnPrev');
  const NAV_BTN_NEXT  = document.getElementById('btnNext');
  const NAV_BTN_LAST  = document.getElementById('btnLast');
  let navKeys = [];  // 儲存所有 { PartNum, Revision } 的清單
  let navIndex = -1; // 目前在清單中的位置

  // 目前這筆的主鍵
  const CURRENT_PARTNUM = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "PartNum").Value ?? "")';
  const CURRENT_REVISION = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "Revision").Value ?? "")';

  // 讀取 Index 頁面儲存的查詢條件
  function loadLastFilters() {
    try {
      const tableName = (window._headerTableName || 'EMOdProdInfo').toLowerCase();
      const filterKey = `orderListQueryFilters:${tableName}`;
      const saved = localStorage.getItem(filterKey);
      return saved ? JSON.parse(saved) : [];
    } catch {
      return [];
    }
  }

  // 跳轉到指定的資料（跳頁前先把目標 index 存入 localStorage，下一頁可立即顯示正確計數）
  function gotoRecord(key, targetIndex) {
    if (!key || !key.PartNum) return;
    const tn = (window._headerTableName || 'emodprodinfo').toLowerCase();
    if (targetIndex !== undefined && navKeys.length > 0) {
      localStorage.setItem(`orderListQueryIndex:${tn}`, targetIndex + 1); // 1-based
      localStorage.setItem(`orderListQueryTotal:${tn}`, navKeys.length);
    }
    const url = `/EMOdProdInfo/Detail?PartNum=${encodeURIComponent(key.PartNum)}&Revision=${encodeURIComponent(key.Revision || '0')}`;
    window.location.href = url;
  }

  // 更新按鈕狀態與計數器
  function updateNavButtons() {
    const hasPrev  = navIndex > 0;
    const hasNext  = navIndex >= 0 && navIndex < navKeys.length - 1;
    const hasFirst = hasPrev;
    const hasLast  = hasNext;

    if (NAV_BTN_FIRST) {
      NAV_BTN_FIRST.disabled = !hasFirst;
      NAV_BTN_FIRST.onclick = () => hasFirst && gotoRecord(navKeys[0], 0);
    }
    if (NAV_BTN_PREV) {
      NAV_BTN_PREV.disabled = !hasPrev;
      NAV_BTN_PREV.onclick = () => hasPrev && gotoRecord(navKeys[navIndex - 1], navIndex - 1);
    }
    if (NAV_BTN_NEXT) {
      NAV_BTN_NEXT.disabled = !hasNext;
      NAV_BTN_NEXT.onclick = () => hasNext && gotoRecord(navKeys[navIndex + 1], navIndex + 1);
    }
    if (NAV_BTN_LAST) {
      NAV_BTN_LAST.disabled = !hasLast;
      NAV_BTN_LAST.onclick = () => hasLast && gotoRecord(navKeys[navKeys.length - 1], navKeys.length - 1);
    }

    // 更新計數器顯示
    updateToolbarCount();
  }

  // 更新工具列計數器
  function updateToolbarCount() {
    const countEl = document.getElementById('toolbarHeaderCount');
    if (!countEl) return;

    // 隱藏單身計數（EMOdProdInfo 不需要）
    const detailCountEl = document.getElementById('toolbarDetailCount');
    if (detailCountEl) detailCountEl.style.display = 'none';

    const total = navKeys.length;
    if (total > 0 && navIndex >= 0) {
      countEl.textContent = `${navIndex + 1} / ${total}`;
    } else {
      // fallback: 使用 localStorage 的資料
      const tableName = (window._headerTableName || 'EMOdProdInfo').toLowerCase();
      const storedIndex = parseInt(localStorage.getItem(`orderListQueryIndex:${tableName}`) || '0', 10);
      const storedTotal = parseInt(localStorage.getItem(`orderListQueryTotal:${tableName}`) || '0', 10);
      if (storedTotal > 0) {
        countEl.textContent = `${storedIndex || '--'} / ${storedTotal}`;
      } else {
        countEl.textContent = '-- / --';
      }
    }
  }

  // 呼叫 API 取得所有主鍵清單
  async function fetchKeyList(filters) {
    // 使用 EMOdProdInfo 的 handler=Data API，支援大量資料
    const res = await fetch('/EMOdProdInfo?handler=Data&pageIndex=1&pageSize=999999');
    if (!res.ok) throw new Error('API 呼叫失敗');
    const json = await res.json();
    const rows = Array.isArray(json.items) ? json.items : [];
    // 回傳 { PartNum, Revision } 物件陣列
    return rows.map(r => ({
      PartNum: (r.PartNum || r.partNum || '').toString().trim(),
      Revision: (r.Revision || r.revision || '0').toString().trim()
    })).filter(k => k.PartNum);
  }

  // 初始化導航
  async function initRowNavigation() {
    // 隱藏單身計數的 --
    const detailCountEl = document.getElementById('toolbarDetailCount');
    if (detailCountEl) detailCountEl.style.display = 'none';

    // 先用 localStorage 立即顯示計數（不用等 API）
    const countEl = document.getElementById('toolbarHeaderCount');
    const tableName = (window._headerTableName || 'emodprodinfo').toLowerCase();
    const storedIndex = localStorage.getItem(`orderListQueryIndex:${tableName}`);
    const storedTotal = localStorage.getItem(`orderListQueryTotal:${tableName}`);
    if (countEl && storedIndex && storedTotal) {
      countEl.textContent = `${storedIndex} / ${storedTotal}`;
    } else if (countEl) {
      countEl.textContent = '載入中...';
    }

    try {
      const filters = loadLastFilters();
      navKeys = await fetchKeyList(filters);

      // 找出目前這筆在清單中的位置
      navIndex = navKeys.findIndex(k =>
        k.PartNum.toLowerCase() === CURRENT_PARTNUM.toLowerCase() &&
        k.Revision.toLowerCase() === CURRENT_REVISION.toLowerCase()
      );

      updateNavButtons();
    } catch (e) {
      console.error('初始化導航失敗', e);
      if (NAV_BTN_PREV) NAV_BTN_PREV.disabled = true;
      if (NAV_BTN_NEXT) NAV_BTN_NEXT.disabled = true;
      updateToolbarCount();
    }
  }

  // 執行初始化
  initRowNavigation();

  document.addEventListener('DOMContentLoaded', function() {
    // ============================
    // 2. 執行禁用邏輯
    // ============================
    disableButton('btnSubAddNew');      
    disableButton('btnSubBatchDelete'); 
    disableButton('btnPrint');          
    disableButton('btnPaperTrace');     
    disableButton('btnSubDetailAdd');   
    disableButton('btnSubDetailDelete'); 

    // ============================
    // 3. 按鈕邏輯 (送審、審核、退審...)
    // ============================
    const PARTNUM = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "PartNum").Value ?? "")';
    const REVISION = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "Revision").Value ?? "0")';
    const USERID = window._userId || localStorage.getItem('erpLoginUserId') || 'admin';

    // 取得目前狀態
    async function getCurrentStatus() {
      try {
        const resp = await fetch(`/api/PaperAction/GetEMOdProdStatus?partNum=${encodeURIComponent(PARTNUM)}&revision=${encodeURIComponent(REVISION)}`);
        if (!resp.ok) return null;
        const data = await resp.json();
        return data.success ? data.status : null;
      } catch {
        return null;
      }
    }

    // 執行 EMOdProdAudit
    async function execEMOdProdAudit(ioType, tag = 0) {
      const resp = await fetch('/api/PaperAction/EMOdProdAudit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          PartNum: PARTNUM,
          Revision: REVISION,
          Tag: tag,
          IOType: ioType,
          UserId: USERID,
          Meno: ''
        })
      });
      return resp;
    }

    // 建立按鈕
    const btnConfirm = document.getElementById('btnConfirm');
    if (btnConfirm) {
      btnConfirm.textContent = '送審';
      btnConfirm.id = 'btnSubmit';

      // 新增審核按鈕
      const btnApprove = document.createElement('button');
      btnApprove.id = 'btnApprove';
      btnApprove.className = 'btn toolbar-btn success';
      btnApprove.type = 'button';
      btnApprove.textContent = '審核';
      btnConfirm.parentNode.insertBefore(btnApprove, btnConfirm.nextSibling);
    }

    // ============================
    // 查詢模式下禁用送審/審核/退審/修改按鈕
    // ============================
    if (isViewOnly) {
      disableButton('btnSubmit');         // 送審
      disableButton('btnApprove');        // 審核
      disableButton('btnCancel');         // 退審
      disableButton('btnViewEditToggle'); // 修改
    }

    // 送審按鈕邏輯
    const btnSubmit = document.getElementById('btnSubmit');
    if (btnSubmit) {
      const newBtnSubmit = btnSubmit.cloneNode(true);
      btnSubmit.parentNode.replaceChild(newBtnSubmit, btnSubmit);
      newBtnSubmit.addEventListener('click', async function() {
        const status = await getCurrentStatus();
        if (status === null) {
          Swal.fire({ icon: 'error', title: '錯誤', text: '無法取得料號狀態' });
          return;
        }

        // Status: 0=設計中, 1=設計完成(已送審), 2=已審核
        if (status === 1) {
          Swal.fire({ icon: 'warning', title: '該料號已送審' });
          return;
        }
        if (status === 2) {
          Swal.fire({ icon: 'warning', title: '該料號已審核' });
          return;
        }

        // Status=0 設計中，正常送審
        const confirm = await Swal.fire({
          title: '確定要送審嗎？',
          text: `料號: ${PARTNUM} / 版序: ${REVISION}`,
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: '確定',
          cancelButtonText: '取消'
        });
        if (!confirm.isConfirmed) return;

        const resp = await execEMOdProdAudit(1, 0);  // IOType=1, Tag=0
        const data = await resp.json();
        if (resp.ok && data.success) {
          Swal.fire({ icon: 'success', title: '送審成功' }).then(() => location.reload());
        } else if (data.errorType === 'fieldCheck') {
          Swal.fire({ icon: 'warning', title: '未鍵入值之必要欄位', html: (data.message || '').replace(/\n/g, '<br>') });
        } else {
          Swal.fire({ icon: 'error', title: '送審失敗', text: data.message });
        }
      });
    }

    // 審核按鈕邏輯
    const btnApprove = document.getElementById('btnApprove');
    if (btnApprove) {
      btnApprove.addEventListener('click', async function() {
        const status = await getCurrentStatus();
        if (status === null) {
          Swal.fire({ icon: 'error', title: '錯誤', text: '無法取得料號狀態' });
          return;
        }

        // Status: 0=設計中, 1=設計完成(已送審), 2=已審核
        if (status === 0) {
          Swal.fire({ icon: 'warning', title: '該料號尚未送審' });
          return;
        }
        if (status === 2) {
          Swal.fire({ icon: 'warning', title: '該料號已審核' });
          return;
        }

        // Status=1 設計完成，正常審核
        const confirm = await Swal.fire({
          title: '確定要審核嗎？',
          text: `料號: ${PARTNUM} / 版序: ${REVISION}`,
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: '確定',
          cancelButtonText: '取消'
        });
        if (!confirm.isConfirmed) return;

        const resp = await execEMOdProdAudit(1, 1);  // IOType=1, Tag=1 (審核需要 Tag=1)
        const data = await resp.json();
        if (resp.ok && data.success) {
          Swal.fire({ icon: 'success', title: '審核成功' }).then(() => location.reload());
        } else if (data.errorType === 'fieldCheck') {
          Swal.fire({ icon: 'warning', title: '未鍵入值之必要欄位', html: (data.message || '').replace(/\n/g, '<br>') });
        } else {
          Swal.fire({ icon: 'error', title: '審核失敗', text: data.message });
        }
      });
    }

    // 退審按鈕邏輯
    overrideButton('btnCancel', async function() {
      const status = await getCurrentStatus();
      if (status === null) {
        Swal.fire({ icon: 'error', title: '錯誤', text: '無法取得料號狀態' });
        return;
      }

      // Status: 0=設計中, 1=設計完成(已送審), 2=已審核
      if (status === 0) {
        Swal.fire({ icon: 'warning', title: '無法退審', text: '該料號尚未送審，無需退審' });
        return;
      }

      const confirm = await Swal.fire({
        title: '確定要退審嗎？',
        text: `料號: ${PARTNUM} / 版序: ${REVISION}`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: '確定',
        cancelButtonText: '取消'
      });
      if (!confirm.isConfirmed) return;

      const resp = await execEMOdProdAudit(6, 0);  // IOType=6 退審
      const data = await resp.json();
      if (resp.ok && data.success) {
        Swal.fire({ icon: 'success', title: '退審成功' }).then(() => location.reload());
      } else {
        Swal.fire({ icon: 'error', title: '退審失敗', text: data.message });
      }
    });

    overrideButton('btnPaperLog', async function() {
       const partNum = '@(Model.MasterKeyValues.FirstOrDefault(k => k.Key == "PartNum").Value ?? "")';
       // (此處省略詳細 fetch 邏輯，請保留您原本的代碼)
    });

    overrideButton('btnSubSearch', function() {
      window.location.href = '@Url.Page("Index", new { mode = "view", itemId = "EMO00018" })';
    });

    // 改為使用 <a> 標籤以支援滑鼠中鍵開啟新分頁
    const btnSwitch = document.getElementById('btnSwitch');
    if (btnSwitch) {
      const anchor = document.createElement('a');
      anchor.className = btnSwitch.className;
      anchor.innerHTML = btnSwitch.innerHTML;
      anchor.style.cssText = btnSwitch.style.cssText;
      anchor.style.textDecoration = 'none';
      anchor.style.display = 'inline-flex'; // 確保圖示垂直置中
      anchor.style.alignItems = 'center';
      anchor.style.justifyContent = 'center';
      anchor.id = 'btnSwitch'; // 保持原 ID，因為上方已移除衝突的監聯器

      // 從 localStorage 讀取上次的頁數，返回時帶上 page 參數
      const tableName = 'emodprodinfo';
      const savedPage = localStorage.getItem(`orderListQueryPage:${tableName}`) || '1';

      if (isViewOnly) {
        anchor.href = `/EMOdProdInfo?mode=view&itemId=EMO00018&page=${savedPage}`;
      } else {
        anchor.href = `/EMOdProdInfo?page=${savedPage}`;
      }
      btnSwitch.parentNode.replaceChild(anchor, btnSwitch);
    }

    // ============================
    // 統一切換工具列編輯狀態（按鈕文字 + 計數器顏色）
    // ============================
    window.setToolbarEditMode = function setToolbarEditMode(isEdit) {
      window.__headerIsEdit = !!isEdit; // 供 ActionRail isHeaderEditMode() 判斷
      const btn = document.getElementById('btnViewEditToggle');
      if (btn) {
        btn.innerHTML = isEdit
          ? '<i class="bi bi-eye"></i>瀏覽'
          : '<i class="bi bi-pencil-square"></i>修改';
      }
      const countBox = document.getElementById('toolbarCountBox');
      if (countBox) {
        countBox.classList.toggle('mode-edit', isEdit);
        countBox.classList.toggle('mode-view', !isEdit);
      }
    };
    const setToolbarEditMode = window.setToolbarEditMode;

    // ============================
    // btnViewEditToggle 修改按鈕邏輯
    // ============================
    overrideButton('btnViewEditToggle', async function() {

      // 查詢模式下不允許修改
      if (isViewOnly) {
        Swal.fire({ icon: 'warning', title: '查詢模式下無法修改' });
        return;
      }

      const enterEdit = !window.isGlobalEditMode;

      if (enterEdit) {
        // ── 進入全域修改模式 ──
        if (window.checkEditPermission && !window.checkEditPermission()) return;

        window.isGlobalEditMode = true;

        // 規格頁籤進入編輯
        if (window.setSpecEditMode) window.setSpecEditMode(true);

        // 所有已載入的表格 editors 進入編輯
        if (window.tabState) {
          Object.values(window.tabState).forEach(state => {
            if (state?.editor?.toggleEdit) state.editor.toggleEdit(true);
          });
        }

        setToolbarEditMode(true);
        // [進入修改模式提示] 若需要在進入修改狀態時顯示提示，取消下方註解（關鍵字：修改模式 跳出提示 Swal）
        // Swal.fire({ icon: 'success', title: '已進入修改模式', timer: 800, showConfirmButton: false });

      } else {
        // ── 退出全域修改模式 ──
        const dirty = window.checkAnyDirty ? window.checkAnyDirty() : false;
        let shouldSave = false;

        if (dirty) {
          const confirmed = await Swal.fire({
            icon: 'question',
            title: '有未儲存的變更',
            text: '是否在退出前儲存？',
            showDenyButton: true,
            showCancelButton: true,
            confirmButtonText: '儲存並退出',
            denyButtonText: '不儲存直接退出',
            cancelButtonText: '取消（繼續編輯）'
          });
          if (confirmed.isDismissed) return; // 按 × 關閉視窗 → 繼續編輯
          if (confirmed.isCancelled) return;  // 繼續編輯
          shouldSave = confirmed.isConfirmed;
        }

        // 處理表格 editors
        if (window.tabState) {
          for (const state of Object.values(window.tabState)) {
            const editor = state?.editor;
            if (!editor?.isEdit?.()) continue;
            if (shouldSave && editor.saveChanges) await editor.saveChanges();
            else if (!shouldSave && editor.cancelChanges) editor.cancelChanges();
            if (editor.toggleEdit) editor.toggleEdit(false);
          }
        }

        // 規格頁籤退出（setSpecEditMode 內部會 save 或 restore）
        window.isGlobalEditMode = false;
        if (window.setSpecEditMode) await window.setSpecEditMode(false, shouldSave);

        // 重置 ✓/× 按鈕
        const btnSave   = document.getElementById('btnSaveHeader');
        const btnCancel = document.getElementById('btnCancelChanges');
        if (btnSave)   btnSave.disabled   = true;
        if (btnCancel) btnCancel.disabled = true;

        setToolbarEditMode(false);
        // [退出修改模式提示] 若需要在退出修改狀態時顯示提示，取消下方註解（關鍵字：修改模式 跳出提示 Swal）
        // Swal.fire({ icon: 'info', title: '已退出修改模式', timer: 800, showConfirmButton: false });
      }
    });
  });
})();
</script>

<script>
// ===== 選擇壓合模型 Modal =====
document.addEventListener('DOMContentLoaded', function () {
  const modalEl    = document.getElementById('modalSelectPressModel');
  const btnOpen    = document.getElementById('btnSelectPressModel');
  if (!btnOpen || !modalEl) return;

  const bsModal    = new bootstrap.Modal(modalEl);
  const btnSearch  = document.getElementById('btnSearchPressModel');
  const btnConfirm = document.getElementById('btnConfirmPressModel');
  const inpTmpId   = document.getElementById('searchPressModelTmpId');
  const inpNotes   = document.getElementById('searchPressModelNotes');
  const inpCode    = document.getElementById('selectedPressModelCode');
  const tbody      = document.getElementById('tblPressModelBody');
  const treeDiv    = document.getElementById('pressModelLayerTree');
  const dtlBody    = document.getElementById('tblPressModelDtl');

  let selectedTr   = null;
  let matClassMap  = {};   // MatClass -> ClassName

  // ── 開啟 ──
  btnOpen.addEventListener('click', () => {
    selectedTr = null;
    inpTmpId.value = '';
    inpNotes.value = '';
    tbody.innerHTML  = '<tr><td colspan="3" class="text-center text-muted small py-3">查詢中…</td></tr>';
    treeDiv.innerHTML = '—';
    dtlBody.innerHTML = '<tr><td colspan="3" class="text-center text-muted small py-3">請先選擇模型</td></tr>';
    bsModal.show();
    loadMatClassMap().then(doSearch);
  });

  // ── 搜尋 ──
  btnSearch.addEventListener('click', doSearch);
  [inpTmpId, inpNotes].forEach(inp =>
    inp.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); })
  );

  async function loadMatClassMap() {
    try {
      const r = await fetch('/api/CommonTable/Query?table=MINdMatClass&top=500&orderBy=MatClass');
      if (!r.ok) return;
      const arr = await r.json();
      (Array.isArray(arr) ? arr : (arr.data ?? [])).forEach(row => {
        matClassMap[row.MatClass?.trim()] = row.ClassName || row.MatClass;
      });
    } catch {}
  }

  async function doSearch() {
    tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted small">查詢中…</td></tr>';
    treeDiv.innerHTML = '—';
    dtlBody.innerHTML = '<tr><td colspan="3" class="text-center text-muted small py-3">請先選擇模型</td></tr>';
    selectedTr = null;
    try {
      const p = new URLSearchParams({ table: 'EMOdTmpPressMas', top: 500, orderBy: 'TmpId' });
      const t = inpTmpId.value.trim(), n = inpNotes.value.trim();
      if (t) p.append('TmpId', t);
      if (n) p.append('Notes', n);
      const r = await fetch(`/api/CommonTable/Query?${p}`);
      if (!r.ok) throw new Error('查詢失敗');
      const data = await r.json();
      const all  = Array.isArray(data) ? data : (data.data ?? []);
      // 只顯示已審核（Status=1）的模型，同 Delphi iTmpActive=1 邏輯
      let filtered = all.filter(row => Number(row.Status) === 1);
      // 依料號的 TmpBOMId 篩選（同 Delphi 以 TmpBomId 預填搜尋欄位的邏輯）
      // 只顯示 model.TmpBOMId == 料號的 TmpBOMId，不依賴命名規則
      const _mTmpBOMId = (window.currentMasterTmpBOMId ?? '').trim();
      if (_mTmpBOMId) filtered = filtered.filter(row => (row.TmpBOMId ?? '').trim() === _mTmpBOMId);
      renderModels(filtered);
    } catch (err) {
      tbody.innerHTML = `<tr><td colspan="3" class="text-danger text-center small">${escHtml(err.message)}</td></tr>`;
    }
  }

  // ── 左欄：模型列表 ──
  function renderModels(rows) {
    if (!rows.length) {
      tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted small py-3">查無資料</td></tr>';
      return;
    }
    tbody.innerHTML = rows.map(r => `
      <tr style="cursor:pointer"
          data-tmpid="${escHtml(r.TmpId?.trim() ?? '')}"
          data-tmpbomid="${escHtml(r.TmpBOMId?.trim() ?? '')}">
        <td>${escHtml(r.TmpId?.trim() ?? '')}</td>
        <td>${escHtml(r.TmpBOMId?.trim() ?? '')}</td>
        <td>${escHtml(r.Notes?.trim() ?? '')}</td>
      </tr>`).join('');

    tbody.querySelectorAll('tr').forEach(tr => {
      tr.addEventListener('click',    () => onModelClick(tr));
      tr.addEventListener('dblclick', () => { onModelClick(tr); confirmSelect(); });
    });
  }

  // ── 左欄點擊 → 載入樹狀 ──
  async function onModelClick(tr) {
    tbody.querySelectorAll('tr').forEach(t => t.classList.remove('table-active'));
    tr.classList.add('table-active');
    selectedTr = tr;
    treeDiv.innerHTML = '<span class="text-muted small">載入中…</span>';
    dtlBody.innerHTML = '<tr><td colspan="3" class="text-center text-muted small">載入中…</td></tr>';

    const tmpBOMId = tr.dataset.tmpbomid;
    const tmpId    = tr.dataset.tmpid;

    try {
      const r = await fetch(`/api/CommonTable/ByKeys?table=EMOdTmpBOMDtl&keyNames=TmpId&keyValues=${encodeURIComponent(tmpBOMId)}&orderBy=Degree`);
      if (!r.ok) throw new Error();
      const data = await r.json();
      renderTree(Array.isArray(data) ? data : (data.data ?? []), tmpId);
    } catch {
      treeDiv.innerHTML = '<span class="text-danger small">載入失敗</span>';
    }
  }

  // ── 中欄：層別樹狀 ──
  function renderTree(nodes, tmpId) {
    treeDiv.innerHTML = '';
    if (!nodes.length) {
      treeDiv.innerHTML = '<span class="text-muted small">無層別資料</span>';
      loadLayerDetail(tmpId, 'L0~0');
      return;
    }
    // Sort by Degree*100 + FL（同 Delphi 的 Sort 欄位算法）
    nodes.sort((a, b) => ((a.Degree||0)*100+(a.FL||0)) - ((b.Degree||0)*100+(b.FL||0)));

    // 建立樹狀結構
    const map = {};
    const roots = [];
    nodes.forEach(n => { map[n.LayerId] = { ...n, children: [] }; });
    nodes.forEach(n => {
      if (n.AftLayerId && map[n.AftLayerId]) map[n.AftLayerId].children.push(map[n.LayerId]);
      else roots.push(map[n.LayerId]);
    });

    roots.forEach(node => treeDiv.appendChild(buildTreeNode(node, tmpId)));

    // 自動點選第一個節點
    const first = treeDiv.querySelector('[data-layerid]');
    if (first) first.click();
  }

  function buildTreeNode(node, tmpId) {
    const wrap = document.createElement('div');

    const nodeDiv = document.createElement('div');
    nodeDiv.className = 'pm-tree-node-item';
    nodeDiv.dataset.layerid = node.LayerId;

    if ((node.children || []).length > 0) {
      const toggle = document.createElement('span');
      toggle.className = 'pm-tree-toggle expanded';
      toggle.addEventListener('click', e => {
        e.stopPropagation();
        const childDiv = wrap.querySelector('.pm-tree-children');
        if (childDiv) {
          const hidden = childDiv.style.display === 'none';
          childDiv.style.display = hidden ? 'block' : 'none';
          toggle.classList.toggle('expanded', hidden);
        }
      });
      nodeDiv.appendChild(toggle);
    } else {
      const spacer = document.createElement('span');
      spacer.style.cssText = 'display:inline-block;width:18px;flex-shrink:0';
      nodeDiv.appendChild(spacer);
    }

    const label = document.createElement('span');
    const _id   = (node.LayerId   || '').trim();
    const _name = (node.LayerName || '').trim();
    label.innerHTML = `${escHtml(_id)}<span style="color:#999;font-size:0.88em;">（${escHtml(_name)}）</span>`;
    nodeDiv.appendChild(label);

    nodeDiv.addEventListener('click', () => {
      treeDiv.querySelectorAll('.pm-tree-node-item').forEach(el => el.classList.remove('selected'));
      nodeDiv.classList.add('selected');
      loadLayerDetail(tmpId, node.LayerId);
    });

    wrap.appendChild(nodeDiv);

    if ((node.children || []).length > 0) {
      const childrenDiv = document.createElement('div');
      childrenDiv.className = 'pm-tree-children';
      node.children.forEach(child => childrenDiv.appendChild(buildTreeNode(child, tmpId)));
      wrap.appendChild(childrenDiv);
    }

    return wrap;
  }

  // ── 右欄：層材料明細 ──
  async function loadLayerDetail(tmpId, layerId) {
    dtlBody.innerHTML = '<tr><td colspan="3" class="text-center text-muted small">載入中…</td></tr>';
    try {
      const qs = new URLSearchParams();
      qs.append('table',     'EMOdTmpPressDtl');
      qs.append('keyNames',  'TmpId');
      qs.append('keyNames',  'LayerId');
      qs.append('keyValues', tmpId);
      qs.append('keyValues', layerId);
      qs.append('orderBy',   'SerialNum');
      const r = await fetch(`/api/CommonTable/ByKeys?${qs}`);
      if (!r.ok) throw new Error();
      const data = await r.json();
      renderLayerDetail(Array.isArray(data) ? data : (data.data ?? []));
    } catch {
      dtlBody.innerHTML = '<tr><td colspan="3" class="text-danger text-center small">載入失敗</td></tr>';
    }
  }

  function renderLayerDetail(rows) {
    if (!rows.length) {
      dtlBody.innerHTML = '<tr><td colspan="3" class="text-muted text-center small py-3">無資料</td></tr>';
      return;
    }
    dtlBody.innerHTML = rows.map(r => {
      const cls     = r.MatClass?.trim() ?? '';
      const clsName = matClassMap[cls] || cls;
      return `<tr>
        <td class="text-center">${escHtml(String(r.SerialNum ?? ''))}</td>
        <td>${escHtml(clsName)}</td>
        <td>${escHtml(r.Notes?.trim() ?? '')}</td>
      </tr>`;
    }).join('');
  }

  // ── 確定 ──
  async function confirmSelect() {
    if (!selectedTr) return;
    const tmpId   = selectedTr.dataset.tmpid;
    const partNum  = (window.currentMasterKeys?.PartNum  || window.currentMasterKeys?.partnum  || '').trim();
    const revision = (window.currentMasterKeys?.Revision || window.currentMasterKeys?.revision || '').trim();

    btnConfirm.disabled = true;
    btnConfirm.textContent = '套用中…';
    try {
      const resp = await fetch('/api/EMOdTmpPress/ApplyPressModel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ TmpId: tmpId, PartNum: partNum, Revision: revision })
      });
      const txt = await resp.text();
      let result = null;
      try { result = txt ? JSON.parse(txt) : null; } catch {}
      if (!resp.ok || result?.ok === false) {
        Swal.fire({ icon: 'error', title: '套用失敗', text: result?.error || txt || '未知錯誤' });
        return;
      }
      // 更新 input 顯示並儲存選取值
      inpCode.value = tmpId;
      window._selectedPressTmpId    = tmpId;
      window._selectedPressTmpBOMId = selectedTr.dataset.tmpbomid;
      bsModal.hide();
      // Reload 壓合明細 tab（layerpress）
      const state = window.tabState?.['layerpress'];
      if (state?.lastFetchUrl && state?.lastDict && typeof window.buildTableForEdit === 'function') {
        try {
          const freshRows = await fetch(state.lastFetchUrl).then(r => r.json());
          await window.buildTableForEdit('layerpress', state.lastDict, freshRows, state.lastFetchUrl);
        } catch (e) { console.warn('[pressModel] reload layerpress failed:', e); }
      }
    } catch (e) {
      Swal.fire({ icon: 'error', title: '套用失敗', text: e.message });
    } finally {
      btnConfirm.disabled = false;
      btnConfirm.textContent = '✓ 確定';
    }
  }
  btnConfirm.addEventListener('click', confirmSelect);

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
});

// ===== 疊構變更 Modal =====
document.addEventListener('DOMContentLoaded', function () {
  const btnOpen  = document.getElementById('btnLayerChange');
  const modalEl  = document.getElementById('modalLayerChange');
  if (!btnOpen || !modalEl) return;

  const bsModal   = new bootstrap.Modal(modalEl);
  const tbody     = document.getElementById('tblLayerChangeBody');
  const spanLayer = document.getElementById('layerChangeLayerId');
  const btnUp     = document.getElementById('btnLayerChangeUp');
  const btnDown   = document.getElementById('btnLayerChangeDown');
  const btnSave   = document.getElementById('btnLayerChangeSave');

  let matClassMap = {};
  let rows = [];          // 目前資料（使用者調整後的顯示順序）
  let originalSerialNums = [];  // 載入時的 SerialNum 清單（固定，用作 UPDATE KEY）

  function getActiveLayer() {
    const el = document.querySelector('.layer-item.active');
    return el ? { layerId: el.dataset.layerId || '', layerName: el.dataset.layerName || '' } : null;
  }
  function getMasterKeys() {
    return {
      partNum:  (window.currentMasterKeys?.PartNum  || window.currentMasterKeys?.partnum  || '').trim(),
      revision: (window.currentMasterKeys?.Revision || window.currentMasterKeys?.revision || '').trim(),
    };
  }

  btnOpen.addEventListener('click', async () => {
    const layer = getActiveLayer();
    if (!layer?.layerId) {
      Swal.fire({ icon: 'warning', title: '請先選擇層別' }); return;
    }
    const { partNum, revision } = getMasterKeys();
    spanLayer.textContent = `${layer.layerId}（${layer.layerName}）`;
    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted small py-3">載入中…</td></tr>';
    bsModal.show();

    try {
      // 載入 MatClass 名稱對照
      if (!Object.keys(matClassMap).length) {
        const mc = await fetch('/api/CommonTable/Query?table=MINdMatClass&top=500&orderBy=MatClass').then(r => r.json());
        (Array.isArray(mc) ? mc : (mc.data ?? [])).forEach(r => { matClassMap[r.MatClass?.trim()] = r.ClassName || r.MatClass; });
      }
      // 載入 EMOdLayerPress
      const qs = new URLSearchParams();
      qs.append('table', 'EMOdLayerPress'); qs.append('keyNames', 'PartNum'); qs.append('keyNames', 'Revision'); qs.append('keyNames', 'LayerId');
      qs.append('keyValues', partNum); qs.append('keyValues', revision); qs.append('keyValues', layer.layerId);
      qs.append('orderBy', 'SerialNum');
      const data = await fetch(`/api/CommonTable/ByKeys?${qs}`).then(r => r.json());
      rows = Array.isArray(data) ? data : (data.data ?? []);
      originalSerialNums = rows.map((r, i) => r.SerialNum ?? (i + 1));
      renderRows();
    } catch { tbody.innerHTML = '<tr><td colspan="4" class="text-danger text-center">載入失敗</td></tr>'; }
  });

  function escHtmlLC(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function syncFromDOM() {
    tbody.querySelectorAll('td.lc-matclass select').forEach(sel => {
      const idx = parseInt(sel.closest('td')?.dataset.idx);
      if (!isNaN(idx)) rows[idx].MatClass = sel.value;
    });
    tbody.querySelectorAll('input.lc-notes').forEach(inp => {
      const idx = parseInt(inp.dataset.idx);
      if (!isNaN(idx)) rows[idx].Notes = inp.value;
    });
  }

  function renderRows() {
    if (!rows.length) { tbody.innerHTML = '<tr><td colspan="4" class="text-muted text-center small py-3">無資料</td></tr>'; return; }
    tbody.innerHTML = rows.map((r, i) => {
      const cls = r.MatClass?.trim() ?? '';
      const clsName = matClassMap[cls] || '';
      const notes = r.Notes?.trim() ?? '';
      return `<tr data-idx="${i}">
        <td class="text-center" style="background:#f0f0f0;color:#666;user-select:none">${i + 1}</td>
        <td class="lc-matclass" data-idx="${i}" title="點擊修改" style="cursor:default">${escHtmlLC(cls)}</td>
        <td style="background:#f0f0f0;color:#666">${escHtmlLC(clsName)}</td>
        <td style="padding:2px 4px"><input type="text" class="lc-notes" data-idx="${i}" value="${escHtmlLC(notes)}" style="width:100%;border:none;outline:none;background:transparent;font-size:inherit;font-family:inherit;padding:0"></td>
      </tr>`;
    }).join('');

    // MatClass: 單擊展開下拉選單
    tbody.querySelectorAll('td.lc-matclass').forEach(td => {
      td.addEventListener('click', () => {
        if (td.querySelector('select')) return;  // 已開啟，忽略冒泡
        const idx = parseInt(td.dataset.idx);
        const currentVal = rows[idx].MatClass?.trim() ?? '';
        const opts = Object.entries(matClassMap)
          .map(([code, name]) => `<option value="${escHtmlLC(code)}"${code === currentVal ? ' selected' : ''}>${escHtmlLC(code)} - ${escHtmlLC(name)}</option>`)
          .join('');
        td.style.padding = '0';
        td.style.position = 'relative';
        td.innerHTML = `<select style="position:absolute;top:0;left:0;width:100%;height:100%;font-size:inherit;border:none;outline:none;padding:0 2px;box-sizing:border-box">${opts}</select>`;
        const sel = td.querySelector('select');
        sel.focus();
        const commit = () => {
          rows[idx].MatClass = sel.value;
          renderRows();
          tbody.querySelectorAll('tr')[idx]?.classList.add('table-active');
        };
        sel.addEventListener('change', commit);
        sel.addEventListener('blur', commit);
      });
    });

    // Notes: 即時同步回 rows[]
    tbody.querySelectorAll('input.lc-notes').forEach(inp => {
      inp.addEventListener('input', () => { rows[parseInt(inp.dataset.idx)].Notes = inp.value; });
    });

    // Row click 選取
    tbody.querySelectorAll('tr').forEach(tr =>
      tr.addEventListener('click', () => {
        tbody.querySelectorAll('tr').forEach(t => t.classList.remove('table-active'));
        tr.classList.add('table-active');
      })
    );
  }

  function getSelectedIdx() {
    const tr = tbody.querySelector('tr.table-active');
    return tr ? parseInt(tr.dataset.idx) : -1;
  }

  btnUp.addEventListener('click', () => {
    syncFromDOM();
    const i = getSelectedIdx();
    if (i <= 0) return;
    [rows[i - 1], rows[i]] = [rows[i], rows[i - 1]];
    renderRows();
    tbody.querySelectorAll('tr')[i - 1]?.classList.add('table-active');
  });

  btnDown.addEventListener('click', () => {
    syncFromDOM();
    const i = getSelectedIdx();
    if (i < 0 || i >= rows.length - 1) return;
    [rows[i], rows[i + 1]] = [rows[i + 1], rows[i]];
    renderRows();
    tbody.querySelectorAll('tr')[i + 1]?.classList.add('table-active');
  });

  btnSave.addEventListener('click', async () => {
    syncFromDOM();
    const { partNum, revision } = getMasterKeys();
    const layer = getActiveLayer();
    // 策略：SerialNum 是 PK，不能改。改為將 rows[i] 的內容填入第 i 個 SerialNum 槽位
    // 這樣 UPDATE SET MatCode=? WHERE SerialNum=originalSerialNums[i] 不會觸發 PK 衝突
    const payload = rows.map((r, i) => {
      const sn = originalSerialNums[i];
      const base = {
        PartNum: r.PartNum || partNum,
        Revision: r.Revision || revision,
        LayerId: r.LayerId || layer.layerId,
        SerialNum: sn,
      };
      // 把所有非 key 欄位都帶過去（MatCode, MatName, Thickness, MatClass, Notes 等）
      const nonKey = Object.fromEntries(
        Object.entries(r).filter(([k]) => !['PartNum','Revision','LayerId','SerialNum'].includes(k))
      );
      return { ...base, ...nonKey };
    });
    try {
      const resp = await fetch('/api/CommonTable/SaveTableChanges', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ TableName: 'EMOdLayerPress', Data: payload, KeyFields: ['PartNum', 'Revision', 'LayerId', 'SerialNum'] })
      });
      const txt = await resp.text();
      let result = null;
      try { result = txt ? JSON.parse(txt) : null; } catch {}
      if (resp.ok && result?.success !== false) {
        bsModal.hide();
        // Reload 壓合明細 tab
        const state = window.tabState?.['layerpress'];
        if (state?.lastFetchUrl && state?.lastDict && typeof window.buildTableForEdit === 'function') {
          try {
            const freshRows = await fetch(state.lastFetchUrl).then(r => r.json());
            await window.buildTableForEdit('layerpress', state.lastDict, freshRows, state.lastFetchUrl);
          } catch (e) { console.warn('[layerChange] reload layerpress failed:', e); }
        }
      } else {
        Swal.fire({ icon: 'error', title: '儲存失敗', text: result?.error || txt || '未知錯誤' });
      }
    } catch (e) { Swal.fire({ icon: 'error', title: '儲存失敗', text: e.message }); }
  });
});

// ===== 材料設定 Modal =====
document.addEventListener('DOMContentLoaded', function () {
  const btnOpen  = document.getElementById('btnMaterialSet');
  const modalEl  = document.getElementById('modalMaterialSet');
  if (!btnOpen || !modalEl) return;

  const bsModal     = new bootstrap.Modal(modalEl);
  const spanLayer   = document.getElementById('matSetLayerId');
  const srcBody     = document.getElementById('tblMatSetSource');
  const tgtBody     = document.getElementById('tblMatSetTarget');
  const pressBody   = document.getElementById('tblMatSetPress');
  const inputFilter = document.getElementById('matSetClassFilter');
  const inputStage  = document.getElementById('matSetStageId');
  const btnAdd      = document.getElementById('btnMatSetAdd');
  const btnRemove   = document.getElementById('btnMatSetRemove');
  const btnUp       = document.getElementById('btnMatSetUp');
  const btnDown     = document.getElementById('btnMatSetDown');
  const btnSave     = document.getElementById('btnMatSetSave');
  const btnRefresh  = document.getElementById('btnMatSetRefresh');

  let allSrcRows = [];        // 全部可選材料（快取）
  let srcRows = [];           // 目前左欄（複製模式：永遠等於 allSrcRows 依篩選）
  let displayedSrcRows = [];  // 篩選後顯示的左欄
  let tgtRows = [];           // 已選（右）
  let originalSerialNums = []; // 載入時各行的 SerialNum（UPDATE key）
  let matClassList = [];       // P4：用料類別別選項快取
  let pressRows = [];          // 壓合結構各列（含 MatClass），用於防呆驗證
  let _savedLayer = null;      // 開啟 modal 時鎖定的 layer（避免 save 時 active 消失）
  let _savedMasterKeys = null;

  function getActiveLayer() {
    const el = document.querySelector('.layer-item.active');
    return el ? { layerId: el.dataset.layerId || '', layerName: el.dataset.layerName || '' } : null;
  }
  function getMasterKeys() {
    return {
      partNum:  (window.currentMasterKeys?.PartNum  || window.currentMasterKeys?.partnum  || '').trim(),
      revision: (window.currentMasterKeys?.Revision || window.currentMasterKeys?.revision || '').trim(),
    };
  }

  async function loadData(forceReload) {
    const layer = getActiveLayer();
    const { partNum, revision } = getMasterKeys();

    // EMOdLayerPress：只取 MatCode 非空的行 → 已選列表（右欄）
    const qsTgt = new URLSearchParams();
    qsTgt.append('table', 'EMOdLayerPress'); qsTgt.append('keyNames', 'PartNum'); qsTgt.append('keyNames', 'Revision'); qsTgt.append('keyNames', 'LayerId');
    qsTgt.append('keyValues', partNum); qsTgt.append('keyValues', revision); qsTgt.append('keyValues', layer.layerId);
    qsTgt.append('orderBy', 'SerialNum');
    const tgtData = await fetch(`/api/CommonTable/ByKeys?${qsTgt}`).then(r => r.json());
    const tgtRaw = (Array.isArray(tgtData) ? tgtData : (tgtData.data ?? []))
      .filter(r => (r.MatCode ?? r.matcode)?.trim());

    tgtRows = tgtRaw.map(r => ({
      MatCode:  (r.MatCode  ?? r.matcode  ?? '').trim(),
      MatName:  (r.MatName  ?? r.matname  ?? '').trim(),
      MatClass: (r.MatClass ?? r.matclass ?? '').trim(),
      SerialNum: r.SerialNum ?? r.serialnum
    }));
    originalSerialNums = tgtRaw.map(r => r.SerialNum ?? r.serialnum);

    // EMOdVPressForDLL：有 BefLayer(內層)、MatClass、LayerName → 右上壓合結構顯示
    if (pressBody) {
      try {
        const qsPress = new URLSearchParams();
        qsPress.append('table', 'EMOdVPressForDLL'); qsPress.append('keyNames', 'PartNum'); qsPress.append('keyNames', 'Revision'); qsPress.append('keyNames', 'LayerId');
        qsPress.append('keyValues', partNum); qsPress.append('keyValues', revision); qsPress.append('keyValues', layer.layerId);
        qsPress.append('orderBy', 'SerialNum');
        const pressData = await fetch(`/api/CommonTable/ByKeys?${qsPress}`).then(r => r.json());
        const pressRaw = Array.isArray(pressData) ? pressData : (pressData.data ?? []);
        pressRows = pressRaw.map(r => ({ SerialNum: r.SerialNum, MatClass: (r.MatClass ?? '').trim() }));
        pressBody.innerHTML = pressRaw.length
          ? pressRaw.map(r => {
              const cls = r.MatClass?.trim() ?? '';
              const clsName = matClassList.find(c => c.code === cls)?.name ?? '';
              return `<tr>
                <td class="text-center">${r.SerialNum ?? ''}</td>
                <td>${escHtmlMS(r.BefLayer?.trim() ?? '')}</td>
                <td>${escHtmlMS(cls)}</td>
                <td>${escHtmlMS(clsName)}</td>
                <td>${escHtmlMS((r.LayerName ?? r.BefLayer)?.trim() ?? '')}</td>
              </tr>`;
            }).join('')
          : '<tr><td colspan="5" class="text-muted text-center small">無資料</td></tr>';
      } catch { pressBody.innerHTML = '<tr><td colspan="5" class="text-danger text-center small">載入失敗</td></tr>'; }
    }

    renderTgt();
  }

  // 依 MatClass 從 server 取左欄料 + 更新屬性 grid
  async function loadSrcByClass(classCode) {
    const attrBody = document.getElementById('tblMatSetAttr');
    if (!classCode) {
      srcBody.innerHTML = '<tr><td colspan="3" class="text-muted text-center small">請選擇用料類別別</td></tr>';
      allSrcRows = []; srcRows = []; displayedSrcRows = [];
      if (attrBody) attrBody.innerHTML = '';
      return;
    }
    srcBody.innerHTML = '<tr><td colspan="3" class="text-muted text-center small">載入中…</td></tr>';
    try {
      // 屬性 grid：依 MatClass 載入屬性清單
      const attrData = await fetch(`/api/MG000006/setnum-sub?setClass=${encodeURIComponent(classCode)}`).then(r => r.json());
      const attrs = Array.isArray(attrData) ? attrData : [];
      if (attrBody) {
        attrBody.innerHTML = attrs.map(a => {
          const numId = (a.NumId ?? '').trim();
          const numName = (a.NumName ?? a.iShowName ?? '').trim();
          return `<tr>
            <td class="text-muted">${escHtmlMS(numId)}</td>
            <td>${escHtmlMS(numName)}</td>
            <td style="padding:1px 2px"><input type="text" class="ms-attr-input" data-attr="${escHtmlMS(numId)}" style="width:100%;border:none;outline:none;font-size:inherit;background:transparent"></td>
            <td></td>
          </tr>`;
        }).join('');
        // 重新綁定屬性 input 事件
        attrBody.querySelectorAll('.ms-attr-input').forEach(inp =>
          inp.addEventListener('input', applyFilter)
        );
      }

      // 左欄材料清單
      const qs = new URLSearchParams();
      qs.append('table', 'EMOdVPressMat');
      qs.append('keyNames', 'MatClass'); qs.append('keyValues', classCode);
      qs.append('orderBy', 'matcode');
      const srcData = await fetch(`/api/CommonTable/ByKeys?${qs}`).then(r => r.json());
      allSrcRows = (Array.isArray(srcData) ? srcData : (srcData.data ?? []))
        .filter(r => (r.matcode ?? r.MatCode)?.trim())
        .map(r => ({
          MatCode:  (r.matcode ?? r.MatCode ?? '').trim(),
          MatName:  r.MatName?.trim() ?? '',
          EngGauge: (r.EngGauge ?? '').trim(),
          MatClass: r.MatClass?.trim() ?? ''
        }));
      srcRows = allSrcRows;
      applyFilter();
    } catch {
      srcBody.innerHTML = '<tr><td colspan="3" class="text-danger text-center small">載入失敗</td></tr>';
    }
  }

  // P1+S4：篩選左欄
  function applyFilter() {
    const attrKws = Array.from(document.querySelectorAll('#tblMatSetAttr .ms-attr-input'))
      .map(inp => inp.value.trim().toLowerCase()).filter(v => v);

    displayedSrcRows = srcRows.filter(r => {
      if (attrKws.length && !attrKws.every(kw => r.MatCode.toLowerCase().includes(kw) || r.MatName.toLowerCase().includes(kw))) return false;
      return true;
    });
    renderSrc();
    renderTgt();
  }

  // S4：B 區屬性 input 事件
  document.querySelectorAll('#tblMatSetAttr .ms-attr-input').forEach(inp =>
    inp.addEventListener('input', applyFilter)
  );

  // P4：用料類別別 suggestion dropdown
  const suggestEl = document.getElementById('matSetClassSuggest');
  async function ensureMatClassList() {
    if (matClassList.length) return;
    try {
      const mc = await fetch('/api/CommonTable/Query?table=MINdMatClass&top=200&orderBy=MatClass').then(r => r.json());
      matClassList = (Array.isArray(mc) ? mc : (mc.data ?? []))
        .map(r => ({ code: r.MatClass?.trim() ?? '', name: r.ClassName?.trim() ?? '' }));
    } catch {}
  }
  function showSuggest(kw) {
    if (!suggestEl) return;
    const filtered = kw
      ? matClassList.filter(r => r.code.toLowerCase().includes(kw) || r.name.toLowerCase().includes(kw))
      : matClassList;
    if (!filtered.length) { suggestEl.style.display = 'none'; return; }
    suggestEl.innerHTML = filtered.slice(0, 60).map((r, i) =>
      `<div class="ms-sug-item" data-idx="${i}">
        <span class="ms-sug-code">${escHtmlMS(r.code)}</span>
        <span class="ms-sug-name">${escHtmlMS(r.name)}</span>
      </div>`).join('');
    suggestEl._filtered = filtered;
    suggestEl.style.display = 'block';
    suggestEl.querySelectorAll('.ms-sug-item').forEach(item => {
      item.addEventListener('mousedown', e => {
        e.preventDefault();
        const code = filtered[parseInt(item.dataset.idx)].code;
        inputFilter.value = code;
        suggestEl.style.display = 'none';
        loadSrcByClass(code);
      });
    });
  }
  inputFilter?.addEventListener('focus', async () => {
    await ensureMatClassList();
    showSuggest(inputFilter.value.trim().toLowerCase());
  });
  inputFilter?.addEventListener('input', () => {
    showSuggest(inputFilter.value.trim().toLowerCase());
    if (!inputFilter.value.trim()) loadSrcByClass('');
  });
  inputFilter?.addEventListener('keydown', e => {
    if (e.key === 'Enter') { suggestEl.style.display = 'none'; loadSrcByClass(inputFilter.value.trim()); }
  });
  inputFilter?.addEventListener('blur', () => setTimeout(() => { if (suggestEl) suggestEl.style.display = 'none'; }, 150));

  document.getElementById('btnMatSetClassClear')?.addEventListener('click', async () => {
    if (inputFilter) { inputFilter.value = ''; inputFilter.focus(); }
    await ensureMatClassList();
    showSuggest('');
  });

  btnOpen.addEventListener('click', async () => {
    const layer = getActiveLayer();
    if (!layer?.layerId) { Swal.fire({ icon: 'warning', title: '請先選擇層別' }); return; }
    _savedLayer = layer;
    _savedMasterKeys = getMasterKeys();
    spanLayer.textContent = `${layer.layerId}（${layer.layerName}）`;
    if (inputStage) inputStage.value = layer.layerId;
    document.querySelectorAll('#tblMatSetAttr .ms-attr-input').forEach(inp => inp.value = '');
    if (inputFilter) inputFilter.value = '';
    allSrcRows = []; srcRows = []; displayedSrcRows = [];
    srcBody.innerHTML = '<tr><td colspan="3" class="text-muted text-center small">請選擇用料類別別</td></tr>';
    tgtBody.innerHTML = '<tr><td colspan="2" class="text-muted text-center small">載入中…</td></tr>';
    bsModal.show();
    await ensureMatClassList();
    try { await loadData(false); }
    catch { tgtBody.innerHTML = '<tr><td colspan="2" class="text-danger text-center">載入失敗</td></tr>'; }
  });

  btnRefresh?.addEventListener('click', async () => {
    try { await loadData(true); }
    catch { tgtBody.innerHTML = '<tr><td colspan="2" class="text-danger text-center">載入失敗</td></tr>'; }
    await loadSrcByClass(inputFilter?.value.trim() ?? '');
  });

  // P1：加入目標（複製模式，不移除左欄；防重複）
  function addToTarget(row) {
    if (!row) return;
    tgtRows.push(row);
    renderTgt();
  }

  function renderSrc() {
    if (!displayedSrcRows.length) { srcBody.innerHTML = '<tr><td colspan="3" class="text-muted text-center small">無資料</td></tr>'; return; }
    srcBody.innerHTML = displayedSrcRows.map((r, i) => `
      <tr style="cursor:pointer;user-select:none" data-idx="${i}">
        <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtmlMS(r.MatCode)}</td>
        <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtmlMS(r.MatName)}</td>
        <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtmlMS(r.EngGauge)}</td>
      </tr>`).join('');
    let lastClickIdx = -1;
    let lastClickTime = 0;
    srcBody.querySelectorAll('tr').forEach(tr => {
      tr.addEventListener('click', () => {
        srcBody.querySelectorAll('tr').forEach(t => t.classList.remove('table-active'));
        tr.classList.add('table-active');
        const idx = parseInt(tr.dataset.idx);
        const now = Date.now();
        if (lastClickIdx === idx && now - lastClickTime < 400) {
          addToTarget(displayedSrcRows[idx]);
          lastClickIdx = -1;
        } else {
          lastClickIdx = idx;
          lastClickTime = now;
        }
      });
    });
  }

  function renderTgt() {
    if (!tgtRows.length) { tgtBody.innerHTML = '<tr><td colspan="2" class="text-muted text-center small">尚未選擇</td></tr>'; return; }
    tgtBody.innerHTML = tgtRows.map((r, i) => `
      <tr style="cursor:pointer;user-select:none" data-idx="${i}">
        <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtmlMS(r.MatCode)}</td>
        <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtmlMS(r.MatName)}</td>
      </tr>`).join('');
    let lastClickIdx = -1;
    let lastClickTime = 0;
    tgtBody.querySelectorAll('tr').forEach(tr => {
      tr.addEventListener('click', () => {
        tgtBody.querySelectorAll('tr').forEach(t => t.classList.remove('table-active'));
        tr.classList.add('table-active');
        const idx = parseInt(tr.dataset.idx);
        const now = Date.now();
        if (lastClickIdx === idx && now - lastClickTime < 400) {
          tgtRows.splice(idx, 1);
          renderTgt();
          lastClickIdx = -1;
        } else {
          lastClickIdx = idx;
          lastClickTime = now;
        }
      });
    });
  }

  btnAdd.addEventListener('click', () => {
    const tr = srcBody.querySelector('tr.table-active');
    if (!tr) return;
    addToTarget(displayedSrcRows[parseInt(tr.dataset.idx)]);
  });

  btnRemove.addEventListener('click', () => {
    const tr = tgtBody.querySelector('tr.table-active');
    if (!tr) return;
    tgtRows.splice(parseInt(tr.dataset.idx), 1); // P1：只從右欄移除，不影響左欄
    renderTgt();
  });

  btnUp.addEventListener('click', () => {
    const tr = tgtBody.querySelector('tr.table-active');
    if (!tr) return;
    const i = parseInt(tr.dataset.idx);
    if (i <= 0) return;
    [tgtRows[i - 1], tgtRows[i]] = [tgtRows[i], tgtRows[i - 1]];
    renderTgt();
    tgtBody.querySelectorAll('tr')[i - 1]?.classList.add('table-active');
  });

  btnDown.addEventListener('click', () => {
    const tr = tgtBody.querySelector('tr.table-active');
    if (!tr) return;
    const i = parseInt(tr.dataset.idx);
    if (i >= tgtRows.length - 1) return;
    [tgtRows[i], tgtRows[i + 1]] = [tgtRows[i + 1], tgtRows[i]];
    renderTgt();
    tgtBody.querySelectorAll('tr')[i + 1]?.classList.add('table-active');
  });

  btnSave.addEventListener('click', async () => {
    const layer = _savedLayer ?? getActiveLayer();
    const { partNum, revision } = _savedMasterKeys ?? getMasterKeys();
    if (!layer?.layerId) { Swal.fire({ icon: 'warning', title: '請先重新開啟材料設定' }); return; }

    // 防呆：物料類別必須符合壓合結構該列的類別（依 SerialNum 對應，非 index）
    for (let i = 0; i < tgtRows.length; i++) {
      const sn = originalSerialNums[i] ?? (i + 1);
      const pressRow = pressRows.find(p => p.SerialNum === sn);
      const expected = pressRow?.MatClass ?? '';
      const actual   = tgtRows[i].MatClass ?? '';
      if (expected && actual && actual !== expected) {
        const expName = matClassList.find(c => c.code === expected)?.name ?? expected;
        const actName = matClassList.find(c => c.code === actual)?.name ?? actual;
        Swal.fire({ icon: 'warning', title: '物料類別不符', text: `第 ${i + 1} 筆：選擇的是「${actual} ${actName}」，此層應為「${expected} ${expName}」` });
        return;
      }
    }

    // SerialNum 是 PK：用 originalSerialNums[i] 對應 tgtRows[i]（同 疊構變更 策略）
    const payload = tgtRows.map((r, i) => ({
      PartNum: partNum, Revision: revision, LayerId: layer.layerId,
      SerialNum: originalSerialNums[i] ?? (i + 1),
      MatCode: r.MatCode, MatName: r.MatName
    }));
    try {
      const resp = await fetch('/api/CommonTable/SaveTableChanges', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ TableName: 'EMOdLayerPress', Data: payload, KeyFields: ['PartNum', 'Revision', 'LayerId', 'SerialNum'] })
      });
      const txt = await resp.text();
      let result = null;
      try { result = txt ? JSON.parse(txt) : null; } catch {}
      if (resp.ok && result?.success !== false) {
        bsModal.hide();
        if (typeof window.loadLayerPressDetail === 'function')
          window.loadLayerPressDetail(layer.layerId, layer.layerName);
      }
      else { Swal.fire({ icon: 'error', title: '儲存失敗', text: result?.error || txt || '未知錯誤' }); }
    } catch (e) { Swal.fire({ icon: 'error', title: '儲存失敗', text: e.message }); }
  });

  function escHtmlMS(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
});
</script>

<script>
// ============================================================
// 途程內容頁籤（layerroute）5 顆按鈕邏輯
// ============================================================
document.addEventListener('DOMContentLoaded', function () {
  'use strict';

  // ── 共用 helper ──────────────────────────────────────────

  function getActiveLayer() {
    const el = document.querySelector('.layer-item.active');
    return el ? { layerId: el.dataset.layerId || '', layerName: el.dataset.layerName || '' } : null;
  }

  function getMasterKeys() {
    return {
      partNum:  (window.currentMasterKeys?.PartNum  || window.currentMasterKeys?.partnum  || '').trim(),
      revision: (window.currentMasterKeys?.Revision || window.currentMasterKeys?.revision || '').trim(),
    };
  }

  function escH(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function requireLayer() {
    const layer = getActiveLayer();
    if (!layer?.layerId) { Swal.fire({ icon: 'warning', title: '請先選擇層別' }); return null; }
    return layer;
  }

  // 更新途程代號 input 顯示
  async function updateTmpRouteId(layerId) {
    const input = document.getElementById('currentTmpRouteId');
    if (!input) return;
    const mk = getMasterKeys();
    if (!mk.partNum || !mk.revision || !layerId) { input.value = ''; return; }
    try {
      const r = await apiGet(
        `/api/EMOdLayerRoute/GetTmpRouteId?partNum=${encodeURIComponent(mk.partNum)}` +
        `&revision=${encodeURIComponent(mk.revision)}&layerId=${encodeURIComponent(layerId)}`
      );
      input.value = r?.tmpRouteId ?? '';
    } catch { input.value = ''; }
  }

  // wrap window.loadLayerPressDetail，讓切換層別時同步更新途程代號
  if (typeof window.loadLayerPressDetail === 'function') {
    const _orig = window.loadLayerPressDetail;
    window.loadLayerPressDetail = function (layerId, layerName) {
      _orig(layerId, layerName);
      updateTmpRouteId(layerId);
    };
  }

  async function apiPost(url, body) {
    const resp = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    return resp.json();
  }

  async function apiGet(url) {
    const resp = await fetch(url);
    return resp.json();
  }

  // 重新載入 layerroute 表格
  function reloadLayerRoute() {
    const layer = getActiveLayer();
    if (!layer?.layerId) return;
    if (typeof window.loadLayerPressDetail === 'function') {
      window.loadLayerPressDetail(layer.layerId, layer.layerName);
    }
  }

  // ── 複製備註（直接呼叫 API，無對話框）─────────────────────

  document.getElementById('btnBackupNotes')?.addEventListener('click', async () => {
    const layer = requireLayer(); if (!layer) return;
    const mk = getMasterKeys();
    try {
      const r = await apiPost('/api/EMOdLayerRoute/BackupNotes',
        { PartNum: mk.partNum, Revision: mk.revision, LayerId: layer.layerId });
      if (!r?.ok) Swal.fire({ icon: 'error', title: '複製備註失敗', text: r?.error || '未知錯誤' });
    } catch (e) { Swal.fire({ icon: 'error', title: '複製備註失敗', text: e.message }); }
  });

  // ── 貼上備註（直接呼叫 API，無對話框）─────────────────────

  document.getElementById('btnPasteNotes')?.addEventListener('click', async () => {
    const layer = requireLayer(); if (!layer) return;
    const mk = getMasterKeys();
    try {
      const r = await apiPost('/api/EMOdLayerRoute/PasteNotes',
        { PartNum: mk.partNum, Revision: mk.revision, LayerId: layer.layerId });
      if (r?.ok) {
        reloadLayerRoute();
      } else Swal.fire({ icon: 'error', title: '貼上備註失敗', text: r?.error || '未知錯誤' });
    } catch (e) { Swal.fire({ icon: 'error', title: '貼上備註失敗', text: e.message }); }
  });

  // ── 生產途程選擇 Modal（C途程異動 / C途程備註 共用）────────

  const rsModalEl = document.getElementById('modalRouteSelect');
  if (!rsModalEl) return;
  const rsModal = new bootstrap.Modal(rsModalEl);

  let _rsMode = 'change';   // 'change' = C途程異動, 'notes' = C途程備註
  let _rsSelectedTmpId = '';

  // 渲染範本清單（左側）
  function renderTmpList(rows) {
    const tbody = document.getElementById('routeSelectTmpBody');
    if (!rows?.length) { tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-2">無資料</td></tr>'; return; }
    tbody.innerHTML = rows.map(r =>
      `<tr class="rs-tmp-row" data-tmp-id="${escH(r.TmpId)}" style="cursor:pointer">
         <td>${escH(r.TmpId)}</td><td>${escH(r.Notes ?? '')}</td>
       </tr>`
    ).join('');
  }

  // 渲染範本製程明細（右側）
  function renderTmpDetail(rows) {
    const tbody = document.getElementById('routeSelectDtlBody');
    if (!rows?.length) { tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-2">無製程</td></tr>'; return; }
    tbody.innerHTML = rows.map(r =>
      `<tr>
         <td>${escH(r.SerialNum)}</td>
         <td>${escH(r.ProcCode)}</td>
         <td>${escH(r.ProcName ?? '')}</td>
         <td>${escH(r.FinishRate ?? '')}</td>
       </tr>`
    ).join('');
  }

  // 範本清單 click → 載入右側明細
  document.getElementById('routeSelectTmpBody')?.addEventListener('click', async (e) => {
    const row = e.target.closest('.rs-tmp-row');
    if (!row) return;
    document.querySelectorAll('.rs-tmp-row').forEach(r => r.classList.remove('table-active'));
    row.classList.add('table-active');
    _rsSelectedTmpId = row.dataset.tmpId;
    const dtlR = await apiGet(`/api/EMOdLayerRoute/GetTmpDetail?tmpId=${encodeURIComponent(_rsSelectedTmpId)}`);
    renderTmpDetail(dtlR?.data ?? []);
  });

  // 查詢按鈕（途程模型 tab）
  document.getElementById('btnRouteSelectSearch')?.addEventListener('click', async () => {
    const tmpId = document.getElementById('routeSelectSearchTmpId')?.value.trim() ?? '';
    const notes = document.getElementById('routeSelectSearchNotes')?.value.trim() ?? '';
    const r = await apiGet(`/api/EMOdLayerRoute/GetTmpList?tmpId=${encodeURIComponent(tmpId)}&notes=${encodeURIComponent(notes)}`);
    renderTmpList(r?.data ?? []);
    _rsSelectedTmpId = '';
    document.getElementById('routeSelectDtlBody').innerHTML =
      '<tr><td colspan="4" class="text-center text-muted py-2">請選擇範本</td></tr>';
  });

  // 查詢按鈕（條件查詢 tab for C途程備註）
  document.getElementById('btnRouteNoteSearch')?.addEventListener('click', async () => {
    const tmpId = document.getElementById('routeNoteSearchTmpId')?.value.trim() ?? '';
    const notes = document.getElementById('routeNoteSearchNotes')?.value.trim() ?? '';
    const r = await apiGet(`/api/EMOdLayerRoute/GetTmpList?tmpId=${encodeURIComponent(tmpId)}&notes=${encodeURIComponent(notes)}`);
    const tbody = document.getElementById('routeNoteQueryBody');
    if (!r?.data?.length) {
      tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-2">無資料</td></tr>'; return;
    }
    tbody.innerHTML = r.data.map(row =>
      `<tr class="rs-note-row" data-tmp-id="${escH(row.TmpId)}" style="cursor:pointer">
         <td>${escH(row.TmpId)}</td><td>${escH(row.Notes ?? '')}</td>
       </tr>`
    ).join('');
  });

  document.getElementById('routeNoteQueryBody')?.addEventListener('click', (e) => {
    const row = e.target.closest('.rs-note-row');
    if (!row) return;
    document.querySelectorAll('.rs-note-row').forEach(r => r.classList.remove('table-active'));
    row.classList.add('table-active');
    _rsSelectedTmpId = row.dataset.tmpId;
  });

  // 確定按鈕
  document.getElementById('btnRouteSelectConfirm')?.addEventListener('click', async () => {
    const layer = getActiveLayer();
    if (!layer?.layerId) { Swal.fire({ icon: 'warning', title: '請先選擇層別' }); return; }
    if (!_rsSelectedTmpId) { Swal.fire({ icon: 'warning', title: '請先選擇途程範本' }); return; }
    const mk = getMasterKeys();

    try {
      let r;
      if (_rsMode === 'change') {
        r = await apiPost('/api/EMOdLayerRoute/InsLayerRoute', {
          PartNum: mk.partNum, Revision: mk.revision,
          LayerId: layer.layerId, TmpId: _rsSelectedTmpId
        });
      } else {
        r = await apiPost('/api/EMOdLayerRoute/InsertNotes', {
          PartNum: mk.partNum, Revision: mk.revision, LayerId: layer.layerId
        });
      }
      if (r?.ok) {
        rsModal.hide();
        reloadLayerRoute();
      } else {
        Swal.fire({ icon: 'error', title: '操作失敗', text: r?.error || '未知錯誤' });
      }
    } catch (e) {
      Swal.fire({ icon: 'error', title: '操作失敗', text: e.message });
    }
  });

  // C途程異動 → 開 Modal（途程模型 tab）
  document.getElementById('btnChangeProcRoute')?.addEventListener('click', async () => {
    if (!requireLayer()) return;
    _rsMode = 'change';
    _rsSelectedTmpId = '';
    document.getElementById('modalRouteSelectTitle').textContent = '生產途程選擇（C途程異動）';
    // 顯示途程模型 tab，隱藏條件查詢 tab
    document.getElementById('routeSelectModelTab').style.display = 'flex';
    document.getElementById('routeSelectQueryTab').style.display = 'none';
    // 清空並預設查詢
    document.getElementById('routeSelectSearchTmpId').value = '';
    document.getElementById('routeSelectSearchNotes').value = '';
    document.getElementById('routeSelectTmpBody').innerHTML =
      '<tr><td colspan="2" class="text-center text-muted py-2">請查詢</td></tr>';
    document.getElementById('routeSelectDtlBody').innerHTML =
      '<tr><td colspan="4" class="text-center text-muted py-2">請選擇範本</td></tr>';
    // 預先載入清單
    const r = await apiGet('/api/EMOdLayerRoute/GetTmpList');
    renderTmpList(r?.data ?? []);
    rsModal.show();
  });

  // C途程備註 → 開 Modal（條件查詢 tab）
  document.getElementById('btnNotesStyleTree')?.addEventListener('click', async () => {
    if (!requireLayer()) return;
    _rsMode = 'notes';
    _rsSelectedTmpId = '';
    document.getElementById('modalRouteSelectTitle').textContent = '生產途程選擇（C途程備註）';
    // 隱藏途程模型 tab，顯示條件查詢 tab
    document.getElementById('routeSelectModelTab').style.display = 'none';
    document.getElementById('routeSelectQueryTab').style.display = 'flex';
    document.getElementById('routeNoteSearchTmpId').value = '';
    document.getElementById('routeNoteSearchNotes').value = '';
    document.getElementById('routeNoteQueryBody').innerHTML =
      '<tr><td colspan="2" class="text-center text-muted py-2">請查詢</td></tr>';
    rsModal.show();
  });

  // ── 途程內容變更 Modal ──────────────────────────────────

  const rcModalEl = document.getElementById('modalRouteChange');
  if (!rcModalEl) return;
  const rcModal = new bootstrap.Modal(rcModalEl);

  // 左側可用製程
  let rcSourceList = [];  // [{ProcCode, ProcName}]
  // 右側已選製程
  let rcTargetList = [];  // [{ProcCode, ProcName}]

  function renderRcSource() {
    const tbody = document.getElementById('rcSourceBody');
    if (!rcSourceList.length) {
      tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-2">無資料</td></tr>'; return;
    }
    tbody.innerHTML = rcSourceList.map((r, i) =>
      `<tr class="rc-src-row" data-idx="${i}" style="cursor:pointer">
         <td>${escH(r.ProcCode)}</td><td>${escH(r.ProcName ?? '')}</td>
       </tr>`
    ).join('');
  }

  function renderRcTarget() {
    const tbody = document.getElementById('rcTargetBody');
    if (!rcTargetList.length) {
      tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-2">尚未選擇</td></tr>'; return;
    }
    tbody.innerHTML = rcTargetList.map((r, i) =>
      `<tr class="rc-tgt-row" data-idx="${i}" style="cursor:pointer">
         <td>${escH(r.ProcCode)}</td><td>${escH(r.ProcName ?? '')}</td>
       </tr>`
    ).join('');
  }

  function getRcSelectedSrcIdx() {
    const el = document.querySelector('.rc-src-row.table-active');
    return el ? parseInt(el.dataset.idx) : -1;
  }

  function getRcSelectedTgtIdx() {
    const el = document.querySelector('.rc-tgt-row.table-active');
    return el ? parseInt(el.dataset.idx) : -1;
  }

  document.getElementById('rcSourceBody')?.addEventListener('click', (e) => {
    const row = e.target.closest('.rc-src-row'); if (!row) return;
    document.querySelectorAll('.rc-src-row').forEach(r => r.classList.remove('table-active'));
    row.classList.add('table-active');
  });

  document.getElementById('rcTargetBody')?.addEventListener('click', (e) => {
    const row = e.target.closest('.rc-tgt-row'); if (!row) return;
    document.querySelectorAll('.rc-tgt-row').forEach(r => r.classList.remove('table-active'));
    row.classList.add('table-active');
  });

  // 雙擊左側 → 加入右側
  document.getElementById('rcSourceBody')?.addEventListener('dblclick', (e) => {
    const row = e.target.closest('.rc-src-row'); if (!row) return;
    document.getElementById('btnRcMoveRight')?.click();
  });

  // 查詢可用製程
  document.getElementById('btnRcSearch')?.addEventListener('click', async () => {
    const r = await apiGet(
      `/api/EMOdLayerRoute/GetProcChoice?bProc=${encodeURIComponent(document.getElementById('rcBProc')?.value ?? '')}` +
      `&eProc=${encodeURIComponent(document.getElementById('rcEProc')?.value ?? '')}` +
      `&procLike=${encodeURIComponent(document.getElementById('rcProcLike')?.value ?? '')}` +
      `&procNameLike=${encodeURIComponent(document.getElementById('rcProcNameLike')?.value ?? '')}`
    );
    rcSourceList = (r?.data ?? []).map(d => ({ ProcCode: d.ProcCode ?? d.procCode, ProcName: d.ProcName ?? d.procName ?? '' }));
    renderRcSource();
  });

  // → 加入
  document.getElementById('btnRcMoveRight')?.addEventListener('click', () => {
    const idx = getRcSelectedSrcIdx(); if (idx < 0) return;
    const item = rcSourceList[idx];
    if (!rcTargetList.find(t => t.ProcCode === item.ProcCode)) {
      rcTargetList.push({ ...item });
      renderRcTarget();
    }
  });

  // ← 移除
  document.getElementById('btnRcMoveLeft')?.addEventListener('click', () => {
    const idx = getRcSelectedTgtIdx(); if (idx < 0) return;
    rcTargetList.splice(idx, 1);
    renderRcTarget();
  });

  // ↑ 上移
  document.getElementById('btnRcMoveUp')?.addEventListener('click', () => {
    const idx = getRcSelectedTgtIdx(); if (idx <= 0) return;
    [rcTargetList[idx - 1], rcTargetList[idx]] = [rcTargetList[idx], rcTargetList[idx - 1]];
    renderRcTarget();
    const newRow = document.querySelector(`.rc-tgt-row[data-idx="${idx - 1}"]`);
    newRow?.classList.add('table-active');
  });

  // ↓ 下移
  document.getElementById('btnRcMoveDown')?.addEventListener('click', () => {
    const idx = getRcSelectedTgtIdx();
    if (idx < 0 || idx >= rcTargetList.length - 1) return;
    [rcTargetList[idx], rcTargetList[idx + 1]] = [rcTargetList[idx + 1], rcTargetList[idx]];
    renderRcTarget();
    const newRow = document.querySelector(`.rc-tgt-row[data-idx="${idx + 1}"]`);
    newRow?.classList.add('table-active');
  });

  // 確定（途程內容變更）
  document.getElementById('btnRcConfirm')?.addEventListener('click', async () => {
    const layer = getActiveLayer();
    if (!layer?.layerId) { Swal.fire({ icon: 'warning', title: '請先選擇層別' }); return; }
    const mk = getMasterKeys();
    try {
      const r = await apiPost('/api/EMOdLayerRoute/RouteChange', {
        PartNum: mk.partNum,
        Revision: mk.revision,
        LayerId: layer.layerId,
        ProcCodes: rcTargetList.map(t => t.ProcCode)
      });
      if (r?.ok) {
        rcModal.hide();
        reloadLayerRoute();
      } else {
        Swal.fire({ icon: 'error', title: '更新失敗', text: r?.error || '未知錯誤' });
      }
    } catch (e) {
      Swal.fire({ icon: 'error', title: '更新失敗', text: e.message });
    }
  });

  // 途程內容變更 → 開 Modal，並載入右側現有途程
  document.getElementById('btnRouteChange')?.addEventListener('click', async () => {
    const layer = requireLayer(); if (!layer) return;
    const mk = getMasterKeys();
    // 清空並重置
    rcSourceList = [];
    rcTargetList = [];
    renderRcSource();
    renderRcTarget();
    document.getElementById('rcBProc').value = '';
    document.getElementById('rcEProc').value = '';
    document.getElementById('rcProcLike').value = '';
    document.getElementById('rcProcNameLike').value = '';
    // 載入右側現有途程
    try {
      const r = await apiGet(
        `/api/EMOdLayerRoute/GetCurrentRoute?partNum=${encodeURIComponent(mk.partNum)}` +
        `&revision=${encodeURIComponent(mk.revision)}&layerId=${encodeURIComponent(layer.layerId)}`
      );
      rcTargetList = (r?.data ?? []).map(d => ({ ProcCode: d.ProcCode ?? d.procCode, ProcName: d.ProcName ?? d.procName ?? '' }));
      renderRcTarget();
    } catch {}
    // 預先載入左側製程清單
    try {
      const r2 = await apiGet('/api/EMOdLayerRoute/GetProcChoice?bProc=&eProc=&procLike=&procNameLike=');
      rcSourceList = (r2?.data ?? []).map(d => ({ ProcCode: d.ProcCode ?? d.procCode, ProcName: d.ProcName ?? d.procName ?? '' }));
      renderRcSource();
    } catch {}
    rcModal.show();
  });

});
</script>

<script>
// ===== 組合模型 (BOM) 選擇 Modal =====
document.addEventListener('DOMContentLoaded', function () {
  const modalEl   = document.getElementById('modalSelectBOMModel');
  if (!modalEl) return;

  const bsModal   = new bootstrap.Modal(modalEl);
  const btnSearch = document.getElementById('btnSearchBOM');
  const btnConfirm = document.getElementById('btnConfirmBOM');
  const inpTmpId  = document.getElementById('searchBOMTmpId');
  const inpNotes  = document.getElementById('searchBOMNotes');
  const tbody     = document.getElementById('tblBOMModelBody');
  const treeDiv   = document.getElementById('bomModelTree');

  let selectedTr  = null;

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── 開啟（由 ActionRail handler 呼叫） ──
  window.openBOMSelectModal = function () {
    selectedTr = null;
    inpTmpId.value = '';
    inpNotes.value = '';
    tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small py-3">查詢中…</td></tr>';
    treeDiv.innerHTML = '<span class="text-muted">請先選擇模型</span>';
    bsModal.show();
    doSearch();
  };

  // ── 搜尋 ──
  btnSearch.addEventListener('click', doSearch);
  [inpTmpId, inpNotes].forEach(inp =>
    inp.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); })
  );

  async function doSearch() {
    tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small">查詢中…</td></tr>';
    treeDiv.innerHTML = '<span class="text-muted">請先選擇模型</span>';
    selectedTr = null;
    try {
      const p = new URLSearchParams({ activeOnly: '1' });
      const t = inpTmpId.value.trim(), n = inpNotes.value.trim();
      if (t) p.append('tmpId', t);
      if (n) p.append('notes', n);
      const r = await fetch(`/api/EMOdTmpPress/GetBOMMasList?${p}`);
      if (!r.ok) throw new Error('查詢失敗');
      const json = await r.json();
      const rows = json.data ?? json ?? [];
      renderList(rows);
    } catch (err) {
      tbody.innerHTML = `<tr><td colspan="2" class="text-danger text-center small">${escHtml(err.message)}</td></tr>`;
    }
  }

  function renderList(rows) {
    if (!rows.length) {
      tbody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small py-3">查無資料</td></tr>';
      return;
    }
    tbody.innerHTML = rows.map(r => `
      <tr style="cursor:pointer" data-tmpid="${escHtml((r.TmpId ?? '').trim())}">
        <td>${escHtml((r.TmpId ?? '').trim())}</td>
        <td>${escHtml((r.Notes ?? '').trim())}</td>
      </tr>`).join('');

    tbody.querySelectorAll('tr').forEach(tr => {
      tr.addEventListener('click', () => onRowClick(tr));
      tr.addEventListener('dblclick', () => { onRowClick(tr); confirmBOM(); });
    });
  }

  // ── 選取列 → 載入樹狀 ──
  async function onRowClick(tr) {
    tbody.querySelectorAll('tr').forEach(t => t.classList.remove('table-active'));
    tr.classList.add('table-active');
    selectedTr = tr;
    treeDiv.innerHTML = '<span class="text-muted small">載入中…</span>';

    const tmpId = tr.dataset.tmpid;
    try {
      const r = await fetch(`/api/EMOdTmpPress/GetBOMMasDtl?tmpId=${encodeURIComponent(tmpId)}`);
      if (!r.ok) throw new Error();
      const json = await r.json();
      const dtlRows = json.data ?? json ?? [];
      renderTree(dtlRows);
    } catch {
      treeDiv.innerHTML = '<span class="text-danger small">載入失敗</span>';
    }
  }

  // ── 樹狀結構渲染 ──
  function renderTree(rows) {
    if (!rows.length) { treeDiv.innerHTML = '<span class="text-muted small">無層別資料</span>'; return; }
    // 依 Degree 分層
    const maxDeg = Math.max(...rows.map(r => r.Degree ?? r.degree ?? 0));
    let html = '';
    for (let d = 0; d <= maxDeg; d++) {
      const items = rows.filter(r => (r.Degree ?? r.degree) === d);
      if (!items.length) continue;
      items.sort((a, b) => (a.FL ?? a.fl ?? 0) - (b.FL ?? b.fl ?? 0));
      const indent = d * 16;
      items.forEach(it => {
        const name = (it.LayerName ?? it.layerName ?? it.LayerId ?? it.layerId ?? '').trim();
        html += `<div style="padding:2px 4px 2px ${indent + 4}px; font-size:13px;">${escHtml(name)}</div>`;
      });
    }
    treeDiv.innerHTML = html || '<span class="text-muted small">無資料</span>';
  }

  // ── 確定 ──
  async function confirmBOM() {
    if (!selectedTr) { alert('請選擇一個組合模型'); return; }
    const tmpBOMId = selectedTr.dataset.tmpid;
    const partNum  = (window.currentMasterKeys?.PartNum  || window.currentMasterKeys?.partnum  || '').trim();
    const revision = (window.currentMasterKeys?.Revision || window.currentMasterKeys?.revision || '').trim();
    if (!partNum) { alert('無法取得料號'); return; }

    if (!confirm(`確定套用組合模型「${tmpBOMId}」？`)) return;

    btnConfirm.disabled = true;
    btnConfirm.textContent = '套用中…';
    try {
      const resp = await fetch('/api/EMOdTmpPress/ApplyBOMModel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ TmpBOMId: tmpBOMId, PartNum: partNum, Revision: revision })
      });
      const txt = await resp.text();
      let result = null;
      try { result = txt ? JSON.parse(txt) : null; } catch {}
      if (!resp.ok || result?.ok === false) {
        alert('套用失敗: ' + (result?.error || txt || '未知錯誤'));
        return;
      }
      bsModal.hide();
      location.reload();
    } catch (e) {
      alert('套用失敗: ' + e.message);
    } finally {
      btnConfirm.disabled = false;
      btnConfirm.textContent = '✓ 確定';
    }
  }
  btnConfirm.addEventListener('click', confirmBOM);

  // ── 註冊 ActionRail handler（btnC1 = 組合模型）──
  window.ActionRailCustomHandlers = window.ActionRailCustomHandlers || {};
  const itemId = window._itemId || '';
  if (itemId) {
    window.ActionRailCustomHandlers[itemId] = window.ActionRailCustomHandlers[itemId] || {};
    window.ActionRailCustomHandlers[itemId]['btnC1'] = async () => {
      window.openBOMSelectModal();
    };
  }
});
</script>

