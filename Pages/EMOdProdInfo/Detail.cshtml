<script>
// ============================================
// 規格頁籤拖曳排版（Vanilla JS，零依賴）
// Admin + Shift 啟動
// ============================================
(function initSpecLayoutDrag() {
  'use strict';
  const PAD = 6, SNAP_PX = 2, SEL = 'md-selected', SEL_LAB = 'md-selected-label';
  const dirtyFields = new Set(); // 記錄被修改過的欄位名稱
  const originalPos = new Map(); // 記錄欄位修改前的原始位置 { fieldName → {ft,fl,fw,fh,lt,ll} }
  let lastMouseXY = { x: 0, y: 0 }; // 追蹤最新滑鼠位置（供頁籤切換 rebase 用）
  let labelDrag = null; // label 拖曳全域狀態 { lab, items: [{el,t0,l0}], startX, startY }

  /* ---- DOM helpers ---- */
  const qAll = (s, p) => Array.from((p || document).querySelectorAll(s));
  const allFields = () => qAll('.spec-draggable');
  const allLabels = () => qAll('.spec-field-label');
  const selected  = () => allFields().filter(el => el.classList.contains(SEL));
  const selectedLabels = () => allLabels().filter(el => el.classList.contains(SEL_LAB));
  const clearSel  = () => { selected().forEach(el => el.classList.remove(SEL)); selectedLabels().forEach(el => el.classList.remove(SEL_LAB)); };
  const labelFor  = el => el ? document.querySelector(`.spec-field-label[data-field="${el.dataset.field}"]`) : null;
  const inLayout = () => document.body.classList.contains('layout-edit-enabled');

  /* ---- snap 吸附（全部用 getBoundingClientRect 統一座標）---- */
  let snap = { tops:[], lefts:[], rights:[], bottoms:[] };
  let snapContainer = null; // 記住容器，給輔助線用

  // 取得元素相對於容器的座標
  function relRect(el, container) {
    const er = el.getBoundingClientRect();
    const cr = container.getBoundingClientRect();
    return { top: er.top - cr.top, left: er.left - cr.left, width: er.width, height: er.height };
  }

  // excludeEls: 要排除的 DOM 元素陣列（拖曳中會跟著動的元素不應參與吸附）
  function buildSnap(dragEl, excludeEls) {
    const s = { tops:[], lefts:[], rights:[], bottoms:[] };
    const tab = dragEl.closest('.master-spec-tab');
    if (!tab) return s;
    snapContainer = tab;
    if (!tab.style.position || tab.style.position === 'static') {
      tab.style.position = 'relative';
    }
    const excl = new Set(excludeEls || []);
    excl.add(dragEl);
    qAll('.spec-draggable, .spec-field-label', tab).forEach(el => {
      if (excl.has(el)) return;
      const r = relRect(el, tab);
      s.tops.push(r.top); s.lefts.push(r.left);
      s.rights.push(r.left + r.width); s.bottoms.push(r.top + r.height);
    });
    s.tops=[...new Set(s.tops)]; s.lefts=[...new Set(s.lefts)];
    s.rights=[...new Set(s.rights)]; s.bottoms=[...new Set(s.bottoms)];
    return s;
  }
  function applySnap(t, l, w, h) {
    let snapH = null, snapV = null;
    // 上邊 ↔ 其他上邊
    for (const e of snap.tops)    { if (Math.abs(t - e) <= SNAP_PX) { t = e; snapH = e; break; } }
    // 下邊 ↔ 其他下邊
    if (snapH === null) for (const e of snap.bottoms) { if (Math.abs(t + h - e) <= SNAP_PX) { t = e - h; snapH = e; break; } }
    // 下邊 ↔ 其他上邊
    if (snapH === null) for (const e of snap.tops)    { if (Math.abs(t + h - e) <= SNAP_PX) { t = e - h; snapH = e; break; } }
    // 上邊 ↔ 其他下邊
    if (snapH === null) for (const e of snap.bottoms) { if (Math.abs(t - e) <= SNAP_PX) { t = e; snapH = e; break; } }
    // 左邊 ↔ 其他左邊
    for (const e of snap.lefts)   { if (Math.abs(l - e) <= SNAP_PX) { l = e; snapV = e; break; } }
    // 左邊 ↔ 其他右邊
    if (snapV === null) for (const e of snap.rights)  { if (Math.abs(l - e) <= SNAP_PX) { l = e; snapV = e; break; } }
    // 右邊 ↔ 其他左邊
    if (snapV === null) for (const e of snap.lefts)   { if (Math.abs(l + w - e) <= SNAP_PX) { l = e - w; snapV = e; break; } }
    // 右邊 ↔ 其他右邊
    if (snapV === null) for (const e of snap.rights)  { if (Math.abs(l + w - e) <= SNAP_PX) { l = e - w; snapV = e; break; } }
    showGuides(snapH, snapV);
    return { top: t, left: l };
  }

  /* ---- 吸附輔助線 ---- */
  function showGuides(hY, vX) {
    clearGuides();
    const container = snapContainer;
    if (!container) return;
    if (hY !== null) {
      const g = document.createElement('div');
      g.className = 'snap-guide guide-h';
      g.style.top = hY + 'px';
      container.appendChild(g);
    }
    if (vX !== null) {
      const g = document.createElement('div');
      g.className = 'snap-guide guide-v';
      g.style.left = vX + 'px';
      container.appendChild(g);
    }
  }
  function clearGuides() {
    document.querySelectorAll('.snap-guide').forEach(g => g.remove());
  }

  /* ---- dirty tracking + save ---- */
  // 在移動/resize 開始前記錄原始位置（只記錄第一次）
  function captureOriginals(els) {
    els.forEach(el => {
      const fn = el.dataset?.field;
      if (!fn || originalPos.has(fn)) return;
      const field = document.querySelector(`.spec-draggable[data-field="${fn}"]`);
      const lab = labelFor(field);
      const container = (field || lab)?.closest('.master-spec-tab') || null;
      originalPos.set(fn, {
        ft: field ? field.style.top : null,
        fl: field ? field.style.left : null,
        fw: field ? field.style.width : null,
        fh: field ? field.style.height : null,
        lt: lab ? lab.style.top : null,
        ll: lab ? lab.style.left : null,
        showWhere: field ? field.dataset.showWhere : null,
        container: container  // 原始所在的頁籤容器
      });
    });
  }
  function markDirty(els) {
    els.forEach(el => {
      const fn = el.dataset?.field;
      if (fn) dirtyFields.add(fn);
    });
    console.log('[LayoutDrag] markDirty:', dirtyFields.size, '個欄位', [...dirtyFields]);
    updateSaveBtn();
  }
  function updateSaveBtn() {
    const wrap = document.getElementById('layout-btn-wrap');
    const btnSave = document.getElementById('layout-save-btn');
    const btnCancel = document.getElementById('layout-cancel-btn');
    if (!wrap) return;
    const n = dirtyFields.size;
    if (!inLayout()) {
      wrap.style.display = 'none';
      return;
    }
    // 編輯模式下永遠顯示
    wrap.style.display = 'flex';
    if (n > 0) {
      btnSave.textContent = `保存 (${n})`;
      btnSave.style.background = '#5b8def';
      btnSave.style.cursor = 'pointer';
      btnSave.disabled = false;
      btnCancel.style.background = '#e74c3c';
      btnCancel.style.cursor = 'pointer';
      btnCancel.disabled = false;
    } else {
      btnSave.textContent = '無修改';
      btnSave.style.background = '#999';
      btnSave.style.cursor = 'default';
      btnSave.disabled = true;
      btnCancel.style.background = '#999';
      btnCancel.style.cursor = 'default';
      btnCancel.disabled = true;
    }
  }
  function saveLayout() {
    if (!dirtyFields.size) return;
    const layout = allFields()
      .filter(el => dirtyFields.has(el.dataset.field))
      .map(el => {
        const lab = labelFor(el);
        return {
          fieldName: el.dataset.field,
          top:  Math.max(0, el.offsetTop - PAD),
          left: el.offsetLeft,
          width: el.offsetWidth,
          height: el.offsetHeight,
          labTop:  lab ? Math.max(0, lab.offsetTop - PAD) : null,
          labLeft: lab ? lab.offsetLeft : null,
          ishowWhere: parseInt(el.dataset.showWhere) || 1
        };
      });
    if (!layout.length) return;
    const btn = document.getElementById('layout-save-btn');
    if (btn) { btn.textContent = '保存中...'; btn.disabled = true; }
    fetch('/api/TableFieldLayout/SaveHeaderLayout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tableName: window._headerTableName || 'EMOdProdInfo', layoutUpdates: layout })
    }).then(r => {
      if (r.ok) {
        dirtyFields.clear();
        originalPos.clear();
        updateSaveBtn();
        console.log('[LayoutDrag] 保存成功:', layout.length, '個欄位');
      } else {
        if (btn) { btn.textContent = `保存失敗 (${dirtyFields.size})`; btn.disabled = false; }
      }
    }).catch(() => {
      if (btn) { btn.textContent = `保存失敗 (${dirtyFields.size})`; btn.disabled = false; }
    });
  }
  function cancelLayout() {
    // 還原所有修改過的欄位到原始位置
    originalPos.forEach((pos, fn) => {
      const field = document.querySelector(`.spec-draggable[data-field="${fn}"]`);
      const lab = labelFor(field);
      // 如果欄位被移到了其他頁籤，先移回原始頁籤
      if (pos.container && field) {
        const currentContainer = field.closest('.master-spec-tab');
        if (currentContainer !== pos.container) {
          pos.container.appendChild(field);
          if (lab) pos.container.appendChild(lab);
          if (pos.showWhere) field.dataset.showWhere = pos.showWhere;
        }
      }
      if (field) {
        if (pos.ft !== null) field.style.top = pos.ft;
        if (pos.fl !== null) field.style.left = pos.fl;
        if (pos.fw !== null) field.style.width = pos.fw;
        if (pos.fh !== null) field.style.height = pos.fh;
        // 同步還原 input 寬高（resize 時有設定 inner）
        const inner = field.querySelector('.master-field');
        if (inner && pos.fw !== null) inner.style.width = pos.fw;
        if (inner && pos.fh !== null) inner.style.height = pos.fh;
      }
      if (lab) {
        if (pos.lt !== null) lab.style.top = pos.lt;
        if (pos.ll !== null) lab.style.left = pos.ll;
      }
    });
    dirtyFields.clear();
    originalPos.clear();
    updateSaveBtn();
    console.log('[LayoutDrag] 已取消所有修改，還原到原始位置');
  }
  // 建立保存 + 取消按鈕 DOM（只建一次）
  (function createBtns() {
    const wrap = document.createElement('div');
    wrap.id = 'layout-btn-wrap';
    wrap.style.cssText = 'display:none;position:fixed;bottom:20px;right:20px;z-index:10000;gap:8px;';

    const btnSave = document.createElement('button');
    btnSave.id = 'layout-save-btn';
    btnSave.type = 'button';
    btnSave.textContent = '保存';
    btnSave.style.cssText = 'padding:8px 18px;background:#5b8def;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.2);';
    btnSave.addEventListener('mouseenter', () => { if (!btnSave.disabled) btnSave.style.background = '#4a7ce0'; });
    btnSave.addEventListener('mouseleave', () => { if (!btnSave.disabled) btnSave.style.background = '#5b8def'; });
    btnSave.addEventListener('click', saveLayout);

    const btnCancel = document.createElement('button');
    btnCancel.id = 'layout-cancel-btn';
    btnCancel.type = 'button';
    btnCancel.textContent = '取消';
    btnCancel.style.cssText = 'padding:8px 18px;background:#e74c3c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.2);';
    btnCancel.addEventListener('mouseenter', () => { if (!btnCancel.disabled) btnCancel.style.background = '#c0392b'; });
    btnCancel.addEventListener('mouseleave', () => { if (!btnCancel.disabled) btnCancel.style.background = '#e74c3c'; });
    btnCancel.addEventListener('click', cancelLayout);

    wrap.appendChild(btnCancel);
    wrap.appendChild(btnSave);
    document.body.appendChild(wrap);
    console.log('[LayoutDrag] 保存/取消按鈕已建立');
  })();

  /* ---- drag state ---- */
  let drag = null; // { el, startX, startY, items:[{el,t0,l0,lab,labT0,labL0}] }

  function startDrag(el, e) {
    if (!inLayout()) return;
    const grpFields = selected().length ? selected() : [el];
    const grpLabels = selectedLabels();
    const allMoving = [...grpFields, ...grpLabels];
    captureOriginals(allMoving); // 移動前記錄原始位置
    snap = buildSnap(el, allMoving);
    const ct = snapContainer;
    drag = {
      el, startX: e.clientX, startY: e.clientY, container: ct,
      items: allMoving.map(f => {
        const r = relRect(f, ct);
        return { el: f, t0: r.top, l0: r.left };
      })
    };
    el.style.opacity = '0.5';
  }

  /* ---- 拖曳切換頁籤 ---- */
  let tabHoverTimer = null;
  let lastSwitchedTab = null; // 記住切換到的頁籤按鈕

  function checkTabSwitch(e) {
    // 只偵測有 data-tab-show-where 的規格頁籤（排除「規格/表單」等頂層頁籤）
    let tabBtn = null;
    document.querySelectorAll('.nav-link[data-tab-show-where]').forEach(btn => {
      const r = btn.getBoundingClientRect();
      if (e.clientX >= r.left && e.clientX <= r.right && e.clientY >= r.top && e.clientY <= r.bottom) {
        tabBtn = btn;
      }
    });
    if (tabBtn && !tabBtn.classList.contains('active')) {
      if (tabHoverTimer && tabHoverTimer._target === tabBtn) return;
      clearTimeout(tabHoverTimer);
      tabHoverTimer = setTimeout(() => {
        const bsTab = new bootstrap.Tab(tabBtn);
        bsTab.show();
        lastSwitchedTab = tabBtn;
        // 立即移動拖曳中的元素到新頁籤（避免舊頁籤隱藏時元素消失）
        const newTabKey = tabBtn.dataset.tabKey;
        const nc = document.querySelector(`#master-content-${newTabKey} .master-spec-tab`);
        if (nc) rebaseDragToNewTab(nc, tabBtn);
        setTimeout(initFields, 200);
      }, 300);
      tabHoverTimer._target = tabBtn;
    } else if (!tabBtn) {
      clearTimeout(tabHoverTimer);
      tabHoverTimer = null;
    }
  }

  // 將欄位（+ 配對的 label/input）移到目標頁籤，保持相對位置
  const _movedFields = new Set(); // 防止同一欄位重複移動
  function moveFieldToTab(el, targetTabBtn) {
    const fn = el.dataset?.field;
    if (!fn || _movedFields.has(fn)) return;
    _movedFields.add(fn);

    const newShowWhere = parseInt(targetTabBtn.dataset.tabShowWhere) || 1;
    const newTabKey = targetTabBtn.dataset.tabKey;
    const newContainer = document.querySelector(`#master-content-${newTabKey} .master-spec-tab`);
    if (!newContainer) return;

    const field = document.querySelector(`.spec-draggable[data-field="${fn}"]`);
    const lab = labelFor(field);

    // 找到來源容器（field 或 label 的）
    const srcEl = field || lab;
    if (!srcEl) return;
    const oldContainer = srcEl.closest('.master-spec-tab');
    if (oldContainer === newContainer) return; // 同一頁籤，不需移動

    // 計算 label 相對於 field 的偏移量
    let labOffsetTop = 0, labOffsetLeft = 0;
    if (field && lab) {
      labOffsetTop  = lab.offsetTop - field.offsetTop;
      labOffsetLeft = lab.offsetLeft - field.offsetLeft;
    }

    // 移動 field 到新容器
    if (field) {
      newContainer.appendChild(field);
      field.dataset.showWhere = newShowWhere;
    }

    // label 也跟著移動，保持相對位置
    if (lab) {
      newContainer.appendChild(lab);
      if (field) {
        lab.style.top  = (field.offsetTop + labOffsetTop) + 'px';
        lab.style.left = (field.offsetLeft + labOffsetLeft) + 'px';
      }
    }

    console.log(`[LayoutDrag] 欄位 ${fn} 移至頁籤 ${newTabKey} (iShowWhere=${newShowWhere})`);
  }
  function clearMovedFields() { _movedFields.clear(); }

  // 頁籤切換時，立即移動拖曳中的元素到新容器並重置座標
  function rebaseDragToNewTab(nc, tabBtn) {
    const items = drag ? drag.items : (labelDrag ? labelDrag.items : null);
    if (!items || !nc) return;
    const newShowWhere = parseInt(tabBtn.dataset.tabShowWhere) || 1;
    const primaryEl = drag ? drag.el : (labelDrag ? labelDrag.lab : null);
    if (!primaryEl) return;

    // Step 1: 用 CSS style.top/left 記錄偏移（getBoundingClientRect 對隱藏元素回傳 0）
    const pTop = parseFloat(primaryEl.style.top) || 0;
    const pLeft = parseFloat(primaryEl.style.left) || 0;
    const offsets = new Map();
    items.forEach(it => {
      const t = parseFloat(it.el.style.top) || 0;
      const l = parseFloat(it.el.style.left) || 0;
      offsets.set(it.el, { dTop: t - pTop, dLeft: l - pLeft });
    });

    // Step 2: 找配對元素，記錄偏移，加入拖曳群組
    const moved = new Set();
    const newItems = [];
    items.forEach(it => {
      const fn = it.el.dataset?.field;
      if (!fn || moved.has(fn)) return;
      moved.add(fn);
      const field = document.querySelector(`.spec-draggable[data-field="${fn}"]`);
      const lab = labelFor(field);
      if (field && !items.some(i => i.el === field)) {
        const t = parseFloat(field.style.top) || 0;
        const l = parseFloat(field.style.left) || 0;
        offsets.set(field, { dTop: t - pTop, dLeft: l - pLeft });
        newItems.push({ el: field, t0: 0, l0: 0 });
      }
      if (lab && !items.some(i => i.el === lab)) {
        const t = parseFloat(lab.style.top) || 0;
        const l = parseFloat(lab.style.left) || 0;
        offsets.set(lab, { dTop: t - pTop, dLeft: l - pLeft });
        newItems.push({ el: lab, t0: 0, l0: 0 });
      }
      // 移動到新容器
      if (field && !nc.contains(field)) { nc.appendChild(field); field.dataset.showWhere = newShowWhere; }
      if (lab && !nc.contains(lab)) nc.appendChild(lab);
    });
    items.push(...newItems);

    // Step 3: 以滑鼠位置為主元素的新位置，所有元素按偏移排列（群組邊界限制）
    const cr = nc.getBoundingClientRect();
    const primaryTop = lastMouseXY.y - cr.top;
    const primaryLeft = lastMouseXY.x - cr.left;
    const rpos = items.map(it => {
      const off = offsets.get(it.el) || { dTop: 0, dLeft: 0 };
      return { el: it.el, newT: Math.round(primaryTop + off.dTop), newL: Math.round(primaryLeft + off.dLeft) };
    });
    const rminT = Math.min(...rpos.map(p => p.newT));
    const rminL = Math.min(...rpos.map(p => p.newL));
    const radjT = rminT < 0 ? -rminT : 0;
    const radjL = rminL < 0 ? -rminL : 0;
    rpos.forEach(p => {
      p.el.style.top  = (p.newT + radjT) + 'px';
      p.el.style.left = (p.newL + radjL) + 'px';
    });

    // Step 4: 重置座標
    snapContainer = nc;
    const mx = lastMouseXY.x, my = lastMouseXY.y;
    if (drag) {
      drag.startX = mx; drag.startY = my;
      drag.items.forEach(it => { const r = relRect(it.el, nc); it.t0 = r.top; it.l0 = r.left; });
      snap = buildSnap(drag.el, drag.items.map(i => i.el));
    }
    if (labelDrag) {
      labelDrag.startX = mx; labelDrag.startY = my;
      labelDrag.items.forEach(it => { const r = relRect(it.el, nc); it.t0 = r.top; it.l0 = r.left; });
      snap = buildSnap(labelDrag.lab, labelDrag.items.map(i => i.el));
    }
    console.log(`[LayoutDrag] rebase 到新頁籤，${moved.size} 個欄位`);
  }

  function onDragMove(e) {
    if (!drag) return;
    lastMouseXY.x = e.clientX; lastMouseXY.y = e.clientY;
    const dx = e.clientX - drag.startX, dy = e.clientY - drag.startY;
    checkTabSwitch(e);
    const base = drag.items.find(i => i.el === drag.el);
    const rawT = base.t0 + dy, rawL = base.l0 + dx;
    const w = drag.el.offsetWidth, h = drag.el.offsetHeight;
    const snapped = applySnap(rawT, rawL, w, h);
    const snapDY = snapped.top - base.t0, snapDX = snapped.left - base.l0;
    // 群組邊界限制：找最小值，整組一起停住（不個別 clamp）
    const positions = drag.items.map(it => ({ el: it.el, newT: it.t0 + snapDY, newL: it.l0 + snapDX }));
    const minT = Math.min(...positions.map(p => p.newT));
    const minL = Math.min(...positions.map(p => p.newL));
    const adjT = minT < 0 ? -minT : 0;
    const adjL = minL < 0 ? -minL : 0;
    positions.forEach(p => {
      p.el.style.top  = Math.round(p.newT + adjT) + 'px';
      p.el.style.left = Math.round(p.newL + adjL) + 'px';
    });
  }

  function onDragEnd() {
    if (!drag) return;
    drag.el.style.opacity = '';
    lastSwitchedTab = null;
    markDirty(drag.items.map(i => i.el));
    snap = { tops:[], lefts:[], rights:[], bottoms:[] };
    clearGuides();
    clearTimeout(tabHoverTimer); tabHoverTimer = null;
    drag = null;
  }

  /* ---- resize state ---- */
  let rsz = null; // { el, startX, startY, w0, h0, edge }

  const MIN_W = 50, MIN_H = 22;

  function startResize(el, e, edge) {
    if (!inLayout()) return;
    e.preventDefault();
    e.stopPropagation();
    captureOriginals([el]);
    const r = relRect(el, snapContainer || el.closest('.master-spec-tab'));
    rsz = { el, startX: e.clientX, startY: e.clientY, w0: el.offsetWidth, h0: el.offsetHeight, edge, elTop: r.top, elLeft: r.left };
    // 建立 resize 用的 snap 資料（排除自己）
    snap = buildSnap(el, [el]);
    document.addEventListener('mousemove', onResizeMove);
    document.addEventListener('mouseup', onResizeEnd);
  }

  function applyResizeSnap(newW, newH, elTop, elLeft) {
    let snapV = null, snapH = null;
    const right = elLeft + newW;
    const bottom = elTop + newH;
    // 右邊緣 ↔ 其他右邊緣
    for (const e of snap.rights)  { if (Math.abs(right - e) <= SNAP_PX) { newW = e - elLeft; snapV = e; break; } }
    // 右邊緣 ↔ 其他左邊緣
    if (snapV === null) for (const e of snap.lefts) { if (Math.abs(right - e) <= SNAP_PX) { newW = e - elLeft; snapV = e; break; } }
    // 下邊緣 ↔ 其他下邊緣
    if (newH !== null) {
      for (const e of snap.bottoms) { if (Math.abs(bottom - e) <= SNAP_PX) { newH = e - elTop; snapH = e; break; } }
      // 下邊緣 ↔ 其他上邊緣
      if (snapH === null) for (const e of snap.tops) { if (Math.abs(bottom - e) <= SNAP_PX) { newH = e - elTop; snapH = e; break; } }
    }
    // 等寬吸附：寬度接近其他欄位的寬度
    if (snapV === null) {
      const tab = snapContainer;
      if (tab) {
        qAll('.spec-draggable', tab).forEach(other => {
          if (other === rsz.el || snapV !== null) return;
          const ow = other.offsetWidth;
          if (Math.abs(newW - ow) <= SNAP_PX) { newW = ow; snapV = elLeft + ow; }
        });
      }
    }
    showGuides(snapH, snapV);
    return { w: newW, h: newH };
  }

  function onResizeMove(e) {
    if (!rsz) return;
    const dx = e.clientX - rsz.startX, dy = e.clientY - rsz.startY;
    let newW = Math.max(MIN_W, rsz.w0 + dx);
    let newH = rsz.edge === 'se' ? Math.max(MIN_H, rsz.h0 + dy) : null;
    // 吸附
    const snapped = applyResizeSnap(newW, newH, rsz.elTop, rsz.elLeft);
    newW = Math.max(MIN_W, snapped.w);
    rsz.el.style.width = newW + 'px';
    const inner = rsz.el.querySelector('.master-field');
    if (inner) inner.style.width = newW + 'px';
    if (rsz.edge === 'se' && snapped.h !== null) {
      const finalH = Math.max(MIN_H, snapped.h);
      rsz.el.style.height = finalH + 'px';
      if (inner) inner.style.height = finalH + 'px';
    }
  }

  function onResizeEnd() {
    if (!rsz) return;
    markDirty([rsz.el]);
    rsz = null;
    snap = { tops:[], lefts:[], rights:[], bottoms:[] };
    clearGuides();
    document.removeEventListener('mousemove', onResizeMove);
    document.removeEventListener('mouseup', onResizeEnd);
  }

  /* ---- 建立 resize 手柄 DOM ---- */
  function addResizeHandles(el) {
    if (el.querySelector('.rsz-handle')) return;
    const mkH = (cls, css) => {
      const d = document.createElement('div');
      d.className = 'rsz-handle ' + cls;
      Object.assign(d.style, { position:'absolute', zIndex:'5', ...css });
      d.addEventListener('mousedown', e => startResize(el, e, cls));
      el.appendChild(d);
    };
    mkH('se', { right:'0', bottom:'0', width:'8px', height:'8px', cursor:'se-resize' });
  }

  /* ---- init：對新渲染的欄位綁定事件 ---- */
  const DEAD_ZONE = 3; // 滑鼠移動超過 3px 才算拖曳，否則算點擊

  function initFields() {
    const fields = allFields();
    console.log('[LayoutDrag] initFields:', fields.length, 'fields');
    fields.forEach(el => {
      if (el._layoutInit) return;
      el._layoutInit = true;
      addResizeHandles(el);
      el.addEventListener('mousedown', function (e) {
        if (!inLayout()) return;
        if (e.target.closest('.rsz-handle')) return;
        e.preventDefault();
        const sX = e.clientX, sY = e.clientY;
        let dragging = false;
        const onMove = ev => {
          if (!dragging && (Math.abs(ev.clientX - sX) > DEAD_ZONE || Math.abs(ev.clientY - sY) > DEAD_ZONE)) {
            dragging = true;
            // 如果這個欄位已被選取，拖全部；否則只拖這個
            if (!el.classList.contains(SEL)) { clearSel(); el.classList.add(SEL); }
            startDrag(el, ev);
          }
          if (dragging && drag) onDragMove(ev);
        };
        const onUp = ev => {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
          if (dragging && drag) {
            onDragEnd();
          } else {
            // 沒超過 dead zone → 當作點擊，處理選取
            if (ev.ctrlKey || ev.metaKey) el.classList.toggle(SEL);
            else { clearSel(); el.classList.add(SEL); }
          }
        };
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });
    // label 也可獨立拖曳（支援多選群組拖曳）
    qAll('.spec-field-label').forEach(lab => {
      if (lab._layoutInit) return;
      lab._layoutInit = true;
      lab.addEventListener('mousedown', function (e) {
        if (!inLayout()) return;
        e.preventDefault();
        const sX = e.clientX, sY = e.clientY;
        let dragging = false;
        const onMove = ev => {
          lastMouseXY.x = ev.clientX; lastMouseXY.y = ev.clientY;
          if (!dragging && (Math.abs(ev.clientX - sX) > DEAD_ZONE || Math.abs(ev.clientY - sY) > DEAD_ZONE)) {
            dragging = true;
            if (!lab.classList.contains(SEL_LAB)) { clearSel(); lab.classList.add(SEL_LAB); }
            const grpLabels = selectedLabels().length ? selectedLabels() : [lab];
            const grpFields = selected();
            const allMoving = [...grpLabels, ...grpFields];
            captureOriginals(allMoving);
            snap = buildSnap(lab, allMoving);
            const ct = snapContainer;
            labelDrag = {
              lab, startX: ev.clientX, startY: ev.clientY,
              items: allMoving.map(l => { const r0 = relRect(l, ct); return { el: l, t0: r0.top, l0: r0.left }; })
            };
          }
          if (dragging && labelDrag && labelDrag.items.length) {
            const base = labelDrag.items.find(i => i.el === lab);
            const rawT = base.t0 + (ev.clientY - labelDrag.startY), rawL = base.l0 + (ev.clientX - labelDrag.startX);
            const s = applySnap(rawT, rawL, lab.offsetWidth, lab.offsetHeight);
            const snapDY = s.top - base.t0, snapDX = s.left - base.l0;
            // 群組邊界限制：整組一起停住
            const lpos = labelDrag.items.map(it => ({ el: it.el, newT: it.t0 + snapDY, newL: it.l0 + snapDX }));
            const lminT = Math.min(...lpos.map(p => p.newT));
            const lminL = Math.min(...lpos.map(p => p.newL));
            const ladjT = lminT < 0 ? -lminT : 0;
            const ladjL = lminL < 0 ? -lminL : 0;
            lpos.forEach(p => {
              p.el.style.top  = Math.round(p.newT + ladjT) + 'px';
              p.el.style.left = Math.round(p.newL + ladjL) + 'px';
            });
            checkTabSwitch(ev);
          }
        };
        const onUp = ev => {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
          if (dragging && labelDrag) {
            lastSwitchedTab = null;
            markDirty(labelDrag.items.map(i => i.el));
            snap = { tops:[], lefts:[], rights:[], bottoms:[] };
            clearGuides();
            clearTimeout(tabHoverTimer); tabHoverTimer = null;
            labelDrag = null;
          } else {
            if (ev.ctrlKey || ev.metaKey) lab.classList.toggle(SEL_LAB);
            else { clearSel(); lab.classList.add(SEL_LAB); }
          }
        };
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });
  }

  /* ---- Admin + Shift toggle（按 Shift 進入，按 Escape 退出） ---- */
  function isAdmin() {
    const uid = localStorage.getItem('erpLoginUserId') || window._userId || '';
    const cached = uid ? localStorage.getItem(`erpIsAdmin:${uid}`) === '1' : false;
    const body = document.body?.dataset?.isAdmin === '1';
    return window.__isAdmin === true || cached || body;
  }
  function setEnabled(on) {
    const can = !!on && isAdmin();
    console.log('[LayoutDrag] setEnabled:', { on, can, __isAdmin: window.__isAdmin });
    document.body.classList.toggle('layout-edit-enabled', can);
    // 編輯模式下才顯示欄位名稱 tooltip
    qAll('[data-layout-title]').forEach(el => {
      if (can) el.title = el.dataset.layoutTitle;
      else el.removeAttribute('title');
    });
    if (can) {
      console.log('%c[LayoutDrag] 編輯模式已啟用 — 按 Escape 退出', 'color:#5b8def;font-weight:bold');
    }
    updateSaveBtn(); // 進入/退出編輯模式時更新按鈕顯示
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Shift' && !e.repeat && !inLayout()) {
      // Shift 按一次 → 進入編輯模式
      setEnabled(true);
    } else if (e.key === 'Escape' && inLayout()) {
      // Escape → 退出編輯模式（有未保存修改時先確認）
      if (dirtyFields.size > 0) {
        if (!confirm(`有 ${dirtyFields.size} 個欄位尚未保存，確定要退出嗎？\n按「確定」= 取消修改並退出\n按「取消」= 留在編輯模式`)) return;
        cancelLayout();
      }
      clearSel();
      setEnabled(false);
    }
  });
  /* adminStateReady 事件由 _Layout.cshtml 觸發，此處不需額外處理 */

  /* ---- 框選 (Marquee Selection) ---- */
  let marquee = null; // { rect: HTMLElement, startX, startY, additive }
  document.addEventListener('mousedown', function (e) {
    if (!inLayout() || e.button !== 0) return;
    // 只在空白處啟動框選（不是點在 field/label/按鈕/resize handle 上）
    if (e.target.closest('.spec-draggable') || e.target.closest('.spec-field-label')
      || e.target.closest('#layout-btn-wrap') || e.target.closest('.rsz-handle')) return;
    // 必須在 spec-tab 容器內
    if (!e.target.closest('.master-spec-tab')) return;
    e.preventDefault();
    const additive = e.ctrlKey || e.metaKey;
    if (!additive) clearSel();
    const rect = document.createElement('div');
    rect.className = 'marquee-rect';
    rect.style.left = e.clientX + 'px';
    rect.style.top  = e.clientY + 'px';
    rect.style.width = '0px';
    rect.style.height = '0px';
    document.body.appendChild(rect);
    marquee = { rect, startX: e.clientX, startY: e.clientY, additive };
  });
  document.addEventListener('mousemove', function (e) {
    if (!marquee) return;
    const x = Math.min(e.clientX, marquee.startX);
    const y = Math.min(e.clientY, marquee.startY);
    const w = Math.abs(e.clientX - marquee.startX);
    const h = Math.abs(e.clientY - marquee.startY);
    marquee.rect.style.left   = x + 'px';
    marquee.rect.style.top    = y + 'px';
    marquee.rect.style.width  = w + 'px';
    marquee.rect.style.height = h + 'px';
  });
  document.addEventListener('mouseup', function (e) {
    if (!marquee) return;
    const mr = marquee.rect.getBoundingClientRect();
    marquee.rect.remove();
    // 只有拖出一定大小才算框選（避免誤觸）
    if (mr.width > 5 || mr.height > 5) {
      // 檢查所有 field 和 label 是否在框選範圍內
      qAll('.spec-draggable').forEach(el => {
        const r = el.getBoundingClientRect();
        if (rectsOverlap(mr, r)) el.classList.add(SEL);
      });
      qAll('.spec-field-label').forEach(el => {
        const r = el.getBoundingClientRect();
        if (rectsOverlap(mr, r)) el.classList.add(SEL_LAB);
      });
    } else if (!marquee.additive) {
      // 小範圍點擊空白處 → 取消選取
      clearSel();
    }
    marquee = null;
  });
  function rectsOverlap(a, b) {
    return !(a.right < b.left || a.left > b.right || a.bottom < b.top || a.top > b.bottom);
  }

  /* ---- keyboard shortcuts（僅方向鍵，capture 攔截 Bootstrap Tab）---- */
  document.addEventListener('keydown', function (e) {
    if (!inLayout()) return;
    if (!['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) return;
    const tag = document.activeElement?.tagName;
    if (tag === 'INPUT' || tag === 'SELECT' || tag === 'TEXTAREA') return;
    e.preventDefault();
    e.stopImmediatePropagation();

    const step = e.shiftKey ? 10 : 1;
    const dT = e.key==='ArrowUp' ? -step : e.key==='ArrowDown' ? step : 0;
    const dL = e.key==='ArrowLeft' ? -step : e.key==='ArrowRight' ? step : 0;

    // 方向鍵移動前記錄原始位置
    const movedFields = selected();
    const movedLabels = selectedLabels();
    captureOriginals([...movedFields, ...movedLabels]);
    // 移動所有選取的 field（各自獨立）
    movedFields.forEach(f => {
      f.style.top = (f.offsetTop + dT) + 'px';
      f.style.left = (f.offsetLeft + dL) + 'px';
    });
    // 移動所有選取的 label（各自獨立）
    movedLabels.forEach(lab => {
      lab.style.top = (lab.offsetTop + dT) + 'px';
      lab.style.left = (lab.offsetLeft + dL) + 'px';
    });
    markDirty([...movedFields, ...movedLabels]);
  }, true); // capture: true 確保在 Bootstrap Tab 之前攔截

  /* ---- MutationObserver：自動偵測新欄位 ---- */
  let initTimer = null;
  const obs = new MutationObserver(() => { clearTimeout(initTimer); initTimer = setTimeout(initFields, 150); });
  function startObs() {
    qAll('.master-spec-tab').forEach(t => obs.observe(t, { childList: true, subtree: true }));
  }
  if (document.readyState === 'complete') { startObs(); setTimeout(initFields, 300); }
  else window.addEventListener('load', () => { startObs(); setTimeout(initFields, 300); });
  const sc = document.getElementById('spec-content');
  if (sc) new MutationObserver(startObs).observe(sc, { childList: true });
})();
</script>

