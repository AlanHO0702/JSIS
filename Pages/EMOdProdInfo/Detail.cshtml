<script>
document.addEventListener('DOMContentLoaded', () => {
  const detailTabs = Array.from(document.querySelectorAll('[data-table][data-dict]'));
  let currentMasterKeys = @Html.Raw(JsonSerializer.Serialize(Model.MasterKeyValues.ToDictionary(kv => kv.Key, kv => kv.Value)));
  window.currentMasterKeys = currentMasterKeys; // 供其他 script 區塊使用
  const tabState = {};
  window.tabState = tabState; // 設為全域變數供其他 script 使用
  let masterData = null;
  let masterDict = null;
  const isViewOnly = @(Model.IsViewOnly ? "true" : "false"); // 查詢模式標記

  // 規格頁籤編輯狀態
  let specEditMode = false;
  window.specEditMode = false;

  // 全域修改狀態：整支作業（所有頁籤）統一切換
  let isGlobalEditMode = false;
  window.isGlobalEditMode = false;

  // 進入/退出規格編輯模式的統一函式（掛到 window 供外部 script 呼叫）
  // autoSave=true 時退出前自動儲存（切換頁籤用）；false 時還原值（×取消用）
  window.setSpecEditMode = async function setSpecEditMode(enable, autoSave = false) {
    // 退出時：先儲存或還原，再關閉模式
    if (!enable && specEditMode) {
      if (autoSave && window.saveSpecChanges) {
        const result = await window.saveSpecChanges();
        if (!result.ok && !result.skipped) {
          // 儲存失敗：提示但仍退出編輯
          if (typeof Swal !== 'undefined') Swal.fire({ icon: 'warning', title: '自動儲存失敗', text: result.text, timer: 2000, showConfirmButton: false });
        }
      } else {
        // 還原為原始值（取消）
        document.querySelectorAll('#spec-content .master-field:not(.readonly-field)').forEach(inp => {
          if (inp.dataset.original !== undefined) {
            if (inp.type === 'checkbox') inp.checked = inp.dataset.original === '1';
            else inp.value = inp.dataset.original;
          }
        });
      }
    }

    specEditMode = enable;
    window.specEditMode = enable;
    // 表單頁籤的操作按鈕：只在修改模式下啟用（放在 specContent 檢查前，確保一定執行）
    document.querySelectorAll('.edit-only-btn').forEach(btn => { btn.disabled = !enable; });

    const specContent = document.getElementById('spec-content');
    if (!specContent) return;
    specContent.classList.toggle('spec-editing', enable);

    specContent.querySelectorAll('.master-field:not(.readonly-field)').forEach(inp => {
      if (inp.type === 'checkbox' || inp.tagName === 'SELECT') {
        inp.disabled = !enable;
      } else {
        if (enable) inp.removeAttribute('readonly');
        else inp.setAttribute('readonly', 'readonly');
      }
    });

    // 進入編輯時：對規格欄位綁 input/change 偵測 dirty
    if (enable) {
      specContent.querySelectorAll('.master-field:not(.readonly-field)').forEach(inp => {
        if (!inp._dirtyListenerAttached) {
          inp._dirtyListenerAttached = true;
          const evtName = inp.tagName === 'SELECT' ? 'change' : 'input';
          inp.addEventListener(evtName, () => {
            if (window.updateSaveCancelButtons) window.updateSaveCancelButtons();
          });
        }
      });
    }
  };

  // 收集規格欄位變更並呼叫 API 儲存（回傳 {ok, skipped}）
  window.saveSpecChanges = async function saveSpecChanges() {
    const partNum  = currentMasterKeys.PartNum  || currentMasterKeys.partnum  || '';
    const revision = currentMasterKeys.Revision || currentMasterKeys.revision || '';
    const masterTable = '@Model.HeaderTableName';

    // 收集有變更的欄位（文字欄位）
    const changes = {};
    document.querySelectorAll('#spec-content .master-field:not(.readonly-field)').forEach(inp => {
      const orig = inp.dataset.original ?? '';
      if (inp.type === 'checkbox') {
        const val = inp.checked ? '1' : '0';
        if (val !== orig) changes[inp.name] = val;
      } else {
        if (inp.value !== orig) changes[inp.name] = inp.value;
      }
    });

    if (Object.keys(changes).length === 0) return { ok: true, skipped: true };

    // 加入主鍵
    changes.PartNum  = partNum;
    changes.Revision = revision;

    try {
      const resp = await fetch('/api/CommonTable/SaveTableChanges', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          TableName: masterTable,
          Data: [changes],
          KeyFields: ['PartNum', 'Revision']
        })
      });
      const txt = await resp.text();
      let result = null;
      try { result = txt ? JSON.parse(txt) : null; } catch {}

      if (resp.ok && result && result.success !== false) {
        // 更新 data-original，避免重複儲存
        document.querySelectorAll('#spec-content .master-field:not(.readonly-field)').forEach(inp => {
          inp.dataset.original = inp.type === 'checkbox' ? (inp.checked ? '1' : '0') : inp.value;
        });
        return { ok: true, skipped: false };
      } else {
        return { ok: false, text: (result?.message || result?.error || txt || '儲存失敗') };
      }
    } catch (err) {
      return { ok: false, text: err.message };
    }
  };

  // btnSaveHeader（✓）：手動儲存並退出編輯模式
  const btnSaveHeader = document.getElementById('btnSaveHeader');
  if (btnSaveHeader) {
    btnSaveHeader.addEventListener('click', async () => {
      // 儲存規格頁籤
      if (window.specEditMode && window.saveSpecChanges) {
        const specResult = await window.saveSpecChanges();
        if (!specResult.ok && !specResult.skipped) {
          if (typeof Swal !== 'undefined')
            Swal.fire({ icon: 'error', title: '規格儲存失敗', text: specResult.text || '' });
          return;
        }
      }
      // 儲存所有表單 editors
      const saveErrors = [];
      if (window.tabState) {
        for (const [key, state] of Object.entries(window.tabState)) {
          const editor = state?.editor;
          if (editor && editor.isEdit && editor.isEdit() && editor.saveChanges) {
            const r = await editor.saveChanges();
            if (!r.ok && !r.skipped) saveErrors.push(key);
          }
        }
      }
      if (saveErrors.length > 0) {
        if (typeof Swal !== 'undefined')
          Swal.fire({ icon: 'error', title: '部分頁籤儲存失敗', text: saveErrors.join(', ') });
      }
      // [儲存成功提示] 若需要顯示儲存成功訊息，取消下方註解（關鍵字：打勾儲存 成功提示 Swal）
      // else {
      //   if (typeof Swal !== 'undefined')
      //     Swal.fire({ icon: 'success', title: '儲存成功', timer: 1000, showConfirmButton: false });
      // }
      if (window.updateSaveCancelButtons) window.updateSaveCancelButtons();
    });
  }

  // btnCancelChanges（×）：放棄變更並退出編輯模式（還原在 setSpecEditMode 裡）
  const btnCancelChanges = document.getElementById('btnCancelChanges');
  if (btnCancelChanges) {
    btnCancelChanges.addEventListener('click', () => {
      // 還原規格頁籤原始值（維持編輯模式）
      document.querySelectorAll('#spec-content .master-field:not(.readonly-field)').forEach(inp => {
        if (inp.dataset.original !== undefined) {
          if (inp.type === 'checkbox') inp.checked = inp.dataset.original === '1';
          else inp.value = inp.dataset.original;
        }
      });
      // 還原所有表單 editors（維持編輯模式）
      if (window.tabState) {
        Object.values(window.tabState).forEach(state => {
          if (!state?.editor?.isEdit?.()) return;
          const wrapper = state.wrapper;
          if (wrapper) {
            wrapper.querySelectorAll('.cell-edit').forEach(inp => {
              if (inp.type === 'checkbox') {
                inp.checked = inp.defaultChecked;
                inp.value   = inp.defaultChecked ? '1' : '0';
              } else {
                inp.value = inp.defaultValue ?? '';
              }
            });
          }
        });
      }
      if (window.updateSaveCancelButtons) window.updateSaveCancelButtons();
      window.isCancellingChanges = false; // 還原完成，解除 auto-save 封鎖
      // [取消還原提示] 若需要顯示已還原訊息，取消下方註解（關鍵字：叉叉取消 還原提示 Swal）
      // if (typeof Swal !== 'undefined')
      //   Swal.fire({ icon: 'info', title: '已還原變更', timer: 800, showConfirmButton: false });
    });

    // 在 mousedown（比 focusout 更早觸發）時設旗標，阻止 cell 失焦觸發的 auto-save
    btnCancelChanges.addEventListener('mousedown', () => {
      window.isCancellingChanges = true;
    });
  }

  // ===== 全域 dirty 偵測：有變更才啟用 ✓/× =====
  window.checkAnyDirty = function checkAnyDirty() {
    if (!window.isGlobalEditMode) return false;
    // 規格頁籤：比對 data-original
    const specDirty = Array.from(
      document.querySelectorAll('#spec-content .master-field:not(.readonly-field)')
    ).some(inp => {
      const orig = inp.dataset.original ?? '';
      return inp.type === 'checkbox'
        ? (inp.checked ? '1' : '0') !== orig
        : inp.value !== orig;
    });
    if (specDirty) return true;
    // 表單 editors：比對 defaultValue
    if (window.tabState) {
      for (const state of Object.values(window.tabState)) {
        if (!state?.editor?.isEdit?.()) continue;
        const wrapper = state.wrapper;
        if (!wrapper) continue;
        const hasDirty = Array.from(
          wrapper.querySelectorAll('.cell-edit:not([data-readonly="1"])')
        ).some(inp =>
          inp.type === 'checkbox'
            ? (inp.checked ? '1' : '0') !== (inp.defaultValue ?? '')
            : inp.value !== (inp.defaultValue ?? '')
        );
        if (hasDirty) return true;
      }
    }
    return false;
  };

  window.updateSaveCancelButtons = function updateSaveCancelButtons() {
    const dirty = window.checkAnyDirty();
    const btnSave   = document.getElementById('btnSaveHeader');
    const btnCancel = document.getElementById('btnCancelChanges');
    if (btnSave)   btnSave.disabled   = !dirty;
    if (btnCancel) btnCancel.disabled = !dirty;
  };

  // 規格子頁籤切換時繼承 specEditMode 狀態
  document.querySelectorAll('#master-tabs [data-bs-toggle="tab"]').forEach(btn => {
    btn.addEventListener('shown.bs.tab', () => {
      if (specEditMode) {
        // 新切換的子頁籤內的欄位也移除 readonly
        const targetId = btn.dataset.bsTarget;
        if (targetId) {
          document.querySelectorAll(`${targetId} .master-field:not(.readonly-field)`).forEach(inp => {
            if (inp.type === 'checkbox' || inp.tagName === 'SELECT') inp.disabled = false;
            else inp.removeAttribute('readonly');
          });
        }
      }
    });
  });

  // 第一行欄位：料號、版序、客戶料號、預鑄列印(checkbox)、預設不料本(checkbox)、暫停發料(checkbox)、混款(checkbox)
  const headerRow1Fields = ['PartNum', 'Revision', 'CustomerPartNum'];
  const headerRow1Checkboxes = [
    { field: 'IsPrintPrecast', label: '傳統列印' },
    { field: 'IsNotTemplate', label: '預設下料版本' },
    { field: 'IsStopIssue', label: '暫停發料' },
    { field: 'IsMixed', label: '混裁' }
  ];

  // 第二行欄位：狀態名稱、製程碼、產品用途、設計者、陣列種、設計日期、客戶機種
  // StatusName 需要透過 Status 欄位 lookup，DesignDate 需要特殊格式化
  const headerRow2Fields = ['StatusName', 'ProcessCode', 'ProductUsage', 'Designer', 'ArrayCount', 'DesignDate', 'CustomerSSName'];

  // 層別資料 API
  const layerPressApiUrl = '@Html.Raw(Model.LayerPressApi ?? "")';

  function getDict(dictName) {
    return fetch(`/api/TableFieldLayout/GetTableFieldsFull?table=${encodeURIComponent(dictName)}`)
      .then(r => r.json());
  }

  // 儲存層別資料
  let layerData = [];

  // 建立階層樹狀結構
  function buildLayerTree(rows) {
    const layerMap = new Map();
    rows.forEach(row => {
      const layerId = getProp(row, 'LayerId').trim();
      layerMap.set(layerId, { ...row, children: [] });
    });

    const rootNodes = [];
    rows.forEach(row => {
      const layerId = getProp(row, 'LayerId').trim();
      const aftLayerId = getProp(row, 'AftLayerId').trim();
      const node = layerMap.get(layerId);

      if (!aftLayerId || aftLayerId === '') {
        // 根節點
        rootNodes.push(node);
      } else {
        // 子節點，加到父節點的 children
        const parentNode = layerMap.get(aftLayerId);
        if (parentNode) {
          parentNode.children.push(node);
        } else {
          // 找不到父節點，視為根節點
          rootNodes.push(node);
        }
      }
    });

    return rootNodes;
  }

  // 不分大小寫取物件屬性
  function getProp(obj, key) {
    const k = key.toLowerCase();
    const found = Object.keys(obj).find(p => p.toLowerCase() === k);
    return found ? (obj[found] || '') : '';
  }

  // 遞迴渲染樹狀節點（巢狀 DOM 結構）
  function renderLayerNode(node, isFirst = false) {
    const layerId = getProp(node, 'LayerId').trim();
    const layerName = getProp(node, 'LayerName').trim();
    const hasChildren = node.children && node.children.length > 0;
    const isActive = isFirst ? 'active' : '';

    // 顯示格式：LayerId（LayerName），有名稱就顯示，無名稱則只顯示 ID
    const label = layerName
      ? `${layerId} <span class="layer-subname">（${layerName}）</span>`
      : layerId;

    let childrenHtml = '';
    if (hasChildren) {
      const childNodes = node.children.map(c => renderLayerNode(c, false)).join('');
      childrenHtml = `<div class="layer-children">${childNodes}</div>`;
    }

    return `<div>
      <div class="layer-item ${isActive}" data-layer-id="${layerId}" data-layer-name="${layerName || layerId}" data-expanded="true">
        <button class="layer-toggle${hasChildren ? ' expanded' : ' leaf'}" tabindex="-1"></button>
        <span class="layer-name">${label}</span>
      </div>
      ${childrenHtml}
    </div>`;
  }

  // 載入層別資料
  function loadLayerPress() {

    const layerListEl = document.getElementById('layer-list');
    if (!layerListEl || !layerPressApiUrl) {
      if (layerListEl) layerListEl.innerHTML = '<div class="text-center text-muted py-3">無層別資料</div>';
      return;
    }

    fetch(layerPressApiUrl)
      .then(r => r.json())
      .then(rows => {
        if (!rows || rows.length === 0) {
          layerListEl.innerHTML = '<div class="text-center text-muted py-3">無層別資料</div>';
          return;
        }

        // 儲存層別資料供後續使用
        layerData = rows;

        // 建立樹狀結構
        const tree = buildLayerTree(rows);

        // 渲染樹狀清單
        let html = '';
        tree.forEach((rootNode, idx) => {
          html += renderLayerNode(rootNode, idx === 0);
        });

        layerListEl.innerHTML = html;

        // 事件委派：toggle 展開/收合，item 選中並載入資料
        layerListEl.addEventListener('click', (e) => {
          const toggle = e.target.closest('.layer-toggle');
          const item = e.target.closest('.layer-item');

          if (toggle && !toggle.classList.contains('leaf')) {
            e.stopPropagation();
            toggleLayerNode(toggle);
            return;
          }

          if (item) {
            layerListEl.querySelectorAll('.layer-item').forEach(el => el.classList.remove('active'));
            item.classList.add('active');
            (window.loadLayerPressDetail ?? loadLayerPressDetail)(item.dataset.layerId, item.dataset.layerName);
          }
        });

        // 內部資料按鈕：跳轉至層別資料維護 (EMOdProdLayer/Detail)
        document.getElementById('btn-goto-layer-detail')?.addEventListener('click', function () {
          const activeItem = layerListEl.querySelector('.layer-item.active');
          if (!activeItem) {
            if (typeof Swal !== 'undefined') {
              Swal.fire({ icon: 'warning', title: '請先選擇一個層別' });
            } else { alert('請先選擇一個層別'); }
            return;
          }
          const partNum  = (currentMasterKeys.PartNum  || currentMasterKeys.partnum  || '').trim();
          const revision = (currentMasterKeys.Revision || currentMasterKeys.revision || '').trim();
          const layerId  = activeItem.dataset.layerId || '';
          const itemId   = isViewOnly ? 'EMO00060' : 'EMO00059';
          window.open(`/EMOdProdLayer/Detail?PartNum=${encodeURIComponent(partNum)}&Revision=${encodeURIComponent(revision)}&LayerId=${encodeURIComponent(layerId)}&itemId=${itemId}`, '_blank');
        });

        // 預設載入第一個層別的資料
        if (rows.length > 0) {
          (window.loadLayerPressDetail ?? loadLayerPressDetail)(getProp(rows[0], 'LayerId').trim(), getProp(rows[0], 'LayerName').trim());
        }
      })
      .catch(err => {
        layerListEl.innerHTML = '<div class="text-center text-danger py-3">載入失敗</div>';
      });
  }

  // 展開/收合層別節點（toggle 直屬的 .layer-children）
  function toggleLayerNode(toggleBtn) {
    const childrenEl = toggleBtn.closest('div').parentElement.querySelector('.layer-children');
    if (!childrenEl) return;
    const isExpanded = toggleBtn.classList.contains('expanded');
    toggleBtn.classList.toggle('expanded', !isExpanded);
    childrenEl.style.display = isExpanded ? 'none' : '';
  }

  // 載入層別相關的資料（壓合明細、壓合方式、途程內容）
  function loadLayerPressDetail(layerId, layerName) {

    // 需要根據 LayerId 載入的頁籤列表
    const layerTabs = [
      { key: 'layerpress', table: 'EMOdLayerPress', dict: 'EMOdLayerPress', title: '壓合明細/替代料' },
      { key: 'pressmethod', table: 'EMOdProdTier', dict: 'EMOdProdTier', title: '壓合方式' },
      { key: 'layerroute', table: 'EMOdLayerRoute', dict: 'EMOdLayerRoute', title: '途程內容' }
    ];

    // 為每個頁籤載入資料
    layerTabs.forEach(tab => {
      // 建立查詢參數（使用 LayerId 來篩選）
      const qs = new URLSearchParams();
      qs.append('keyNames', 'PartNum');
      qs.append('keyValues', currentMasterKeys.PartNum || currentMasterKeys.partnum || '');
      qs.append('keyNames', 'Revision');
      qs.append('keyValues', currentMasterKeys.Revision || currentMasterKeys.revision || '');
      qs.append('keyNames', 'LayerId');
      qs.append('keyValues', layerId);

      const url = `/api/CommonTable/ByKeys?table=${encodeURIComponent(tab.table)}&${qs.toString()}`;

      Promise.all([
        getDict(tab.dict),
        fetch(url).then(r => r.json())
      ]).then(([dict, rows]) => {
        buildTable(tab.key, dict, rows, url);
      }).catch(err => {
        console.error('[DEBUG loadLayerPressDetail] 載入失敗, tab:', tab.key, 'err:', err);
        const table = document.getElementById(`grid-${tab.key}`);
        if (table) {
          const tbody = table.querySelector('tbody');
          if (tbody) tbody.innerHTML = `<tr><td colspan="100" class="text-center text-danger py-3">載入失敗: ${err.message}</td></tr>`;
        }
      });
    });
  }
  window.loadLayerPressDetail = loadLayerPressDetail; // 供其他 script 區塊呼叫

  // IOType + AftStatus → 中文作業名稱
  function formatLogIOType(row) {
    const ioType   = String(row.IOType   ?? row.ioType   ?? row.iotype   ?? '').trim();
    const aftStatus = String(row.AftStatus ?? row.aftStatus ?? row.aftstatus ?? '').trim();
    if (ioType === '12') return '料號產生';
    if (ioType === '1') {
      if (aftStatus === '2') return '審核';
      return '送審';
    }
    if (ioType === '6') return '退審';
    return ioType; // 未知就原樣顯示
  }

  // 載入左下角內部資料
  async function loadSidebarHaltLog() {
    const table = document.getElementById('grid-haltlog-sidebar');
    if (!table) return;

    const qs = new URLSearchParams();
    qs.append('keyNames', 'PartNum');
    qs.append('keyValues', currentMasterKeys.PartNum || currentMasterKeys.partnum || '');
    qs.append('keyNames', 'Revision');
    qs.append('keyValues', currentMasterKeys.Revision || currentMasterKeys.revision || '');

    const url = `/api/CommonTable/ByKeys?table=EMOdProdLog&${qs.toString()}`;

    try {
      const [dict, rows] = await Promise.all([
        getDict('EMOdProdLog'),
        fetch(url).then(r => r.json())
      ]);

      // 將每筆的 IOType 轉成中文，存入虛擬欄位 _IOTypeLabel
      const processedRows = (rows || []).map(r => ({
        ...r,
        IOType: formatLogIOType(r)
      }));

      await buildTable('haltlog-sidebar', dict, processedRows);
    } catch (err) {
      const tbody = table.querySelector('tbody');
      if (tbody) {
        tbody.innerHTML = '<tr><td colspan="100" class="text-center text-danger py-2">載入失敗</td></tr>';
      }
    }
  }

  function formatDateOnly(val) {
    if (!val) return '';
    try {
      const date = new Date(val);
      if (isNaN(date.getTime())) return val;
      return date.toLocaleDateString('zh-TW', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit'
      }).replace(/\//g, '/');
    } catch {
      return val;
    }
  }

  function formatDateTime(val) {
    if (!val) return '';
    try {
      const date = new Date(val);
      if (isNaN(date.getTime())) return val;
      return date.toLocaleString('zh-TW', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      }).replace(/\//g, '/');
    } catch {
      return val;
    }
  }

  window.checkEditPermission = function checkEditPermission() {
    const statusValue = (masterData?.Status ?? masterData?.status ?? '').toString();
    if (statusValue !== '0') {
      alert('只有「設計中」狀態才能修改！\n\n目前狀態：' +
            (statusValue === '1' ? '設計完成' :
             statusValue === '2' ? '已審核' :
             statusValue === '3' ? '已核准' : statusValue));
      return false;
    }
    return true;
  }

  // 狀態代碼對應表（根據系統中的狀態定義）
  const statusLookupMap = {
    '0': '設計中',
    '1': '設計完成',
    '2': '已審核',
    '3': '已核准'
  };

  async function renderHeaderFields(dict, row) {
    const row1Container = document.getElementById('header-row-1');
    const row2Container = document.getElementById('header-row-2');
    if (!row1Container || !row2Container) return;

    // 載入所有欄位的 Lookup Maps
    const headerFields = [...headerRow1Fields, ...headerRow2Fields]
      .map(fn => dict.find(f => f.FieldName === fn))
      .filter(f => f);

    const lookupMaps = {};
    const ocxMaps = {};

    for (const field of headerFields) {
      lookupMaps[field.FieldName] = await loadLookup(field);
      ocxMaps[field.FieldName] = await loadOCXLookup(field);
    }

    // === 第一行 ===
    let row1Html = '';

    // 第一行的一般欄位
    const row1Fields = headerRow1Fields.map(fn => dict.find(f => f.FieldName === fn)).filter(f => f);
    row1Fields.forEach(f => {
      let rawValue = row[f.FieldName] ?? row[f.FieldName?.toLowerCase()] ?? '';
      let displayValue = rawValue;

      // 套用 Lookup
      if (ocxMaps[f.FieldName] && rawValue) {
        displayValue = ocxMaps[f.FieldName][rawValue] ?? rawValue;
      } else if (lookupMaps[f.FieldName] && rawValue) {
        displayValue = lookupMaps[f.FieldName][rawValue] ?? rawValue;
      }

      row1Html += `
        <div class="d-flex align-items-center me-2">
          <label class="mb-0 me-1" style="white-space:nowrap; font-size:12px; font-weight:600; color:#0066cc;">${f.DisplayLabel || f.FieldName}</label>
          <input type="text" class="form-control form-control-sm bg-white" style="width:140px; font-size:12px; padding:1px 5px; height:22px;" value="${displayValue}" readonly>
        </div>
      `;
    });

    // 第一行的勾選框
    headerRow1Checkboxes.forEach(chk => {
      const val = row[chk.field] ?? row[chk.field.toLowerCase()] ?? '';
      const isChecked = val === '1' || val === 1 || val === true || val === 'true';
      row1Html += `
        <div class="form-check me-2" style="font-size:12px;">
          <input class="form-check-input header-checkbox" type="checkbox" id="chk_${chk.field}"
                 ${isChecked ? 'checked' : ''} disabled style="width:14px;height:14px;margin-top:3px;">
          <label class="form-check-label" for="chk_${chk.field}" style="color:#000; font-weight:500;">
            ${chk.label}
          </label>
        </div>
      `;
    });

    row1Container.innerHTML = row1Html;

    // === 第二行 ===
    let row2Html = '';

    const row2Fields = headerRow2Fields.map(fn => dict.find(f => f.FieldName === fn)).filter(f => f);
    for (const f of row2Fields) {
      let rawValue = row[f.FieldName] ?? row[f.FieldName?.toLowerCase()] ?? '';
      let displayValue = rawValue;

      // 特殊處理：StatusName 需要從 Status 欄位 lookup
      if (f.FieldName === 'StatusName') {
        const statusCode = row['Status'] ?? row['status'] ?? '';
        displayValue = statusLookupMap[statusCode.toString()] || statusCode.toString();
      }
      // 套用 Lookup（除了 StatusName，因為已特殊處理）
      else {
        if (ocxMaps[f.FieldName] && rawValue) {
          displayValue = ocxMaps[f.FieldName][rawValue] ?? rawValue;
        } else if (lookupMaps[f.FieldName] && rawValue) {
          displayValue = lookupMaps[f.FieldName][rawValue] ?? rawValue;
        }
      }

      // 特殊處理：DesignDate 只顯示年月日
      if (f.FieldName === 'DesignDate' && displayValue) {
        displayValue = formatDateOnly(displayValue);
      }

      row2Html += `
        <div class="d-flex align-items-center me-2">
          <label class="mb-0 me-1" style="white-space:nowrap; font-size:12px; font-weight:600; color:#0066cc;">${f.DisplayLabel || f.FieldName}</label>
          <input type="text" class="form-control form-control-sm bg-white" style="width:140px; font-size:12px; padding:1px 5px; height:22px;" value="${displayValue}" readonly>
        </div>
      `;
    }

    row2Container.innerHTML = row2Html;
  }

  // 計算欄位的最大底部，用來設定容器最小高度
  function calcTabMinHeight(fields) {
    let max = 300;
    fields.forEach(f => {
      const top = (f.iFieldTop || 0) + 6;
      const h = f.iFieldHeight || 22;
      if (top + h + 20 > max) max = top + h + 20;
    });
    return max;
  }

  // 計算欄位的最大右側，用來設定容器最小寬度
  function calcTabMinWidth(fields) {
    let max = 400;
    fields.forEach(f => {
      const fieldRight = (f.iFieldLeft || 0) + (f.iFieldWidth || 160);
      const labRight = (f.iLabLeft || 0) + (f.iLabWidth || 80);
      if (fieldRight + 10 > max) max = fieldRight + 10;
      if (labRight + 10 > max) max = labRight + 10;
    });
    return max;
  }

  async function renderMasterTab(tabKey, dict, row) {
    const tabBtn = document.querySelector(`[data-tab-key="${tabKey}"]`);
    if (!tabBtn) return;

    const showWhere = parseInt(tabBtn.dataset.tabShowWhere || '0', 10);
    const container = document.querySelector(`#master-content-${tabKey} .master-spec-tab`);
    if (!container) return;

    // 從 dict 篩選此 IShowWhere 且 Visible != 0 的欄位，依 SerialNum 排序
    const fields = (dict || [])
      .filter(f => (f.IShowWhere ?? f.iShowWhere ?? 0) === showWhere)
      .filter(f => (f.Visible ?? 1) != 0)
      .sort((a, b) => (a.SerialNum ?? 9999) - (b.SerialNum ?? 9999));

    if (fields.length === 0) {
      container.innerHTML = '<li class="text-muted p-3">此頁籤暫無欄位資料</li>';
      return;
    }

    // 判斷是否有任一欄位設定了座標（非全 0）
    const hasCoords = fields.some(f =>
      (f.iFieldTop ?? 0) > 0 || (f.iFieldLeft ?? 0) > 0
    );
    const headerTopPad = 6;

    let html = '';
    if (hasCoords) {
      // === 絕對座標模式（複用 _DetailHeaderSection 邏輯）===
      const minH = calcTabMinHeight(fields);
      const minW = calcTabMinWidth(fields);
      container.style.minHeight = minH + 'px';
      // position:absolute 的子元素不撐開 scrollWidth，用一個佔位 div 來撐
      const spacer = document.createElement('div');
      spacer.style.cssText = `position:absolute;top:0;left:0;width:${minW}px;height:${minH}px;pointer-events:none;`;
      container.appendChild(spacer);
      container.parentElement.style.overflowX = 'auto';
      let labelHtml = '';
      let inputHtml2 = '';
      for (const f of fields) {
        const fn = f.FieldName ?? '';
        const hideInput = (f.iFieldWidth ?? -1) === 0;
        let val = row[fn] ?? row[fn.toLowerCase()] ?? '';
        // 日期欄位：格式化，1899-12-30 視為空值
        const isDate = /^(date|datetime|smalldatetime)/i.test(f.DataType ?? '') || /^\d{4}-\d{2}-\d{2}T/.test(String(val));
        if (isDate && val) {
          const d = new Date(val);
          if (!isNaN(d) && d.getFullYear() <= 1899) val = '';
          else if (!isNaN(d)) val = d.toLocaleDateString('zh-TW');
        }
        const isReadOnly = (f.ReadOnly ?? 0) !== 0;
        const isNumber = /^(number|int|smallint|tinyint|bigint|decimal|numeric|money|float|real)/i.test(f.DataType ?? '');
        const isCheckbox = (f.ComboStyle ?? 0) === 1;
        const lookupMap = f.LookupTable ? await loadLookup(f) : null;
        const itemsList = (!lookupMap && f.Items) ? f.Items.split(';').filter(s => s.trim()) : null;
        const displayVal = applyFormatStr(val, f.FormatStr);

        const top = (f.iFieldTop || 0) + headerTopPad;
        const left = f.iFieldLeft || 0;
        const width = f.iFieldWidth || 160;
        const height = f.iFieldHeight || 22;
        const labTop = (f.iLabTop || 0) + headerTopPad;
        const labLeft = f.iLabLeft || 0;
        const labWidth = f.iLabWidth || 80;
        const labHeight = f.iLabHeight || 22;

        const label = f.DisplayLabel || fn;
        // title 由 JS 在編輯模式下動態加入
        const titleAttr = `data-layout-title="${fn}：${label}"`;

        // 所有 label 先收集（先渲染 = 在下層），iLabWidth=0 不顯示
        if ((f.iLabWidth ?? -1) !== 0) {
          labelHtml += `<li class="spec-field-label"
            data-field="${fn}" data-show-where="${showWhere}"
            style="top:${labTop}px; left:${labLeft}px; width:${labWidth}px; height:${labHeight}px;"
            ${titleAttr}>${label}</li>`;
        }

        // input 後收集（後渲染 = 在上層，白色背景蓋住不相關的 label）
        if (!hideInput) {
          const fieldClass = `spec-draggable${isNumber ? ' field-number' : ' field-text'}`;
          let inputHtml = '';
          if (lookupMap) {
            let opts = `<option value=""></option>`;
            Object.entries(lookupMap).forEach(([k, v]) => {
              const sel = String(k) === String(val) ? ' selected' : '';
              opts += `<option value="${k}"${sel}>${v}</option>`;
            });
            inputHtml = `<select class="master-field${isReadOnly ? ' readonly-field' : ''}" name="${fn}" data-original="${val}" disabled style="width:100%;height:100%;font-size:12px;background:#fff;box-sizing:border-box;">${opts}</select>`;
          } else if (itemsList) {
            let opts = `<option value=""></option>`;
            itemsList.forEach(item => {
              const sel = item.trim() === String(val) ? ' selected' : '';
              opts += `<option value="${item.trim()}"${sel}>${item.trim()}</option>`;
            });
            inputHtml = `<select class="master-field${isReadOnly ? ' readonly-field' : ''}" name="${fn}" data-original="${val}" disabled style="width:100%;height:100%;font-size:12px;background:#fff;box-sizing:border-box;">${opts}</select>`;
          } else if (isCheckbox) {
            const checked = (val == 1 || val === true || val === 'true') ? 'checked' : '';
            inputHtml = `<input type="checkbox" class="master-field${isReadOnly ? ' readonly-field' : ''}" name="${fn}" value="1" ${checked} data-original="${(val == 1 || val === true || val === 'true') ? '1' : '0'}" disabled style="width:16px;height:16px;cursor:default;accent-color:#0066cc;">`;
          } else {
            inputHtml = `<input type="text"
              class="master-field${isReadOnly ? ' readonly-field' : ''}"
              name="${fn}" value="${displayVal}" data-original="${val}" readonly>`;
          }
          inputHtml2 += `<li class="${fieldClass}"
            data-field="${fn}" data-show-where="${showWhere}"
            style="top:${top}px; left:${left}px; width:${width}px; height:${height}px;"
            ${titleAttr}>${inputHtml}</li>`;
        }
      }
      // label 全部在前（下層），input 全部在後（上層蓋住不相關 label）
      html = labelHtml + inputHtml2;
    } else {
      // === Fallback：流式排列（欄位無座標設定時）===
      container.style.minHeight = '';
      container.style.position = 'relative';
      container.style.display = 'flex';
      container.style.flexWrap = 'wrap';
      container.style.gap = '8px';
      container.style.padding = '8px';

      for (const f of fields) {
        const fn = f.FieldName ?? '';
        const val = row[fn] ?? row[fn.toLowerCase()] ?? '';
        const isReadOnly = (f.ReadOnly ?? 0) !== 0;
        const w = f.iFieldWidth ? `${f.iFieldWidth}px` : '150px';
        const label = f.DisplayLabel || fn;
        const lookupMap = f.LookupTable ? await loadLookup(f) : null;
        const itemsList = (!lookupMap && f.Items) ? f.Items.split(';').filter(s => s.trim()) : null;
        const displayVal = applyFormatStr(val, f.FormatStr);
        let inputEl = '';
        if (lookupMap) {
          let opts = `<option value=""></option>`;
          Object.entries(lookupMap).forEach(([k, v]) => {
            const sel = String(k) === String(val) ? ' selected' : '';
            opts += `<option value="${k}"${sel}>${v}</option>`;
          });
          inputEl = `<select class="master-field${isReadOnly ? ' readonly-field' : ''}" name="${fn}" data-original="${val}"
            style="width:${w};font-size:12px;border:1px solid #999;border-radius:2px;padding:2px 4px;background:#fff;box-sizing:border-box;" disabled>${opts}</select>`;
        } else if (itemsList) {
          let opts = `<option value=""></option>`;
          itemsList.forEach(item => {
            const sel = item.trim() === String(val) ? ' selected' : '';
            opts += `<option value="${item.trim()}"${sel}>${item.trim()}</option>`;
          });
          inputEl = `<select class="master-field${isReadOnly ? ' readonly-field' : ''}" name="${fn}" data-original="${val}"
            style="width:${w};font-size:12px;border:1px solid #999;border-radius:2px;padding:2px 4px;background:#fff;box-sizing:border-box;" disabled>${opts}</select>`;
        } else {
          inputEl = `<input type="text" class="master-field${isReadOnly ? ' readonly-field' : ''}" name="${fn}" value="${displayVal}" data-original="${val}"
            style="width:${w};font-size:12px;border:1px solid #999;border-radius:2px;padding:2px 6px;background:#fff;box-sizing:border-box;" readonly>`;
        }
        html += `<div class="d-flex align-items-center gap-1" style="white-space:nowrap;">
          <label class="mb-0 me-1" style="font-size:12px; font-weight:600; color:#0066cc; white-space:nowrap;">${label}</label>
          ${inputEl}
        </div>`;
      }
    }

    container.innerHTML = html;
  }

  // 載入產品工程圖的四張圖片
  function loadProductMapImages() {
    const partNum = currentMasterKeys.PartNum || currentMasterKeys.partnum;
    const revision = currentMasterKeys.Revision || currentMasterKeys.revision;

    if (!partNum || !revision) {
      console.error('無法取得料號或版序');
      return;
    }

    // MapType 對應：panel=排板圖, cut=裁板圖, pf=PF裁剪圖, stackup=疊構圖
    const mapTypes = [
      { id: 'img-cut', type: 'cut', name: '裁板圖' },
      { id: 'img-panel', type: 'panel', name: '排板圖' },
      { id: 'img-pf', type: 'pf', name: 'PF裁剪圖' },
      { id: 'img-stackup', type: 'stackup', name: '疊構圖' }
    ];

    mapTypes.forEach(map => {
      const img = document.getElementById(map.id);
      const loadingDiv = img?.nextElementSibling;

      if (!img) return;

      // 設定圖片 URL
      const url = `/api/imagegeneration/preview/${encodeURIComponent(partNum)}/${encodeURIComponent(revision)}/${map.type}`;

      // 載入圖片
      img.src = url;

      // 圖片載入成功
      img.onload = () => {
        if (loadingDiv) loadingDiv.style.display = 'none';
        img.style.display = 'block';
      };

      // 圖片載入失敗
      img.onerror = () => {
        if (loadingDiv) {
          loadingDiv.innerHTML = `<span class="text-danger small"><i class="bi bi-exclamation-triangle"></i> ${map.name}載入失敗</span>`;
        }
        img.style.display = 'none';
      };
    });
  }

  // ========== 欄位格式化（Delphi FormatStr）==========
  // 格式字串規則：# 有值才顯示，0 補零，. 小數點，% 附加%符號（不乘100）
  function applyFormatStr(rawVal, formatStr) {
    if (!formatStr) return rawVal;
    const numVal = parseFloat(rawVal);
    if (isNaN(numVal)) return rawVal;

    const hasPct = formatStr.endsWith('%');
    const fmt = hasPct ? formatStr.slice(0, -1) : formatStr;

    const dotIdx = fmt.indexOf('.');
    let decimals = 0;
    if (dotIdx >= 0) {
      // 計算小數部分有幾個 0 或 #
      decimals = fmt.length - dotIdx - 1;
    }

    const formatted = numVal.toFixed(decimals);
    return hasPct ? formatted + '%' : formatted;
  }

  // ========== 通用 Lookup 功能 ==========
  const LOOKUP_CACHE = {};
  const OCX_CACHE = {};

  // 載入一般 Lookup（實體欄位）
  async function loadLookup(field) {
    if (!field.LookupTable || !field.LookupKeyField || !field.LookupResultField) {
      return null;
    }

    const key = `${field.LookupTable}|${field.LookupKeyField}|${field.LookupResultField}`;
    if (LOOKUP_CACHE[key]) return LOOKUP_CACHE[key];

    try {
      const url = `/api/TableFieldLayout/LookupData`
        + `?table=${encodeURIComponent(field.LookupTable)}`
        + `&key=${encodeURIComponent(field.LookupKeyField)}`
        + `&result=${encodeURIComponent(field.LookupResultField)}`;

      const response = await fetch(url);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const rows = await response.json();
      const map = {};
      rows.forEach(r => {
        map[r.key] = r.result0;
      });

      LOOKUP_CACHE[key] = map;
      return map;
    } catch (err) {
      LOOKUP_CACHE[key] = null;
      return null;
    }
  }

  // 載入 OCX Lookup（虛擬欄位）
  async function loadOCXLookup(field) {
    if (!field.OCXLKTableName || !field.KeyFieldName || !field.OCXLKResultName) {
      return null;
    }

    const key = `${field.OCXLKTableName}|${field.KeyFieldName}|${field.OCXLKResultName}`;
    if (OCX_CACHE[key]) return OCX_CACHE[key];

    try {
      const url = `/api/TableFieldLayout/LookupData`
        + `?table=${encodeURIComponent(field.OCXLKTableName)}`
        + `&key=${encodeURIComponent(field.KeyFieldName)}`
        + `&result=${encodeURIComponent(field.OCXLKResultName)}`;

      const response = await fetch(url);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const rows = await response.json();
      const map = {};
      rows.forEach(r => {
        map[r.key] = r.result0;
      });

      OCX_CACHE[key] = map;
      return map;
    } catch (err) {
      OCX_CACHE[key] = null;
      return null;
    }
  }

  // 解析 Delphi 風格格式字串（如 ##0.000）並格式化數字
  function applyDelphiFormat(num, formatStr) {
    if (!formatStr) return null;
    const dotIdx = formatStr.indexOf('.');
    if (dotIdx === -1) {
      // 無小數點 → 整數顯示
      return Math.round(num).toString();
    }
    // 小數位數 = 小數點後 '0'/'#' 字元數
    const afterDot = formatStr.slice(dotIdx + 1);
    const decimalPlaces = afterDot.replace(/[^0#]/g, '').length;
    return num.toFixed(decimalPlaces);
  }

  // 格式化顯示值
  function formatCellValue(value, field) {
    if (value == null || value === '') return '';

    const dataType = (field.DataType || '').toLowerCase();

    // 日期格式化
    if (dataType.includes('date') || dataType.includes('time')) {
      try {
        const date = new Date(value);
        if (!isNaN(date.getTime())) {
          return date.toLocaleDateString('zh-TW', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit'
          }).replace(/\//g, '/');
        }
      } catch {}
    }

    // 數字格式化（優先套用 FormatStr）
    const isNumericType = dataType.includes('int') || dataType.includes('decimal')
      || dataType.includes('numeric') || dataType.includes('real')
      || dataType.includes('float') || dataType.includes('money');
    if (isNumericType || field.FormatStr) {
      const num = Number(value);
      if (!isNaN(num)) {
        if (field.FormatStr) {
          const formatted = applyDelphiFormat(num, field.FormatStr);
          if (formatted !== null) return formatted;
        }
        return num.toLocaleString();
      }
    }

    return String(value);
  }

  // 建立表格（支援自動 Lookup）
  async function buildTable(tabKey, dict, rows, fetchUrl) {
    const table = document.getElementById(`grid-${tabKey}`);
    if (!table) return;
    const thead = table.querySelector('thead');
    const tbody = table.querySelector('tbody');
    if (!thead || !tbody) return;

    // 儲存 fetchUrl 與 dict 供自動存檔後重新載入使用
    if (!tabState[tabKey]) tabState[tabKey] = { editor: null };
    if (fetchUrl) tabState[tabKey].lastFetchUrl = fetchUrl;
    tabState[tabKey].lastDict = dict;

    // Build header - 使用宽松比较 (==) 而不是严格比较 (===)
    // 因为 API 可能返回字符串 "1" 或数字 1
    const visibleFields = dict.filter(f => (f.Visible ?? 1) == 1).sort((a, b) => (a.SerialNum || 0) - (b.SerialNum || 0));

    // 构建表头，设置列宽（含 th-resize handle）
    thead.innerHTML = '<tr>' + visibleFields.map(f => {
      // 计算列宽：DisplaySize 或 iFieldWidth，一字宽 10px
      const width = Number(f.DisplaySize || f.iFieldWidth || 0);
      const widthPx = width > 0 ? width * 10 : 100; // 默认 100px
      const widthStyle = `style="width: ${widthPx}px; min-width: ${widthPx}px;"`;
      return `<th ${widthStyle} data-field="${f.FieldName}">${f.DisplayLabel || f.FieldName}<div class="th-resize"></div></th>`;
    }).join('') + '</tr>';

    // Build body
    if (!rows || rows.length === 0) {
      tbody.innerHTML = '<tr><td colspan="100" class="text-center text-muted py-3">無資料</td></tr>';
      return;
    }

    // 載入所有欄位的 Lookup Maps
    const lookupMaps = {};
    const ocxMaps = {};

    for (const field of visibleFields) {
      lookupMaps[field.FieldName] = await loadLookup(field);
      ocxMaps[field.FieldName] = await loadOCXLookup(field);
    }

    // 取得 keyFields（用於判斷哪些欄位是主鍵）
    const keyFields = (table.dataset.keyFields || '').split(',').filter(k => k.trim());
    const keyFieldSet = new Set(keyFields.map(k => k.toLowerCase()));

    // 渲染表格資料（套用 Lookup，並生成可編輯結構）
    tbody.innerHTML = rows.map(row => {
      // 為每一行生成主鍵隱藏欄位
      let pkHiddenHtml = '';
      keyFields.forEach(k => {
        const val = row[k] ?? row[k.toLowerCase()] ?? '';
        pkHiddenHtml += `<input type="hidden" class="mmd-pk-hidden" name="${k}" value="${val}">`;
      });
      // 額外加入 PartNum 和 Revision（確保主鍵正確傳遞）
      if (!keyFieldSet.has('partnum')) {
        const partNum = currentMasterKeys.PartNum || currentMasterKeys.partnum || '';
        pkHiddenHtml += `<input type="hidden" class="mmd-fk-hidden" name="PartNum" value="${partNum}">`;
      }
      if (!keyFieldSet.has('revision')) {
        const revision = currentMasterKeys.Revision || currentMasterKeys.revision || '';
        pkHiddenHtml += `<input type="hidden" class="mmd-fk-hidden" name="Revision" value="${revision}">`;
      }

      const cells = visibleFields.map(f => {
        let rawValue = row[f.FieldName] ?? row[f.FieldName?.toLowerCase()] ?? '';
        let displayValue = rawValue;
        let lookupApplied = false; // 是否套用了 Lookup（Lookup 欄位的 input 需保留原始代碼，不能用格式化後的文字）

        // 優先使用 OCX Lookup（虛擬欄位）
        if (ocxMaps[f.FieldName] && rawValue) {
          const lookupResult = ocxMaps[f.FieldName][rawValue];
          if (lookupResult != null) {
            displayValue = lookupResult;
            lookupApplied = true;
          }
        }
        // 其次使用一般 Lookup（實體欄位）
        else if (lookupMaps[f.FieldName] && rawValue) {
          const lookupResult = lookupMaps[f.FieldName][rawValue];
          if (lookupResult != null) {
            displayValue = lookupResult;
            lookupApplied = true;
          }
        }

        // 格式化顯示
        displayValue = formatCellValue(displayValue, f);

        // input 的值：Lookup 欄位用 rawValue（原始代碼）
        // number 欄位也用 rawValue（toLocaleString 加逗號會讓 type=number 的 value 被瀏覽器清空，造成誤判 dirty）
        const isNumericField = (f.DataType || '').toLowerCase().match(/int|decimal|numeric|real|float|money/);
        const inputValue = (lookupApplied || isNumericField) ? rawValue : displayValue;

        // 判斷欄位是否為唯讀
        const isReadonly = (f.ReadOnly ?? 0) !== 0 || keyFieldSet.has((f.FieldName || '').toLowerCase());
        const readonlyAttr = isReadonly ? 'data-readonly="1"' : '';
        const dataType = (f.DataType || '').toLowerCase();
        const inputType = dataType.includes('int') || dataType.includes('decimal') || dataType.includes('numeric') ? 'number' : 'text';

        // 生成包含 .cell-view 和 .cell-edit 的結構
        return `<td data-field="${f.FieldName}" data-raw="${rawValue}">
          <span class="cell-view">${displayValue}</span>
          <input type="${inputType}" class="cell-edit form-control form-control-sm d-none" name="${f.FieldName}" value="${inputValue}" ${readonlyAttr} data-type="${dataType}">
        </td>`;
      }).join('');
      return `<tr>${pkHiddenHtml}${cells}</tr>`;
    }).join('');

    // Make editable
    const tableName = table.dataset.tableName;

    // 切換頁籤前保留編輯狀態，切換回來後恢復
    const wasEditing = tabState[tabKey]?.editor?.isEdit?.() ?? false;

    if (!tabState[tabKey]) {
      tabState[tabKey] = { editor: null };
    }

    const wrapper = table.closest('.table-responsive');
    // 清除舊的 edit-mode class，避免殘留造成樣式異常
    wrapper.classList.remove('edit-mode');

    const saveUrl = "/api/CommonTable/SaveTableChanges";

    tabState[tabKey].editor  = window.makeEditableGrid({
      wrapper: wrapper,
      table: table,
      tableName: tableName,
      keyFields: keyFields,
      saveUrl: saveUrl
    });
    tabState[tabKey].wrapper = wrapper; // 供 dirty 偵測使用

    // 若切換前在編輯模式，或全域修改狀態已開啟，自動套用
    if (wasEditing || window.isGlobalEditMode) {
      tabState[tabKey].editor.toggleEdit(true);
    }

    // Show controls
    const controls = wrapper?.parentElement?.querySelector('.tab-local-controls');
    if (controls) controls.classList.remove('d-none');

    // 啟用欄寬拖曳調整
    enableThResize(table);

    // dirty 偵測 + 列 blur 自動存檔（Problem 2 + 3）
    if (!wrapper._dirtyListenerAttached) {
      wrapper._dirtyListenerAttached = true;

      // ① 任何欄位變更時更新 ✓/× 狀態
      wrapper.addEventListener('input', () => {
        if (window.updateSaveCancelButtons) window.updateSaveCancelButtons();
      });

      // ② 列失焦時自動存檔（觸發 SQL trigger 計算）
      wrapper.addEventListener('focusout', async function(e) {
        if (!window.isGlobalEditMode) return;
        if (window.isCancellingChanges) return; // 使用者點了 × 取消，不觸發 auto-save
        const cell = e.target;
        if (!cell.classList.contains('cell-edit') || cell.dataset.readonly === '1') return;
        const currentRow = cell.closest('tr');
        if (!currentRow) return;
        // focus 仍在同一列 → 不存檔
        if (e.relatedTarget && currentRow.contains(e.relatedTarget)) return;
        // 檢查該列是否有變更
        const rowDirty = Array.from(
          currentRow.querySelectorAll('.cell-edit:not([data-readonly="1"])')
        ).some(inp =>
          inp.type === 'checkbox'
            ? (inp.checked ? '1' : '0') !== (inp.defaultValue ?? '')
            : inp.value !== (inp.defaultValue ?? '')
        );
        if (!rowDirty) return;
        const editor = tabState[tabKey]?.editor;
        if (!editor?.saveChanges) return;
        try {
          await editor.saveChanges();
          // 重新載入資料，以顯示 SQL trigger 計算結果（例如 mm 自動換算）
          const state = tabState[tabKey];
          if (state?.lastFetchUrl && state?.lastDict) {
            try {
              const freshRows = await fetch(state.lastFetchUrl).then(r => r.json());
              if (freshRows) await buildTable(tabKey, state.lastDict, freshRows, state.lastFetchUrl);
            } catch (fetchErr) { console.warn('[auto-save refresh]', fetchErr); }
          }
          if (window.updateSaveCancelButtons) window.updateSaveCancelButtons();
        } catch (err) { console.error('[auto-save row blur]', err); }
      });
    }
  }

  // 為表頭加上拖曳調整欄寬功能（含置中指示線特效）
  function enableThResize(table) {
    table.querySelectorAll('thead th').forEach(th => {
      const handle = th.querySelector('.th-resize');
      if (!handle) return;
      handle.addEventListener('mousedown', (e) => {
        e.stopPropagation();
        e.preventDefault();
        handle.classList.add('dragging');
        const startX = e.clientX;
        const startW = th.offsetWidth;
        const startTableW = table.offsetWidth;
        function onMove(ev) {
          const delta = ev.clientX - startX;
          const newW = Math.max(30, startW + delta);
          th.style.width = newW + 'px';
          th.style.minWidth = newW + 'px';
          table.style.width = (startTableW + (newW - startW)) + 'px';
        }
        function onUp() {
          handle.classList.remove('dragging');
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });
  }

  // 暴露 buildTable 給外部 script 使用
  window.buildTableForEdit = buildTable;

  function loadDetailTab(tabBtn) {
    const tabKey = tabBtn.getAttribute('aria-controls')?.replace('tab-', '');
    if (!tabKey) return;

    const tableName = tabBtn.dataset.table;
    const dictName = tabBtn.dataset.dict;

    // 特殊處理：產品工程圖頁籤載入圖片
    if (tabKey === 'prodmap') {
      loadProductMapImages();
      return;
    }

    // 特殊處理：這些頁籤由左側層別控制，不在此處載入
    const layerControlledTabs = ['layerpress', 'pressmethod', 'layerroute'];
    if (layerControlledTabs.includes(tabKey)) {
      // 顯示提示訊息
      const table = document.getElementById(`grid-${tabKey}`);
      if (table) {
        const tbody = table.querySelector('tbody');
        if (tbody && tbody.querySelector('td')?.textContent.includes('請點選上方主檔資料')) {
          tbody.innerHTML = '<tr><td colspan="100" class="text-center text-muted py-3">請點選左側層別以顯示對應資料</td></tr>';
        }
      }
      return;
    }

    const keyFields = (tabBtn.dataset.keyfields || '').split(',').filter(k => k.trim());
    const extraKeys = tabBtn.dataset.extraKeys || '';

    if (!tableName || !dictName) return;

    // Build query
    const qs = new URLSearchParams();
    keyFields.forEach(k => {
      const val = currentMasterKeys[k] ?? currentMasterKeys[k.toLowerCase()] ?? '';
      if (val) {
        qs.append('keyNames', k);
        qs.append('keyValues', val);
      }
    });

    // Add extra keys
    if (extraKeys) {
      extraKeys.split(';').forEach(pair => {
        const [k, v] = pair.split('=');
        if (k && v) {
          qs.append('keyNames', k.trim());
          qs.append('keyValues', v.trim());
        }
      });
    }

    const url = `/api/CommonTable/ByKeys?table=${encodeURIComponent(tableName)}&${qs.toString()}`;

    Promise.all([
      getDict(dictName),
      fetch(url).then(r => r.json())
    ]).then(([dict, rows]) => {
      buildTable(tabKey, dict, rows, url);
    }).catch(err => {
      const table = document.getElementById(`grid-${tabKey}`);
      if (table) {
        const tbody = table.querySelector('tbody');
        if (tbody) tbody.innerHTML = `<tr><td colspan="100" class="text-center text-danger py-3">載入失敗: ${err.message}</td></tr>`;
      }
    });
  }

  // Load master data
  const masterApiUrl = '@Html.Raw(cfg?.MasterApi ?? "")';
  const dictName = '@cfg?.MasterDict';

  if (masterApiUrl && dictName) {
    Promise.all([
      getDict(dictName),
      fetch(masterApiUrl).then(r => r.json())
    ]).then(async ([dict, rows]) => {
      masterDict = dict;
      masterData = rows && rows.length > 0 ? rows[0] : {};

      // Render header
      renderHeaderFields(dict, masterData);

      // 載入層別資料
      loadLayerPress();

      // 載入左下角內部資料 (暫停記錄) - 使用與右側相同的表格渲染邏輯
      loadSidebarHaltLog();

      // Render all master tabs
      const masterTabs = document.querySelectorAll('#master-tabs [data-tab-key]');
      for (const tab of masterTabs) {
        await renderMasterTab(tab.dataset.tabKey, dict, masterData);
      }

      // 預填 選擇壓合模型 input（TmpPressId = 目前已使用的壓合疊構代碼）
      const _pressModeInp = document.getElementById('selectedPressModelCode');
      if (_pressModeInp) {
        const _curTmpPressId = (masterData.TmpPressId ?? '').trim();
        _pressModeInp.value = _curTmpPressId;
        if (_curTmpPressId) window._selectedPressTmpId = _curTmpPressId;
      }
      // 暴露 TmpBOMId 供 選擇壓合模型 篩選（比命名規則更可靠）
      window.currentMasterTmpBOMId = (masterData.TmpBOMId ?? masterData.TmpBomid ?? '').trim();
    }).catch(err => {
      // Load error handled silently
    });
  }

  // Detail tab click handler
  detailTabs.forEach(tabBtn => {
    tabBtn.addEventListener('shown.bs.tab', () => {
      loadDetailTab(tabBtn);
    });
  });

  // 當切換到「表單」頁籤時，先自動儲存規格（若在編輯中），再載入第一個單身資料頁籤
  let formTabLoaded = false;
  const formTabBtn = document.getElementById('form-tab');
  if (formTabBtn) {
    formTabBtn.addEventListener('shown.bs.tab', async () => {
      // 若規格頁籤在編輯中，自動儲存但維持編輯狀態
      if (window.specEditMode && window.saveSpecChanges) {
        await window.saveSpecChanges();
      }
      if (!formTabLoaded && detailTabs.length > 0) {
        formTabLoaded = true;
        setTimeout(() => loadDetailTab(detailTabs[0]), 100);
      }
    });
  }

  // 當切換回「規格」頁籤時（不需要動作，只是留意狀態）
  const specTabBtn = document.getElementById('spec-tab');
  if (specTabBtn) {
    specTabBtn.addEventListener('shown.bs.tab', () => {
      // 規格頁籤切回來時，不自動進入編輯，讓使用者手動點修改
    });
  }

  // 產生圖檔按鈕移入 btn-toolbar（與其他文字按鈕並排）
  const btnToolbar = document.querySelector('#topToolbar .btn-toolbar');
  const btnGenerateImages = document.getElementById('btnGenerateImages');
  if (btnToolbar && btnGenerateImages) {
    btnToolbar.appendChild(btnGenerateImages);
  }
  if (btnGenerateImages) {
    btnGenerateImages.addEventListener('click', async () => {
      // 查詢模式下不允許產生圖檔
      if (isViewOnly) {
        alert('查詢模式下無法產生圖檔');
        return;
      }

      const partNum = currentMasterKeys.PartNum || currentMasterKeys.partnum;
      const revision = currentMasterKeys.Revision || currentMasterKeys.revision;

      if (!partNum || !revision) {
        alert('無法取得料號或版序，請重新載入頁面');
        return;
      }

      if (!confirm(`確定要產生圖檔？\n\n料號: ${partNum}\n版序: ${revision}`)) {
        return;
      }

      // 顯示載入中狀態
      const originalHtml = btnGenerateImages.innerHTML;
      btnGenerateImages.disabled = true;
      btnGenerateImages.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>產生中...';

      try {
        const response = await fetch('/api/imagegeneration/generate', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            PartNum: partNum,
            Revision: revision
          })
        });

        const text = await response.text();

        // 檢查回應狀態
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${text.substring(0, 200)}`);
        }

        // 嘗試解析 JSON
        let result;
        try {
          result = JSON.parse(text);
        } catch (e) {
          throw new Error(`回應不是有效的 JSON 格式。回應內容：${text.substring(0, 200)}`);
        }

        if (result.success) {
          let message = '圖檔產生成功！\n\n';
          if (result.images && result.images.length > 0) {
            message += '產生的圖檔：\n';
            result.images.forEach(img => {
              message += `- ${img.type}: ${img.success ? img.fileName : '失敗 - ' + (img.errorMessage || '未知錯誤')}\n`;
            });
          }
          alert(message);
        } else {
          alert('產生圖檔失敗：\n' + (result.message || '未知錯誤'));
        }
      } catch (err) {
        alert('產生圖檔時發生錯誤：\n' + err.message);
      } finally {
        // 恢復按鈕狀態
        btnGenerateImages.disabled = false;
        btnGenerateImages.innerHTML = originalHtml;
      }
    });
  }

  // Tab local controls
  document.querySelectorAll('[data-btn="edit"]').forEach(btn => {
    btn.addEventListener('click', () => {

      // 查詢模式下不允許編輯
      if (isViewOnly) {
        alert('查詢模式下無法編輯資料');
        return;
      }

      // 先檢查權限
      if (!window.checkEditPermission || !window.checkEditPermission()) {
        return;
      }

      const tabKey = btn.dataset.tab;

      const editor = tabState[tabKey]?.editor;

      if (editor && editor.toggleEdit) {
        editor.toggleEdit(true);
        btn.classList.add('d-none');
        btn.parentElement?.querySelector('[data-btn="save"]')?.classList.remove('d-none');
      }
    });
  });

  document.querySelectorAll('[data-btn="save"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const tabKey = btn.dataset.tab;
      const editor = tabState[tabKey]?.editor;
      if (editor && editor.saveChanges) {
        const result = await editor.saveChanges();
        if (result.ok) {
          alert('儲存成功');
          editor.toggleEdit(false);
          btn.classList.add('d-none');
          btn.parentElement?.querySelector('[data-btn="edit"]')?.classList.remove('d-none');
        } else {
          alert('儲存失敗');
        }
      }
    });
  });

  // ========== 新增：工具列按鈕功能 ==========

  // 查詢按鈕 - 返回列表頁（查詢模式）
  const btnOpenQuery = document.getElementById('btnOpenQuery');
  if (btnOpenQuery) {
    btnOpenQuery.addEventListener('click', function() {
      window.location.href = '@Url.Page("Index", new { mode = "view", itemId = "EMO00018" })';
    });
  }

});
</script>

