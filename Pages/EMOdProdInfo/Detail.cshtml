@page "/EMOdProdInfo/Detail"
@model PcbErpApi.Pages.EMOdProdInfo.DetailModel
@using System.Text.Json
@{
    Layout = "_Layout";
    var cfg = Model.Config;
    ViewData["DictTableName"] = cfg?.MasterDict;
    ViewData["ActionRailPartial"] = Model.ActionRailPartial;
}

@await Html.PartialAsync("~/Pages/Shared/_FieldDictModal.cshtml", null, ViewData)
<script src="~/js/editableGrid.js"></script>

<script>
    // 設定全域變數供 ActionRail 使用
    window._itemId = '@(Model.IsViewOnly ? "EMO00018" : "EMO00004")';
    window._headerTableName = '@Model.HeaderTableName';
    // 提供 masterRow 給 ActionRail execByButton（EMOdProdInfo 用 PartNum+Revision 而非 PaperNum）
    window._getMasterRow = () => {
        const mk = window.currentMasterKeys || {};
        return {
            PartNum:  (mk.PartNum  || mk.partnum  || '').trim(),
            Revision: (mk.Revision || mk.revision || '').trim()
        };
    };
</script>

@* 左侧按钮条样式调整 *@
@if ((Model.CustomButtons?.Count > 0))
{
    <style>
    /* EMOdProdInfo 使用 Action Rail（左側自訂按鈕）時，需預留左側空間，避免單頭/頁籤被擋住 */
    :root{
      --fab-left: 12px;
      --fab-width: 120px;
      --fab-gap: 14px;
      --rail-reserve: calc(var(--fab-left) + var(--fab-width) + var(--fab-gap));
    }

    .content-wrapper {
        padding-left: var(--rail-reserve) !important;
    }

    /* toolbar 往左延伸貼齊 action-rail，參考 PaperDetail 做法 */
    #topToolbar {
        margin-left: calc(-1 * var(--rail-reserve) + var(--fab-left)) !important;
        width: calc(100% + var(--rail-reserve) - var(--fab-left) * 2) !important;
        position: sticky;
        top: 4px;
        z-index: 1200;
    }

    /* Action Rail 容器樣式 */
    .action-rail{
      position: fixed;
      left: var(--fab-left);
      top: 80px; /* 初始值，由 JS 動態覆蓋 */
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: 1px;
      z-index: 900;
      overflow-y: auto;
      overflow-x: visible;
      max-height: calc(100vh - 100px);
      background: transparent;
    }

    /* 按鈕的共同外觀 */
    .fab{
      position: relative;
      width: var(--fab-width);
      min-width: 0;
      min-height: 0;
      padding: 5px 8px;
      font-size: .88rem;
      letter-spacing: 0;
      white-space: normal;
      word-break: break-word;
      background:#f8f9fb;
      color:#1f5fbf;
      font-weight:600;
      border-radius:10px;
      cursor:pointer;
      box-shadow:0 2px 8px rgba(20,40,80,.12);
      border:1px solid #cfd7e6;
    }
    .fab:hover{
      background:#e9f1ff;
      border-color:#9fbaf0;
    }
    .fab:focus-visible{
      outline:2px solid #9fbaf0;
      outline-offset:2px;
    }
    </style>
}

<style>
/* Modal backdrop 透明 */
.modal-backdrop { opacity: 0 !important; }
/* 移除大頁籤底線，讓兩排頁籤緊貼 */
#main-category-tabs {
  border-bottom: none;
  margin-bottom: 0;
}
/* === 規格/表單 大頁籤 + 子頁籤（與銷售訂單一致） === */
#main-category-tabs .nav-link,
#master-tabs .nav-link,
#extra-tabs .nav-link {
  --bs-nav-link-padding-y: 4px;
  --bs-nav-link-padding-x: 10px;
  --bs-nav-link-font-size: 14px;
  font-size: 14px;
  padding: 4px 10px;
  line-height: 1.4;
  white-space: nowrap;
  color: #495057;
  display: inline-flex;
  align-items: center;
}
#main-category-tabs .nav-link.active,
#master-tabs .nav-link.active,
#extra-tabs .nav-link.active {
  font-weight: bold;
  color: #000;
}
/* === 規格頁籤絕對座標排版 === */
:root { --field-label-size: 12px; --field-value-size: 12px; }
.master-spec-tab { position: relative; box-sizing: border-box; padding-top: 6px; padding-bottom: 8px; }
.spec-field-label { position: absolute; display: flex; align-items: center; justify-content: flex-end; text-align: right; font-size: var(--field-label-size); line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 4px 0 2px; pointer-events: none; color: #333; }
.spec-draggable { position: absolute; display: flex; flex-direction: row; align-items: center; box-sizing: border-box; overflow: hidden; background: #fff; }
.spec-draggable .master-field {
  width: 100%;
  height: 100%;
  min-height: 20px;
  padding: 2px 6px;
  font-size: var(--field-value-size);
  border: 1px solid #999;
  border-radius: 2px;
  box-sizing: border-box;
  background: #fff;
  color: #333;
  outline: none;
}
.spec-draggable.field-number .master-field { text-align: right; }
/* .md-selected 僅在編輯模式下生效（由 body.layout-edit-enabled 控制） */

/* resize 時由 JS 直接設定 input 寬度，不再用 flex-shrink */
/* === Layout 編輯模式（Admin + Shift） === */
body.layout-edit-enabled { user-select: none; -webkit-user-select: none; }
body.layout-edit-enabled .spec-draggable {
  cursor: move;
}
body.layout-edit-enabled .spec-draggable,
body.layout-edit-enabled .spec-draggable .master-field {
  outline: none !important;
  box-shadow: none !important;
}
/* layout 模式下 input/select 不攔截滑鼠，讓 li 接收拖曳 */
body.layout-edit-enabled .spec-draggable .master-field {
  pointer-events: none !important;
}
/* 確保 li 本身接收滑鼠 */
body.layout-edit-enabled .spec-draggable {
  pointer-events: auto !important;
}
/* 選取時的淡藍背景 */
body.layout-edit-enabled .spec-draggable.md-selected {
  background: rgba(91,141,239, 0.12);
}
body.layout-edit-enabled .spec-draggable.md-selected input.master-field,
body.layout-edit-enabled .spec-draggable.md-selected select.master-field {
  background: rgba(91,141,239, 0.12) !important;
}
body.layout-edit-enabled .spec-field-label.md-selected-label {
  background: rgba(91,141,239, 0.12);
}
/* resize 三角形（右下角直角三角形） */
body.layout-edit-enabled .rsz-handle.se {
  width: 0 !important; height: 0 !important;
  border-style: solid;
  border-width: 0 0 10px 10px;
  border-color: transparent transparent #5b8def transparent;
  cursor: se-resize;
  opacity: 0.6;
}
body.layout-edit-enabled .rsz-handle.se:hover { opacity: 1; }
/* 右邊 resize handle 已移除，只保留右下角三角形 */
/* 編輯模式下隱藏 tooltip（靠 JS 動態控制） */
body:not(.layout-edit-enabled) .spec-draggable[title],
body:not(.layout-edit-enabled) .spec-field-label[title] {
  pointer-events: auto;
}
/* 吸附輔助線 */
.snap-guide {
  position: absolute;
  background: #5b8def;
  z-index: 9999;
  pointer-events: none;
}
.snap-guide.guide-h { height: 1px; left: 0; right: 0; }
.snap-guide.guide-v { width: 1px; top: 0; bottom: 0; }
/* 框選矩形 */
.marquee-rect {
  position: fixed;
  border: 1px solid #5b8def;
  background: rgba(91,141,239, 0.08);
  z-index: 9999;
  pointer-events: none;
}
body.layout-edit-enabled .spec-draggable:hover {
  background: rgba(74, 144, 226, 0.05);
}
body.layout-edit-enabled .spec-field-label {
  pointer-events: auto;
  cursor: move;
  border: 1px dashed transparent;
}
body.layout-edit-enabled .spec-field-label:hover {
  border-color: #aab8cf;
}
/* jQuery UI resizable 手柄 */
body.layout-edit-enabled .ui-resizable-handle {
  background: #5b8def; opacity: 0.5; border-radius: 2px;
}
body.layout-edit-enabled .ui-resizable-e { width: 4px; right: 0; }
body.layout-edit-enabled .ui-resizable-se { width: 8px; height: 8px; right: 0; bottom: 0; }

/* 規格頁籤編輯狀態（排除 checkbox） */
#spec-content.spec-editing .master-field:not(.readonly-field):not([type="checkbox"]) {
  border-color: #5b8def !important;
  background: #f0f6ff !important;
  cursor: text !important;
}
#spec-content.spec-editing .master-field:not(.readonly-field):not([type="checkbox"]):focus {
  border-color: #2564b3 !important;
  outline: 2px solid rgba(37,100,179,0.25) !important;
  background: #fff !important;
}
/* select 瀏覽狀態：不顯示下拉箭頭、維持白底 */
#spec-content .master-field[disabled]:is(select) {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  pointer-events: none;
  background-color: #fff !important;
  color: inherit !important;
  opacity: 1 !important;
}
/* select 編輯狀態：顯示下拉箭頭、手型游標 */
#spec-content.spec-editing select.master-field:not(.readonly-field):not([disabled]) {
  cursor: pointer !important;
}
/* checkbox 編輯狀態：手型游標、無藍框 */
#spec-content.spec-editing .master-field[type="checkbox"]:not(.readonly-field) {
  cursor: pointer !important;
  outline: none !important;
  box-shadow: none !important;
  background: transparent !important;
  border: none !important;
  accent-color: #2564b3;
}
/* 表單頁籤 edit mode：td padding 歸零，input 填滿整格 */
.table-responsive.edit-mode td {
  padding: 0 !important;
}
.table-responsive.edit-mode td .cell-edit:not(.d-none) {
  min-height: unset !important;
  height: auto !important;
  padding: 2px 6px !important;
  font-size: 12px !important;
  line-height: 1.4 !important;
  border: none !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  outline: none !important;
  background: #ffffff !important;
  color: #212529 !important;
  width: 100%;
  display: block;
  box-sizing: border-box;
}
/* 唯讀欄位：灰底、黑字、禁止指標，hover/focus 無框線 */
.table-responsive.edit-mode td .cell-edit.readonly-cell:not(.d-none) {
  background: #e9ecef !important;
  cursor: not-allowed !important;
}
.table-responsive.edit-mode td .cell-edit:not(.d-none):hover,
.table-responsive.edit-mode td .cell-edit:not(.d-none):focus {
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
}
</style>

@* 左側自訂按鈕區（Action Rail） *@
@if (!string.IsNullOrWhiteSpace(Model.ActionRailPartial))
{
    <div class="action-rail">
        @await Html.PartialAsync(Model.ActionRailPartial, Model)
    </div>
    <script>
    // 動態計算 action-rail 的 top，讓它從 toolbar 下方開始
    (function () {
        function positionActionRail() {
            var toolbar = document.getElementById('topToolbar');
            var rail = document.querySelector('.action-rail');
            if (!toolbar || !rail) return;
            var bottom = toolbar.getBoundingClientRect().bottom;
            rail.style.top = (bottom + 4) + 'px';
            rail.style.maxHeight = 'calc(100vh - ' + (bottom + 8) + 'px)';
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', positionActionRail);
        } else {
            positionActionRail();
        }
        window.addEventListener('resize', positionActionRail);
    })();
    </script>
}

@* 自訂按鈕邏輯腳本（如果存在） *@
@if (ViewData["ActionRailLogicPartial"] is string logicPartial && !string.IsNullOrWhiteSpace(logicPartial))
{
    @await Html.PartialAsync(logicPartial)
}

@if (cfg == null)
{
    <div class="alert alert-warning mt-3">初始化工程資料維護畫面失敗，請稍後再試。</div>
}
else
{
    <div class="content-wrapper" style="display: flex; flex-direction: column; height: calc(100vh - 60px); overflow: visible;">
    <div id="topToolbar" class="top-toolbar" data-dict-table="@cfg?.MasterTable">
        <div class="toolbar-icon-row" role="group" aria-label="row-nav-and-sub-detail">
            <button type="button" class="btn toolbar-btn toolbar-btn-icon" id="btnFirst" title="第一筆" aria-label="第一筆"><i class="bi bi-chevron-bar-left"></i></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon" id="btnPrev" title="上一筆" aria-label="上一筆"><i class="bi bi-chevron-left"></i></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon" id="btnNext" title="下一筆" aria-label="下一筆"><i class="bi bi-chevron-right"></i></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon" id="btnLast" title="最後一筆" aria-label="最後一筆"><i class="bi bi-chevron-bar-right"></i></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-add" id="btnSubDetailAdd" title="新增" aria-label="新增"><span class="toolbar-icon">+</span></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-del" id="btnSubDetailDelete" title="刪除" aria-label="刪除"><span class="toolbar-icon">-</span></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-add toolbar-btn-check" id="btnSaveHeader" title="儲存" aria-label="儲存" disabled><span class="toolbar-icon">✓</span></button>
            <button type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-del toolbar-btn-check" id="btnCancelChanges" title="取消變更" aria-label="取消變更" disabled><span class="toolbar-icon">&times;</span></button>
        </div>
        @await Html.PartialAsync("~/Pages/Shared/_TableToolbar.cshtml", new TableToolbarModel {
            SearchBtnId = "btnSubSearch",
            AddBtnId = "btnSubAddNew",
            DeleteBtnId = "btnSubBatchDelete",
            SearchText = "查詢",
            AddText = "新增",
            DeleteText = "作廢",
            ModalId = "searchModal",
            ReportSpName = ""
        })
        <!-- 產生圖檔按鈕（工程資料特有） -->
        <button id="btnGenerateImages" class="btn toolbar-btn" type="button" @(Model.IsViewOnly ? "disabled" : "")>產生圖檔</button>
    </div>

    <!-- 頂部基本資訊區（全寬度）-->
    <div id="emodprodinfo-header"
         class="card shadow-sm border-0 rounded mb-2"
         data-dict="@cfg?.MasterDict"
         style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); padding: 4px 10px;">
        <!-- 第一行 -->
        <div class="d-flex align-items-center flex-wrap gap-1" id="header-row-1" style="margin-bottom:2px"></div>
        <!-- 第二行 -->
        <div class="d-flex align-items-center flex-wrap gap-1" id="header-row-2"></div>
    </div>

    <!-- 主要內容區：左側層別+內部資料 + 右側規格/表單 -->
    <div class="d-flex gap-2" style="align-items: stretch; flex: 1; overflow-y: auto; min-height: 0;">
        <!-- 左側：層別面板 + 內部資料 -->
        <div style="width: 180px; flex-shrink: 0;">
            <!-- 層別面板 -->
            <div class="card shadow-sm border-0 rounded mb-2" style="height: 350px; display: flex; flex-direction: column;">
                <div class="card-header bg-light fw-bold text-center py-2" style="border-bottom: 2px solid #dee2e6; flex-shrink: 0;">
                    層別
                </div>
                <div class="card-body p-0" id="layer-list" style="flex: 1; overflow-y: auto; overflow-x: hidden;">
                    <div class="text-center text-muted py-3">載入中...</div>
                </div>
                <div class="card-footer p-1 bg-transparent border-top d-flex justify-content-start" style="flex-shrink: 0;">
                    <button type="button" id="btn-goto-layer-detail"
                            class="btn btn-sm btn-info text-white fw-bold py-0 px-2"
                            style="font-size: 11px;">
                        內部資料
                    </button>
                </div>
            </div>

            <!-- 內部資料 (暫停記錄) -->
            <div class="card shadow-sm border-0 rounded" style="height: 250px; display: flex; flex-direction: column;">
                <div class="card-body p-0" style="flex: 1; overflow: auto;">
                    <div class="table-responsive" style="height: 100%;">
                        <table class="table table-sm table-hover align-middle mb-0"
                               id="grid-haltlog-sidebar"
                               data-table-name="EMOdProdLog"
                               data-dict-name="EMOdProdLog"
                               data-dict-table="EMOdProdLog"
                               data-key-fields="PartNum,Revision,SerialNum"
                               style="font-size: 11px;">
                            <thead class="table-light">
                                <tr><th class="text-center text-muted">載入中...</th></tr>
                            </thead>
                            <tbody>
                                <tr><td class="text-center text-muted py-2">載入中...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- 右側：規格/表單頁籤 -->
        <div style="flex: 1; min-width: 0;">
    <!-- 最外層頁籤：規格/表單 -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-2">
            <!-- 規格/表單 切換頁籤 -->
            <ul class="nav nav-tabs border-bottom-0 mb-0" role="tablist" id="main-category-tabs">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold"
                            id="spec-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#spec-content"
                            type="button"
                            role="tab"
                            aria-selected="true">
                        規格
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold"
                            id="form-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#form-content"
                            type="button"
                            role="tab"
                            aria-selected="false">
                        表單
                    </button>
                </li>
            </ul>

            <!-- 規格/表單 內容區 -->
            <div class="tab-content pt-0">
                <!-- 規格頁籤內容 (原主單頁籤區) -->
                <div class="tab-pane fade show active" id="spec-content" role="tabpanel" aria-labelledby="spec-tab">
                    <ul class="nav nav-tabs flex-wrap" role="tablist" id="master-tabs" style="gap:1px;">
                        @for (int i = 0; i < Model.MasterTabs.Count; i++)
                        {
                            var tab = Model.MasterTabs[i];
                            var active = i == 0 ? "active" : "";
                            <li class="nav-item" role="presentation">
                                <button class="nav-link @active"
                                        id="master-tab-@tab.Key"
                                        data-bs-toggle="tab"
                                        data-bs-target="#master-content-@tab.Key"
                                        type="button"
                                        role="tab"
                                        aria-selected="@(i == 0 ? "true" : "false")"
                                        data-tab-key="@tab.Key"
                                        data-tab-show-where="@tab.ShowWhere">
                                    @tab.Title
                                </button>
                            </li>
                        }
                    </ul>
                    <div class="tab-content" style="overflow-x: auto;">
                        @for (int i = 0; i < Model.MasterTabs.Count; i++)
                        {
                            var tab = Model.MasterTabs[i];
                            var active = i == 0 ? "show active" : "";
                            <div class="tab-pane fade @active"
                                 id="master-content-@tab.Key"
                                 role="tabpanel"
                                 style="padding: 12px;">
                                <ul class="list-unstyled master-spec-tab"
                                    data-tab-key="@tab.Key"
                                    data-show-where="@tab.ShowWhere"
                                    style="position: relative; min-height: 300px; margin: 0; padding: 0;"></ul>
                            </div>
                        }
                    </div>
                </div>

                <!-- 表單頁籤內容 (原單身頁籤區) -->
                <div class="tab-pane fade" id="form-content" role="tabpanel" aria-labelledby="form-tab">
                    <ul class="nav nav-tabs flex-wrap" role="tablist" id="extra-tabs">
                        @for (int i = 0; i < Model.ExtraTabs.Count; i++)
                        {
                            var tab = Model.ExtraTabs[i];
                            var active = i == 0 ? "active" : "";
                            <li class="nav-item" role="presentation">
                                <button class="nav-link @active"
                                        id="tab-@tab.Key-tab"
                                        data-bs-toggle="tab"
                                        data-bs-target="#tab-@tab.Key"
                                        type="button"
                                        role="tab"
                                        aria-controls="tab-@tab.Key"
                                        aria-selected="@(i == 0 ? "true" : "false")"
                                        data-table="@tab.TableName"
                                        data-dict="@tab.DictName"
                                        data-keyfields="@string.Join(",", tab.KeyFields ?? Enumerable.Empty<string>())"
                                        data-extra-keys="@string.Join(";", tab.ExtraKeys?.Select(k => $"{k.Key}={k.Value}") ?? Array.Empty<string>())">
                                    @tab.Title
                                </button>
                            </li>
                        }
                    </ul>
                    <div class="tab-content">
                        @for (int i = 0; i < Model.ExtraTabs.Count; i++)
                        {
                            var tab = Model.ExtraTabs[i];
                            var active = i == 0 ? "show active" : "";
                            <div class="tab-pane fade @active" id="tab-@tab.Key" role="tabpanel" aria-labelledby="tab-@tab.Key-tab">
                                @if (tab.Key == "layerpress")
                                {
                                    <!-- 壓合明細/替代料：上方操作按鈕 + 表格 -->
                                    <div class="d-flex gap-2 align-items-center px-2 py-1 border-bottom">
                                        <button type="button" id="btnSelectPressModel" class="btn btn-outline-primary btn-sm edit-only-btn" disabled>選擇壓合模型</button>
                                        <input type="text" id="selectedPressModelCode" class="form-control form-control-sm text-primary fw-semibold" style="width:120px" readonly placeholder="未選擇">
                                        <button type="button" id="btnLayerChange" class="btn btn-outline-primary btn-sm edit-only-btn" disabled>疊構變更</button>
                                        <button type="button" id="btnMaterialSet" class="btn btn-outline-primary btn-sm edit-only-btn" disabled>材料設定</button>
                                    </div>
                                    <div class="table-responsive" data-tab-key="@tab.Key">
                                        <table class="table table-sm table-hover align-middle mb-0"
                                               id="grid-@tab.Key"
                                               data-table-name="@tab.TableName"
                                               data-dict-name="@tab.DictName"
                                               data-dict-table="@tab.DictName"
                                               data-key-fields="@string.Join(",", tab.KeyFields ?? Enumerable.Empty<string>())">
                                            <thead class="table-light">
                                                <tr><th class="text-center text-muted">載入中...</th></tr>
                                            </thead>
                                            <tbody>
                                                <tr><td class="text-center text-muted py-3">請點選上方主檔資料</td></tr>
                                            </tbody>
