<script>
// ===== 裁板/排版圖 - 左側列表 + 右側大圖 =====
document.addEventListener('DOMContentLoaded', function () {
  const btn = document.getElementById('btnGenerateCutLayout');
  if (!btn) return;

  const statusSpan  = document.getElementById('cutLayoutStatus');
  const listTbody   = document.querySelector('#cutLayoutMapList tbody');
  const previewImg  = document.getElementById('cutLayoutPreviewImg');
  const previewMsg  = document.getElementById('cutLayoutPreviewMsg');

  const mapKindName = { 1: '裁板圖', 3: '排板圖', 9: 'PP裁切圖' };
  const mapKindType = { 1: 'panel',  3: 'cut',    9: 'pf' };

  function getKeys() {
    const mk = window.currentMasterKeys || {};
    return {
      partNum:  (mk.PartNum  || mk.partnum  || '').trim(),
      revision: (mk.Revision || mk.revision || '').trim()
    };
  }

  // 顯示選中的預覽圖
  function showPreview(mapKindNo) {
    const { partNum, revision } = getKeys();
    if (!partNum) return;
    const type = mapKindType[mapKindNo];
    if (!type) return;

    previewImg.style.display = 'none';
    previewMsg.textContent = '載入中…';
    previewMsg.style.display = '';

    const url = `/api/mappreview/${encodeURIComponent(partNum)}/${encodeURIComponent(revision)}/${type}?width=800&height=650&_t=${Date.now()}`;
    previewImg.onload = () => { previewImg.style.display = ''; previewMsg.style.display = 'none'; };
    previewImg.onerror = () => { previewMsg.textContent = '無資料'; previewMsg.style.display = ''; };
    previewImg.src = url;

    // highlight selected row
    listTbody.querySelectorAll('tr').forEach(r => r.classList.remove('table-active'));
    const activeRow = listTbody.querySelector(`tr[data-kind="${mapKindNo}"]`);
    if (activeRow) activeRow.classList.add('table-active');
  }

  // 載入 EMOdProdMap 列表
  function loadMapList() {
    const { partNum, revision } = getKeys();
    if (!partNum) {
      listTbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">無資料</td></tr>';
      return;
    }

    const url = `/api/CommonTable/ByKeys?table=EMOdProdMap&keyNames=PartNum&keyValues=${encodeURIComponent(partNum)}&keyNames=Revision&keyValues=${encodeURIComponent(revision)}`;
    fetch(url).then(r => r.json()).then(rows => {
      if (!rows || rows.length === 0) {
        listTbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">尚未產生</td></tr>';
        previewImg.style.display = 'none';
        previewMsg.textContent = '請先產生裁版圖';
        previewMsg.style.display = '';
        return;
      }

      // 排序：依 MapKindNo
      rows.sort((a, b) => (a.MapKindNo || a.mapKindNo || 0) - (b.MapKindNo || b.mapKindNo || 0));

      listTbody.innerHTML = '';
      rows.forEach((row, idx) => {
        const kind = row.MapKindNo ?? row.mapKindNo;
        const serial = row.SerialNum ?? row.serialNum ?? (idx + 1);
        const name = mapKindName[kind] || `圖別${kind}`;
        const tr = document.createElement('tr');
        tr.dataset.kind = kind;
        tr.innerHTML = `<td class="px-2">${serial}</td><td class="px-2">${kind}</td><td class="px-2">${name}</td>`;
        tr.addEventListener('click', () => showPreview(kind));
        listTbody.appendChild(tr);
      });

      // 自動選中第一筆
      const firstKind = rows[0].MapKindNo ?? rows[0].mapKindNo;
      showPreview(firstKind);
    }).catch(() => {
      listTbody.innerHTML = '<tr><td colspan="3" class="text-center text-danger py-3">載入失敗</td></tr>';
    });
  }

  // 切到 cutlayout tab 時自動載入列表
  const cutlayoutTabBtn = document.getElementById('tab-cutlayout-tab');
  if (cutlayoutTabBtn) {
    cutlayoutTabBtn.addEventListener('shown.bs.tab', () => {
      loadMapList();
    });
  }

  // 產生裁版圖按鈕
  btn.addEventListener('click', async () => {
    const { partNum, revision } = getKeys();
    if (!partNum) { alert('無法取得料號'); return; }

    btn.disabled = true;
    statusSpan.textContent = '產生中，請稍候…';
    try {
      const resp = await fetch('/api/mappreview/generateMapData', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ PartNum: partNum, Revision: revision })
      });
      const data = await resp.json();
      if (!resp.ok || data.ok === false) {
        statusSpan.textContent = '產生失敗: ' + (data.error || '未知錯誤');
        return;
      }
      statusSpan.textContent = '產生完成';
      loadMapList();
    } catch (e) {
      statusSpan.textContent = '產生失敗: ' + e.message;
    } finally {
      btn.disabled = false;
    }
  });
});
</script>

