@page "/MPH/MPH00052"
@model PcbErpApi.Pages.MPH.MPH00052Model
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.PageTitle;
    ViewData["EnableRowDelete"] = true;
    ViewData["HideSingleGridToolbar"] = true;
    ViewData["HideSingleGridPager"] = true;
    ViewData["DisableSingleGridAutoLoadAllRows"] = true;
    ViewData["EnableSingleGridLookupDropdown"] = true;
    ViewData["SingleGridEnableDatePicker"] = true;
    ViewData["SingleGridForceDateOnlyInput"] = true;
    ViewData["SingleGridEnableSaveInEdit"] = true;
    var toolbarButtonVisibility = ViewData["ToolbarButtonVisibility"] as Dictionary<string, bool>
        ?? new Dictionary<string, bool>(StringComparer.OrdinalIgnoreCase);
    bool IsToolbarVisible(string name) => !toolbarButtonVisibility.TryGetValue(name, out var visible) || visible;
    var showBtnInq = IsToolbarVisible("btnInq");
    var showBtnToExcel = IsToolbarVisible("btnToExcel");
    var showBtnUpdate = IsToolbarVisible("btnUpdate");
    var enableRowDelete = (ViewData["EnableRowDelete"] as bool?)
        ?? (string.Equals(ViewData["EnableRowDelete"]?.ToString(), "true", StringComparison.OrdinalIgnoreCase)
            || string.Equals(ViewData["EnableRowDelete"]?.ToString(), "1", StringComparison.OrdinalIgnoreCase));
    var partLabel = Model.ModeNum == 1 ? "品名" : "料號";
}

<style>
  .mph00052-page {
    padding: 8px 12px 20px 12px;
  }
  .mph00052-toolbar {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 4px;
    padding: 4px;
    border: 1px solid #d8e0ee;
    background: #f7f9ff;
    border-radius: 8px;
  }
  .mph00052-toolbar-group {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .mph00052-toolbar .toolbar-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid #cfd7e6;
    background: #fff;
    color: #1d2b4f;
    border-radius: 8px;
    padding: 4px 8px;
    font-size: 0.85rem;
  }
  .mph00052-toolbar .toolbar-btn-icon {
    width: 30px;
    height: 28px;
    padding: 0;
    justify-content: center;
  }
  .mph00052-toolbar-group.actions {
    margin-right: auto;
  }
  .mph00052-toolbar-group.align-right {
    margin-left: auto;
  }
  .mph00052-toolbar .toolbar-count-box {
    min-width: 74px;
  }
  .mph00052-top-pager {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    flex-wrap: nowrap;
  }
  .mph00052-top-pager .toolbar-btn {
    min-height: 28px;
    padding: 2px 6px;
  }
  .mph00052-top-pager .toolbar-btn-icon {
    width: 28px;
    height: 28px;
    padding: 0;
  }
  .mph00052-top-pager .pager-go {
    width: 54px;
    height: 28px;
    padding: 2px 6px;
    font-size: 0.8rem;
  }
  .mph00052-top-pager .pager-info {
    display: none;
  }
  .mph00052-state {
    margin-top: 6px;
    border: 1px solid #d8e0ee;
    background: #fff;
    border-radius: 8px;
    padding: 6px;
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .mph00052-state .state-cond {
    display: flex;
    gap: 10px 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .mph00052-state .cond-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .mph00052-state .cond-item .input-group{
    width: 198px;
    flex-wrap: nowrap;
  }
  .mph00052-state .cond-item .input-group .form-select{
    width: 56px;
    max-width: 56px;
    flex: 0 0 56px;
  }
  .mph00052-state .cond-label {
    min-width: 48px;
    text-align: right;
    color: #1d3b6b;
    font-size: 0.86rem;
  }
  .mph00052-state .state-radio {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: 0;
  }
  .mph00052-state .state-radio label {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #1d3b6b;
    font-size: 0.86rem;
  }
  .mph00052-state .state-btn {
    height: 28px;
    padding: 0 10px;
    border-radius: 6px;
  }
  .mph00052-state .form-select{
    height: 28px;
    min-height: 28px;
    font-size: 0.86rem;
    padding: 2px 24px 2px 6px;
    border: 1px solid #c7d0e0;
    border-radius: 0;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-image: url('data:image/svg+xml;utf8,<svg width="11" height="11" fill="gray" xmlns="http://www.w3.org/2000/svg"><path d="M2 4.5l3.5 3.5L9 4.5" stroke="gray" stroke-width="2" fill="none" stroke-linecap="round"/></svg>');
    background-repeat: no-repeat;
    background-position: right 8px center;
    background-size: 12px 12px;
  }
  .mph00052-state .form-control{
    height: 28px;
    min-height: 28px;
    font-size: 0.86rem;
    border: 1px solid #c7d0e0;
    border-radius: 0;
  }
  .mph00052-state .filter-lookup-wrap{
    position: relative;
    min-width: 142px;
    width: 142px;
    flex: 0 0 142px;
  }
  .mph00052-state .filter-lookup-name{
    width: 138px;
    min-width: 138px;
    max-width: 138px;
    background: #eef2f8;
    color: #1f2937;
  }
  .mph00052-state .filter-lookup-wrap .form-control{
    padding-right: 22px;
  }
  .mph00052-state .filter-lookup-toggle{
    position:absolute;
    right:2px;
    top:50%;
    transform:translateY(-50%);
    width:18px;
    height:18px;
    border:none;
    background:transparent;
    padding:0;
  }
  .mph00052-state .filter-lookup-toggle::before{
    content:"";
    display:block;
    width:100%;
    height:100%;
    background-repeat:no-repeat;
    background-position:center;
    background-size:12px 12px;
    background-image:url('data:image/svg+xml;utf8,<svg width="11" height="11" fill="gray" xmlns="http://www.w3.org/2000/svg"><path d="M2 4.5l3.5 3.5L9 4.5" stroke="gray" stroke-width="2" fill="none" stroke-linecap="round"/></svg>');
  }
  .mph00052-filter-dropdown-list{
    position:fixed;
    z-index:2000;
    background:#fff;
    border:1px solid #b6c2d9;
    border-radius:6px;
    box-shadow:0 8px 20px rgba(30,41,59,0.18);
    overflow:auto;
  }
  .mph00052-filter-dropdown-item{
    display:block;
    width:100%;
    border:0;
    margin:0;
    background:transparent;
    text-align:left;
    padding:3px 10px;
    font-size:0.86rem;
    line-height:1.4;
    min-height:24px;
    cursor:pointer;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }
  .mph00052-filter-dropdown-item .lookup-code{
    display:inline-block;
    min-width:96px;
    margin-right:10px;
    color:#0f3a7a;
    font-weight:600;
  }
  .mph00052-filter-dropdown-item .lookup-name{
    color:#1f2937;
  }
  .mph00052-filter-dropdown-item:hover,
  .mph00052-filter-dropdown-item:focus{ background:#e2e8f0; outline:none; }
  .mph00052-filter-dropdown-item.is-selected{ background:#dbeafe; }
  .mph00052-page #mainGrid .cell-edit.sg-lookup-input{
    padding-right: 22px !important;
    background-image: url('data:image/svg+xml;utf8,<svg width="11" height="11" fill="gray" xmlns="http://www.w3.org/2000/svg"><path d="M2 4.5l3.5 3.5L9 4.5" stroke="gray" stroke-width="2" fill="none" stroke-linecap="round"/></svg>');
    background-repeat: no-repeat !important;
    background-position: right 6px center !important;
    background-size: 12px 12px !important;
  }
  .import-modal-btn {
    background: #fff;
    color: #000;
    border: 1px solid #000;
  }
  .import-modal-btn:hover,
  .import-modal-btn:focus {
    background: #fff;
    color: #000;
    border-color: #000;
  }
  .mph00052-page .table-wrapper {
    height: auto;
  }
  .mph00052-page .table-fix-wrapper {
    overflow-y: hidden;
    overflow-x: auto;
  }
  @@media (max-width: 960px) {
    .mph00052-state .state-radio {
      width: 100%;
      margin-left: 0;
      justify-content: flex-start;
    }
  }
</style>

<div class="mph00052-page">
    <div class="mph00052-toolbar">
        <div class="mph00052-toolbar-group" role="group" aria-label="row-nav-and-actions">
            <button id="sgFirst" type="button" class="btn toolbar-btn toolbar-btn-icon" title="First" aria-label="First"><i class="bi bi-chevron-bar-left toolbar-icon"></i></button>
            <button id="sgPrev" type="button" class="btn toolbar-btn toolbar-btn-icon" title="Prev" aria-label="Prev"><i class="bi bi-chevron-left toolbar-icon"></i></button>
            <button id="sgNext" type="button" class="btn toolbar-btn toolbar-btn-icon" title="Next" aria-label="Next"><i class="bi bi-chevron-right toolbar-icon"></i></button>
            <button id="sgLast" type="button" class="btn toolbar-btn toolbar-btn-icon" title="Last" aria-label="Last"><i class="bi bi-chevron-bar-right toolbar-icon"></i></button>
            <button id="sgAdd" type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-add" title="Add" aria-label="Add" disabled><span class="toolbar-icon">+</span></button>
            <button id="sgDelete" type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-del" title="Delete" aria-label="Delete" disabled @(enableRowDelete ? "" : "data-lock='1'")><span class="toolbar-icon">-</span></button>
            <button id="sgSave" type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-add toolbar-btn-check" title="Save" aria-label="Save" disabled><span class="toolbar-icon">&#10003;</span></button>
            <button id="sgCancel" type="button" class="btn toolbar-btn toolbar-btn-icon toolbar-btn-cancel toolbar-btn-check" title="Cancel" aria-label="Cancel" disabled><span class="toolbar-icon">&times;</span></button>
        </div>

        <div class="mph00052-toolbar-group count-box">
            <div id="singleGridCountBox" class="toolbar-count-box mode-view">
                <div id="singleGridMode" class="count-line">瀏覽模式</div>
                <div id="singleGridCount" class="count-line">0 / 0</div>
            </div>
        </div>

        <div class="mph00052-toolbar-group actions">
            <button id="btnOpenQuery" type="button" class="btn toolbar-btn @(showBtnInq ? "" : "d-none")" data-toolbar-btn="btnInq">
                <i class="bi bi-search"></i>查詢</button>
            <button id="btnExportExcel" type="button" class="btn toolbar-btn @(showBtnToExcel ? "" : "d-none")" data-toolbar-btn="btnToExcel">
                <i class="bi bi-file-earmark-excel"></i>Excel
            </button>
            <button id="btnImportExcel" type="button" class="btn toolbar-btn">
                <i class="bi bi-file-earmark-arrow-up"></i>匯入</button>
            <button id="btnEditToggle" type="button" class="btn toolbar-btn @(showBtnUpdate ? "" : "d-none")" data-toolbar-btn="btnUpdate">
                <i class="bi bi-pencil-square"></i>修改</button>
            <button id="btnUpdatLog" type="button" class="btn toolbar-btn" title="History" aria-label="History">
                <i class="bi bi-clock-history"></i>歷史</button>
        </div>

        <div class="mph00052-toolbar-group align-right">
            <div class="mph00052-top-pager">
                <button id="pagerFirst" type="button" class="btn toolbar-btn toolbar-btn-icon" title="第一頁" aria-label="第一頁"><i class="bi bi-chevron-bar-left"></i></button>
                <button id="pagerPrev" type="button" class="btn toolbar-btn toolbar-btn-icon" title="上一頁" aria-label="上一頁"><i class="bi bi-chevron-left"></i></button>
                <button id="pagerNext" type="button" class="btn toolbar-btn toolbar-btn-icon" title="下一頁" aria-label="下一頁"><i class="bi bi-chevron-right"></i></button>
                <button id="pagerLast" type="button" class="btn toolbar-btn toolbar-btn-icon" title="最後頁" aria-label="最後頁"><i class="bi bi-chevron-bar-right"></i></button>
                <input id="pagerGoInput" type="number" min="1" value="@Model.PageNumber" class="form-control form-control-sm pager-go" />
                <button id="pagerGoBtn" type="button" class="btn toolbar-btn">Go</button>
                <span id="pagerInfo" class="pager-info"></span>
            </div>
        </div>
    </div>

    <form id="filterForm" method="get" class="mph00052-state">
        <div class="state-cond">
            <div class="cond-item">
                <label class="cond-label">廠商</label>
                <div class="input-group input-group-sm">
                    <select class="form-select" name="CustomerOp" disabled="@(Model.ModeNum == 1)">
                        <option value="=" selected="@((Model.CustomerOp ?? string.Empty).Equals("=", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">=</option>
                        <option value="like" selected="@((Model.CustomerOp ?? string.Empty).Equals("like", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">like</option>
                    </select>
                    <div class="filter-lookup-wrap">
                        <input type="text"
                               class="form-control filter-lookup-input"
                               name="Customer"
                               value="@Model.Customer"
                               data-lookup-source="customerList"
                               placeholder="SupplierId"
                               autocomplete="off"
                               disabled="@(Model.ModeNum == 1)" />
                        <button type="button" class="filter-lookup-toggle" data-lookup-toggle="Customer" tabindex="-1"></button>
                    </div>
                </div>
                <input type="text" class="form-control form-control-sm filter-lookup-name" data-lookup-name-for="Customer" readonly tabindex="-1" />
                <datalist id="customerList">
                    @foreach (var c in Model.Customers)
                    {
                        <option value="@c.Value">@c.Label</option>
                    }
                </datalist>
            </div>
            <div class="cond-item">
                <label class="cond-label">@partLabel</label>
                <div class="input-group input-group-sm">
                    <select class="form-select" name="PartOp">
                        <option value="=" selected="@((Model.PartOp ?? string.Empty).Equals("=", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">=</option>
                        <option value="like" selected="@((Model.PartOp ?? string.Empty).Equals("like", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">like</option>
                    </select>
                    <div class="filter-lookup-wrap">
                        <input type="text"
                               class="form-control filter-lookup-input"
                               name="Part"
                               value="@Model.Part"
                               data-lookup-source="partList"
                               placeholder="@partLabel"
                               autocomplete="off" />
                        <button type="button" class="filter-lookup-toggle" data-lookup-toggle="Part" tabindex="-1"></button>
                    </div>
                </div>
                <input type="text" class="form-control form-control-sm filter-lookup-name" data-lookup-name-for="Part" readonly tabindex="-1" />
                <datalist id="partList">
                    @foreach (var p in Model.Parts)
                    {
                        <option value="@p.Value">@p.Label</option>
                    }
                </datalist>
            </div>
        </div>

        <button type="submit" class="btn btn-primary btn-sm state-btn">資料重取</button>

        <div class="state-radio" role="group" aria-label="Effect filter">
            <label>
                <input type="radio" name="Effect" id="effect-valid" value="valid" checked="@(Model.Effect != "invalid" && Model.Effect != "all" ? "checked" : null)">生效</label>
            <label>
                <input type="radio" name="Effect" id="effect-invalid" value="invalid" checked="@(Model.Effect == "invalid" ? "checked" : null)">失效</label>
            <label>
                <input type="radio" name="Effect" id="effect-all" value="all" checked="@(Model.Effect == "all" ? "checked" : null)">不限</label>
        </div>

        <input type="hidden" name="pageIndex" value="@Model.PageNumber" />
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <input type="hidden" name="doQuery" value="1" />
    </form>

    <input type="file" id="mphImportFile" accept=".xlsx,.xls" class="d-none">

    <div class="modal fade" id="mph-import-modal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">匯出 / 匯入</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body d-grid gap-2">
            <button type="button" class="btn import-modal-btn" id="btnMphImportExportCurrent">匯出Data(以目前格式)</button>
            <button type="button" class="btn import-modal-btn" id="btnMphImportExportFast">匯出Data(快速)</button>
            <button type="button" class="btn import-modal-btn" id="btnMphImportEditFormat">編修格式(匯入專用)</button>
            <button type="button" class="btn import-modal-btn" id="btnMphImportExportFormat">匯出格式(FOR輸入轉檔資料)</button>
            <button type="button" class="btn import-modal-btn" id="btnMphImportExec">匯入</button>
            <button type="button" class="btn import-modal-btn" data-bs-dismiss="modal">關閉</button>
          </div>
        </div>
      </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.LoadError))
    {
        <div class="alert alert-warning mt-2">Load failed: @Model.LoadError</div>
    }
    else
    {
        @await Html.PartialAsync("~/Pages/Shared/_TableSingleGrid.cshtml", new
        {
            TableName = Model.TableName,
            Items = Model.Items,
            TableFields = Model.TableFields,
            QueryFields = Model.QueryFields,
            PageNumber = Model.PageNumber,
            PageSize = Model.PageSize,
            TotalCount = Model.TotalCount
        }, ViewData)
    }
</div>

<script>
  window._singleItemId = "@(Model.ItemId ?? "MPH00053")";
  window._dictTableName = "@(ViewData["DictTableName"] ?? Model.DictTableName ?? Model.TableName)";
  window._singleGridDateFormat = "date";
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    let activeList = null;
    let activeInput = null;
    const normalize = (v) => String(v || "").trim().toLowerCase();
    const closeList = () => {
      if (activeList) activeList.remove();
      activeList = null;
      activeInput = null;
      document.removeEventListener("mousedown", onDocDown, true);
      document.removeEventListener("keydown", onKeyDown, true);
      window.removeEventListener("resize", closeList, true);
    };
    const onDocDown = (ev) => {
      if (activeList && activeList.contains(ev.target)) return;
      if (activeInput && activeInput.contains(ev.target)) return;
      closeList();
    };
    const onKeyDown = (ev) => {
      if (ev.key === "Escape") closeList();
    };
    const openList = (input, showAll) => {
      if (!input || input.disabled || input.readOnly) return;
      const sourceId = input.dataset.lookupSource;
      const dl = sourceId ? document.getElementById(sourceId) : null;
      if (!dl) return;
      closeList();
      const list = document.createElement("div");
      list.className = "mph00052-filter-dropdown-list";
      const current = normalize(input.value);
      const filter = showAll ? "" : normalize(input.value);
      const addItem = (key, label) => {
        const keyText = String(key || "").trim();
        const labelText = String(label || "").trim();
        const item = document.createElement("button");
        item.type = "button";
        item.className = "mph00052-filter-dropdown-item";
        item.dataset.key = keyText;
        item.dataset.label = labelText;
        if (keyText) {
          const codeSpan = document.createElement("span");
          codeSpan.className = "lookup-code";
          codeSpan.textContent = keyText;
          const nameSpan = document.createElement("span");
          nameSpan.className = "lookup-name";
          nameSpan.textContent = labelText;
          item.appendChild(codeSpan);
          item.appendChild(nameSpan);
        } else {
          item.textContent = "(清空)";
        }
        if (normalize(keyText) === current) item.classList.add("is-selected");
        list.appendChild(item);
      };
      addItem("", "(清空)");
      Array.from(dl.options || []).forEach(o => {
        const key = String(o.value || "").trim();
        const label = String((o.label || o.textContent || "")).trim();
        if (!key) return;
        const display = label ? `${key} ${label}` : key;
        if (filter) {
          const hit = normalize(key).includes(filter) || normalize(label).includes(filter) || normalize(display).includes(filter);
          if (!hit) return;
        }
        addItem(key, label);
      });
      const pick = (ev) => {
        const item = ev.target.closest(".mph00052-filter-dropdown-item");
        if (!item) return;
        ev.preventDefault();
        ev.stopPropagation();
        input.value = item.dataset.key || "";
        setLookupName(input, item.dataset.label || "");
        input.dispatchEvent(new Event("input", { bubbles: true }));
        input.dispatchEvent(new Event("change", { bubbles: true }));
        closeList();
      };
      list.addEventListener("mousedown", pick);
      list.addEventListener("click", pick);
      document.body.appendChild(list);
      const rect = input.getBoundingClientRect();
      const spaceBelow = window.innerHeight - rect.bottom;
      const maxHeight = Math.max(200, Math.min(380, spaceBelow - 8));
      const placeBelow = spaceBelow >= 140;
      list.style.left = `${Math.max(6, rect.left)}px`;
      list.style.top = placeBelow ? `${rect.bottom}px` : `${Math.max(6, rect.top - maxHeight)}px`;
      list.style.minWidth = `${Math.max(320, rect.width + 120)}px`;
      list.style.maxHeight = `${maxHeight}px`;
      activeList = list;
      activeInput = input;
      document.addEventListener("mousedown", onDocDown, true);
      document.addEventListener("keydown", onKeyDown, true);
      window.addEventListener("resize", closeList, true);
    };

    const form = document.getElementById("filterForm");
    if (!form) return;

    const findLookupOptionLabel = (input) => {
      if (!input) return "";
      const sourceId = input.dataset.lookupSource;
      const dl = sourceId ? document.getElementById(sourceId) : null;
      if (!dl) return "";
      const raw = String(input.value || "").trim();
      if (!raw) return "";
      const code = raw.split(/\s+/)[0];
      const hit = Array.from(dl.options || []).find(o => String(o.value || "").trim().toLowerCase() === code.toLowerCase());
      return hit ? String(hit.label || hit.textContent || "").trim() : "";
    };

    const setLookupName = (input, label) => {
      if (!input) return;
      const nameInput = form.querySelector(`.filter-lookup-name[data-lookup-name-for="${input.name}"]`);
      if (!(nameInput instanceof HTMLInputElement)) return;
      nameInput.value = String(label || "").trim();
    };

    const syncLookupName = (input) => {
      if (!input) return;
      setLookupName(input, findLookupOptionLabel(input));
    };
    const radios = form.querySelectorAll('input[name="Effect"]');
    radios.forEach(radio => {
      radio.addEventListener("change", () => {
        const pageIndex = form.querySelector('input[name="pageIndex"]');
        if (pageIndex) pageIndex.value = "1";
        form.submit();
      });
    });

    form.querySelectorAll(".filter-lookup-input").forEach(input => {
      input.addEventListener("focus", () => openList(input, false));
      input.addEventListener("input", () => { syncLookupName(input); openList(input, false); });
      input.addEventListener("keydown", (ev) => {
        if (ev.key === "ArrowDown" || ev.key === "F4") {
          ev.preventDefault();
          openList(input, true);
        }
      });
      input.addEventListener("change", () => syncLookupName(input));
      syncLookupName(input);
    });

    form.querySelectorAll(".filter-lookup-toggle").forEach(btn => {
      btn.addEventListener("click", () => {
        const targetName = btn.dataset.lookupToggle;
        const input = targetName ? form.querySelector(`.filter-lookup-input[name="${targetName}"]`) : null;
        if (!input) return;
        openList(input, true);
        input.focus();
      });
    });
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const importBtn = document.getElementById("btnImportExcel");
    const importInput = document.getElementById("mphImportFile");
    const importModalEl = document.getElementById("mph-import-modal");
    const btnExportCurrent = document.getElementById("btnMphImportExportCurrent");
    const btnExportFast = document.getElementById("btnMphImportExportFast");
    const btnEditFormat = document.getElementById("btnMphImportEditFormat");
    const btnExportFormat = document.getElementById("btnMphImportExportFormat");
    const btnImportExec = document.getElementById("btnMphImportExec");
    const itemId = '@(Model.ItemId ?? "MPH00052")';

    const openImportModal = () => {
      if (!importModalEl || !window.bootstrap) return;
      const modal = bootstrap.Modal.getOrCreateInstance(importModalEl);
      modal.show();
    };

    const exportData = (fast) => {
      const url = new URL(window.location.href);
      url.searchParams.set("handler", "Export");
      if (fast) {
        url.searchParams.set("pageIndex", "1");
        url.searchParams.set("pageSize", "100000");
      }
      window.location.href = url.toString();
    };

    const uploadFile = async (file) => {
      if (!file) return;
      const formData = new FormData();
      formData.append("file", file);
      formData.append("itemId", itemId);

      try {
        const res = await fetch("/api/ImportXls/PriceTable", {
          method: "POST",
          body: formData
        });
        const raw = await res.text();
        let data;
        try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
        if (!res.ok || data.ok === false) {
          throw new Error(data.error || `HTTP ${res.status}`);
        }
        Swal.fire({ icon: "success", title: `匯入完成 (${data.inserted ?? 0}筆)` });
        location.reload();
      } catch (err) {
        Swal.fire({ icon: "error", title: `匯入失敗`, text: err?.message || err });
      } finally {
        if (importInput) importInput.value = "";
      }
    };

    importBtn?.addEventListener("click", () => openImportModal());
    btnExportCurrent?.addEventListener("click", () => exportData(false));
    btnExportFast?.addEventListener("click", () => exportData(true));
    btnEditFormat?.addEventListener("click", () => {
      const baseTable = (window._dictTableName || "").trim();
      if (!baseTable) {
        Swal.fire({ icon: "info", title: "尚未提供編修畫面", text: "請提供匯入格式編修的目標頁面或 ItemId。" });
        return;
      }

      const importDictTable = `${baseTable}_4IMP`;
      if (typeof window.showDictModal === "function") {
        window.showDictModal("fieldDictModal", importDictTable);
      } else if (typeof window.initFieldDictModal === "function") {
        window.initFieldDictModal(importDictTable, "fieldDictModal");
        const el = document.getElementById("fieldDictModal");
        if (el && window.bootstrap) {
          bootstrap.Modal.getOrCreateInstance(el).show();
        }
      } else {
        Swal.fire({ icon: "info", title: "尚未提供編修畫面", text: "請提供匯入格式編修的目標頁面或 ItemId。" });
      }
    });

    btnExportFormat?.addEventListener("click", () => {
      const url = `/api/ImportXls/PriceTable/Template?itemId=${encodeURIComponent(itemId)}`;
      window.location.href = url;
    });
    btnImportExec?.addEventListener("click", () => importInput?.click());
    importInput?.addEventListener("change", () => uploadFile(importInput.files?.[0]));

    document.addEventListener("keydown", (e) => {
      if (e.key === "F12") {
        e.preventDefault();
        openImportModal();
      }
    });
  });
</script>

@await Html.PartialAsync("_FieldDictModal", Model.FieldDictList, ViewData)
<script src="~/js/fieldDictModal.js" asp-append-version="true"></script>
