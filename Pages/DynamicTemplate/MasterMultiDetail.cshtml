      };
      try {
        const res = await fetch("/api/PaperSearch/Search", withJwtHeaders({
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        }));
        const raw = await res.text();
        let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
        if (!res.ok || !data.ok) throw new Error(data.error || `HTTP ${res.status}`);
        const available = Array.isArray(data.data) ? data.data : [];
        const selected = Array.isArray(data.selected) ? data.selected : [];
        state.available = available.map((r, i) => ({ idx: i, data: r }));
        state.selected = selected.map((r, i) => ({ idx: i, data: r }));
        state.selectedAvailIdx.clear();
        state.selectedSelIdx.clear();
        renderRows();
      } finally {
        setFetchLoading(false);
      }
    };

    const confirmInsert = async () => {
      psCollectInputs();
      const rows = readSelectedRows();
      if (!rows.length) {
        alert("尚未選擇任何項目");
        return;
      }
      const payload = {
        itemId: state.itemId,
        buttonName: state.buttonName,
        paperNum: state.paperNum,
        replace: !!ckReplace?.checked,
        inputs: state.inputs,
        rows
      };
      const res = await fetch("/api/PaperSearch/Confirm", withJwtHeaders({
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      }));
      const raw = await res.text();
      let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
      if (!res.ok || !data.ok) {
        alert(`匯入失敗: ${data.error || `HTTP ${res.status}`}`);
        return;
      }
      if (window.bootstrap && modalEl) {
        try { bootstrap.Modal.getOrCreateInstance(modalEl).hide(); } catch {}
      }
      localStorage.setItem("afterSave", "1");
      location.reload();
    };

    const open = async (ctx, meta) => {
      if (!modalEl) return;
      state.itemId = ctx.itemId || "";
      state.buttonName = ctx.buttonName || "";
      state.paperNum = ctx.paperNum || "";
      state.allowSelCount = toNumber(meta.allowSelCount, 0);
      state.replaceExists = toNumber(meta.replaceExists, 0);
      state.editableFields = new Set();

      const configUrl = `/api/PaperSearch/Config?itemId=${encodeURIComponent(state.itemId)}&buttonName=${encodeURIComponent(state.buttonName)}`;
      const res = await fetch(configUrl, withJwtHeaders());
      if (!res.ok) {
        alert(await res.text());
        return;
      }
      const cfg = await res.json();
      state.searchParams = cfg.searchParams || cfg.SearchParams || [];
      state.insertKeys = cfg.insertKeys || cfg.InsertKeys || [];

      state.editableFields = new Set(
        (state.insertKeys || [])
          .filter(k => Number(k.PositionType ?? k.positionType) === 0)
          .map(k => normalizeKey(k.KeyFieldName || k.keyFieldName))
          .filter(k => k)
      );

      const caption = meta.dialogCaption || cfg.dialogCaption || cfg.DialogCaption || ctx.caption || "查詢並挑選";
      if (titleEl) titleEl.textContent = caption;
      if (ckReplace) ckReplace.checked = false;
      if (state.replaceExists) ckReplace?.closest(".ps-replace")?.classList.remove("d-none");
      else ckReplace?.closest(".ps-replace")?.classList.add("d-none");

      clearTable(availTable);
      clearTable(selTable);
      await loadDict(meta.multiSelectDd || cfg.multiSelectDd || cfg.MultiSelectDd || "");
      buildHeads();
      await buildFormPaperSearch(state.itemId, state.buttonName);
      state.available = [];
      state.selected = [];
      state.selectedAvailIdx.clear();
      state.selectedSelIdx.clear();
      renderRows();

      if (window.bootstrap) {
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
      }
    };

    const toggleRowSelection = (tr, set) => {
      const idx = Number(tr.dataset.idx);
      if (!Number.isFinite(idx)) return;
      if (set.has(idx)) set.delete(idx);
      else set.add(idx);
      tr.classList.toggle("ps-row-selected");
    };

    availTable?.addEventListener("click", (ev) => {
      if (ev.detail > 1) return;
      if (ev.target?.closest("input, select, textarea, button, a")) return;
      const tr = ev.target?.closest("tbody tr");
      if (!tr) return;
      toggleRowSelection(tr, state.selectedAvailIdx);
    });

    selTable?.addEventListener("click", (ev) => {
      if (ev.detail > 1) return;
      if (ev.target?.closest("input, select, textarea, button, a")) return;
      const tr = ev.target?.closest("tbody tr");
      if (!tr) return;
      toggleRowSelection(tr, state.selectedSelIdx);
    });

    availTable?.addEventListener("dblclick", (ev) => {
      if (ev.target?.closest("input, select, textarea, button, a")) return;
      const tr = ev.target?.closest("tbody tr");
      if (!tr) return;
      const idx = Number(tr.dataset.idx);
      if (!Number.isFinite(idx)) return;
      if (!state.selectedAvailIdx.has(idx)) {
        state.selectedAvailIdx.add(idx);
        tr.classList.add("ps-row-selected");
      }
      moveRight();
    });

    selTable?.addEventListener("dblclick", (ev) => {
      if (ev.target?.closest("input, select, textarea, button, a")) return;
      const tr = ev.target?.closest("tbody tr");
      if (!tr) return;
      const idx = Number(tr.dataset.idx);
      if (!Number.isFinite(idx)) return;
      if (!state.selectedSelIdx.has(idx)) {
        state.selectedSelIdx.add(idx);
        tr.classList.add("ps-row-selected");
      }
      moveLeft();
    });

    btnRight?.addEventListener("click", moveRight);
    btnLeft?.addEventListener("click", moveLeft);
    btnRightAll?.addEventListener("click", moveAllRight);
    btnLeftAll?.addEventListener("click", moveAllLeft);
    btnConfirm?.addEventListener("click", (e) => { e.preventDefault(); confirmInsert(); });
    modalEl?.addEventListener("click", (ev) => {
      const btn = ev.target.closest(".ps-fetch");
      if (!btn) return;
      ev.preventDefault();
      fetchSearch().catch(err => alert(`查詢失敗: ${err?.message || err}`));
    });

    return { open };
  })();

  // ============================================================
  //  FormulaDesign — 公式設計編輯器
  // ============================================================
  const formulaDesign = (() => {
    const modalEl = document.getElementById('formulaDesignModal');
    if (!modalEl) return null;

    const elFactorId    = document.getElementById('fdFactorId');
    const elFactorType  = document.getElementById('fdFactorType');
    const elFactorTypeD = document.getElementById('fdFactorTypeDisplay');
    const elDataType    = document.getElementById('fdDataType');
    const elDataTypeD   = document.getElementById('fdDataTypeDisplay');
    const elProcCode    = document.getElementById('fdProcCode');
    const elProcCodeD   = document.getElementById('fdProcCodeDisplay');
    const elProcCount   = document.getElementById('fdProcCount');
    const elProcCountD  = document.getElementById('fdProcCountDisplay');
    const elFormula     = document.getElementById('fdFormulaText');
    const elTree        = document.getElementById('fdTreeContainer');
    const elOps         = document.getElementById('fdOperators');
    const btnSave       = document.getElementById('fdBtnSave');
    const btnReset      = document.getElementById('fdBtnReset');
    const btnTestCal    = document.getElementById('fdBtnTestCal');

    const operators = ['+','-','*','/','%','ABS()','ROUND(,)','ISNULL(,)',
                       'CEILING()','FLOOR()','POWER(,)','MAX()','MIN()','AVG()','SUM()','COUNT()'];

    let _sysId = '', _factorId = '', _factorType = 0, _fixedFactorType = '', _originalFormula = '';

    // Lookup data cache: { key: [{value, text}] }
    const _lkData = {};

    // --- 填充 select options ---
    const fillSelect = (selectEl, items) => {
      selectEl.innerHTML = '';
      const blank = document.createElement('option');
      blank.value = '';
      blank.textContent = '';
      selectEl.appendChild(blank);
      (items || []).forEach(it => {
        const opt = document.createElement('option');
        opt.value = it.value;
        opt.textContent = it.value; // 收合時只顯示代碼
        opt.dataset.full = it.text ? `${it.value} ${it.text}` : it.value;
        selectEl.appendChild(opt);
      });
    };

    // --- select 展開時顯示完整文字，收合時只顯示代碼 ---
    const bindSelectDisplay = (selectEl, displayEl, dataKey) => {
      // 展開前：所有 option 切換成完整文字
      const showFull = () => {
        selectEl.querySelectorAll('option').forEach(o => {
          if (o.dataset.full) o.textContent = o.dataset.full;
        });
      };
      // 收合後：選中的 option 改回只顯示代碼，同步 display name
      const showCode = () => {
        selectEl.querySelectorAll('option').forEach(o => {
          if (o.value) o.textContent = o.value;
        });
        const v = selectEl.value;
        const items = _lkData[dataKey] || [];
        const found = items.find(it => String(it.value).trim() === String(v).trim());
        displayEl.textContent = found ? found.text : '';
      };
      selectEl.addEventListener('focus', showFull);
      selectEl.addEventListener('mousedown', showFull);
      selectEl.addEventListener('change', showCode);
      selectEl.addEventListener('blur', showCode);
    };

    // --- 設定 select 欄位值 ---
    const setLkValue = (selectEl, displayEl, value, dataKey) => {
      const v = String(value ?? '').trim();
      selectEl.value = v;
      // 確保收合狀態只顯示代碼
      selectEl.querySelectorAll('option').forEach(o => {
        if (o.value) o.textContent = o.value;
      });
      const items = _lkData[dataKey] || [];
      const found = items.find(it => String(it.value).trim() === v);
      displayEl.textContent = found ? found.text : '';
    };

    // --- 載入下拉選項 ---
    const loadLookups = async () => {
      if (Object.keys(_lkData).length > 0) return;
      const [ftRes, dtRes, pcRes, pctRes] = await Promise.all([
        fetch('/api/SQUdFormulaDesign/FactorTypes').then(r => r.json()),
        fetch('/api/SQUdFormulaDesign/DataTypes').then(r => r.json()),
        fetch('/api/SQUdFormulaDesign/ProcCodes').then(r => r.json()),
        fetch('/api/SQUdFormulaDesign/ProcCounts').then(r => r.json())
      ]);
      _lkData.factorType = ftRes;
      _lkData.dataType = dtRes;
      _lkData.procCode = pcRes;
      _lkData.procCount = pctRes;
      // 填充所有 select
      fillSelect(elFactorType, ftRes);
      fillSelect(elDataType, dtRes);
      fillSelect(elProcCode, pcRes);
      fillSelect(elProcCount, pctRes);
    };

    // --- 建構運算元列表 ---
    const buildOperators = () => {
      elOps.innerHTML = '';
      operators.forEach(op => {
        const div = document.createElement('div');
        div.className = 'fd-op-item';
        div.textContent = op;
        div.addEventListener('dblclick', () => insertAtCursor(op));
        elOps.appendChild(div);
      });
    };

    // --- 在游標位置插入文字 ---
    const insertAtCursor = (text) => {
      const ta = elFormula;
      const start = ta.selectionStart;
      const before = ta.value.substring(0, start);
      const after = ta.value.substring(ta.selectionEnd);
      ta.value = before + text + after;
      ta.focus();
      ta.selectionStart = ta.selectionEnd = start + text.length;
    };

    // --- 建構樹狀結構 ---
    const buildTree = (data) => {
      elTree.innerHTML = '';
      const parents = data.filter(d => d.levelNo === 0);
      const childMap = {};
      data.filter(d => d.levelNo !== 0).forEach(d => {
        const key = (d.superId || '').trim();
        if (!childMap[key]) childMap[key] = [];
        childMap[key].push(d);
      });

      parents.forEach(p => {
        const node = document.createElement('div');
        node.className = 'fd-tree-node';
        const parentName = p.itemName || p.itemId;

        const header = document.createElement('div');
        header.className = 'fd-tree-parent';
        const toggle = document.createElement('span');
        toggle.className = 'fd-tree-toggle collapsed';
        toggle.textContent = '▼';
        const label = document.createElement('span');
        label.textContent = parentName;
        header.appendChild(toggle);
        header.appendChild(label);

        const children = document.createElement('div');
        children.className = 'fd-tree-children collapsed';

        const kids = childMap[p.itemId] || [];
        kids.forEach(c => {
          const childName = c.itemName || c.itemId;
          const leaf = document.createElement('div');
          leaf.className = 'fd-tree-leaf';
          // 葉節點顯示「父.子」格式
          leaf.textContent = `${parentName}.${childName}`;
          leaf.dataset.parentText = parentName;
          leaf.dataset.childText = childName;
          leaf.addEventListener('dblclick', () => {
            // FactorType 0 或 5: {Parent.Child}，否則: {Child}
            const tag = (_factorType === 0 || _factorType === 5)
              ? `{${parentName}.${childName}}`
              : `{${childName}}`;
            insertAtCursor(tag);
          });
          children.appendChild(leaf);
        });

        header.addEventListener('click', () => {
          const collapsed = children.classList.toggle('collapsed');
          toggle.classList.toggle('collapsed', collapsed);
        });

        node.appendChild(header);
        node.appendChild(children);
        elTree.appendChild(node);
      });
    };

    // --- 載入因素資料 ---
    const loadFactor = async () => {
      const res = await fetch(`/api/SQUdFormulaDesign/Factor?sysId=${encodeURIComponent(_sysId)}&factorId=${encodeURIComponent(_factorId)}`);
      const data = await res.json();
      if (!data.ok || !data.found) {
        elFormula.value = '';
        return;
      }
      elFormula.value = (data.formulaText || '').trim();
      _originalFormula = elFormula.value;
      _factorType = parseInt(data.factorType) || 0;
      // 類別：優先用 _fixedFactorType（來自 master row），若為 0 或空則用 API 回傳的 factorType
      const ftVal = (_fixedFactorType && _fixedFactorType !== '0') ? _fixedFactorType : String(_factorType);
      setLkValue(elFactorType, elFactorTypeD, ftVal, 'factorType');
      setLkValue(elDataType, elDataTypeD, data.dataType ?? '', 'dataType');
      setLkValue(elProcCode, elProcCodeD, data.procCode ?? '', 'procCode');
      setLkValue(elProcCount, elProcCountD, data.procCount ?? '', 'procCount');
    };

    // --- 載入樹狀資料 ---
    const loadTree = async () => {
      const ft = parseInt(elFactorType.value) || 0;
      const powerType = (ft === 0) ? 0 : ft;
      const url = `/api/SQUdFormulaDesign/TreeData?powerType=${powerType}&systemId=${encodeURIComponent(_sysId)}`;
      const data = await fetch(url).then(r => r.json());
      buildTree(data);
    };

    // --- 儲存 ---
    const save = async () => {
      const userId = (document.querySelector('[data-user-name]')?.dataset?.userName
                     || document.querySelector('.navbar .dropdown-toggle')?.textContent?.trim()
                     || '').replace(/\s+/g, '');
      const body = {
        sysId: _sysId,
        factorId: _factorId,
        formulaText: elFormula.value,
        factorType: elFactorType.value,
        dataType: elDataType.value,
        procCode: elProcCode.value,
        procCount: elProcCount.value,
        userId: userId
      };
      try {
        const res = await fetch('/api/SQUdFormulaDesign/Save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.ok) {
          _originalFormula = elFormula.value;
          if (window.Swal?.fire) {
            await Swal.fire({ icon: 'success', title: '儲存完成', timer: 1200, showConfirmButton: false });
          } else {
            alert('儲存完成');
          }
        } else {
          alert(`儲存失敗: ${data.error || '未知錯誤'}`);
        }
      } catch (err) {
        alert(`儲存失敗: ${err.message}`);
      }
    };

    // --- 放棄 (重新載入) ---
    const reset = async () => {
      await loadFactor();
    };

    // --- 綁定事件 ---
    btnSave?.addEventListener('click', save);
    btnReset?.addEventListener('click', reset);
    buildOperators();

    // 綁定 select 展開/收合顯示切換
    bindSelectDisplay(elFactorType, elFactorTypeD, 'factorType');
    bindSelectDisplay(elDataType, elDataTypeD, 'dataType');
    bindSelectDisplay(elProcCode, elProcCodeD, 'procCode');
    bindSelectDisplay(elProcCount, elProcCountD, 'procCount');

    // 類別變更時重新載入樹狀資料
    elFactorType.addEventListener('change', () => { _factorType = parseInt(elFactorType.value) || 0; loadTree(); });

    // --- 關閉前確認 ---
    const isChanged = () => {
      return elFormula.value.trim() !== _originalFormula.trim();
    };
    modalEl.addEventListener('hide.bs.modal', (e) => {
      if (isChanged()) {
        if (!confirm('資料有變更，確定放棄？')) {
          e.preventDefault();
        }
      }
    });

    // ============================================================
    //  試算功能
    // ============================================================
    const tcModalEl   = document.getElementById('testCalcModal');
    const tcFactorId  = document.getElementById('tcFactorId');
    const tcPartNum   = document.getElementById('tcPartNum');
    const tcRevision  = document.getElementById('tcRevision');
    const tcLayerId   = document.getElementById('tcLayerId');
    const tcLayerIdD  = document.getElementById('tcLayerIdDisplay');
    const tcResult    = document.getElementById('tcResult');
    const tcTreeEl    = document.getElementById('tcTreeContainer');
    const tcBtnExec   = document.getElementById('tcBtnExecute');

    let _tcLayerData = []; // 層別資料快取

    // 層別：料號/版本輸入後動態載入（select + name span）
    const loadProdLayers = async () => {
      const pn = (tcPartNum?.value || '').trim();
      const rev = (tcRevision?.value || '').trim();
      _tcLayerData = [];
      tcLayerId.innerHTML = '<option value="">--</option>';
      tcLayerIdD.textContent = '';
      if (!pn) return;
      try {
        const res = await fetch(`/api/SQUdFormulaDesign/ProdLayers?partNum=${encodeURIComponent(pn)}&revision=${encodeURIComponent(rev)}`);
        const list = await res.json();
        _tcLayerData = list || [];
        _tcLayerData.forEach(it => {
          const opt = document.createElement('option');
          opt.value = it.value;
          opt.textContent = it.value; // 收合只顯示代碼
          opt.dataset.full = it.text ? `${it.value} ${it.text}` : it.value;
          tcLayerId.appendChild(opt);
        });
      } catch (e) { /* ignore */ }
    };
    // 層別 select 展開/收合顯示
    const tcShowFull = () => { tcLayerId.querySelectorAll('option').forEach(o => { if (o.dataset.full) o.textContent = o.dataset.full; }); };
    const tcShowCode = () => {
      tcLayerId.querySelectorAll('option').forEach(o => { if (o.value) o.textContent = o.value; });
      const v = tcLayerId.value;
      const found = _tcLayerData.find(it => String(it.value).trim() === v);
      tcLayerIdD.textContent = found ? (found.text || '') : '';
    };
    tcLayerId?.addEventListener('focus', tcShowFull);
    tcLayerId?.addEventListener('mousedown', tcShowFull);
    tcLayerId?.addEventListener('change', tcShowCode);
    tcLayerId?.addEventListener('blur', tcShowCode);

    tcPartNum?.addEventListener('change', loadProdLayers);
    tcRevision?.addEventListener('change', loadProdLayers);

    // 建構試算結果樹
    const buildTcTree = (data) => {
      tcTreeEl.innerHTML = '';
      if (!data || data.length === 0) {
        tcTreeEl.textContent = '(無試算結果)';
        return;
      }
      // 兩階段建構：先建立所有節點，再連接父子關係
      const nodeMap = {};
      const nodes = [];
      data.forEach((row, idx) => {
        const id = (row.Item || row.item || String(idx)).trim();
        const level = parseInt(row.LevelNo || row.levelNo || '0');
        const superId = (row.SuperId || row.superId || '').trim();
        const caption = row.Caption || row.caption || id;
        const node = { id, level, superId, caption, children: [] };
        nodeMap[id] = node;
        nodes.push(node);
      });
      const roots = [];
      nodes.forEach(node => {
        // SuperId 指向自己 → 根節點；SuperId 空或不存在 → 根節點
        if (node.superId && node.superId !== node.id && nodeMap[node.superId]) {
          nodeMap[node.superId].children.push(node);
        } else {
          roots.push(node);
        }
      });

      const renderNode = (node, depth) => {
        const div = document.createElement('div');
        div.className = 'fd-tree-node';
        if (depth > 0) div.style.paddingLeft = `${depth * 16}px`;
        if (node.children.length > 0) {
          const header = document.createElement('div');
          header.className = 'fd-tree-parent';
          const toggle = document.createElement('span');
          toggle.className = 'fd-tree-toggle'; // 預設展開
          toggle.textContent = '\u25BC';
          const label = document.createElement('span');
          label.textContent = node.caption;
          header.appendChild(toggle);
          header.appendChild(label);
          const childrenWrap = document.createElement('div');
          childrenWrap.className = 'fd-tree-children'; // 不加 collapsed，預設展開
          node.children.forEach(c => childrenWrap.appendChild(renderNode(c, depth + 1)));
          header.addEventListener('click', () => {
            const collapsed = childrenWrap.classList.toggle('collapsed');
            toggle.classList.toggle('collapsed', collapsed);
          });
          div.appendChild(header);
          div.appendChild(childrenWrap);
        } else {
          const leaf = document.createElement('div');
          leaf.className = 'fd-tree-leaf';
          leaf.textContent = node.caption;
          div.appendChild(leaf);
        }
        return div;
      };
      roots.forEach(r => tcTreeEl.appendChild(renderNode(r, 0)));
    };

    // 執行試算
    const execTestCalc = async () => {
      const factorId = _factorId;
      const partNum = (tcPartNum?.value || '').trim().toUpperCase();
      const revision = (tcRevision?.value || '').trim().toUpperCase();
      const layerId = (tcLayerId?.value || '').trim();
      const factorType = parseInt(elFactorType.value) || 0;

      tcResult.value = '計算中...';
      tcTreeEl.innerHTML = '';
      tcBtnExec.disabled = true;

      try {
        const qs = new URLSearchParams({
          factorId, partNum, revision, layerId,
          factorType: String(factorType),
          sysId: _sysId
        });
        const res = await fetch(`/api/SQUdFormulaDesign/TestCalc?${qs}`);
        const json = await res.json();
        if (!json.ok) {
          tcResult.value = `錯誤: ${json.error || '未知錯誤'}`;
          return;
        }
        const rows = json.data || [];
        // Rs 欄位：每列都相同，只取第一筆非空值
        const firstRs = rows.find(r => (r.Rs || r.rs || '').trim());
        tcResult.value = firstRs ? (firstRs.Rs || firstRs.rs || '') : (rows.length === 0 ? '(無結果)' : '');
        buildTcTree(rows);
      } catch (err) {
        tcResult.value = `錯誤: ${err.message}`;
      } finally {
        tcBtnExec.disabled = false;
      }
    };
    tcBtnExec?.addEventListener('click', execTestCalc);

    // 開啟試算 Modal
    const openTestCalc = () => {
      tcFactorId.value = _factorId;
      tcPartNum.value = '';
      tcRevision.value = '';
      tcLayerId.innerHTML = '<option value="">--</option>';
      tcLayerIdD.textContent = '';
      _tcLayerData = [];
      tcResult.value = '';
      tcTreeEl.innerHTML = '';
      const tcModal = bootstrap.Modal.getOrCreateInstance(tcModalEl);
      tcModal.show();
    };
    btnTestCal?.addEventListener('click', openTestCalc);

    // --- 開啟 ---
    const open = async (sysId, factorId, factorTypeVal) => {
      _sysId = sysId;
      _factorId = factorId;
      _fixedFactorType = String(factorTypeVal ?? '').trim();
      elFactorId.value = factorId;

      await loadLookups();
      await loadFactor();
      await loadTree();

      const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
      modal.show();
    };

    return { open };
  })();

  const runCustomButton = async (btn) => {
    const name = btn.dataset.buttonName || btn.dataset.customBtn || "";
    if (!name) return;
    const bucket = getSelectedBucket();
    const masterRow = bucket.master || null;
    const detailRow = bucket.lastDetailRow || null;
    const ctx = {
      buttonName: name,
      itemId,
      domId,
      masterRow,
      detailRow,
      paperNum: pickPaperNum(masterRow)
    };
    const needInEdit = (btn.dataset.bNeedInEdit || "").toString();
    if (needInEdit === "1" && !window._mmdEditing) {
      alert("此按鈕僅能在編輯模式使用，請先點「修改」切換到編輯模式。");
      return;
    }

    const searchTemplate = (btn.dataset.searchTemplate || "").toString().trim().toLowerCase();
    const designType = parseInt(btn.dataset.designType || "0", 10);

    // FormulaTextUpdate DLL → 公式設計編輯器
    const ocxName = (btn.dataset.ocxName || "").toString().trim().toLowerCase();
    if (searchTemplate.includes("formulatextupdate") || ocxName.includes("formulatextupdate")) {
      if (!formulaDesign) { alert("公式設計元件未載入"); return; }
      if (!masterRow) { alert("請先選取一筆 Master 資料列"); return; }
      // 從按鈕參數取得 FactorId(SeqNum=1, 欄位值) 和 SysId(SeqNum=2, 常數)
      try {
        const params = await fetch(`/api/SQUdFormulaDesign/ButtonParams?itemId=${encodeURIComponent(itemId)}&buttonName=${encodeURIComponent(name)}`).then(r => r.json());
        // SeqNum=1: FactorId (欄位值 paramType=0)
        const p1 = params.find(p => p.seqNum === 1);
        const factorField = p1?.paramFieldName || 'FactorId';
        const factorId = masterRow[factorField] || masterRow.FactorId || masterRow.factorId || "";
        if (!factorId) { alert("無法取得 FactorId，請先選取資料列"); return; }
        // SeqNum=2: SysId (常數 paramType=1)
        const p2 = params.find(p => p.seqNum === 2);
        const sysId = (p2?.paramType === 1) ? p2.paramFieldName : 'SQU';
        // SeqNum=3: FactorType (欄位值 paramType=0)
        const p3 = params.find(p => p.seqNum === 3);
        const ftField = p3?.paramFieldName || 'FactorType';
        const factorTypeVal = masterRow[ftField] || masterRow.FactorType || masterRow.factorType || '';
        await formulaDesign.open(sysId, factorId, factorTypeVal);
      } catch (err) {
        alert(`開啟公式設計失敗: ${err.message}`);
      }
      return;
    }

    if (searchTemplate === "jsdcondrunspdll.dll" && designType === 1) {
      await condRunSp.open(ctx, { dialogCaption: btn.dataset.dialogCaption || "" });
      return;
    }

    if (searchTemplate === "jsdpapersearchdll.dll") {
      if (designType !== 1) {
        alert("此按鈕 SearchTemplate=JSdPaperSearchDLL.dll，但 DesignType 不是 1，請調整按鈕設定。");
        return;
      }
      try {
        const meta = {
          dialogCaption: btn.dataset.dialogCaption || "",
          allowSelCount: btn.dataset.allowSelCount || 0,
          replaceExists: btn.dataset.replaceExists || 0,
          multiSelectDd: btn.dataset.multiSelectDd || ""
        };
        await paperSearch.open(ctx, meta);
      } catch (err) {
        console.error("paper search template error", err);
        alert(`執行失敗: ${err?.message || err}`);
      }
      return;
    }

    if (designType === 3) {
      try {
        const resp = await fetch('/api/StoredProc/execByButton', withJwtHeaders({
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            itemId: ctx.itemId,
            buttonName: ctx.buttonName,
            paperNum: ctx.paperNum,
            args: {
              opKind: window._mmdEditing ? 1 : 0,
              masterRow,
              detailRow
            }
          })
        }));
        const raw = await resp.text();
        let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
        if (resp.ok && data.ok) {
          const msgRaw = String(data.message ?? data.Message ?? "").trim();
          const msgText = msgRaw.replace(/^MESGE:\s*/i, "").trim();

          const total = Number(data.total ?? data.Total);
          const sent = Number(data.sent ?? data.Sent);
          const skipped = Number(data.skipped ?? data.Skipped);
          const hasStats = Number.isFinite(total) && Number.isFinite(sent) && Number.isFinite(skipped);

          const title = hasStats
            ? "已寄出"
            : (msgText || "執行完成");
          const tip = hasStats
            ? `已寄出 ${sent} 筆（總數 ${total}，略過 ${skipped}）`
            : msgText;

          if (window.Swal?.fire) {
            await Swal.fire({
              icon: "success",
              title,
              text: tip,
              timer: 1800,
              showConfirmButton: false
            });
          } else {
            alert(tip || title);
          }
          return;
        }
        alert(`執行失敗: ${data.error || `HTTP ${resp.status}`}`);
      } catch (err) {
        alert(`執行失敗: ${err?.message || err}`);
      }
      return;
    }

    alert(`尚未實作按鈕: ${name}`);
  };

  bar.querySelectorAll('[data-custom-btn]').forEach(btn => {
    if (btn.dataset.cbBound === "1") return;
    btn.dataset.cbBound = "1";
    btn.addEventListener('click', () => runCustomButton(btn));
  });
});
</script>
