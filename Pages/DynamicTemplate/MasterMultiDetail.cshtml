@page "/CUR/MasterMultiDetail/{itemId}"
@using WebRazor.Models
@model PcbErpApi.Pages.CUR.MasterMultiDetailModel
@{
    Layout = "_Layout";
    var cfg = Model.Config;
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.ItemName) ? Model.ItemId : $"{Model.ItemId}{Model.ItemName}";
}

@if (!string.IsNullOrWhiteSpace(Model.LoadError))
{
    <div class="alert alert-warning mt-3">@Model.LoadError</div>
}

@if (cfg == null)
{
    <div class="alert alert-warning mt-3">找不到 Master/Multi-Detail 設定資料。</div>
}
else
{
    ViewData["CustomButtonsHtml"] = Model.CustomButtonsHtml;
    @await Html.PartialAsync("_MasterMultiDetailTemplate", cfg, ViewData)
}

@await Html.PartialAsync("~/Pages/Shared/_FieldDictModal.cshtml", null, ViewData)
<script src="~/js/fieldDictModal.js" asp-append-version="true"></script>
<script src="/js/mastermultidetail/@(Model.ItemId).js" onerror="this.onerror=null"></script>

<!-- CondRunSp Modal -->
<div class="modal fade" id="condRunSpModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog cond-runsp-dialog">
    <div class="modal-content cond-runsp-modal">
      <div class="modal-header">
        <h5 class="modal-title">輸入條件</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form class="cond-runsp-form"></form>
      </div>
      <div class="modal-footer">
        <button class="btn btn-success crs-confirm">確定</button>
        <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

@await Html.PartialAsync("~/Pages/Shared/_PaperSearchModal.cshtml")

<style>
  #condRunSpModal .cond-runsp-dialog { --bs-modal-width: 520px; }
  #condRunSpModal .cond-runsp-modal { display: flex; flex-direction: column; }
  #condRunSpModal .modal-body { padding: 16px 18px; }
  #condRunSpModal .cond-runsp-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #condRunSpModal .crs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px 12px;
  }
  #condRunSpModal .crs-field {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #condRunSpModal .crs-label {
    white-space: nowrap;
    margin: 0;
    flex: 0 0 90px;
    text-align: right;
    font-size: var(--field-label-size);
  }
  #condRunSpModal .crs-control {
    flex: 1 1 auto;
    min-width: 0;
    font-size: var(--field-value-size);
  }
</style>

<!-- FormulaDesign Modal -->
<div class="modal fade" id="formulaDesignModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl formula-design-dialog">
    <div class="modal-content formula-design-modal">
      <div class="modal-header">
        <h5 class="modal-title">運算式編輯</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <!-- Toolbar -->
        <div class="fd-toolbar">
          <input type="text" id="fdFactorId" class="form-control form-control-sm fd-factorid" readonly>
          <div class="fd-lk-field">
            <label>類別：</label>
            <select id="fdFactorType" class="form-select form-select-sm fd-lk-select"></select>
            <span class="fd-lk-name" id="fdFactorTypeDisplay"></span>
          </div>
          <div class="fd-lk-field">
            <label>運算結果：</label>
            <select id="fdDataType" class="form-select form-select-sm fd-lk-select"></select>
            <span class="fd-lk-name" id="fdDataTypeDisplay"></span>
          </div>
          <div class="fd-actions">
            <button type="button" class="btn btn-sm btn-info text-white" id="fdBtnTestCal">試算</button>
            <button type="button" class="btn btn-sm btn-success" id="fdBtnSave">儲存</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="fdBtnReset">放棄</button>
          </div>
        </div>
        <!-- Main content -->
        <div class="fd-content">
          <!-- Left: Tree -->
          <div class="fd-panel fd-tree-panel">
            <div class="fd-panel-title">資料來源項目</div>
            <div class="fd-tree-scroll" id="fdTreeContainer"></div>
          </div>
          <!-- Middle: Operators -->
          <div class="fd-panel fd-ops-panel">
            <div class="fd-panel-title">運算元</div>
            <div class="fd-ops-list" id="fdOperators"></div>
          </div>
          <!-- Right: Formula editor -->
          <div class="fd-panel fd-editor-panel">
            <div class="fd-panel-title">運算式編輯</div>
            <textarea id="fdFormulaText" class="fd-formula-textarea" spellcheck="false"></textarea>
            <div class="fd-editor-bottom">
              <div class="fd-lk-field">
                <label>製程：</label>
                <select id="fdProcCode" class="form-select form-select-sm fd-lk-select"></select>
                <span class="fd-lk-name" id="fdProcCodeDisplay"></span>
              </div>
              <div class="fd-lk-field">
                <label>計算方式：</label>
                <select id="fdProcCount" class="form-select form-select-sm fd-lk-select"></select>
                <span class="fd-lk-name" id="fdProcCountDisplay"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== 試算參數 Modal ========== -->
<div class="modal fade" id="testCalcModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-lg tc-dialog">
    <div class="modal-content tc-modal">
      <div class="modal-header">
        <h5 class="modal-title">試算參數</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <!-- 輸入區 -->
        <div class="tc-form">
          <div class="tc-row">
            <label class="tc-label">計算方式</label>
            <input type="text" id="tcFactorId" class="form-control form-control-sm tc-input" readonly>
          </div>
          <div class="tc-row">
            <label class="tc-label">料　　號</label>
            <input type="text" id="tcPartNum" class="form-control form-control-sm tc-input" style="text-transform:uppercase;">
          </div>
          <div class="tc-row">
            <label class="tc-label">版　　本</label>
            <input type="text" id="tcRevision" class="form-control form-control-sm tc-input tc-short" style="text-transform:uppercase;">
          </div>
          <div class="tc-row">
            <label class="tc-label">層　　別</label>
            <div class="fd-lk-field">
              <select id="tcLayerId" class="form-select form-select-sm fd-lk-select tc-layer-sel"></select>
              <span class="fd-lk-name" id="tcLayerIdDisplay"></span>
            </div>
          </div>
          <div class="tc-row tc-row-btn">
            <button type="button" class="btn btn-sm btn-primary" id="tcBtnExecute">試算</button>
          </div>
          <div class="tc-row">
            <label class="tc-label">結　　果</label>
            <textarea id="tcResult" class="form-control form-control-sm tc-result" readonly rows="5"></textarea>
          </div>
        </div>
        <!-- 樹狀結構 -->
        <div class="tc-tree-wrap">
          <div id="tcTreeContainer" class="tc-tree-scroll"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">關閉</button>
      </div>
    </div>
  </div>
</div>

