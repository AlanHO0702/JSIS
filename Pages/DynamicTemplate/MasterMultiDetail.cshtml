  #formulaDesignModal .formula-design-dialog { --bs-modal-width: 1000px; }
  #formulaDesignModal .formula-design-modal { display: flex; flex-direction: column; height: 70vh; }
  #formulaDesignModal .modal-header { padding: 6px 12px; }
  #formulaDesignModal .modal-body { flex: 1 1 auto; display: flex; flex-direction: column; min-height: 0; padding: 8px 12px; gap: 8px; }
  /* Toolbar */
  .fd-toolbar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding-bottom: 6px; border-bottom: 1px solid #e5e7eb; }
  .fd-factorid { width: 140px !important; background: #f1f5f9; font-size: var(--field-value-size, 13px); height: 24px; padding: 2px 6px; }
  .fd-actions { margin-left: auto; display: flex; gap: 6px; }
  .fd-actions .btn { padding: 2px 14px; font-size: var(--field-value-size, 13px); height: 24px; line-height: 1; }
  /* Lookup field: label + native select + display name */
  .fd-lk-field { display: inline-flex; align-items: center; gap: 0; position: relative; }
  .fd-lk-field label { white-space: nowrap; font-size: var(--field-value-size, 13px); color: #475569; margin: 0 4px 0 0; }
  .fd-lk-select { width: auto !important; min-width: 72px; max-width: 100px; font-size: var(--field-value-size, 13px); border-radius: 3px 0 0 3px !important; padding: 0 22px 0 6px; height: 24px; }
  .fd-lk-name { display: inline-block; font-size: var(--field-value-size, 13px); padding: 2px 6px; border: 1px solid #ced4da; border-left: 0; border-radius: 0 3px 3px 0; background: #f8fafc; color: #334155; white-space: nowrap; min-width: 60px; height: 24px; line-height: 20px; }
  /* Content */
  .fd-content { flex: 1 1 auto; display: flex; gap: 6px; min-height: 0; }
  .fd-panel { display: flex; flex-direction: column; border: 1px solid #e5e7eb; border-radius: 6px; overflow: hidden; }
  .fd-panel-title { font-size: 13px; font-weight: 600; color: #475569; padding: 4px 8px; background: #f8fafc; border-bottom: 1px solid #e5e7eb; }
  .fd-tree-panel { flex: 0 0 220px; }
  .fd-tree-scroll { flex: 1 1 auto; overflow: auto; padding: 4px; font-size: 13px; }
  .fd-ops-panel { flex: 0 0 100px; }
  .fd-ops-list { flex: 1 1 auto; overflow: auto; }
  .fd-ops-list .fd-op-item { padding: 3px 8px; cursor: pointer; font-size: 13px; font-family: monospace; border-bottom: 1px solid #f1f5f9; }
  .fd-ops-list .fd-op-item:hover { background: #dbeafe; }
  .fd-editor-panel { flex: 1 1 auto; }
  .fd-formula-textarea { flex: 1 1 auto; width: 100%; border: none; resize: none; padding: 8px; font-family: monospace; font-size: 13px; outline: none; min-height: 0; }
  .fd-editor-bottom { display: flex; gap: 10px; padding: 6px 8px; border-top: 1px solid #e5e7eb; background: #f8fafc; }
  /* Tree styles */
  .fd-tree-node { user-select: none; }
  .fd-tree-parent { font-weight: 600; padding: 3px 4px; cursor: pointer; display: flex; align-items: center; gap: 2px; }
  .fd-tree-parent:hover { background: #f1f5f9; }
  .fd-tree-toggle { display: inline-block; width: 16px; text-align: center; font-size: 11px; transition: transform .15s; }
  .fd-tree-toggle.collapsed { transform: rotate(-90deg); }
  .fd-tree-children { padding-left: 18px; }
  .fd-tree-children.collapsed { display: none; }
  .fd-tree-leaf { padding: 2px 4px 2px 6px; cursor: pointer; border-radius: 3px; }
  .fd-tree-leaf:hover { background: #dbeafe; }
  .fd-tree-leaf.selected { background: #bfdbfe; }

  /* ========== 試算 Modal ========== */
  #testCalcModal { z-index: 1060; }
  #testCalcModal + .modal-backdrop { z-index: 1055; }
  #testCalcModal .tc-dialog { --bs-modal-width: 480px; }
  #testCalcModal .tc-modal { display: flex; flex-direction: column; height: 80vh; }
  #testCalcModal .modal-header { padding: 6px 12px; }
  #testCalcModal .modal-body { flex: 1 1 auto; display: flex; flex-direction: column; padding: 10px 14px; gap: 8px; min-height: 0; overflow: auto; }
  #testCalcModal .modal-footer { padding: 6px 12px; }
  .tc-form { flex: 0 0 auto; display: flex; flex-direction: column; gap: 6px; }
  .tc-row { display: flex; align-items: center; gap: 8px; }
  .tc-row-btn { justify-content: flex-end; }
  .tc-label { width: 70px; text-align: right; font-size: 13px; color: #475569; white-space: nowrap; flex-shrink: 0; }
  .tc-input { font-size: 13px; height: 26px; }
  .tc-short { width: 80px !important; flex: 0 0 auto; }
  .tc-mid { width: 180px !important; flex: 0 0 auto; }
  .tc-layer-sel { min-width: 90px; max-width: 120px; }
  .tc-result { font-size: 13px; resize: none; background: #f1f5f9; }
  .tc-tree-wrap { flex: 1 1 auto; min-height: 200px; border: 1px solid #e5e7eb; border-radius: 6px; overflow: auto; }
  .tc-tree-scroll { padding: 4px; font-size: 13px; }
  .tc-tree-scroll .fd-tree-node { user-select: none; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const domId = '@(Model.Config?.DomId ?? string.Empty)';
  const itemId = '@Model.ItemId';
  const bar = document.getElementById(`${domId}-custom-slot`);
  if (!bar) return;

  const withJwtHeaders = (init = {}) => {
    const jwt = localStorage.getItem("jwtId");
    const headers = Object.assign({}, init.headers || {});
    if (jwt) headers["X-JWTID"] = jwt;
    return { ...init, headers };
  };

  const hasDateOnlyMask = (mask) => {
    const m = (mask || "").toString().toLowerCase();
    if (!m) return false;
    const isDate = m.includes("yyyy") && m.includes("mm") && m.includes("dd");
    const hasTime = m.includes("hh") || m.includes("ss") || m.includes("tt");
    return isDate && !hasTime;
  };

  const parseDateValue = (value) => {
    if (!value) return null;
    if (value instanceof Date && !isNaN(value)) return value;
    const s = String(value).trim();
    if (!s) return null;
    if (/^\d{4}-\d{2}-\d{2}/.test(s)) return new Date(s.slice(0, 10));
    if (/^\d{4}[/.]\d{1,2}[/.]\d{1,2}$/.test(s)) {
      const [y, m, d] = s.split(/[/.]/).map(Number);
      if (y && m && d) return new Date(y, m - 1, d);
    }
    const d = new Date(s);
    return isNaN(d) ? null : d;
  };

  const formatDateByMask = (value, mask) => {
    const dt = parseDateValue(value);
    if (!dt) return value;
    const y = dt.getFullYear();
    const m = String(dt.getMonth() + 1).padStart(2, "0");
    const d = String(dt.getDate()).padStart(2, "0");
    if (mask?.includes("-")) return `${y}-${m}-${d}`;
    return `${y}/${m}/${d}`;
  };

  const applyEditMask = (value, editMask) => {
    if (hasDateOnlyMask(editMask)) return formatDateByMask(value, editMask);
    return value;
  };

  const normalizeKey = (name) => (name || "").replace(/^@@+/, "").toLowerCase();

  const getRowFieldValue = (row, field) => {
    if (!row || !field) return "";
    const key = String(field).toLowerCase();
    const hit = Object.keys(row).find(k => String(k).toLowerCase() === key);
    const val = hit ? row[hit] : "";
    return val == null ? "" : String(val).trim();
  };

  const pickPaperNum = (row) => {
    if (!row) return "";
    const direct = getRowFieldValue(row, "PaperNum");
    if (direct) return direct;
    const keys = Object.keys(row);
    const findBy = (re) => {
      const k = keys.find(name => re.test(String(name)));
      return k ? getRowFieldValue(row, k) : "";
    };
    return findBy(/paper.*num/i)
      || findBy(/doc.*num/i)
      || findBy(/bill.*num/i)
      || findBy(/order.*num/i)
      || "";
  };

  const getSelectedBucket = () => window._mmdSelectedRows?.[domId] || { master: null, details: {} };
  const getDetailRowByIndex = (index) => {
    const bucket = getSelectedBucket();
    return bucket.details?.[index] || null;
  };

  const getDefaultFromTableKind = (tableKind, fieldName) => {
    const kind = (tableKind || "").toString().trim().toLowerCase();
    if (!kind || !fieldName) return "";
    if (kind.startsWith("master")) {
      return getRowFieldValue(getSelectedBucket().master, fieldName);
    }
    const m = kind.match(/detail(\d+)/);
    if (m) {
      const idx = Math.max(0, parseInt(m[1], 10) - 1);
      return getRowFieldValue(getDetailRowByIndex(idx), fieldName);
    }
    return "";
  };

  const condRunSp = (() => {
    const modalEl = document.getElementById("condRunSpModal");
    if (modalEl && modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }
    const formEl = modalEl?.querySelector(".cond-runsp-form");
    const btnConfirm = modalEl?.querySelector(".crs-confirm");
    const titleEl = modalEl?.querySelector(".modal-title");

    const state = {
      itemId: "",
      buttonName: "",
      paperNum: "",
      searchParams: [],
      inputs: {},
      onSuccess: null
    };

    const loadParamOptions = async (itemId, buttonName, paramName, superValue) => {
      const extra = superValue ? `&superValue=${encodeURIComponent(superValue)}` : "";
      const url = `/api/PaperSearch/ParamOptionsV2?itemId=${encodeURIComponent(itemId)}&buttonName=${encodeURIComponent(buttonName)}&paramName=${encodeURIComponent(paramName)}${extra}`;
      const res = await fetch(url, withJwtHeaders());
      if (!res.ok) throw new Error(await res.text());
      return await res.json();
    };

    const getSuperValueCrs = (p) => {
      const rawSuperId = (p.SuperId || p.superId || "").toString().trim().replace(/^@@+/, "");
      const superKey = normalizeKey(rawSuperId);
      if (!superKey) return "";
      const superInput = formEl?.querySelector(`[data-param="${superKey}"]`);
      if (superInput && (superInput.value ?? "") !== "") return superInput.value ?? "";

      const superParam = (state.searchParams || []).find(sp => normalizeKey(sp.ParamName || sp.paramName) === superKey);
      if (!superParam) return "";
      const tk = superParam.TableKind ?? superParam.tableKind;
      const pv = superParam.ParamValue ?? superParam.paramValue;
      const fromKind = pv ? getDefaultFromTableKind(tk, pv) : "";
      return fromKind || (superParam.DefaultValue ?? superParam.defaultValue ?? "");
    };

    const buildForm = async (itemId, buttonName) => {
      if (!formEl) return;
      formEl.innerHTML = "";
      const visibleParams = (state.searchParams || []).filter(p => {
        return Number(p.iVisible ?? p.IVisible ?? 0) === 1;
      });

      if (!visibleParams.length) {
        formEl.innerHTML = '<div class="text-muted small">（沒有可輸入的條件）</div>';
        return;
      }

      const grid = document.createElement("div");
      grid.className = "crs-grid";
      formEl.appendChild(grid);

      for (const p of visibleParams) {
        const name = normalizeKey(p.ParamName || p.paramName);
        if (!name) continue;

        const wrap = document.createElement("div");
        wrap.className = "crs-field";
        const label = document.createElement("label");
        label.className = "form-label crs-label";
        label.textContent = p.DisplayName || p.displayName || name;
        wrap.appendChild(label);

        const controlType = Number(p.ControlType ?? p.controlType ?? 0);
        const tableKind = p.TableKind ?? p.tableKind;
        const paramValue = p.ParamValue ?? p.paramValue;
        let headerDefault = "";
        if (paramValue) {
          headerDefault = getDefaultFromTableKind(tableKind, paramValue);
        }

        if (controlType === 1) {
          const select = document.createElement("select");
          select.className = "form-select form-select-sm crs-control";
          select.setAttribute("data-param", name);
          const emptyOpt = document.createElement("option");
          emptyOpt.value = "";
          emptyOpt.textContent = "";
          select.appendChild(emptyOpt);
          wrap.appendChild(select);
          try {
            const superValue = getSuperValueCrs(p);
            const options = await loadParamOptions(itemId, buttonName, p.ParamName || p.paramName, superValue);
            if (Array.isArray(options)) {
              options.forEach(opt => {
                const o = document.createElement("option");
                const val = opt.value ?? opt.Value ?? "";
                const text = opt.text ?? opt.Text ?? "";
                o.value = val;
                o.textContent = text ? `${val} ${text}`.trim() : val;
                if (text && text !== val) o.title = text;
                select.appendChild(o);
              });
            }
            const defVal = headerDefault || (p.DefaultValue ?? p.defaultValue ?? "");
            if (defVal != null && defVal !== "") {
              select.value = applyEditMask(defVal, p.EditMask ?? p.editMask);
            }
          } catch (err) {
            console.warn("load param options failed", err);
          }
        } else {
          const input = document.createElement("input");
          input.className = "form-control form-control-sm crs-control";
          input.type = "text";
          input.setAttribute("data-param", name);
          const defVal = headerDefault || (p.DefaultValue ?? p.defaultValue);
          if (defVal != null && defVal !== "") {
            input.value = applyEditMask(defVal, p.EditMask ?? p.editMask);
          }
          const readOnly = Number(p.iReadOnly ?? p.IReadOnly ?? 0) === 1;
          if (readOnly) input.readOnly = true;
          wrap.appendChild(input);
        }

        grid.appendChild(wrap);
      }
    };

    const collectInputs = () => {
      const values = {};
      (state.searchParams || []).forEach(p => {
        const name = normalizeKey(p.ParamName || p.paramName);
        if (!name) return;
        const input = formEl?.querySelector(`[data-param="${name}"]`);
        if (input) {
          values[name] = input.value ?? "";
          return;
        }
        const tableKind = p.TableKind ?? p.tableKind;
        const paramValue = p.ParamValue ?? p.paramValue;
        const fromKind = paramValue ? getDefaultFromTableKind(tableKind, paramValue) : "";
        const defVal = fromKind || (p.DefaultValue ?? p.defaultValue ?? p.ParamValue ?? p.paramValue);
        values[name] = defVal == null ? "" : defVal;
      });
      if (values.useid != null && String(values.useid).trim() === "") {
        values.useid = window.DEFAULT_USEID || window._useId || "A001";
      }
      state.inputs = values;
      return values;
    };

    const setConfirmLoading = (loading) => {
      if (!btnConfirm) return;
      btnConfirm.disabled = loading;
      btnConfirm.textContent = loading ? "執行中..." : "確定";
    };

    const runSp = async () => {
      setConfirmLoading(true);
      const payload = {
        itemId: state.itemId,
        buttonName: state.buttonName,
        paperNum: state.paperNum,
        params: collectInputs()
      };
      try {
        const res = await fetch("/api/PaperSearch/RunSpExec", withJwtHeaders({
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        }));
        const raw = await res.text();
        let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
        if (!res.ok || !data.ok) throw new Error(data.error || `HTTP ${res.status}`);
        if (typeof state.onSuccess === 'function') {
          if (window.bootstrap) {
            const modal = bootstrap.Modal.getInstance(modalEl);
            modal?.hide();
          }
          await state.onSuccess();
        } else {
          localStorage.setItem("afterSave", "1");
          location.reload();
        }
      } catch (err) {
        alert(`執行失敗: ${err?.message || err}`);
      } finally {
        setConfirmLoading(false);
      }
    };

    const open = async (ctx, meta) => {
      if (!modalEl) return;
      state.itemId = ctx.itemId || "";
      state.buttonName = ctx.buttonName || "";
      state.paperNum = ctx.paperNum || "";
      state.onSuccess = meta.onSuccess || null;

      const configUrl = `/api/PaperSearch/Config?itemId=${encodeURIComponent(state.itemId)}&buttonName=${encodeURIComponent(state.buttonName)}`;
      const res = await fetch(configUrl, withJwtHeaders());
      if (!res.ok) {
        alert(await res.text());
        return;
      }
      const cfg = await res.json();
      state.searchParams = cfg.searchParams || cfg.SearchParams || [];

      const caption = meta.dialogCaption || cfg.dialogCaption || cfg.DialogCaption || ctx.caption || "輸入條件";
      if (titleEl) titleEl.textContent = caption;

      await buildForm(state.itemId, state.buttonName);
      if (window.bootstrap) {
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
      }
    };

    btnConfirm?.addEventListener("click", (e) => { e.preventDefault(); runSp(); });

    return { open };
  })();

  // ============================================================
  //  FormulaDesign — 公式設計編輯器
  // ============================================================
  const formulaDesign = (() => {
    const modalEl = document.getElementById('formulaDesignModal');
    if (!modalEl) return null;

    const elFactorId    = document.getElementById('fdFactorId');
    const elFactorType  = document.getElementById('fdFactorType');
    const elFactorTypeD = document.getElementById('fdFactorTypeDisplay');
    const elDataType    = document.getElementById('fdDataType');
    const elDataTypeD   = document.getElementById('fdDataTypeDisplay');
    const elProcCode    = document.getElementById('fdProcCode');
    const elProcCodeD   = document.getElementById('fdProcCodeDisplay');
    const elProcCount   = document.getElementById('fdProcCount');
    const elProcCountD  = document.getElementById('fdProcCountDisplay');
    const elFormula     = document.getElementById('fdFormulaText');
    const elTree        = document.getElementById('fdTreeContainer');
    const elOps         = document.getElementById('fdOperators');
    const btnSave       = document.getElementById('fdBtnSave');
    const btnReset      = document.getElementById('fdBtnReset');
    const btnTestCal    = document.getElementById('fdBtnTestCal');

    const operators = ['+','-','*','/','%','ABS()','ROUND(,)','ISNULL(,)',
                       'CEILING()','FLOOR()','POWER(,)','MAX()','MIN()','AVG()','SUM()','COUNT()'];

    let _sysId = '', _factorId = '', _factorType = 0, _fixedFactorType = '', _originalFormula = '';

    // Lookup data cache: { key: [{value, text}] }
    const _lkData = {};

    // --- 填充 select options ---
    const fillSelect = (selectEl, items) => {
      selectEl.innerHTML = '';
      const blank = document.createElement('option');
      blank.value = '';
      blank.textContent = '';
      selectEl.appendChild(blank);
      (items || []).forEach(it => {
        const opt = document.createElement('option');
        opt.value = it.value;
        opt.textContent = it.value; // 收合時只顯示代碼
        opt.dataset.full = it.text ? `${it.value} ${it.text}` : it.value;
        selectEl.appendChild(opt);
      });
    };

    // --- select 展開時顯示完整文字，收合時只顯示代碼 ---
    const bindSelectDisplay = (selectEl, displayEl, dataKey) => {
      // 展開前：所有 option 切換成完整文字
      const showFull = () => {
        selectEl.querySelectorAll('option').forEach(o => {
          if (o.dataset.full) o.textContent = o.dataset.full;
        });
      };
      // 收合後：選中的 option 改回只顯示代碼，同步 display name
      const showCode = () => {
        selectEl.querySelectorAll('option').forEach(o => {
          if (o.value) o.textContent = o.value;
        });
        const v = selectEl.value;
        const items = _lkData[dataKey] || [];
        const found = items.find(it => String(it.value).trim() === String(v).trim());
        displayEl.textContent = found ? found.text : '';
      };
      selectEl.addEventListener('focus', showFull);
      selectEl.addEventListener('mousedown', showFull);
      selectEl.addEventListener('change', showCode);
      selectEl.addEventListener('blur', showCode);
    };

    // --- 設定 select 欄位值 ---
    const setLkValue = (selectEl, displayEl, value, dataKey) => {
      const v = String(value ?? '').trim();
      selectEl.value = v;
      // 確保收合狀態只顯示代碼
      selectEl.querySelectorAll('option').forEach(o => {
        if (o.value) o.textContent = o.value;
      });
      const items = _lkData[dataKey] || [];
      const found = items.find(it => String(it.value).trim() === v);
      displayEl.textContent = found ? found.text : '';
    };

    // --- 載入下拉選項 ---
    const loadLookups = async () => {
      if (Object.keys(_lkData).length > 0) return;
      const [ftRes, dtRes, pcRes, pctRes] = await Promise.all([
        fetch('/api/SQUdFormulaDesign/FactorTypes').then(r => r.json()),
        fetch('/api/SQUdFormulaDesign/DataTypes').then(r => r.json()),
        fetch('/api/SQUdFormulaDesign/ProcCodes').then(r => r.json()),
        fetch('/api/SQUdFormulaDesign/ProcCounts').then(r => r.json())
      ]);
      _lkData.factorType = ftRes;
      _lkData.dataType = dtRes;
      _lkData.procCode = pcRes;
      _lkData.procCount = pctRes;
      // 填充所有 select
      fillSelect(elFactorType, ftRes);
      fillSelect(elDataType, dtRes);
      fillSelect(elProcCode, pcRes);
      fillSelect(elProcCount, pctRes);
    };

    // --- 建構運算元列表 ---
    const buildOperators = () => {
      elOps.innerHTML = '';
      operators.forEach(op => {
        const div = document.createElement('div');
        div.className = 'fd-op-item';
        div.textContent = op;
        div.addEventListener('dblclick', () => insertAtCursor(op));
        elOps.appendChild(div);
      });
    };

    // --- 在游標位置插入文字 ---
    const insertAtCursor = (text) => {
      const ta = elFormula;
      const start = ta.selectionStart;
      const before = ta.value.substring(0, start);
      const after = ta.value.substring(ta.selectionEnd);
      ta.value = before + text + after;
      ta.focus();
      ta.selectionStart = ta.selectionEnd = start + text.length;
    };

    // --- 建構樹狀結構 ---
    const buildTree = (data) => {
      elTree.innerHTML = '';
      const parents = data.filter(d => d.levelNo === 0);
      const childMap = {};
      data.filter(d => d.levelNo !== 0).forEach(d => {
        const key = (d.superId || '').trim();
        if (!childMap[key]) childMap[key] = [];
        childMap[key].push(d);
      });

      parents.forEach(p => {
        const node = document.createElement('div');
        node.className = 'fd-tree-node';
        const parentName = p.itemName || p.itemId;

        const header = document.createElement('div');
        header.className = 'fd-tree-parent';
        const toggle = document.createElement('span');
        toggle.className = 'fd-tree-toggle collapsed';
        toggle.textContent = '▼';
        const label = document.createElement('span');
        label.textContent = parentName;
        header.appendChild(toggle);
        header.appendChild(label);

        const children = document.createElement('div');
        children.className = 'fd-tree-children collapsed';

        const kids = childMap[p.itemId] || [];
        kids.forEach(c => {
          const childName = c.itemName || c.itemId;
          const leaf = document.createElement('div');
          leaf.className = 'fd-tree-leaf';
          // 葉節點顯示「父.子」格式
          leaf.textContent = `${parentName}.${childName}`;
          leaf.dataset.parentText = parentName;
          leaf.dataset.childText = childName;
          leaf.addEventListener('dblclick', () => {
            // FactorType 0 或 5: {Parent.Child}，否則: {Child}
            const tag = (_factorType === 0 || _factorType === 5)
              ? `{${parentName}.${childName}}`
              : `{${childName}}`;
            insertAtCursor(tag);
          });
          children.appendChild(leaf);
        });

        header.addEventListener('click', () => {
          const collapsed = children.classList.toggle('collapsed');
          toggle.classList.toggle('collapsed', collapsed);
        });

        node.appendChild(header);
        node.appendChild(children);
        elTree.appendChild(node);
      });
    };

    // --- 載入因素資料 ---
    const loadFactor = async () => {
      const res = await fetch(`/api/SQUdFormulaDesign/Factor?sysId=${encodeURIComponent(_sysId)}&factorId=${encodeURIComponent(_factorId)}`);
      const data = await res.json();
      if (!data.ok || !data.found) {
        elFormula.value = '';
        return;
      }
      elFormula.value = (data.formulaText || '').trim();
      _originalFormula = elFormula.value;
      _factorType = parseInt(data.factorType) || 0;
      // 類別：優先用 _fixedFactorType（來自 master row），若為 0 或空則用 API 回傳的 factorType
      const ftVal = (_fixedFactorType && _fixedFactorType !== '0') ? _fixedFactorType : String(_factorType);
      setLkValue(elFactorType, elFactorTypeD, ftVal, 'factorType');
      setLkValue(elDataType, elDataTypeD, data.dataType ?? '', 'dataType');
      setLkValue(elProcCode, elProcCodeD, data.procCode ?? '', 'procCode');
      setLkValue(elProcCount, elProcCountD, data.procCount ?? '', 'procCount');
    };

    // --- 載入樹狀資料 ---
    const loadTree = async () => {
      const ft = parseInt(elFactorType.value) || 0;
      const powerType = (ft === 0) ? 0 : ft;
      const url = `/api/SQUdFormulaDesign/TreeData?powerType=${powerType}&systemId=${encodeURIComponent(_sysId)}`;
      const data = await fetch(url).then(r => r.json());
      buildTree(data);
    };

    // --- 儲存 ---
    const save = async () => {
      const userId = (document.querySelector('[data-user-name]')?.dataset?.userName
                     || document.querySelector('.navbar .dropdown-toggle')?.textContent?.trim()
                     || '').replace(/\s+/g, '');
      const body = {
        sysId: _sysId,
        factorId: _factorId,
        formulaText: elFormula.value,
        factorType: elFactorType.value,
        dataType: elDataType.value,
        procCode: elProcCode.value,
        procCount: elProcCount.value,
        userId: userId
      };
      try {
        const res = await fetch('/api/SQUdFormulaDesign/Save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.ok) {
          _originalFormula = elFormula.value;
          if (window.Swal?.fire) {
            await Swal.fire({ icon: 'success', title: '儲存完成', timer: 1200, showConfirmButton: false });
          } else {
            alert('儲存完成');
          }
        } else {
          alert(`儲存失敗: ${data.error || '未知錯誤'}`);
        }
      } catch (err) {
        alert(`儲存失敗: ${err.message}`);
      }
    };

    // --- 放棄 (重新載入) ---
    const reset = async () => {
      await loadFactor();
    };

    // --- 綁定事件 ---
    btnSave?.addEventListener('click', save);
    btnReset?.addEventListener('click', reset);
    buildOperators();

    // 綁定 select 展開/收合顯示切換
    bindSelectDisplay(elFactorType, elFactorTypeD, 'factorType');
    bindSelectDisplay(elDataType, elDataTypeD, 'dataType');
    bindSelectDisplay(elProcCode, elProcCodeD, 'procCode');
    bindSelectDisplay(elProcCount, elProcCountD, 'procCount');

    // 類別變更時重新載入樹狀資料
    elFactorType.addEventListener('change', () => { _factorType = parseInt(elFactorType.value) || 0; loadTree(); });

    // --- 關閉前確認 ---
    const isChanged = () => {
      return elFormula.value.trim() !== _originalFormula.trim();
    };
    modalEl.addEventListener('hide.bs.modal', (e) => {
      if (isChanged()) {
        if (!confirm('資料有變更，確定放棄？')) {
          e.preventDefault();
        }
      }
    });

    // ============================================================
    //  試算功能
    // ============================================================
    const tcModalEl   = document.getElementById('testCalcModal');
    const tcFactorId  = document.getElementById('tcFactorId');
    const tcPartNum   = document.getElementById('tcPartNum');
    const tcRevision  = document.getElementById('tcRevision');
    const tcLayerId   = document.getElementById('tcLayerId');
    const tcLayerIdD  = document.getElementById('tcLayerIdDisplay');
    const tcResult    = document.getElementById('tcResult');
    const tcTreeEl    = document.getElementById('tcTreeContainer');
    const tcBtnExec   = document.getElementById('tcBtnExecute');

    let _tcLayerData = []; // 層別資料快取

    // 層別：料號/版本輸入後動態載入（select + name span）
    const loadProdLayers = async () => {
      const pn = (tcPartNum?.value || '').trim();
      const rev = (tcRevision?.value || '').trim();
      _tcLayerData = [];
      tcLayerId.innerHTML = '<option value="">--</option>';
      tcLayerIdD.textContent = '';
      if (!pn) return;
      try {
        const res = await fetch(`/api/SQUdFormulaDesign/ProdLayers?partNum=${encodeURIComponent(pn)}&revision=${encodeURIComponent(rev)}`);
        const list = await res.json();
        _tcLayerData = list || [];
        _tcLayerData.forEach(it => {
          const opt = document.createElement('option');
          opt.value = it.value;
          opt.textContent = it.value; // 收合只顯示代碼
          opt.dataset.full = it.text ? `${it.value} ${it.text}` : it.value;
          tcLayerId.appendChild(opt);
        });
      } catch (e) { /* ignore */ }
    };
    // 層別 select 展開/收合顯示
    const tcShowFull = () => { tcLayerId.querySelectorAll('option').forEach(o => { if (o.dataset.full) o.textContent = o.dataset.full; }); };
    const tcShowCode = () => {
      tcLayerId.querySelectorAll('option').forEach(o => { if (o.value) o.textContent = o.value; });
      const v = tcLayerId.value;
      const found = _tcLayerData.find(it => String(it.value).trim() === v);
      tcLayerIdD.textContent = found ? (found.text || '') : '';
    };
    tcLayerId?.addEventListener('focus', tcShowFull);
    tcLayerId?.addEventListener('mousedown', tcShowFull);
    tcLayerId?.addEventListener('change', tcShowCode);
    tcLayerId?.addEventListener('blur', tcShowCode);

    tcPartNum?.addEventListener('change', loadProdLayers);
    tcRevision?.addEventListener('change', loadProdLayers);

    // 建構試算結果樹
    const buildTcTree = (data) => {
      tcTreeEl.innerHTML = '';
      if (!data || data.length === 0) {
        tcTreeEl.textContent = '(無試算結果)';
        return;
      }
      // 兩階段建構：先建立所有節點，再連接父子關係
      const nodeMap = {};
      const nodes = [];
      data.forEach((row, idx) => {
        const id = (row.Item || row.item || String(idx)).trim();
        const level = parseInt(row.LevelNo || row.levelNo || '0');
        const superId = (row.SuperId || row.superId || '').trim();
        const caption = row.Caption || row.caption || id;
        const node = { id, level, superId, caption, children: [] };
        nodeMap[id] = node;
        nodes.push(node);
      });
      const roots = [];
      nodes.forEach(node => {
        // SuperId 指向自己 → 根節點；SuperId 空或不存在 → 根節點
        if (node.superId && node.superId !== node.id && nodeMap[node.superId]) {
          nodeMap[node.superId].children.push(node);
        } else {
          roots.push(node);
        }
      });

      const renderNode = (node, depth) => {
        const div = document.createElement('div');
        div.className = 'fd-tree-node';
        if (depth > 0) div.style.paddingLeft = `${depth * 16}px`;
        if (node.children.length > 0) {
          const header = document.createElement('div');
          header.className = 'fd-tree-parent';
          const toggle = document.createElement('span');
          toggle.className = 'fd-tree-toggle'; // 預設展開
          toggle.textContent = '\u25BC';
          const label = document.createElement('span');
          label.textContent = node.caption;
          header.appendChild(toggle);
          header.appendChild(label);
          const childrenWrap = document.createElement('div');
          childrenWrap.className = 'fd-tree-children'; // 不加 collapsed，預設展開
          node.children.forEach(c => childrenWrap.appendChild(renderNode(c, depth + 1)));
          header.addEventListener('click', () => {
            const collapsed = childrenWrap.classList.toggle('collapsed');
            toggle.classList.toggle('collapsed', collapsed);
          });
          div.appendChild(header);
          div.appendChild(childrenWrap);
        } else {
          const leaf = document.createElement('div');
          leaf.className = 'fd-tree-leaf';
          leaf.textContent = node.caption;
          div.appendChild(leaf);
        }
        return div;
      };
      roots.forEach(r => tcTreeEl.appendChild(renderNode(r, 0)));
    };

    // 執行試算
    const execTestCalc = async () => {
      const factorId = _factorId;
      const partNum = (tcPartNum?.value || '').trim().toUpperCase();
      const revision = (tcRevision?.value || '').trim().toUpperCase();
      const layerId = (tcLayerId?.value || '').trim();
      const factorType = parseInt(elFactorType.value) || 0;

      tcResult.value = '計算中...';
      tcTreeEl.innerHTML = '';
      tcBtnExec.disabled = true;

      try {
        const qs = new URLSearchParams({
          factorId, partNum, revision, layerId,
          factorType: String(factorType),
          sysId: _sysId
        });
        const res = await fetch(`/api/SQUdFormulaDesign/TestCalc?${qs}`);
        const json = await res.json();
        if (!json.ok) {
          tcResult.value = `錯誤: ${json.error || '未知錯誤'}`;
          return;
        }
        const rows = json.data || [];
        // Rs 欄位：每列都相同，只取第一筆非空值
        const firstRs = rows.find(r => (r.Rs || r.rs || '').trim());
        tcResult.value = firstRs ? (firstRs.Rs || firstRs.rs || '') : (rows.length === 0 ? '(無結果)' : '');
        buildTcTree(rows);
      } catch (err) {
        tcResult.value = `錯誤: ${err.message}`;
      } finally {
        tcBtnExec.disabled = false;
      }
    };
    tcBtnExec?.addEventListener('click', execTestCalc);

    // 開啟試算 Modal
    const openTestCalc = () => {
      tcFactorId.value = _factorId;
      tcPartNum.value = '';
      tcRevision.value = '';
      tcLayerId.innerHTML = '<option value="">--</option>';
      tcLayerIdD.textContent = '';
      _tcLayerData = [];
      tcResult.value = '';
      tcTreeEl.innerHTML = '';
      const tcModal = bootstrap.Modal.getOrCreateInstance(tcModalEl);
      tcModal.show();
    };
    btnTestCal?.addEventListener('click', openTestCalc);

    // --- 開啟 ---
    const open = async (sysId, factorId, factorTypeVal) => {
      _sysId = sysId;
      _factorId = factorId;
      _fixedFactorType = String(factorTypeVal ?? '').trim();
      elFactorId.value = factorId;

      await loadLookups();
      await loadFactor();
      await loadTree();

      const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
      modal.show();
    };

    return { open };
  })();

  const runCustomButton = async (btn) => {
    const name = btn.dataset.buttonName || btn.dataset.customBtn || "";
    if (!name) return;
    const bucket = getSelectedBucket();
    const masterRow = bucket.master || null;
    const detailRow = bucket.lastDetailRow || null;
    const ctx = {
      buttonName: name,
      itemId,
      domId,
      masterRow,
      detailRow,
      paperNum: pickPaperNum(masterRow)
    };
    const needInEdit = (btn.dataset.bNeedInEdit || "").toString();
    if (needInEdit === "1" && !window._mmdEditing) {
      alert("此按鈕僅能在編輯模式使用，請先點「修改」切換到編輯模式。");
      return;
    }

    // 按自訂按鈕前，若有未儲存的變更，先自動儲存
    const mmdApi = window._mmdApi?.[domId];
    if (mmdApi?.isDirty && typeof mmdApi?.saveAll === 'function') {
      try {
        const saveResult = await mmdApi.saveAll();
        if (!saveResult || !saveResult.ok) return;
      } catch (err) {
        console.error('自訂按鈕前自動儲存失敗', err);
        alert(`儲存失敗: ${err?.message || err}`);
        return;
      }
    }

    const searchTemplate = (btn.dataset.searchTemplate || "").toString().trim().toLowerCase();
    const designType = parseInt(btn.dataset.designType || "0", 10);

    // FormulaTextUpdate DLL → 公式設計編輯器
    const ocxName = (btn.dataset.ocxName || "").toString().trim().toLowerCase();
    if (searchTemplate.includes("formulatextupdate") || ocxName.includes("formulatextupdate")) {
      if (!formulaDesign) { alert("公式設計元件未載入"); return; }
      if (!masterRow) { alert("請先選取一筆 Master 資料列"); return; }
      // 從按鈕參數取得 FactorId(SeqNum=1, 欄位值) 和 SysId(SeqNum=2, 常數)
      try {
        const params = await fetch(`/api/SQUdFormulaDesign/ButtonParams?itemId=${encodeURIComponent(itemId)}&buttonName=${encodeURIComponent(name)}`).then(r => r.json());
        // SeqNum=1: FactorId (欄位值 paramType=0)
        const p1 = params.find(p => p.seqNum === 1);
        const factorField = p1?.paramFieldName || 'FactorId';
        const factorId = masterRow[factorField] || masterRow.FactorId || masterRow.factorId || "";
        if (!factorId) { alert("無法取得 FactorId，請先選取資料列"); return; }
        // SeqNum=2: SysId (常數 paramType=1)
        const p2 = params.find(p => p.seqNum === 2);
        const sysId = (p2?.paramType === 1) ? p2.paramFieldName : 'SQU';
        // SeqNum=3: FactorType (欄位值 paramType=0)
        const p3 = params.find(p => p.seqNum === 3);
        const ftField = p3?.paramFieldName || 'FactorType';
        const factorTypeVal = masterRow[ftField] || masterRow.FactorType || masterRow.factorType || '';
        await formulaDesign.open(sysId, factorId, factorTypeVal);
      } catch (err) {
        alert(`開啟公式設計失敗: ${err.message}`);
      }
      return;
    }

    if (searchTemplate === "jsdcondrunspdll.dll" && designType === 1) {
      await condRunSp.open(ctx, {
        dialogCaption: btn.dataset.dialogCaption || "",
        onSuccess: async () => {
          window._mmdApi?.[domId]?.reloadDetails?.();
        }
      });
      return;
    }

    if (searchTemplate === "jsdpapersearchdll.dll") {
      if (designType !== 1) {
        alert("此按鈕 SearchTemplate=JSdPaperSearchDLL.dll，但 DesignType 不是 1，請調整按鈕設定。");
        return;
      }
      try {
        const meta = {
          dialogCaption: btn.dataset.dialogCaption || "",
          allowSelCount: btn.dataset.allowSelCount || 0,
          replaceExists: btn.dataset.replaceExists || 0,
          multiSelectDd: btn.dataset.multiSelectDd || ""
        };
        window.__paperSearchOnDone = async () => { localStorage.setItem(afterSave, 1); location.reload(); };
        await window.paperSearch.open(ctx, meta);
      } catch (err) {
        console.error("paper search template error", err);
        alert(`執行失敗: ${err?.message || err}`);
      }
      return;
    }

    if (designType === 3) {
      try {
        const resp = await fetch('/api/StoredProc/execByButton', withJwtHeaders({
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            itemId: ctx.itemId,
            buttonName: ctx.buttonName,
            paperNum: ctx.paperNum,
            args: {
              opKind: window._mmdEditing ? 1 : 0,
              masterRow,
              detailRow
            }
          })
        }));
        const raw = await resp.text();
        let data; try { data = JSON.parse(raw); } catch { data = { ok: false, error: raw }; }
        if (resp.ok && data.ok) {
          const msgRaw = String(data.message ?? data.Message ?? "").trim();
          const msgText = msgRaw.replace(/^MESGE:\s*/i, "").trim();

          const total = Number(data.total ?? data.Total);
          const sent = Number(data.sent ?? data.Sent);
          const skipped = Number(data.skipped ?? data.Skipped);
          const hasStats = Number.isFinite(total) && Number.isFinite(sent) && Number.isFinite(skipped);

          const title = hasStats
            ? "已寄出"
            : (msgText || "執行完成");
          const tip = hasStats
            ? `已寄出 ${sent} 筆（總數 ${total}，略過 ${skipped}）`
            : msgText;

          // 執行完畢後重新載入所有 detail 頁籤
          window._mmdApi?.[domId]?.reloadDetails?.();

          if (window.Swal?.fire) {
            await Swal.fire({
              icon: "success",
              title,
              text: tip,
              timer: 1800,
              showConfirmButton: false
            });
          } else {
            alert(tip || title);
          }
          return;
        }
        alert(`執行失敗: ${data.error || `HTTP ${resp.status}`}`);
      } catch (err) {
        alert(`執行失敗: ${err?.message || err}`);
      }
      return;
    }

    alert(`尚未實作按鈕: ${name}`);
  };

  bar.querySelectorAll('[data-custom-btn]').forEach(btn => {
    if (btn.dataset.cbBound === "1") return;
    btn.dataset.cbBound = "1";
    btn.addEventListener('click', () => runCustomButton(btn));
  });
});
</script>
