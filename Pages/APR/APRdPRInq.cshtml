@page "/APR/APRdPRInq"
@using PcbErpApi.Models
@model PcbErpApi.Pages.APR.APRdPRInqModel
@{
    Layout = "_InquiryTemplate";
    ViewData["Title"] = Model.PageTitle;
    ViewData["ShowInqHeader"] = false;
    ViewData["ShowInqRail"] = true;
    ViewData["InqRailWidth"] = "120px";
    ViewData["InqBodyFill"] = true;
}

<style>
  /* 50/50 split */
  .inq-split-container {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }
  .inq-split-master {
    flex: 0 0 50%;
    min-height: 8%;
    overflow: auto;
  }
  .inq-split-resizer {
    flex: 0 0 6px;
    background: #e1e7f0;
    cursor: row-resize;
    position: relative;
    z-index: 10;
    transition: background 0.15s;
    border-radius: 3px;
    margin: 2px 0;
  }
  .inq-split-resizer:hover,
  .inq-split-resizer.active {
    background: #5b8def;
  }
  .inq-split-resizer::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 2px;
    background: #fff;
    border-radius: 1px;
    opacity: 0.7;
  }
  .inq-split-detail {
    flex: 1 1 0;
    min-height: 8%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  /* Detail tabs */
  .detail-section {
    flex: 1 1 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .detail-tabs {
    flex: 0 0 auto;
  }
  .detail-tabs .nav-link {
    font-size: 0.82rem;
    padding: 4px 12px;
  }
  .detail-tab-content {
    border: 1px solid #d8dee8;
    border-top: 0;
    border-radius: 0 0 8px 8px;
    background: #fff;
    padding: 0;
    overflow: auto;
    min-height: 0;
  }
  .detail-section > .tab-content {
    flex: 1 1 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .detail-section > .tab-content > .tab-pane.active {
    flex: 1 1 0;
    min-height: 0;
    overflow: auto;
  }
  .detail-toolbar {
    padding: 4px 8px;
    background: #f8fafc;
    border-bottom: 1px solid #e1e7f0;
    position: sticky;
    top: 0;
    z-index: 3;
  }
  .detail-toolbar .btn {
    font-size: 0.78rem;
    padding: 2px 10px;
  }
  #tabCertif .inq-table th {
    top: 35px;
  }
  .detail-tab-content .inq-table input[type="checkbox"] {
    height: auto;
    width: auto;
    padding: 0;
    display: block;
    margin: 0 auto;
  }
</style>

@section InqRail {
    <button type="submit" form="inqForm" class="inq-rail-btn">查詢</button>
    <button type="button" class="inq-rail-btn" id="btnExportExcel">匯出Excel</button>
    <button type="button" class="inq-rail-btn" id="btnPaperTrace">單據追蹤</button>
<button type="button" class="inq-rail-btn" id="btnSaveHeight">儲存高度設定</button>
    <button type="button" class="inq-rail-btn" id="btnEditDict">編輯辭典</button>
    <button type="button" class="inq-rail-btn" id="btnResetParams">重設參數</button>
    <button type="button" class="inq-rail-btn" id="btnClearInq">清除</button>
    <div class="inq-rail-status">
      <div>資料筆數：<span id="inqTotalCount">0</span></div>
      <div>目前位置：<span id="inqCurrentPos">0</span></div>
    </div>
}


@{
  var gDict = Model.GridDictFields ?? new List<CURdTableField>();
  var gFields = gDict
      .Where(f => (f.Visible ?? 1) != 0)
      .OrderBy(f => f.SerialNum ?? int.MaxValue)
      .ToList();

  string GLabel(CURdTableField f) => string.IsNullOrWhiteSpace(f.DisplayLabel) ? f.FieldName : f.DisplayLabel!;

  bool IsCheckbox(CURdTableField f)
  {
      if ((f.ComboStyle ?? 0) == 1) return true;
      var dt = (f.DataType ?? "").ToLowerInvariant();
      if (dt.Contains("bit")) return true;
      if (dt.Contains("tinyint") || dt.Contains("int"))
      {
          var n = f.FieldName?.TrimStart('@') ?? "";
          if (n.StartsWith("i", StringComparison.OrdinalIgnoreCase) || n.StartsWith("b", StringComparison.OrdinalIgnoreCase))
              return true;
      }
      return false;
  }

  object? GVal(object? row, string? name)
  {
      if (row == null || string.IsNullOrWhiteSpace(name)) return null;
      if (row is IDictionary<string, object?> dict)
      {
          if (dict.TryGetValue(name, out var v)) return v;
          var key = dict.Keys.FirstOrDefault(k => string.Equals(k, name, StringComparison.OrdinalIgnoreCase));
          return key != null ? dict[key] : null;
      }
      var prop = row.GetType().GetProperty(name, System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.IgnoreCase);
      return prop?.GetValue(row);
  }

  string GFormat(object? v, CURdTableField f)
  {
      return FormatHelper.FormatValue(v, f.DataType, f.FormatStr);
  }

  // Detail dict helpers
  List<CURdTableField> VisibleFields(List<CURdTableField> fields)
      => fields.Where(f => (f.Visible ?? 1) != 0).OrderBy(f => f.SerialNum ?? int.MaxValue).ToList();

  var detailFields = VisibleFields(Model.DetailDictFields);
  var certifFields = VisibleFields(Model.CertifDictFields);
  var strikeFields = VisibleFields(Model.StrikeDictFields);
}

<!-- Master + Detail 50/50 layout -->
<div class="inq-split-container">

<!-- Master Grid -->
<div class="inq-table-wrap inq-split-master">
  <table class="table table-sm table-hover align-middle inq-table" id="masterGrid">
    <thead>
      <tr>
        @foreach (var f in gFields)
        {
          <th class="inq-sortable" data-field="@f.FieldName">
            <span class="th-text">@GLabel(f)</span>
            <span class="col-resizer" draggable="false"></span>
          </th>
        }
      </tr>
    </thead>
    <tbody>
    @if (Model.Items.Count == 0)
    {
      <tr>
        <td colspan="@(Math.Max(1, gFields.Count))" class="text-center text-muted py-2">沒有資料</td>
      </tr>
    }
    else
    {
      foreach (var row in Model.Items)
      {
        var paperId = GVal(row, "PaperId")?.ToString() ?? "";
        var paperNum = GVal(row, "PaperNum")?.ToString() ?? "";
        <tr data-paper-id="@paperId" data-paper-num="@paperNum">
          @foreach (var f in gFields)
          {
            var val = GVal(row, f.FieldName);
            <td>@GFormat(val, f)</td>
          }
        </tr>
      }
    }
    </tbody>
  </table>
</div>

<!-- Split Resizer -->
<div class="inq-split-resizer" id="splitResizer" title="拖曳調整上下比例"></div>

<!-- Detail Tabs (Delphi PageControl1: 3 tabs) -->
<div class="detail-section inq-split-detail">
  <ul class="nav nav-tabs detail-tabs" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabDetail" type="button" role="tab">單據資料</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabCertif" type="button" role="tab">憑證明細</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabStrike" type="button" role="tab">沖帳明細</button>
    </li>
  </ul>
  <div class="tab-content">
    <!-- Tab1: 單據資料 (Delphi dbgSub / qryDetail) -->
    <div class="tab-pane fade show active detail-tab-content" id="tabDetail" role="tabpanel">
      <table class="table table-sm table-hover align-middle inq-table" id="gridDetail">
        <thead>
          <tr>
            @foreach (var f in detailFields)
            {
              <th class="inq-sortable" data-field="@f.FieldName">
                <span class="th-text">@GLabel(f)</span>
                <span class="col-resizer" draggable="false"></span>
              </th>
            }
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="@(Math.Max(1, detailFields.Count))" class="text-center text-muted py-2">請選擇主檔資料</td></tr>
        </tbody>
      </table>
    </div>
    <!-- Tab2: 憑證明細 (Delphi dbgCertif / qryOrderSub) -->
    <div class="tab-pane fade detail-tab-content" id="tabCertif" role="tabpanel">
      <div class="detail-toolbar">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btnCertifTraceInTab">憑證來源追蹤</button>
      </div>
      <table class="table table-sm table-hover align-middle inq-table" id="gridCertif">
        <thead>
          <tr>
            @foreach (var f in certifFields)
            {
              <th class="inq-sortable" data-field="@f.FieldName">
                <span class="th-text">@GLabel(f)</span>
                <span class="col-resizer" draggable="false"></span>
              </th>
            }
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="@(Math.Max(1, certifFields.Count))" class="text-center text-muted py-2">請選擇主檔資料</td></tr>
        </tbody>
      </table>
    </div>
    <!-- Tab3: 沖帳明細 (Delphi dbgStrike / qryOutSubInq) -->
    <div class="tab-pane fade detail-tab-content" id="tabStrike" role="tabpanel">
      <table class="table table-sm table-hover align-middle inq-table" id="gridStrike">
        <thead>
          <tr>
            @foreach (var f in strikeFields)
            {
              <th class="inq-sortable" data-field="@f.FieldName">
                <span class="th-text">@GLabel(f)</span>
                <span class="col-resizer" draggable="false"></span>
              </th>
            }
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="@(Math.Max(1, strikeFields.Count))" class="text-center text-muted py-2">請選擇主檔資料</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

</div><!-- end inq-split-container -->

@if (Model.TotalPages > 1)
{
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-1">
    <div class="d-flex align-items-center gap-1">
      <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber <= 1 ? "disabled" : "")"
         href="@(Model.PageNumber <= 1 ? "#" : Model.BuildPageUrl(Model.PageNumber - 1))">上一頁</a>
      <span>Page: <strong>@Model.PageNumber</strong> / <span>@Model.TotalPages</span></span>
      <a class="btn btn-outline-secondary btn-sm @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")"
         href="@(Model.PageNumber >= Model.TotalPages ? "#" : Model.BuildPageUrl(Model.PageNumber + 1))">下一頁</a>
    </div>
    <div class="text-muted">Total: @Model.TotalCount</div>
  </div>
}

<script>
  const pageItemId = "@Model.ResolvedItemId";
  const basePath = "/APR/APRdPRInq";
  const totalCount = @Model.TotalCount;
  const totalEl = document.getElementById("inqTotalCount");
  const posEl = document.getElementById("inqCurrentPos");
  if (totalEl) totalEl.textContent = String(totalCount);

  const masterRows = Array.from(document.querySelectorAll("#masterGrid tbody tr"));
  let selectedRow = null;
  let selectedDetailRow = null;
  let selectedCertifRow = null;
  let selectedStrikeRow = null;

  const setPos = (idx) => {
    if (!posEl) return;
    posEl.textContent = totalCount === 0 ? "0" : String(idx);
  };

  // Show summary if rows have summary fields
  if (totalCount > 0) {
    const firstRow = masterRows[0];
    if (firstRow) {
      setPos(1);
      selectedRow = firstRow;
      firstRow.classList.add("table-active");
      loadDetailForRow(firstRow);
    }
  }

  masterRows.forEach((tr, i) => {
    tr.addEventListener("click", () => {
      masterRows.forEach(r => r.classList.remove("table-active"));
      tr.classList.add("table-active");
      selectedRow = tr;
      setPos(i + 1);
      loadDetailForRow(tr);
    });
  });


  // Detail dict field names for rendering
  const detailFieldNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(detailFields.Select(f => f.FieldName ?? "")));
  const certifFieldNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(certifFields.Select(f => f.FieldName ?? "")));
  const strikeFieldNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(strikeFields.Select(f => f.FieldName ?? "")));

  // Checkbox field sets per detail tab (from dict ComboStyle / DataType)
  const detailCheckFields = new Set(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(detailFields.Where(f => IsCheckbox(f)).Select(f => (f.FieldName ?? "").ToLowerInvariant()))));
  const certifCheckFields = new Set(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(certifFields.Where(f => IsCheckbox(f)).Select(f => (f.FieldName ?? "").ToLowerInvariant()))));
  const strikeCheckFields = new Set(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(strikeFields.Where(f => IsCheckbox(f)).Select(f => (f.FieldName ?? "").ToLowerInvariant()))));

  // Format helpers for detail grid values
  function formatDetailVal(v, isCheck) {
    if (isCheck) {
      const checked = v === true || v === 1 || v === "1" || v === "True" || v === "true" || v === "Y" || v === "y";
      return `<input type="checkbox" disabled ${checked ? "checked" : ""} >`;
    }
    if (v == null) return "";
    if (typeof v === "string" && /^\d{4}-\d{2}-\d{2}T/.test(v)) {
      return v.substring(0, 10);
    }
    return String(v);
  }

  function renderDetailGrid(tbodySelector, fields, rows, checkFields) {
    const tbody = document.querySelector(tbodySelector);
    if (!tbody) return;
    // Read current header order from DOM (respects drag reorder)
    const table = tbody.closest("table");
    const currentFields = table
      ? Array.from(table.querySelectorAll("thead th")).map(th => th.dataset.field).filter(Boolean)
      : fields;
    const cols = currentFields.length > 0 ? currentFields : fields;
    const chk = checkFields || new Set();
    if (!rows || rows.length === 0) {
      tbody.innerHTML = `<tr><td colspan="${Math.max(1, cols.length)}" class="text-center text-muted py-2">沒有資料</td></tr>`;
      return;
    }
    tbody.innerHTML = rows.map(row => {
      const cells = cols.map(f => {
        const key = Object.keys(row).find(k => k.toLowerCase() === f.toLowerCase()) || f;
        const isCheck = chk.has(f.toLowerCase());
        return `<td>${formatDetailVal(row[key], isCheck)}</td>`;
      }).join("");
      const pnum = row.PaperNum || row.paperNum || "";
      const pid = row.PaperId || row.paperId || "";
      return `<tr data-paper-num="${pnum}" data-paper-id="${pid}">${cells}</tr>`;
    }).join("");
  }

  async function loadDetailForRow(tr) {
    const pnum = tr.getAttribute("data-paper-num");
    if (!pnum) return;

    // Load all 3 detail tabs in parallel
    const [detailRes, certifRes, strikeRes] = await Promise.all([
      fetch(`${basePath}?handler=Detail&paperNum=${encodeURIComponent(pnum)}&itemId=${encodeURIComponent(pageItemId)}`).then(r => r.json()).catch(() => ({ rows: [] })),
      fetch(`${basePath}?handler=Certif&paperNum=${encodeURIComponent(pnum)}&itemId=${encodeURIComponent(pageItemId)}`).then(r => r.json()).catch(() => ({ rows: [] })),
      fetch(`${basePath}?handler=Strike&paperNum=${encodeURIComponent(pnum)}&itemId=${encodeURIComponent(pageItemId)}`).then(r => r.json()).catch(() => ({ rows: [] }))
    ]);

    renderDetailGrid("#gridDetail tbody", detailFieldNames, detailRes.rows || [], detailCheckFields);
    renderDetailGrid("#gridCertif tbody", certifFieldNames, certifRes.rows || [], certifCheckFields);
    renderDetailGrid("#gridStrike tbody", strikeFieldNames, strikeRes.rows || [], strikeCheckFields);

    // Bind detail row selection
    const detailRows = Array.from(document.querySelectorAll("#gridDetail tbody tr"));
    selectedDetailRow = detailRows.length > 0 ? detailRows[0] : null;
    if (selectedDetailRow) selectedDetailRow.classList.add("table-active");
    detailRows.forEach(dr => {
      dr.addEventListener("click", () => {
        detailRows.forEach(r => r.classList.remove("table-active"));
        dr.classList.add("table-active");
        selectedDetailRow = dr;
      });
    });

    // Bind certif row selection
    const certifRows = Array.from(document.querySelectorAll("#gridCertif tbody tr"));
    selectedCertifRow = certifRows.length > 0 ? certifRows[0] : null;
    if (selectedCertifRow) selectedCertifRow.classList.add("table-active");
    certifRows.forEach(cr => {
      cr.addEventListener("click", () => {
        certifRows.forEach(r => r.classList.remove("table-active"));
        cr.classList.add("table-active");
        selectedCertifRow = cr;
      });
    });

    // Bind strike row selection
    const strikeRows = Array.from(document.querySelectorAll("#gridStrike tbody tr"));
    selectedStrikeRow = strikeRows.length > 0 ? strikeRows[0] : null;
    if (selectedStrikeRow) selectedStrikeRow.classList.add("table-active");
    strikeRows.forEach(sr => {
      sr.addEventListener("click", () => {
        strikeRows.forEach(r => r.classList.remove("table-active"));
        sr.classList.add("table-active");
        selectedStrikeRow = sr;
      });
    });
  }

  // Clear
  document.getElementById("btnClearInq")?.addEventListener("click", () => {
    window.location.href = `${basePath}?itemId=${encodeURIComponent(pageItemId)}`;
  });

  // Sort
  const parseSortValue = (text) => {
    if (text == null) return "";
    const t = String(text).trim();
    if (!t) return "";
    const d = t.match(/^(\d{4})[\/-](\d{2})[\/-](\d{2})$/);
    if (d) return new Date(`${d[1]}-${d[2]}-${d[3]}`).getTime();
    const n = t.replace(/,/g, "");
    if (!isNaN(n) && n !== "") return parseFloat(n);
    return t.toLowerCase();
  };

  const sortTableByColumn = (table, colIndex, asc) => {
    const tbody = table.querySelector("tbody");
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll("tr"))
      .filter(r => !r.querySelector("td[colspan]"));
    const dir = asc ? 1 : -1;
    rows.sort((a, b) => {
      const aText = a.children[colIndex]?.textContent ?? "";
      const bText = b.children[colIndex]?.textContent ?? "";
      const av = parseSortValue(aText);
      const bv = parseSortValue(bText);
      if (av < bv) return -1 * dir;
      if (av > bv) return 1 * dir;
      return 0;
    });
    rows.forEach(r => tbody.appendChild(r));
  };

  const masterTable = document.getElementById("masterGrid");
  if (masterTable) {
    const headers = Array.from(masterTable.querySelectorAll("thead th"));
    headers.forEach((th, idx) => {
      th.addEventListener("click", (e) => {
        if (e.target && e.target.classList?.contains("col-resizer")) return;
        if (th.dataset.resizing === "1") return;
        const isAsc = !th.classList.contains("inq-sort-asc");
        headers.forEach(h => h.classList.remove("inq-sort-asc", "inq-sort-desc"));
        th.classList.add(isAsc ? "inq-sort-asc" : "inq-sort-desc");
        sortTableByColumn(masterTable, idx, isAsc);
      });
    });
  }

  // Column resize
  const dictTableName = "@(Model.DictTableName ?? "")";
  const fieldNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(gFields.Select(f => f.FieldName ?? "")));

  function applyColumnWidth(table, ths, index, width) {
    const w = Math.max(20, Math.round(width));
    const th = ths[index];
    if (!th) return;
    th.style.width = `${w}px`;
    th.style.minWidth = `${w}px`;
    Array.from(table.querySelectorAll(`tbody tr td:nth-child(${index + 1})`))
      .forEach(td => { td.style.width = `${w}px`; td.style.minWidth = `${w}px`; });
  }

  function applySavedWidths(table, dictTable, fields) {
    const tn = (dictTable || "").trim();
    if (!tn) return;
    try {
      const raw = localStorage.getItem(`colwidth:${tn}`);
      if (!raw) return;
      const cols = JSON.parse(raw) || [];
      const ths = Array.from(table.querySelectorAll('thead th'));
      cols.forEach(c => {
        const f = (c.fieldName || '').toString();
        const w = Number(c.width);
        if (!f || !Number.isFinite(w)) return;
        const idx = fields.findIndex(x => x.toLowerCase() === f.toLowerCase());
        if (idx >= 0) applyColumnWidth(table, ths, idx, w);
      });
    } catch { }
  }

  function initColumnResize(tableEl, dictTable, fields) {
    if (!tableEl) return;
    const ths = Array.from(tableEl.querySelectorAll('thead th'));
    applySavedWidths(tableEl, dictTable, fields);

    let isResizing = false;
    let startX = 0;
    let startWidth = 0;
    let thIndex = -1;

    ths.forEach((th, idx) => {
      const handle = th.querySelector('.col-resizer');
      if (!handle) return;
      handle.addEventListener('mousedown', (e) => {
        e.preventDefault();
        isResizing = true;
        startX = e.pageX;
        startWidth = th.getBoundingClientRect().width;
        thIndex = idx;
        document.body.classList.add('resizing');
      });
    });

    document.addEventListener('mousemove', (e) => {
      if (!isResizing || thIndex < 0) return;
      const dx = e.pageX - startX;
      const newW = Math.max(20, startWidth + dx);
      applyColumnWidth(tableEl, ths, thIndex, newW);
    });

    document.addEventListener('mouseup', () => {
      if (!isResizing) return;
      isResizing = false;
      document.body.classList.remove('resizing');
      const tn = (dictTable || "").trim();
      if (tn) {
        const payload = ths.map(th => ({ fieldName: th.dataset.field, width: Math.round(th.getBoundingClientRect().width) }));
        try { localStorage.setItem(`colwidth:${tn}`, JSON.stringify(payload)); } catch { }
      }
      thIndex = -1;
    });
  }

  initColumnResize(masterTable, dictTableName, fieldNames);

  // Detail tab tables: sort, resize, drag reorder
  const detailTable = document.getElementById("gridDetail");
  const certifTable = document.getElementById("gridCertif");
  const strikeTable = document.getElementById("gridStrike");

  // Sort click handlers for detail tabs (same as master)
  function initSortForTable(tableEl) {
    if (!tableEl) return;
    const headers = Array.from(tableEl.querySelectorAll("thead th"));
    headers.forEach((th) => {
      th.addEventListener("click", (e) => {
        if (e.target && e.target.classList?.contains("col-resizer")) return;
        if (th.dataset.resizing === "1") return;
        // Use current DOM index (may change after drag reorder)
        const currentIdx = Array.from(th.parentElement.children).indexOf(th);
        const isAsc = !th.classList.contains("inq-sort-asc");
        th.parentElement.querySelectorAll("th").forEach(h => h.classList.remove("inq-sort-asc", "inq-sort-desc"));
        th.classList.add(isAsc ? "inq-sort-asc" : "inq-sort-desc");
        sortTableByColumn(tableEl, currentIdx, isAsc);
      });
    });
  }
  initSortForTable(detailTable);
  initSortForTable(certifTable);
  initSortForTable(strikeTable);

  // Column resize for detail tabs
  initColumnResize(detailTable, "APRdPRSubInq", detailFieldNames);
  initColumnResize(certifTable, "APRdCertifInq", certifFieldNames);
  initColumnResize(strikeTable, "APRdStrikeInq", strikeFieldNames);

  // Column drag reorder (SortableJS) for detail tabs
  if (window.initColumnDragSort) {
    const initDrag = (tableEl, tableName, fieldsArr) => {
      if (!tableEl) return;
      const hRow = tableEl.querySelector("thead tr");
      if (hRow) {
        initColumnDragSort({
          headerRow: hRow,
          tbody: tableEl.querySelector("tbody"),
          scrollWrap: tableEl.closest(".detail-tab-content") || tableEl.closest(".inq-table-wrap") || tableEl.parentElement,
          tableName: tableName,
          fieldsArray: fieldsArr,
          onSaved: null
        });
      }
    };
    initDrag(detailTable, "APRdPRSubInq", detailFieldNames.map(f => ({ FieldName: f })));
    initDrag(certifTable, "APRdCertifInq", certifFieldNames.map(f => ({ FieldName: f })));
    initDrag(strikeTable, "APRdStrikeInq", strikeFieldNames.map(f => ({ FieldName: f })));
  }

  // Form submit
  const inqForm = document.getElementById("inqForm");
  inqForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    const fd = new FormData(inqForm);
    const params = new URLSearchParams();
    for (const [k, v] of fd.entries()) {
      const val = (v ?? "").toString().trim();
      if (!val) continue;
      params.append(k, val);
    }
    if (new URLSearchParams(window.location.search).has("debug")) {
      params.set("debug", "1");
    }
    const qs = params.toString();
    window.location.href = qs ? (`${basePath}?${qs}`) : `${basePath}?itemId=${encodeURIComponent(pageItemId)}`;
  });

  // Export Excel
  document.getElementById("btnExportExcel")?.addEventListener("click", () => {
    const url = new URL(window.location.href);
    url.searchParams.set("handler", "Export");
    window.location.href = url.toString();
  });

  const currentUserId = "@Model.CurrentUserId";
  const currentUseId = "@Model.CurrentUseId";

  // Delphi btnPaperTraceClick: trace based on focused grid
  document.getElementById("btnPaperTrace")?.addEventListener("click", async () => {
    // Determine which sub-grid has focus, or use master grid
    let tracePaperId = "";
    let tracePaperNum = "";

    const activeDetail = document.querySelector("#gridDetail tbody tr.table-active");
    const activeCertif = document.querySelector("#gridCertif tbody tr.table-active");
    const activeStrike = document.querySelector("#gridStrike tbody tr.table-active");
    const activeTab = document.querySelector(".detail-tabs .nav-link.active");
    const tabTarget = activeTab?.getAttribute("data-bs-target") || "";

    if (tabTarget === "#tabDetail" && activeDetail) {
      tracePaperId = activeDetail.getAttribute("data-paper-id") || "";
      tracePaperNum = activeDetail.getAttribute("data-paper-num") || "";
    } else if (tabTarget === "#tabCertif" && activeCertif) {
      tracePaperId = activeCertif.getAttribute("data-paper-id") || "";
      tracePaperNum = activeCertif.getAttribute("data-paper-num") || "";
    } else if (tabTarget === "#tabStrike" && activeStrike) {
      tracePaperId = activeStrike.getAttribute("data-paper-id") || "";
      tracePaperNum = activeStrike.getAttribute("data-paper-num") || "";
    } else if (selectedRow) {
      tracePaperId = selectedRow.getAttribute("data-paper-id") || "";
      tracePaperNum = selectedRow.getAttribute("data-paper-num") || "";
    }

    if (!tracePaperId || !tracePaperNum) return alert("請先選擇一筆資料");

    try {
      const res = await fetch("/api/Flow/ResolveItemIdByFromType", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ paperId: tracePaperId, paperNum: tracePaperNum, userId: currentUserId, useId: currentUseId })
      });
      if (res.ok) {
        const data = await res.json();
        const itemId = data.itemId || tracePaperId;
        window.open(`/DynamicTemplate/Paper/${encodeURIComponent(itemId)}/${encodeURIComponent(tracePaperNum)}`, "_blank");
        return;
      }
    } catch {}
    window.open(`/DynamicTemplate/Paper/${encodeURIComponent(tracePaperId)}/${encodeURIComponent(tracePaperNum)}`, "_blank");
  });

  // Delphi btnCertifTraceClick: trace certif source via qryCertifId
  async function doCertifTrace() {
    const certifRow = selectedCertifRow || document.querySelector("#gridCertif tbody tr.table-active");
    if (!certifRow) return alert("請先在憑證明細頁籤選擇一筆資料");
    const pnum = certifRow.getAttribute("data-paper-num") || "";
    if (!pnum) return alert("找不到憑證單號");

    try {
      const res = await fetch(`${basePath}?handler=CertifTrace&certifPaperNum=${encodeURIComponent(pnum)}&itemId=${encodeURIComponent(pageItemId)}`);
      if (res.ok) {
        const data = await res.json();
        if (data.ok && data.paperNum && data.paperId) {
          let itemId = data.paperId;
          try {
            const r2 = await fetch("/api/Flow/ResolveItemIdByFromType", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ paperId: data.paperId, paperNum: data.paperNum, userId: currentUserId, useId: currentUseId })
            });
            if (r2.ok) {
              const d2 = await r2.json();
              itemId = d2.itemId || data.paperId;
            }
          } catch {}
          window.open(`/DynamicTemplate/Paper/${encodeURIComponent(itemId)}/${encodeURIComponent(data.paperNum)}`, "_blank");
          return;
        }
        alert(data.message || "找不到憑證來源單據");
        return;
      }
    } catch {}
    alert("憑證來源追蹤查詢失敗");
  }

  document.getElementById("btnCertifTrace")?.addEventListener("click", doCertifTrace);
  document.getElementById("btnCertifTraceInTab")?.addEventListener("click", doCertifTrace);

  // Save height
  document.getElementById("btnSaveHeight")?.addEventListener("click", async () => {
    const h = document.querySelector(".inq-body")?.clientHeight || 0;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
    const res = await fetch("/api/MatInfoUtility/SaveBrowseHeight", {
      method: "POST",
      headers: { "Content-Type": "application/json", "RequestVerificationToken": token },
      body: JSON.stringify({ itemId: pageItemId, height: h })
    });
    if (!res.ok) return alert("儲存失敗");
    alert("已儲存高度設定");
  });

  // Reset params
  document.getElementById("btnResetParams")?.addEventListener("click", async () => {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
    const res = await fetch(`${basePath}?handler=ResetParams&itemId=${encodeURIComponent(pageItemId)}`, {
      method: "POST",
      headers: { "RequestVerificationToken": token }
    });
    if (!res.ok) return alert("重設失敗");
    alert("已重設參數");
    window.location.reload();
  });

  // Lookup suggest (aligned with shared _InquiryTemplate behavior)
  const resolveCondValue = (name) => {
    if (!name) return "";
    const el = document.querySelector(`[name="${name}"]`);
    if (!el) return "";
    if (el.type === "checkbox") return el.checked ? "1" : "0";
    return el.value || "";
  };

  const parseItems = (raw) => {
    if (!raw) return [];
    return raw.split(/[;,]/).map(p => p.trim()).filter(Boolean).map(p => {
      const kv = p.split(/=|:/);
      if (kv.length >= 2) return { value: kv[0].trim(), label: kv.slice(1).join(":").trim() };
      return { value: p, label: p };
    });
  };

  const nameFromLabel = (val, lbl) => {
    if (!lbl) return val || "";
    const pfx = String(val || "").trim() + " - ";
    return lbl.startsWith(pfx) ? lbl.slice(pfx.length) : lbl;
  };

  const buildCondKey = (el) => {
    const table = el.dataset.lookupTable || "";
    const key = el.dataset.lookupKey || "";
    const result = el.dataset.lookupResult || "";
    const cond1Field = (el.dataset.cond1Field || "").trim();
    const cond1Source = (el.dataset.cond1Source || "").trim();
    const cond2Field = (el.dataset.cond2Field || "").trim();
    const cond2Source = (el.dataset.cond2Source || "").trim();
    const cond1ValueField = cond1Source || cond1Field;
    const cond2ValueField = cond2Source || cond2Field;
    const cond1Value = cond1ValueField ? resolveCondValue(cond1ValueField) : "";
    const cond2Value = cond2ValueField ? resolveCondValue(cond2ValueField) : "";
    const items = el.dataset.items || "";
    return [table, key, result, cond1Field, cond1Value, cond2Field, cond2Value, items].join("|");
  };

  const fetchLookupOptions = async (el) => {
    const items = parseItems(el.dataset.items || "");
    const table = el.dataset.lookupTable || "";
    const key = el.dataset.lookupKey || "";
    const result = el.dataset.lookupResult || "";
    const selected = el.dataset.selected || "";

    let options = [...items];

    if (table && key && result) {
      const cond1Field = (el.dataset.cond1Field || "").trim();
      const cond1Source = (el.dataset.cond1Source || "").trim();
      const cond2Field = (el.dataset.cond2Field || "").trim();
      const cond2Source = (el.dataset.cond2Source || "").trim();
      const cond1ValueField = cond1Source || cond1Field;
      const cond2ValueField = cond2Source || cond2Field;
      const cond1Value = cond1ValueField ? resolveCondValue(cond1ValueField) : "";
      const cond2Value = cond2ValueField ? resolveCondValue(cond2ValueField) : "";

      const url = `/api/TableFieldLayout/LookupData?table=${encodeURIComponent(table)}&key=${encodeURIComponent(key)}&result=${encodeURIComponent(result)}`
        + (cond1Field && cond1Value ? `&cond1Field=${encodeURIComponent(cond1Field)}&cond1Value=${encodeURIComponent(cond1Value)}` : "")
        + (cond2Field && cond2Value ? `&cond2Field=${encodeURIComponent(cond2Field)}&cond2Value=${encodeURIComponent(cond2Value)}` : "");
      const res = await fetch(url);
      if (res.ok) {
        const data = await res.json();
        if (Array.isArray(data)) {
          const lookups = data.map(row => {
            const val = row?.key ?? "";
            const label = Object.keys(row || {}).filter(k => k.startsWith("result")).map(k => row[k]).join(" - ");
            return { value: String(val), label: label || String(val) };
          });
          options = options.concat(lookups);
        }
      }
    }

    const map = new Map();
    options.forEach(o => { if (!o.value) return; if (!map.has(o.value)) map.set(o.value, o); });
    if (selected && !map.has(selected)) map.set(selected, { value: selected, label: selected });
    return Array.from(map.values());
  };

  const getCodeInput = (el) => {
    const id = el?.dataset?.codeTarget;
    if (id) return document.getElementById(id);
    return el?.closest(".inq-select")?.querySelector(".inq-select-code-hidden");
  };

  const syncDisplayValue = (displayEl, options) => {
    if (!displayEl) return;
    const codeInput = getCodeInput(displayEl);
    const codeVal = (codeInput?.value || "").toString().trim();
    if (!codeVal) {
      displayEl.value = "";
      const emptyNameBtn = displayEl.closest(".inq-lookup-wrapper")?.querySelector(".inq-name-btn");
      if (emptyNameBtn) emptyNameBtn.textContent = "";
      return;
    }
    const hit = (options || []).find(o => String(o.value).trim() === codeVal);
    const fullLabel = hit ? (hit.label || hit.value) : codeVal;
    const inWrapper = !!displayEl.dataset.codeTarget;
    displayEl.value = inWrapper ? codeVal : fullLabel;
    const nameBtn = displayEl.closest(".inq-lookup-wrapper")?.querySelector(".inq-name-btn");
    if (nameBtn) nameBtn.textContent = nameFromLabel(codeVal, fullLabel);
  };

  const suggest = document.createElement("div");
  suggest.className = "inq-suggest";
  suggest.style.display = "none";
  document.body.appendChild(suggest);
  let suggestTarget = null;
  let suggestOptions = [];
  let keepSuggestUntil = 0;

  const positionSuggest = (el) => {
    const rect = el.getBoundingClientRect();
    suggest.style.left = `${rect.left + window.scrollX}px`;
    suggest.style.top = `${rect.bottom + window.scrollY}px`;
    const width = Math.max(rect.width, 280);
    suggest.style.width = `${width}px`;
  };

  const hideSuggest = () => {
    if (Date.now() < keepSuggestUntil) return;
    suggest.style.display = "none";
    suggest.innerHTML = "";
    suggestTarget = null;
    suggestOptions = [];
  };

  const renderSuggest = (el, list) => {
    const q = (el.value || "").trim().toLowerCase();
    const filtered = q
      ? list.filter(o => (o.value || "").toLowerCase().includes(q) || (o.label || "").toLowerCase().includes(q))
      : list;

    suggest.innerHTML = "";
    if (filtered.length === 0) { hideSuggest(); return; }

    const inWrapper = !!el.dataset.codeTarget;
    filtered.slice(0, 200).forEach(o => {
      const displayLabel = nameFromLabel(o.value, o.label);
      const item = document.createElement("div");
      item.className = "inq-suggest-item";
      item.innerHTML = `<div class="inq-suggest-code">${o.value}</div><div class="inq-suggest-label">${displayLabel}</div>`;
      item.addEventListener("mousedown", (e) => {
        e.preventDefault();
        const codeInput = getCodeInput(el);
        if (codeInput) codeInput.value = o.value;
        el.value = inWrapper ? o.value : (o.label || o.value);
        const nameBtn = el.closest(".inq-lookup-wrapper")?.querySelector(".inq-name-btn");
        if (nameBtn) nameBtn.textContent = nameFromLabel(o.value, o.label);
        hideSuggest();
      });
      suggest.appendChild(item);
    });

    positionSuggest(el);
    suggest.style.display = "block";
  };

  const lookupCache = new Map();

  const showSuggest = async (el) => {
    const key = buildCondKey(el);
    if (!lookupCache.has(key)) {
      const opts = await fetchLookupOptions(el);
      lookupCache.set(key, opts);
    }
    suggestTarget = el;
    suggestOptions = lookupCache.get(key) || [];
    syncDisplayValue(el, suggestOptions);
    renderSuggest(el, suggestOptions);
  };

  document.querySelectorAll(".inq-select-btn").forEach(btn => {
    btn.addEventListener("mousedown", (e) => {
      e.preventDefault();
      keepSuggestUntil = Date.now() + 250;
      const input = btn.previousElementSibling;
      if (input) { input.focus(); showSuggest(input); }
    });
  });

  document.addEventListener("click", (e) => {
    if (!suggestTarget) return;
    if (e.target === suggestTarget || suggest.contains(e.target)) return;
    hideSuggest();
  });

  document.querySelectorAll(".inq-lookup-display[data-lookup-table], .inq-lookup-display[data-items]").forEach(el => {
    el.addEventListener("focus", () => showSuggest(el));
    el.addEventListener("input", () => {
      if (suggestTarget !== el) return showSuggest(el);
      renderSuggest(el, suggestOptions);
    });
    el.addEventListener("blur", () => {
      setTimeout(() => { if (!suggest.matches(":hover")) hideSuggest(); }, 120);
      const codeInput = getCodeInput(el);
      if (!codeInput) return;
      const text = (el.value || "").trim();
      const key = buildCondKey(el);
      const opts = lookupCache.get(key) || [];
      if (!text) {
        codeInput.value = "";
        const nameBtn = el.closest(".inq-lookup-wrapper")?.querySelector(".inq-name-btn");
        if (nameBtn) nameBtn.textContent = "";
        return;
      }
      const hit = opts.find(o => {
        const v = String(o.value ?? "").trim();
        const l = String(o.label ?? "").trim();
        return v === text || l === text;
      });
      if (hit) {
        codeInput.value = hit.value;
        const inWrapper = !!el.dataset.codeTarget;
        el.value = inWrapper ? hit.value : (hit.label || hit.value);
        const nameBtn = el.closest(".inq-lookup-wrapper")?.querySelector(".inq-name-btn");
        if (nameBtn) nameBtn.textContent = nameFromLabel(hit.value, hit.label);
      } else {
        syncDisplayValue(el, opts);
      }
    });
  });

  (async () => {
    const inputs = Array.from(document.querySelectorAll(".inq-lookup-display"));
    for (const el of inputs) {
      if (!(el instanceof HTMLInputElement)) continue;
      const key = buildCondKey(el);
      if (!lookupCache.has(key)) {
        const opts = await fetchLookupOptions(el);
        lookupCache.set(key, opts);
      }
      const opts = lookupCache.get(key) || [];
      syncDisplayValue(el, opts);
    }
  })();

  suggest.addEventListener("mousedown", () => { keepSuggestUntil = Date.now() + 250; });
  // Name-search modal for lookup (same data source as suggest)
  let _inqNsAllRows = [];
  let _inqNsFilteredRows = [];
  let _inqNsCodeInput = null;
  let _inqNsNameBtn = null;

  const bindNameSearchModal = (inqNsModal) => {
    if (!inqNsModal) return false;
    if (inqNsModal.dataset.lookupInit === "1") return true;

    const pickInModal = (idBase) =>
      inqNsModal.querySelector(`#${idBase}`)
      || inqNsModal.querySelector(`[id^="${idBase}"]`);

    const inqNsCodeFilter = pickInModal("inqNameSearchCode");
    const inqNsNameFilter = pickInModal("inqNameSearchName");
    const inqNsBody = pickInModal("inqNameSearchBody");
    const inqNsConfirm = pickInModal("inqNameSearchConfirm");

    if (!inqNsBody || !inqNsConfirm) return false;

    inqNsModal.dataset.lookupInit = "1";

    const renderInqNsRows = () => {
      const cq = (inqNsCodeFilter?.value || "").toLowerCase();
      const nq = (inqNsNameFilter?.value || "").toLowerCase();
      _inqNsFilteredRows = _inqNsAllRows.filter(r =>
        (!cq || (r.value || "").toLowerCase().includes(cq)) &&
        (!nq || (r.label || "").toLowerCase().includes(nq))
      );
      inqNsBody.innerHTML = _inqNsFilteredRows.map((r, i) =>
        '<tr data-idx="' + i + '" style="cursor:pointer;">'
        + '<td style="padding:2px 4px;">' + (r.value || '') + '</td>'
        + '<td style="padding:2px 4px;">' + nameFromLabel(r.value, r.label) + '</td>'
        + '</tr>'
      ).join("");

      inqNsBody.querySelectorAll("tr").forEach(tr => {
        tr.addEventListener("click", () => {
          const idx = Number(tr.dataset.idx);
          if (Number.isFinite(idx) && idx >= 0) applyInqNsRow(_inqNsFilteredRows[idx]);
          bootstrap.Modal.getInstance(inqNsModal)?.hide();
        });
        tr.addEventListener("mouseover", () => {
          inqNsBody.querySelectorAll("tr").forEach(r => r.classList.remove("table-active"));
          tr.classList.add("table-active");
        });
      });
    };

    const applyInqNsRow = (row) => {
      if (!row) return;
      const value = row.value || "";
      if (_inqNsCodeInput) _inqNsCodeInput.value = value;
      if (_inqNsNameBtn) _inqNsNameBtn.textContent = nameFromLabel(value, row.label);

      let displayEl = _inqNsNameBtn?.closest(".inq-lookup-wrapper")?.querySelector(".inq-lookup-display");
      if (!displayEl && _inqNsCodeInput) {
        displayEl = _inqNsCodeInput.parentElement?.querySelector(".inq-lookup-display");
      }
      if (!displayEl) return;

      const inWrapper = !!displayEl.dataset.codeTarget;
      displayEl.value = inWrapper ? value : (row.label || value);
      displayEl.dataset.selected = value;
    };

    inqNsConfirm.addEventListener("click", () => {
      const tr = inqNsBody.querySelector("tr.table-active");
      if (tr) {
        const idx = Number(tr.dataset.idx);
        if (Number.isFinite(idx) && idx >= 0) applyInqNsRow(_inqNsFilteredRows[idx]);
      }
      bootstrap.Modal.getInstance(inqNsModal)?.hide();
    });

    inqNsCodeFilter?.addEventListener("input", renderInqNsRows);
    inqNsNameFilter?.addEventListener("input", renderInqNsRows);

    inqNsModal.addEventListener("show.bs.modal", async (e) => {
      const btn = e.relatedTarget;
      if (!btn) return;
      _inqNsNameBtn = btn;
      const codeTarget = btn.dataset.codeTarget;
      _inqNsCodeInput = codeTarget ? document.getElementById(codeTarget) : null;

      let displayEl = btn.closest(".inq-lookup-wrapper")?.querySelector(".inq-lookup-display");
      if (!displayEl && _inqNsCodeInput) {
        displayEl = _inqNsCodeInput.parentElement?.querySelector(".inq-lookup-display");
      }
      if (!displayEl) {
        _inqNsAllRows = [];
        _inqNsFilteredRows = [];
        renderInqNsRows();
        return;
      }

      if (inqNsCodeFilter) inqNsCodeFilter.value = "";
      if (inqNsNameFilter) inqNsNameFilter.value = "";

      try {
        const key = buildCondKey(displayEl);
        if (!lookupCache.has(key)) {
          lookupCache.set(key, await fetchLookupOptions(displayEl));
        }
        _inqNsAllRows = lookupCache.get(key) || [];
      } catch {
        _inqNsAllRows = [];
      }

      renderInqNsRows();
    });

    return true;
  };

  const initNameSearchModal = () => {
    const modals = Array.from(document.querySelectorAll('.modal[id^="inqNameSearchModal"]'));
    if (!modals.length) return false;
    let ok = false;
    modals.forEach(m => { if (bindNameSearchModal(m)) ok = true; });
    return ok;
  };

  if (!initNameSearchModal()) {
    window.addEventListener("DOMContentLoaded", () => { initNameSearchModal(); }, { once: true });
  }

  // Split resizer drag
  (() => {
    const resizer = document.getElementById("splitResizer");
    const container = resizer?.parentElement;
    const master = container?.querySelector(".inq-split-master");
    const detail = container?.querySelector(".inq-split-detail");
    if (!resizer || !container || !master || !detail) return;

    const STORAGE_KEY = `splitRatio:${pageItemId}`;
    let dragging = false;

    const resizerH = resizer.offsetHeight + 4; // 6px + 4px margin

    const applyRatio = (pct) => {
      const available = container.clientHeight - resizerH;
      const masterH = Math.round(available * pct / 100);
      master.style.flex = `0 0 ${masterH}px`;
      detail.style.flex = '1 1 0';
    };

    // Restore saved ratio
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const pct = parseFloat(saved);
        if (pct > 10 && pct < 90) applyRatio(pct);
      }
    } catch {}

    resizer.addEventListener("mousedown", (e) => {
      e.preventDefault();
      dragging = true;
      resizer.classList.add("active");
      document.body.style.cursor = "row-resize";
      document.body.style.userSelect = "none";
    });

    document.addEventListener("mousemove", (e) => {
      if (!dragging) return;
      const rect = container.getBoundingClientRect();
      const offset = e.clientY - rect.top;
      let pct = (offset / rect.height) * 100;
      pct = Math.max(10, Math.min(90, pct));
      applyRatio(pct);
    });

    document.addEventListener("mouseup", () => {
      if (!dragging) return;
      dragging = false;
      resizer.classList.remove("active");
      document.body.style.cursor = "";
      document.body.style.userSelect = "";
      // Save ratio
      try {
        const rect = container.getBoundingClientRect();
        const masterRect = master.getBoundingClientRect();
        const pct = (masterRect.height / rect.height) * 100;
        localStorage.setItem(STORAGE_KEY, pct.toFixed(1));
      } catch {}
    });
  })();
</script>

<script>
  (function initDictForInq() {
    const dictForQuery = "@Model.ParamTableName";
    const dictForGrid = "@Model.DictTableName";
    const dictForDetail = "APRdPRSubInq";
    const dictForCertif = "APRdCertifInq";
    const dictForStrike = "APRdStrikeInq";
    let currentDict = dictForQuery;

    const setDict = (name) => { currentDict = name || currentDict; window._dictTableName = currentDict; };
    setDict(dictForQuery);

    const queryArea = document.getElementById("inqForm");
    const table = document.getElementById("masterGrid");
    const gridDetail = document.getElementById("gridDetail");
    const gridCertif = document.getElementById("gridCertif");
    const gridStrike = document.getElementById("gridStrike");

    queryArea?.addEventListener("focusin", () => setDict(dictForQuery));
    queryArea?.addEventListener("click", () => setDict(dictForQuery));
    table?.addEventListener("click", () => setDict(dictForGrid));
    gridDetail?.addEventListener("click", () => setDict(dictForDetail));
    gridCertif?.addEventListener("click", () => setDict(dictForCertif));
    gridStrike?.addEventListener("click", () => setDict(dictForStrike));

    const openFieldDict = () => {
      if (typeof window.initFieldDictModal === "function") {
        window.initFieldDictModal(currentDict, "fieldDictModal");
        const el = document.getElementById("fieldDictModal");
        if (el) { const md = bootstrap.Modal.getOrCreateInstance(el); md.show(); }
      } else if (typeof window.loadFieldDict === "function") {
        window.loadFieldDict(currentDict);
      }
    };

    document.getElementById("btnEditDict")?.addEventListener("click", openFieldDict);
    document.addEventListener("keydown", (e) => {
      if (e.key !== "F3") return;
      const target = e.target;
      const inText = target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA");
      if (inText) return;
      e.preventDefault();
      openFieldDict();
    });
  })();
</script>

@if (Request.Query.ContainsKey("debug"))
{
  <div class="mt-3 p-2 border rounded bg-light">
    <div class="fw-bold mb-1">Debug Exec</div>
    <div class="small text-muted">@Model.DebugExecText</div>
    <ul class="small mb-0">
      @foreach (var p in Model.DebugParams)
      {
        <li>@p.Name = @(p.Value ?? "NULL")</li>
      }
    </ul>
    <div class="fw-bold mt-2 mb-1">Debug Query</div>
    <ul class="small mb-0">
      @foreach (var kv in Request.Query)
      {
        <li>@kv.Key = @kv.Value.ToString()</li>
      }
    </ul>
  </div>
}




