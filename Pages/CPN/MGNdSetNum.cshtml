  function pickRowValueCI(row, fieldName) {
    if (!row || !fieldName) return '';
    if (row[fieldName] != null) return row[fieldName];
    const key = String(fieldName).toLowerCase();
    const hit = Object.keys(row).find(k => String(k).toLowerCase() === key);
    return hit ? row[hit] : '';
  }

  function escSel(raw) {
    return String(raw || '').replace(/["\\#.;?+*~':!^$[\]()=>|/\x40]/g, '\\$&');
  }

  function parseLookupItems(rawItems) {
    const text = String(rawItems || '').trim();
    if (!text) return [];
    const parts = text
      .split(/\r?\n|;/)
      .map(x => x.trim())
      .filter(Boolean);
    const out = [];
    for (const p of parts) {
      let value = p;
      let label = p;
      if (p.includes('=')) {
        const i = p.indexOf('=');
        value = p.slice(0, i).trim();
        label = p.slice(i + 1).trim() || value;
      } else if (p.includes(':')) {
        const i = p.indexOf(':');
        value = p.slice(0, i).trim();
        label = p.slice(i + 1).trim() || value;
      } else if (p.includes(',')) {
        const i = p.indexOf(',');
        value = p.slice(0, i).trim();
        label = p.slice(i + 1).trim() || value;
      }
      if (!value) continue;
      out.push({ value, label });
    }
    return out;
  }

  function normalizeLookupIdentifier(raw) {
    const s = String(raw || '').trim();
    if (!s) return '';
    if (/^[A-Za-z0-9_]+$/.test(s)) return s;
    const m = s.match(/[A-Za-z_][A-Za-z0-9_]*/);
    return m ? m[0] : '';
  }

  function normalizeLookupResultForApi(rawResult) {
    return String(rawResult || '')
      .split(',')
      .map(part => {
        const text = String(part || '').trim();
        if (!text) return '';
        const left = text.includes('=') ? text.split('=')[0].trim() : text;
        return normalizeLookupIdentifier(left);
      })
      .filter(Boolean)
      .join(',');
  }

  function getRowFieldValue(tr, fieldName) {
    if (!tr || !fieldName) return '';
    const key = String(fieldName || '').trim();
    if (!key) return '';
    const inp = tr.querySelector(`input.cell-edit[name="${escSel(key)}"]`);
    if (inp) return String(inp.value ?? '').trim();
    const td = tr.querySelector(`td[data-field="${escSel(key)}"]`);
    const fromEdit = td?.querySelector('input.cell-edit')?.value;
    const fromView = td?.querySelector('.cell-view')?.textContent;
    return String(fromEdit ?? fromView ?? '').trim();
  }

  function getLookupMetaFromDictEntry(d) {
    const staticItems = parseLookupItems(d?.Items ?? d?.items ?? '');
    if (staticItems.length) {
      return { type: 'items', items: staticItems };
    }
    const table = String(d?.LookupTable ?? d?.lookupTable ?? '').trim();
    const keyFieldRaw = String(d?.LookupKeyField ?? d?.lookupKeyField ?? '').trim();
    const resultRaw = String(d?.LookupResultField ?? d?.lookupResultField ?? '').trim();
    const resultForApi = normalizeLookupResultForApi(resultRaw);
    if (!table || !resultForApi) return null;
    const parts = resultForApi.split(',').map(x => x.trim()).filter(Boolean);
    const keyField = normalizeLookupIdentifier(keyFieldRaw) || parts[0] || '';
    const nameField = parts.length >= 2 ? parts[1] : (parts[0] || '');
    if (!keyField || !nameField) return null;
    const cond1Field = String(d?.LookupCond1Field ?? d?.lookupCond1Field ?? '').trim();
    const cond2Field = String(d?.LookupCond2Field ?? d?.lookupCond2Field ?? '').trim();
    const cond1ResultField = String(d?.LookupCond1ResultField ?? d?.lookupCond1ResultField ?? '').trim();
    const cond2ResultField = String(d?.LookupCond2ResultField ?? d?.lookupCond2ResultField ?? '').trim();
    return {
      type: 'table',
      table,
      keyField,
      nameField,
      resultField: resultForApi,
      resultFieldRaw: resultRaw,
      cond1Field,
      cond2Field,
      cond1ResultField,
      cond2ResultField
    };
  }

  async function getLookupOptions(meta, tr) {
    if (!meta) return [];
    if (meta.type === 'items') {
      return Array.isArray(meta.items) ? meta.items : [];
    }

    const cond1Value = meta.cond1Field && meta.cond1ResultField
      ? getRowFieldValue(tr, meta.cond1ResultField)
      : '';
    const cond2Value = meta.cond2Field && meta.cond2ResultField
      ? getRowFieldValue(tr, meta.cond2ResultField)
      : '';

    const cacheKey = [
      String(meta.table || '').toLowerCase(),
      String(meta.keyField || '').toLowerCase(),
      String(meta.resultField || '').toLowerCase(),
      String(meta.cond1Field || '').toLowerCase(),
      cond1Value,
      String(meta.cond2Field || '').toLowerCase(),
      cond2Value
    ].join('|');
    if (lookupRowsCache.has(cacheKey)) return lookupRowsCache.get(cacheKey);

    const qs = new URLSearchParams({
      table: meta.table,
      key: meta.keyField,
      result: meta.resultField
    });
    if (meta.cond1Field && meta.cond1ResultField && cond1Value) {
      qs.set('cond1Field', meta.cond1Field);
      qs.set('cond1Value', cond1Value);
    }
    if (meta.cond2Field && meta.cond2ResultField && cond2Value) {
      qs.set('cond2Field', meta.cond2Field);
      qs.set('cond2Value', cond2Value);
    }

    try {
      const rows = await fetchJson(`/api/TableFieldLayout/LookupData?${qs.toString()}`);
      const options = (Array.isArray(rows) ? rows : [])
        .map(r => {
          const value = String(r?.key ?? '').trim();
          const label = String(r?.result1 ?? r?.result0 ?? '').trim() || value;
          return value ? { value, label } : null;
        })
        .filter(Boolean);
      lookupRowsCache.set(cacheKey, options);
      return options;
    } catch {
      lookupRowsCache.set(cacheKey, []);
      return [];
    }
  }

  function closeLookupDropdown() {
    if (!activeLookupDropdown) return;
    const { list, onDocDown, onResize } = activeLookupDropdown;
    document.removeEventListener('mousedown', onDocDown, true);
    window.removeEventListener('resize', onResize, true);
    window.removeEventListener('scroll', onResize, true);
    list.remove();
    activeLookupDropdown = null;
  }

  function positionLookupDropdown(input, list) {
    const r = input.getBoundingClientRect();
    list.style.position = 'fixed';
    list.style.left = `${Math.max(8, r.left)}px`;
    list.style.top = `${Math.min(window.innerHeight - 180, r.bottom + 2)}px`;
    list.style.width = `${Math.max(220, r.width)}px`;
    list.style.maxHeight = '280px';
  }

  function openLookupDropdown(input, options) {
    closeLookupDropdown();
    const list = document.createElement('div');
    list.className = 'setnum-lookup-dropdown-list';
    positionLookupDropdown(input, list);
    (options || []).forEach(opt => {
      const item = document.createElement('button');
      item.type = 'button';
      item.className = 'setnum-lookup-dropdown-item';
      item.textContent = opt.label ? `${opt.value} ${opt.label}` : opt.value;
      item.title = item.textContent;
      item.addEventListener('mousedown', (ev) => {
        ev.preventDefault();
        ev.stopPropagation();
        input.value = opt.value;
        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.dispatchEvent(new Event('change', { bubbles: true }));
        closeLookupDropdown();
      });
      list.appendChild(item);
    });
    if (!list.children.length) {
      const empty = document.createElement('div');
      empty.className = 'setnum-lookup-dropdown-empty';
      empty.textContent = '無可選資料';
      list.appendChild(empty);
    }
    const onDocDown = (ev) => {
      if (ev.target === input || list.contains(ev.target)) return;
      closeLookupDropdown();
    };
    const onResize = () => {
      if (!activeLookupDropdown) return;
      positionLookupDropdown(input, list);
    };
    document.body.appendChild(list);
    document.addEventListener('mousedown', onDocDown, true);
    window.addEventListener('resize', onResize, true);
    window.addEventListener('scroll', onResize, true);
    activeLookupDropdown = { list, onDocDown, onResize };
  }

  function bindLookupEditorsForTable(table, cols) {
    if (!table || !Array.isArray(cols) || !cols.length) return;
    const lookupCols = cols.filter(c => c?.lookup);
    if (!lookupCols.length) return;
    table.querySelectorAll('tbody input.cell-edit').forEach(inp => {
      inp.removeAttribute('list');
    });
    lookupCols.forEach(col => {
      const fieldLower = String(col.key || '').toLowerCase();
      const openFromInput = async (inp, ev) => {
        ev?.preventDefault?.();
        ev?.stopPropagation?.();
        if (!inp || inp.readOnly || inp.disabled || inp.classList.contains('d-none')) return;
        const tr = inp.closest('tr');
        const options = await getLookupOptions(col.lookup, tr);
        openLookupDropdown(inp, options);
      };
      table.querySelectorAll('tbody input.cell-edit').forEach(inp => {
        if (String(inp.name || '').toLowerCase() !== fieldLower) return;
        if (inp.dataset.lkBound === '1') return;
        inp.dataset.lkBound = '1';

        const normalizeCode = () => {
          const v = String(inp.value || '');
          const first = v.split(/\s+/).filter(Boolean)[0] || '';
          if (first !== v) inp.value = first;
        };
        inp.addEventListener('input', normalizeCode);
        inp.addEventListener('change', normalizeCode);
        inp.addEventListener('dblclick', (ev) => openFromInput(inp, ev));
        inp.addEventListener('keydown', async (ev) => {
          if (ev.key === 'F4' || (ev.altKey && ev.key === 'ArrowDown')) {
            await openFromInput(inp, ev);
          } else if (ev.key === 'Escape') {
            closeLookupDropdown();
          }
        });

        const td = inp.closest('td');
        if (td && td.dataset.lkCellBound !== '1') {
          td.dataset.lkCellBound = '1';
          td.addEventListener('dblclick', (ev) => openFromInput(inp, ev));
        }
      });
    });
  }
  let mainDeleteBtn, setMainDeleteBtn, setSubDeleteBtn, setDtlDeleteBtn;
  let msgTimer = null;
  let activeEncodeSection = 'setMain';
  const sortState = {
    main: { field: '', dir: 'asc' },
    setMain: { field: '', dir: 'asc' },
    setSub: { field: '', dir: 'asc' },
    setDtl: { field: '', dir: 'asc' }
  };

  function tableToEncodeSection(tableName) {
    const t = (tableName || '').toLowerCase();
    if (t === 'mgndsetnumsubdtl') return 'setDtl';
    if (t === 'mgndsetnumsub') return 'setSub';
    return 'setMain';
  }

  function setActiveEncodeSectionByElement(el) {
    const t = resolveTableNameFrom(el);
    if (!t) return;
    activeEncodeSection = tableToEncodeSection(t);
    refreshEncodeModeFromActive();
  }

  function resolveTableNameFrom(el) {
    if (!el) return '';
    const closest = el.closest?.('[data-table-name]');
    if (closest && closest.dataset?.tableName) return closest.dataset.tableName;

    let cur = el;
    while (cur) {
      if (cur.dataset && cur.dataset.tableName) return cur.dataset.tableName;
      cur = cur.parentElement;
    }
    return '';
  }

  function resolveTableNameByMouse() {
    const pt = window.__lastMouse || { x: 0, y: 0 };
    if (typeof document.elementFromPoint !== 'function') return '';
    const el = document.elementFromPoint(pt.x, pt.y);
    return resolveTableNameFrom(el);
  }

  function rememberTableNameFrom(el) {
    const t = resolveTableNameFrom(el);
    if (t) lastTableName = t;
    return t;
  }

  function toggleEdit(grid, btn, toEdit) {
    if (!grid) return;
    const next = toEdit !== undefined ? toEdit : !grid.isEdit();
    grid.toggleEdit(next);
    if (btn?.id === 'mainToggleEdit') {
      btn.innerHTML = next
        ? '<i class="bi bi-eye"></i>瀏覽'
        : '<i class="bi bi-pencil-square"></i>修改';
    } else if (btn) {
      btn.textContent = next ? '瀏覽' : '修改';
    }
    const modeLine = document.querySelector('#mainModeBox .count-line');
    if (btn?.id === 'mainToggleEdit' && modeLine) {
      modeLine.textContent = next ? '編輯模式' : '瀏覽模式';
      document.getElementById('mainModeBox')?.classList.toggle('mode-edit', next);
      document.getElementById('mainModeBox')?.classList.toggle('mode-view', !next);
    }
    if (btn?.id === 'setMainToggleEdit' || btn?.id === 'setSubToggleEdit' || btn?.id === 'setDtlToggleEdit') {
      refreshEncodeModeFromActive(next);
    }
    syncMutationButtons();
  }

  function isMainEditing() {
    return !!(mainGrid && mainGrid.isEdit && mainGrid.isEdit());
  }

  function isEncodeEditing() {
    return [setMainGrid, setSubGrid, setDtlGrid].some(g => !!(g && g.isEdit && g.isEdit()));
  }

  function syncMainMutationButtons() {
    const editing = isMainEditing();
    ['mainAddRow', 'mainDelete', 'mainSave', 'mainCancel'].forEach(id => {
      const btn = document.getElementById(id);
      if (btn) btn.disabled = !editing;
    });
  }

  function syncEncodeMutationButtons() {
    const editing = isEncodeEditing();
    ['encodeAdd', 'encodeDelete', 'encodeSave', 'encodeCancel', 'btnCopyToMat', 'btnImportMapping'].forEach(id => {
      const btn = document.getElementById(id);
      if (btn) btn.disabled = !editing;
    });
  }

  function syncMutationButtons() {
    syncMainMutationButtons();
    syncEncodeMutationButtons();
  }

  function currentEncodeGrid() {
    if (activeEncodeSection === 'setSub') return setSubGrid;
    if (activeEncodeSection === 'setDtl') return setDtlGrid;
    return setMainGrid;
  }

  function refreshEncodeModeFromActive(forceEdit) {
    const editing = (typeof forceEdit === 'boolean')
      ? forceEdit
      : [setMainGrid, setSubGrid, setDtlGrid].some(g => !!(g && g.isEdit && g.isEdit()));
    const line = encodeModeBox?.querySelector('.count-line');
    if (line) line.textContent = editing ? '編輯模式' : '瀏覽模式';
    encodeModeBox?.classList.toggle('mode-edit', editing);
    encodeModeBox?.classList.toggle('mode-view', !editing);
    if (encodeUnifiedBtns.edit) {
      encodeUnifiedBtns.edit.innerHTML = editing
        ? '<i class="bi bi-eye"></i>瀏覽'
        : '<i class="bi bi-pencil-square"></i>修改';
    }
    syncMutationButtons();
  }

  function resolveTableNameByActiveTab() {
    const activeTab = document.querySelector('.tab-pane.active');
    if (!activeTab) return '';
    const target = activeTab.querySelector('[data-table-name]');
    return target?.dataset?.tableName || '';
  }

  function showMsg(text, type = 'info') {
    if (type === 'success') return;
    const message = (text ?? '').toString();
    if (window.Swal?.fire) {
      const icon = type === 'error' ? 'error'
        : type === 'warning' ? 'warning'
        : type === 'success' ? 'success'
        : 'info';
      const opts = { icon, title: message, confirmButtonText: '確定' };
      if (icon === 'info') {
        opts.timer = 1200;
        opts.showConfirmButton = false;
      }
      return window.Swal.fire(opts);
    }
    window.alert(message);
  }

  function clearMsg() {
    if (msgTimer) {
      clearTimeout(msgTimer);
      msgTimer = null;
    }
    if (window.Swal?.isVisible?.()) window.Swal.close();
    alertBox?.classList.add('d-none');
  }

  function buildHead(headEl, cols, withActions = false) {
    headEl.innerHTML = '';
    cols.forEach(c => {
      const th = document.createElement('th');
      th.className = 'text-nowrap sortable-header';
      th.dataset.field = c.key;
      const label = document.createElement('span');
      label.className = 'header-label';
      label.textContent = c.label || c.key;
      th.appendChild(label);
      const sortIcon = document.createElement('span');
      sortIcon.className = 'sort-icon';
      th.appendChild(sortIcon);
      const resizer = document.createElement('span');
      resizer.className = 'col-resizer';
      resizer.setAttribute('draggable', 'false');
      th.appendChild(resizer);
      if (c.width) th.style.width = c.width;
      headEl.appendChild(th);
    });
  }

  function bindColumnResize(table, widthKey) {
    if (!table) return;
    const storageKey = `MGNdSetNum:${window._itemId || 'MG000006'}:${widthKey}:colWidth`;
    const headerRow = table.querySelector('thead tr');
    if (!headerRow) return;

    const getHeaderCells = () => Array.from(headerRow.querySelectorAll('th[data-field]'));
    const getFieldKey = (el) => (el?.getAttribute('data-field') || '').toLowerCase();

    const setColumnWidthByIndex = (colIdx, widthPx) => {
      if (colIdx < 0) return;
      const w = `${Math.max(48, Math.round(widthPx))}px`;
      Array.from(table.rows).forEach(r => {
        const cell = r.cells[colIdx];
        if (cell) {
          cell.style.width = w;
          cell.style.minWidth = w;
        }
      });
    };

    const widthMap = (() => {
      try {
        const raw = localStorage.getItem(storageKey);
        const parsed = raw ? JSON.parse(raw) : {};
        return (parsed && typeof parsed === 'object') ? parsed : {};
      } catch {
        return {};
      }
    })();

    const applySavedWidths = () => {
      getHeaderCells().forEach((th, idx) => {
        const field = getFieldKey(th);
        const saved = Number(widthMap[field] || 0);
        if (field && saved > 0) setColumnWidthByIndex(idx, saved);
      });
    };

    const saveWidthMap = () => {
      try { localStorage.setItem(storageKey, JSON.stringify(widthMap)); } catch { }
    };

    getHeaderCells().forEach(th => {
      if (th.dataset.resizeBound === '1') return;
      th.dataset.resizeBound = '1';
      const resizer = th.querySelector('.col-resizer');
      if (!resizer) return;
      resizer.addEventListener('click', (e) => e.stopPropagation());

      resizer.addEventListener('mousedown', (e) => {
        if (e.button !== 0) return;
        e.preventDefault();
        e.stopPropagation();
        document.body.style.cursor = 'col-resize';
        const startX = e.clientX;
        const startWidth = th.getBoundingClientRect().width;
        const colIdx = Array.from(headerRow.children).indexOf(th);
        const field = getFieldKey(th);
        if (colIdx < 0 || !field) return;

        const onMove = (ev) => {
          const nextWidth = startWidth + (ev.clientX - startX);
          setColumnWidthByIndex(colIdx, nextWidth);
        };

        const onUp = (ev) => {
          const finalWidth = Math.max(48, Math.round(startWidth + (ev.clientX - startX)));
          setColumnWidthByIndex(colIdx, finalWidth);
          widthMap[field] = finalWidth;
          saveWidthMap();
          document.body.style.cursor = '';
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        };

        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });

    applySavedWidths();
  }

  function bindHeaderDragReorder(table, orderKey) {
    if (!table) return;
    const storageKey = `MGNdSetNum:${window._itemId || 'MG000006'}:${orderKey}:colOrder`;

    const getHeaderCells = () => Array.from(table.querySelectorAll('thead th[data-field]'));
    const getFieldKey = (el) => (el?.getAttribute('data-field') || '').toLowerCase();
    const clearMarks = () => getHeaderCells().forEach(h => h.classList.remove('col-dragging', 'col-drag-over-left', 'col-drag-over-right'));

    const saveOrder = () => {
      try {
        const order = getHeaderCells().map(h => h.getAttribute('data-field')).filter(Boolean);
        localStorage.setItem(storageKey, JSON.stringify(order));
      } catch { }
    };

    const applyOrder = () => {
      try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        const order = JSON.parse(raw);
        if (!Array.isArray(order) || !order.length) return;

        const headerRow = table.querySelector('thead tr');
        if (!headerRow) return;
        const headerMap = new Map(getHeaderCells().map(h => [getFieldKey(h), h]));
        const orderedKeys = order.map(x => String(x || '').toLowerCase()).filter(k => headerMap.has(k));
        const remainingKeys = Array.from(headerMap.keys()).filter(k => !orderedKeys.includes(k));
        const finalKeys = [...orderedKeys, ...remainingKeys];
        finalKeys.forEach(k => {
          const th = headerMap.get(k);
          if (th) headerRow.appendChild(th);
        });
        table.querySelectorAll('tbody tr').forEach(tr => {
          const tdMap = new Map(Array.from(tr.querySelectorAll('td[data-field]'))
            .map(td => [getFieldKey(td), td]));
          finalKeys.forEach(k => {
            const td = tdMap.get(k);
            if (td) tr.appendChild(td);
          });
        });
      } catch { }
    };

    let draggingField = '';
    const moveColumn = (fromKey, toKey, placeAfter) => {
      const headerRow = table.querySelector('thead tr');
      if (!headerRow) return;
      const headers = Array.from(headerRow.querySelectorAll('th[data-field]'));
      const fromTh = headers.find(h => getFieldKey(h) === fromKey);
      const toTh = headers.find(h => getFieldKey(h) === toKey);
      if (!fromTh || !toTh || fromTh === toTh) return;
      headerRow.insertBefore(fromTh, placeAfter ? toTh.nextSibling : toTh);
      table.querySelectorAll('tbody tr').forEach(tr => {
        const cells = Array.from(tr.querySelectorAll('td[data-field]'));
        const fromTd = cells.find(td => getFieldKey(td) === fromKey);
        const toTd = cells.find(td => getFieldKey(td) === toKey);
        if (!fromTd || !toTd || fromTd === toTd) return;
        tr.insertBefore(fromTd, placeAfter ? toTd.nextSibling : toTd);
      });
    };

    getHeaderCells().forEach(th => {
      if (th.dataset.dragBound === '1') return;
      th.dataset.dragBound = '1';
      th.setAttribute('draggable', 'true');

      th.addEventListener('dragstart', (e) => {
        if (e.target?.closest?.('.col-resizer')) {
          e.preventDefault();
          return;
        }
        const field = getFieldKey(th);
        if (!field) return;
        draggingField = field;
        clearMarks();
        th.classList.add('col-dragging');
        if (e.dataTransfer) {
          e.dataTransfer.effectAllowed = 'move';
          try { e.dataTransfer.setData('text/plain', field); } catch { }
        }
      });

      th.addEventListener('dragenter', (e) => {
        if (!draggingField) return;
        const targetField = getFieldKey(th);
        if (!targetField || targetField === draggingField) return;
        e.preventDefault();
      });

      th.addEventListener('dragover', (e) => {
        if (e.target?.closest?.('.col-resizer')) return;
        if (!draggingField) return;
        const targetField = getFieldKey(th);
        if (!targetField || targetField === draggingField) return;
        e.preventDefault();
        const rect = th.getBoundingClientRect();
        const placeAfter = (e.clientX - rect.left) >= rect.width / 2;
        th.classList.toggle('col-drag-over-left', !placeAfter);
        th.classList.toggle('col-drag-over-right', placeAfter);
        if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
      });

      th.addEventListener('dragleave', () => {
        th.classList.remove('col-drag-over-left', 'col-drag-over-right');
      });

      th.addEventListener('drop', (e) => {
        if (e.target?.closest?.('.col-resizer')) return;
        if (!draggingField) return;
        e.preventDefault();
        const targetField = getFieldKey(th);
        if (!targetField || targetField === draggingField) {
          clearMarks();
          draggingField = '';
          table.dataset.suppressSortUntil = String(Date.now() + 260);
          return;
        }
        const rect = th.getBoundingClientRect();
        const placeAfter = (e.clientX - rect.left) >= rect.width / 2;
        moveColumn(draggingField, targetField, placeAfter);
        saveOrder();
        clearMarks();
        draggingField = '';
        table.dataset.suppressSortUntil = String(Date.now() + 260);
      });

      th.addEventListener('dragend', () => {
        draggingField = '';
        clearMarks();
        table.dataset.suppressSortUntil = String(Date.now() + 220);
      });
    });

    applyOrder();
  }

  function createCell(col, value) {
    const td = document.createElement('td');
    td.dataset.field = col.key;
    const view = document.createElement('span');
    view.className = 'cell-view';
    const inp = document.createElement('input');
    inp.name = col.key;
    inp.dataset.raw = value ?? '';
    inp.dataset.type = col.type || '';
    inp.className = 'form-control form-control-sm cell-edit d-none';
    if (col.readonly) inp.dataset.readonly = '1';

    if (col.type === 'checkbox') {
      td.classList.add('cell-check');
      inp.classList.remove('form-control', 'form-control-sm');
      inp.type = 'checkbox';
      inp.classList.add('form-check-input');
      inp.checked = value == 1 || value === true || value === '1';
      view.innerHTML = `<input type="checkbox" disabled ${inp.checked ? 'checked' : ''} class="form-check-input">`;
    } else if (col.type === 'number') {
      td.classList.add('cell-number');
      inp.type = 'number';
      inp.step = 'any';
      inp.value = value ?? '';
      view.textContent = value ?? '';
    } else {
      td.classList.add('cell-text');
      inp.type = 'text';
      inp.value = value ?? '';
      view.textContent = value ?? '';
    }

    td.appendChild(view);
    td.appendChild(inp);
    return td;
  }

  function applyDictWidths(tableName, cols) {
    if (!tableName || !dictWidths[tableName.toLowerCase()]) return;
    const map = dictWidths[tableName.toLowerCase()];
    cols.forEach(c => {
      const w = map[c.key.toLowerCase()];
      if (w && w > 0) {
        c.width = `${w}px`;
      }
    });
  }

  async function loadDictWidths() {
    try {
      const arr = await fetchJson('/api/MG000006/dict-widths');
      dictWidths = {};
      (Array.isArray(arr) ? arr : []).forEach(x => {
        const tbl = (x?.tableName || x?.TableName || '').toLowerCase();
        const field = (x?.fieldName || x?.FieldName || '').toLowerCase();
        const w = Number(x?.width ?? x?.Width ?? 0);
        if (!tbl || !field || !w) return;
        if (!dictWidths[tbl]) dictWidths[tbl] = {};
        dictWidths[tbl][field] = w;
      });
    } catch (err) {
      showMsg(err.message || '讀取欄位寬度失敗', 'warning');
    }
  }

  function guessType(dataType, fallbackType, key) {
    if (fallbackType) return fallbackType;
    const dt = (dataType || '').toLowerCase();
    if (dt.includes('check') || dt === 'bit' || dt === 'boolean' || dt === 'bool') return 'checkbox';
    if (dt.includes('int') || dt.includes('dec') || dt.includes('num') || dt.includes('float') || dt.includes('double')) return 'number';
    const k = (key || '').toLowerCase();
    if (k.startsWith('is') || k.startsWith('has') || k.startsWith('need') || k.startsWith('iuse') || k.includes('flag')) return 'checkbox';
    return 'text';
  }

  async function loadDict(tableName) {
    if (dictCache[tableName]) return dictCache[tableName];
    const res = await fetchJson(`/api/TableFieldLayout/GetTableFieldsFull?table=${encodeURIComponent(tableName)}`);
    dictCache[tableName] = Array.isArray(res) ? res : [];
    return dictCache[tableName];
  }

  async function buildColumns(tableName, fallbackCols) {
    const dict = await loadDict(tableName);
    if (!dict || dict.length === 0) return fallbackCols;
    const fbMap = new Map(fallbackCols.map(c => [c.key.toLowerCase(), c]));
    const numericOverride = new Set(['setmon','classType','type','prepared','accept','distraptomatinfo','defkeepdays','sendmsgdaypre','seqbyfront','igetwatermethod','igetwaterbegin','igetwaterend']);
    const textOverride = new Set(['matclass', 'setclass', 'numid', 'dtlnumid', 'encode']);
    const cols = dict
      .filter(d => (d.Visible ?? d.visible ?? 1) == 1)
      .sort((a, b) => (a.SerialNum ?? a.serialNum ?? 9999) - (b.SerialNum ?? b.serialNum ?? 9999))
      .map(d => {
        const key = d.FieldName || d.fieldName;
        const fb = fbMap.get((key || '').toLowerCase()) || {};
        const ds = d.DisplaySize ?? d.displaySize;
        const widthRaw = d.iFieldWidth ?? d.iLabWidth ?? ds;
        const widthVal = d.iFieldWidth ? `${widthRaw}px`
                         : ds ? `${ds}ch`
                         : fb.width;
        let t = guessType(d.DataType || d.dataType, fb.type, key);
        const lk = (key || '').toLowerCase();
        if (numericOverride.has(lk)) t = 'number';
        if (textOverride.has(lk)) t = 'text';
        return {
          key,
          label: d.DisplayLabel || d.displayLabel || fb.label || key,
          width: widthVal,
          required: fb.required,
          readonly: fb.readonly || (d.ReadOnly ?? d.readOnly ?? 0) == 1,
          type: t,
          lookup: getLookupMetaFromDictEntry(d)
        };
      });
    return cols.length ? cols : fallbackCols;
  }

  function attachRowSelection(tbody, data, onSelect, isLocked) {
    Array.from(tbody.querySelectorAll('tr')).forEach(tr => {
      tr.addEventListener('click', () => {
        if (isLocked && isLocked()) {
          showMsg('目前有未儲存的新資料，請先儲存或取消', 'warning');
          return;
        }
        rememberTableNameFrom(tr);
        Array.from(tbody.querySelectorAll('tr')).forEach(r => r.classList.remove('table-primary'));
        tr.classList.add('table-primary');
        const idx = Number(tr.dataset.idx);
        if (!Number.isNaN(idx) && data[idx]) onSelect(data[idx]);
      });
    });
  }

  function showEditRow(tr) {
    if (!tr) return;
    tr.querySelectorAll('.cell-view').forEach(v => v.classList.add('d-none'));
    tr.querySelectorAll('.cell-edit').forEach(inp => inp.classList.remove('d-none'));
  }

  function addHiddenKeys(tr, data, keys) {
    keys?.forEach(k => {
      const hidden = document.createElement('input');
      hidden.type = 'hidden';
      hidden.className = 'mmd-pk-hidden';
      hidden.name = k;
      hidden.value = data?.[k] ?? '';
      tr.appendChild(hidden);
    });
  }

  function renderBody(tbody, cols, data, keyFields = [], withActions = false) {
    tbody.innerHTML = '';
    data.forEach((row, idx) => {
      const tr = document.createElement('tr');
      tr.dataset.idx = idx;
      addHiddenKeys(tr, row, keyFields);
      cols.forEach(col => {
        const val = row?.[col.key];
        const td = createCell(col, val);
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
    const table = tbody.closest('table');
    syncRowsToHeaderOrder(table);
    bindLookupEditorsForTable(table, cols);
    if (table?.id === 'mainTable' && mainGrid?.toggleEdit) {
      mainGrid.toggleEdit(!!mainGrid.isEdit?.());
    } else if (table?.id === 'setMainTable' && setMainGrid?.toggleEdit) {
      setMainGrid.toggleEdit(!!setMainGrid.isEdit?.());
    } else if (table?.id === 'setSubTable' && setSubGrid?.toggleEdit) {
      setSubGrid.toggleEdit(!!setSubGrid.isEdit?.());
    } else if (table?.id === 'setDtlTable' && setDtlGrid?.toggleEdit) {
      setDtlGrid.toggleEdit(!!setDtlGrid.isEdit?.());
    }
  }

  function getTableSortKey(table) {
    if (table === mainTable) return 'main';
    if (table === setMainTable) return 'setMain';
    if (table === setSubTable) return 'setSub';
    return 'setDtl';
  }

  function compareValues(a, b, type) {
    const av = a ?? '';
    const bv = b ?? '';
    if (type === 'number' || type === 'checkbox') {
      const na = Number(av) || 0;
      const nb = Number(bv) || 0;
      return na - nb;
    }
    return String(av).localeCompare(String(bv), 'zh-Hant', { numeric: true, sensitivity: 'base' });
  }

  function updateSortIcons(table, key) {
    const st = sortState[key];
    table.querySelectorAll('thead th[data-field]').forEach(th => {
      const icon = th.querySelector('.sort-icon');
      if (!icon) return;
      const f = (th.getAttribute('data-field') || '').toLowerCase();
      if (f && f === (st.field || '').toLowerCase()) {
        icon.textContent = st.dir === 'asc' ? '▲' : '▼';
      } else {
        icon.textContent = '';
      }
    });
  }

  function renderByKey(key) {
    if (key === 'main') {
      renderBody(mainTable.tBodies[0], mainCols, mainData, ['MatClass'], true);
      attachRowSelection(mainTable.tBodies[0], mainData, (row) => {
        if (pendingLock) return;
        currentSetClass = row?.MatClass || '';
        badgeSetClass.textContent = currentSetClass ? `SetClass: ${currentSetClass}` : '';
        loadSetSub(currentSetClass);
      }, () => pendingLock);
      return;
    }
    if (key === 'setMain') {
      renderBody(setMainTable.tBodies[0], setMainCols, setMainData, ['SetClass']);
      attachRowSelection(setMainTable.tBodies[0], setMainData, (row) => {
        if (controllers.setMain?.lock) return;
        activeEncodeSection = 'setMain';
        refreshEncodeModeFromActive();
        currentSetClass = row?.SetClass || '';
        badgeSetClass.textContent = currentSetClass ? `SetClass: ${currentSetClass}` : '';
        loadSetSub(currentSetClass);
      }, () => controllers.setMain?.lock);
      return;
    }
    if (key === 'setSub') {
      renderBody(setSubTable.tBodies[0], setSubCols, setSubData, ['SetClass','NumId']);
      attachRowSelection(setSubTable.tBodies[0], setSubData, (row) => {
        activeEncodeSection = 'setSub';
        refreshEncodeModeFromActive();
        currentSetClass = row?.SetClass || currentSetClass;
        currentNumId = row?.NumId || '';
        badgeSubKey.textContent = currentNumId ? `SetClass: ${currentSetClass} / NumId: ${currentNumId}` : '';
        loadSetDtl(currentSetClass, currentNumId);
      }, () => controllers.setSub?.lock);
      return;
    }
    renderBody(setDtlTable.tBodies[0], setDtlCols, setDtlData, ['SetClass','NumId','EnCode']);
    attachRowSelection(setDtlTable.tBodies[0], setDtlData, () => { activeEncodeSection = 'setDtl'; }, () => controllers.setDtl?.lock);
  }

  function bindHeaderSort(table) {
    if (!table) return;
    const key = getTableSortKey(table);
    table.querySelectorAll('thead th[data-field]').forEach(th => {
      if (th.dataset.sortBound === '1') return;
      th.dataset.sortBound = '1';
      th.addEventListener('click', (e) => {
        if (e.target?.closest?.('.col-resizer')) return;
        const suppressUntil = Number(table.dataset.suppressSortUntil || 0);
        if (Date.now() < suppressUntil) return;
        const field = th.getAttribute('data-field') || '';
        if (!field) return;
        const cols = key === 'main' ? mainCols : key === 'setMain' ? setMainCols : key === 'setSub' ? setSubCols : setDtlCols;
        const col = cols.find(c => (c.key || '').toLowerCase() === field.toLowerCase());
        const st = sortState[key];
        st.dir = (st.field || '').toLowerCase() === field.toLowerCase() ? (st.dir === 'asc' ? 'desc' : 'asc') : 'asc';
        st.field = field;
        const arr = key === 'main' ? mainData : key === 'setMain' ? setMainData : key === 'setSub' ? setSubData : setDtlData;
        arr.sort((a, b) => {
          const c = compareValues(a?.[field], b?.[field], col?.type || '');
          return st.dir === 'asc' ? c : -c;
        });
        renderByKey(key);
        updateSortIcons(table, key);
      });
    });
    updateSortIcons(table, key);
  }

  function syncRowsToHeaderOrder(table) {
    if (!table) return;
    const headerKeys = Array.from(table.querySelectorAll('thead th[data-field]'))
      .map(th => (th.getAttribute('data-field') || '').toLowerCase())
      .filter(Boolean);
    if (!headerKeys.length) return;
    table.querySelectorAll('tbody tr').forEach(tr => {
      const tdMap = new Map(Array.from(tr.querySelectorAll('td[data-field]'))
        .map(td => [String(td.getAttribute('data-field') || '').toLowerCase(), td]));
      headerKeys.forEach(k => {
        const td = tdMap.get(k);
        if (td) tr.appendChild(td);
      });
    });
  }

  function ensureDtlKeySync() {
    // EnCode 需同步回寫到 DtlNumId，保持後端鍵值一致
    setDtlTable?.querySelectorAll('tbody tr').forEach(tr => {
      const enInput = tr.querySelector('input[name="EnCode"]');
      const idInput = tr.querySelector('input[name="DtlNumId"]');
      if (!enInput || !idInput) return;
      const val = enInput.value ?? '';
      idInput.value = val;
      idInput.dataset.raw = val;
      idInput.defaultValue = val;
    });
  }

  async function fetchJson(url, options) {
    const res = await fetch(url, options);
    if (!res.ok) {
      const text = await res.text();
      throw new Error(text || res.statusText);
    }
    return await res.json();
  }

  async function loadMain() {
    try {
      clearMsg();
      const data = await fetchJson('/api/MG000006/mat-class');
      mainData = Array.isArray(data) ? data : [];
      renderBody(mainTable.tBodies[0], mainCols, mainData, ['MatClass'], true);
      attachRowSelection(mainTable.tBodies[0], mainData, (row) => {
        if (pendingLock) return;
        currentSetClass = row?.MatClass || '';
        badgeSetClass.textContent = currentSetClass ? `SetClass: ${currentSetClass}` : '';
        loadSetSub(currentSetClass);
      }, () => pendingLock);
    } catch (err) {
      showMsg(err.message || '讀取主分類資料失敗', 'error');
    }
  }

  async function loadSetMain(preferredSetClass = '', preferredNumId = '') {
    try {
      clearMsg();
      const data = await fetchJson('/api/MG000006/setnum-main');
      setMainData = Array.isArray(data) ? data : [];
      renderBody(setMainTable.tBodies[0], setMainCols, setMainData, ['SetClass']);
      attachRowSelection(setMainTable.tBodies[0], setMainData, (row) => {
        if (controllers.setMain?.lock) return;
        activeEncodeSection = 'setMain';
        currentSetClass = row?.SetClass || '';
        badgeSetClass.textContent = currentSetClass ? `SetClass: ${currentSetClass}` : '';
        loadSetSub(currentSetClass);
      }, () => controllers.setMain?.lock);
      if (setMainData.length) {
        const want = preferredSetClass || currentSetClass;
        const idx = want
          ? setMainData.findIndex(x => String(x?.SetClass ?? '').toLowerCase() === String(want).toLowerCase())
          : -1;
        const row = setMainData[idx >= 0 ? idx : 0];
        currentSetClass = row?.SetClass || '';
        badgeSetClass.textContent = currentSetClass ? `SetClass: ${currentSetClass}` : '';
        const tr = setMainTable.tBodies[0]?.querySelector(`tr[data-idx="${idx >= 0 ? idx : 0}"]`);
        if (tr) tr.classList.add('table-primary');
        loadSetSub(currentSetClass, preferredNumId);
      } else {
        currentSetClass = '';
        currentNumId = '';
        badgeSetClass.textContent = '';
        badgeSubKey.textContent = '';
      }
    } catch (err) {
      showMsg(err.message || '讀取品號編碼原則失敗', 'error');
    }
  }

  async function loadSetSub(setClass, preferredNumId = '') {
    if (!setClass) {
      setSubData = [];
      renderBody(setSubTable.tBodies[0], setSubCols, setSubData, ['SetClass','NumId']);
      renderBody(setDtlTable.tBodies[0], setDtlCols, [], ['SetClass','NumId','EnCode']);
      currentNumId = '';
      badgeSubKey.textContent = '';
      return;
    }
    try {
      const data = await fetchJson(`/api/MG000006/setnum-sub?setClass=${encodeURIComponent(setClass)}`);
      setSubData = Array.isArray(data) ? data : [];
      renderBody(setSubTable.tBodies[0], setSubCols, setSubData, ['SetClass','NumId']);
      attachRowSelection(setSubTable.tBodies[0], setSubData, (row) => {
        activeEncodeSection = 'setSub';
        currentSetClass = row?.SetClass || currentSetClass;
        currentNumId = row?.NumId || '';
        badgeSubKey.textContent = currentNumId ? `SetClass: ${currentSetClass} / NumId: ${currentNumId}` : '';
        loadSetDtl(currentSetClass, currentNumId);
      }, () => controllers.setSub?.lock);
      if (setSubData.length) {
        const want = preferredNumId || currentNumId;
        const idx = want
          ? setSubData.findIndex(x => String(x?.NumId ?? '').toLowerCase() === String(want).toLowerCase())
          : -1;
        const row = setSubData[idx >= 0 ? idx : 0];
        currentNumId = row?.NumId || '';
        badgeSubKey.textContent = currentNumId ? `SetClass: ${currentSetClass} / NumId: ${currentNumId}` : '';
        const tr = setSubTable.tBodies[0]?.querySelector(`tr[data-idx="${idx >= 0 ? idx : 0}"]`);
