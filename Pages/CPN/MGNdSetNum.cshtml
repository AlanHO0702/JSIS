<div class="card shadow-sm mt-2 setnum-page">
  <div class="card-body" data-item-id="@Model.ItemId" data-page-mode="@(isEncodeOnly ? "encode" : "main")">
    <ul class="nav nav-tabs @(hideTabs ? "d-none" : string.Empty)" id="mg-tabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link @(mainTabActive ? "active" : string.Empty)" id="tab-main-tab" data-bs-toggle="tab" data-bs-target="#tab-main" type="button" role="tab">主分類</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link @(encodeTabActive ? "active" : string.Empty)" id="tab-encode-tab" data-bs-toggle="tab" data-bs-target="#tab-encode" type="button" role="tab">編碼設定</button>
      </li>
    </ul>

    <div class="tab-content pt-3">
      <div class="@mainPaneClass" id="tab-main" role="tabpanel" aria-labelledby="tab-main-tab">
        <div class="top-toolbar">
          <div class="toolbar-count-box mode-view" id="mainModeBox">
            <div class="count-line">瀏覽模式</div>
          </div>
          <div class="d-flex gap-1 mb-0" id="mainToolbar">
            <button class="btn toolbar-btn" id="mainToggleEdit"><i class="bi bi-pencil-square"></i>修改</button>
            <button class="btn toolbar-btn" id="mainAddRow"><i class="bi bi-plus-circle"></i>新增</button>
            <button class="btn toolbar-btn" id="mainDelete"><i class="bi bi-dash-circle"></i>刪除</button>
            <button class="btn toolbar-btn" id="mainSave"><i class="bi bi-check2-circle"></i>保留</button>
            <button class="btn toolbar-btn" id="mainCancel"><i class="bi bi-x-circle"></i>取消</button>
          </div>
        </div>
        <div class="table-responsive grid-scroll" id="mainWrapper" data-table-name="MGN_MINdMatClass">
          <table class="table table-sm table-bordered align-middle mb-0 grid-table" id="mainTable">
            <thead class="table-light">
              <tr id="mainHead"></tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>

      <div class="@encodePaneClass" id="tab-encode" role="tabpanel" aria-labelledby="tab-encode-tab">
        <div class="top-toolbar">
          <div class="toolbar-count-box mode-view" id="encodeModeBox"><div class="count-line">瀏覽模式</div></div>
          <div class="setnum-toolbar-main">
            <div class="d-flex gap-1 me-2" id="encodeUnifiedToolbar">
              <button class="btn toolbar-btn" id="encodeEdit"><i class="bi bi-pencil-square"></i>修改</button>
              <button class="btn toolbar-btn" id="encodeAdd"><i class="bi bi-plus-circle"></i>新增</button>
              <button class="btn toolbar-btn" id="encodeDelete"><i class="bi bi-dash-circle"></i>刪除</button>
              <button class="btn toolbar-btn" id="encodeSave"><i class="bi bi-check2-circle"></i>保留</button>
              <button class="btn toolbar-btn" id="encodeCancel"><i class="bi bi-x-circle"></i>取消</button>
            </div>
            <button class="btn toolbar-btn" id="btnRefreshAll">重取資料</button>
            <button class="btn toolbar-btn" id="btnInfo">編碼說明</button>
          </div>
        </div>
        <div class="row g-1 encode-layout">
          <div class="col-12 col-lg-7 encode-left">
            <div class="card h-100 border-secondary-subtle">
              <div class="card-header py-2 d-flex align-items-center gap-2 flex-wrap">
                <span id="setMainTitle" class="setnum-section-title">品號編碼原則 (SetNumMain)</span>
                <div class="setnum-header-actions">
                  <button class="btn toolbar-btn" id="btnTestEncode">測試編碼</button>
                  <input type="text" class="form-control form-control-sm w-auto" id="txtTestResult" placeholder="測試結果" style="min-width:120px;">
                </div>
                <div class="btn-group btn-group-sm btn-tight-group section-action-group">
                  <button class="btn btn-primary toolbar-btn" id="setMainToggleEdit">修改</button>
                  <button class="btn btn-outline-secondary toolbar-btn" id="setMainAddRow">新增</button>
                  <button class="btn btn-success toolbar-btn" id="setMainSave">儲存</button>
                  <button class="btn btn-warning toolbar-btn" id="setMainCancel">取消</button>
                </div>
              </div>
              <div class="card-body p-2">
                <div class="table-responsive grid-scroll" id="setMainWrapper" data-table-name="MGNdSetNumMain">
                  <table class="table table-sm table-bordered align-middle mb-0 grid-table" id="setMainTable">
                    <thead class="table-light">
                      <tr id="setMainHead"></tr>
                    </thead>
                    <tbody></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

