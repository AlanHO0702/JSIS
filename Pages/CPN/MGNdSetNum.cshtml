    bindDictOpen(document.getElementById('setMainWrapper'));
    bindDictOpen(document.getElementById('setSubWrapper'));
    bindDictOpen(document.getElementById('setDtlWrapper'));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'F3') {
        e.preventDefault();
        const tableName =
          resolveTableNameFrom(document.activeElement) ||
          resolveTableNameByMouse() ||
          resolveTableNameByActiveTab() ||
          lastTableName ||
          'MGN_MINdMatClass';
        if (tableName) lastTableName = tableName;
        if (!tableName) {
          showMsg('找不到可開啟的欄位設定資料表', 'warning');
          return;
        }
        if (window.showDictModal) {
          window.showDictModal('fieldDictModal', tableName);
        }
      }
    });

    // EnCode 輸入時同步更新 DtlNumId
    setDtlTable?.addEventListener('input', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLInputElement)) return;
      if ((target.name || '').toLowerCase() !== 'encode') return;
      const tr = target.closest('tr');
      if (!tr) return;
      const idInput = tr.querySelector('input[name="DtlNumId"]');
      if (idInput) {
        idInput.value = target.value ?? '';
        idInput.dataset.raw = target.value ?? '';
      }
    });
  }

  function initGrids() {
    buildHead(mainHead, mainCols);
    buildHead(setMainHead, setMainCols);
    buildHead(setSubHead, setSubCols);
    buildHead(setDtlHead, setDtlCols);

    mainGrid = window.makeEditableGrid({
      wrapper: document.getElementById('mainWrapper'),
      table: document.getElementById('mainTable'),
      tableName: 'MINdMatClass',
      keyFields: ['MatClass'],
      keepInputLayout: true
    });

    setMainGrid = window.makeEditableGrid({
      wrapper: document.getElementById('setMainWrapper'),
      table: document.getElementById('setMainTable'),
      tableName: 'MGNdSetNumMain',
      keyFields: ['SetClass'],
      keepInputLayout: true
    });

    setSubGrid = window.makeEditableGrid({
      wrapper: document.getElementById('setSubWrapper'),
      table: document.getElementById('setSubTable'),
      tableName: 'MGNdSetNumSub',
      keyFields: ['SetClass','NumId'],
      keepInputLayout: true
    });

  setDtlGrid = window.makeEditableGrid({
    wrapper: document.getElementById('setDtlWrapper'),
    table: document.getElementById('setDtlTable'),
    tableName: 'MGNdSetNumSubDtl',
    keyFields: ['SetClass','NumId','DtlNumId'],
    keepInputLayout: true
  });

    bindHeaderDragReorder(mainTable, 'main');
    bindHeaderDragReorder(setMainTable, 'setMain');
    bindHeaderDragReorder(setSubTable, 'setSub');
    bindHeaderDragReorder(setDtlTable, 'setDtl');
    bindHeaderSort(mainTable);
    bindHeaderSort(setMainTable);
    bindHeaderSort(setSubTable);
    bindHeaderSort(setDtlTable);
    bindColumnResize(mainTable, 'main');
    bindColumnResize(setMainTable, 'setMain');
    bindColumnResize(setSubTable, 'setSub');
    bindColumnResize(setDtlTable, 'setDtl');
  }

  async function init() {
    const setText = (id, text) => { const el = document.getElementById(id); if (el) el.textContent = text; };
    setText('tab-main-tab', '主分類');
    setText('tab-encode-tab', '編碼設定');
    const mainSaveBtn = document.getElementById('mainSave');
    if (mainSaveBtn) mainSaveBtn.innerHTML = '<i class="bi bi-check2-circle"></i>保留';
    const encodeSaveBtn = document.getElementById('encodeSave');
    if (encodeSaveBtn) encodeSaveBtn.innerHTML = '<i class="bi bi-check2-circle"></i>保留';
    setText('setMainToggleEdit', '修改');
    setText('setMainAddRow', '新增');
    setText('setMainSave', '儲存');
    setText('setMainCancel', '取消');
    setText('setSubToggleEdit', '修改');
    setText('setSubAddRow', '新增');
    setText('setSubSave', '儲存');
    setText('setSubCancel', '取消');
    setText('setSubDelete', '刪除');
    setText('setDtlToggleEdit', '修改');
    setText('setDtlAddRow', '新增');
    setText('setDtlSave', '儲存');
    setText('setDtlCancel', '取消');
    await loadDictWidths();
    mainCols    = await buildColumns('MGN_MINdMatClass', fallbackMainCols);
    setMainCols = await buildColumns('MGNdSetNumMain', fallbackSetMainCols);
    setSubCols  = await buildColumns('MGNdSetNumSub', fallbackSetSubCols);
    setDtlCols  = await buildColumns('MGNdSetNumSubDtl', fallbackSetDtlCols);

    initGrids();
    if (btnMainToggle) btnMainToggle.innerHTML = '<i class="bi bi-pencil-square"></i>修改';
    if (btnSetMainToggle) btnSetMainToggle.textContent = '修改';
    if (btnSetSubToggle) btnSetSubToggle.textContent = '修改';
    if (btnSetDtlToggle) btnSetDtlToggle.textContent = '修改';
    activeEncodeSection = 'setMain';
    refreshEncodeModeFromActive(false);
    syncMutationButtons();
    wireButtons();
    await Promise.all([loadMain(), loadSetMain()]);
  }

  document.addEventListener('DOMContentLoaded', init);
})();
</script>
}






