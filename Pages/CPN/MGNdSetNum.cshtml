@page "/CPN/MGNdSetNum/{itemId?}"
@model PcbErpApi.Pages.CPN.MGNdSetNumModel
@{
    Layout = "_Layout";
    ViewData["Title"] = $"{Model.ItemId} {Model.PageTitle}";
    var isMainOnly = Model.IsMainOnly;
    var isEncodeOnly = Model.IsEncodeOnly;
    var hideTabs = isMainOnly || isEncodeOnly;
    var mainTabActive = !isEncodeOnly;
    var encodeTabActive = isEncodeOnly;
    var mainPaneClass = mainTabActive ? "tab-pane fade show active" : "tab-pane fade";
    var encodePaneClass = encodeTabActive ? "tab-pane fade show active" : "tab-pane fade";
    if (isEncodeOnly)
    {
        mainPaneClass += " d-none";
    }
    if (isMainOnly)
    {
        encodePaneClass += " d-none";
    }
}

<link rel="stylesheet" href="~/css/grid-toolbar.css" />
