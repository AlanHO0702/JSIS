  async function saveGrid(grid, name) {
    const res = await grid.saveChanges();
    if (res.ok) {
      showMsg(`${name} 儲存成功`, 'success');
    } else if (!res.skipped) {
      showMsg(`${name} 儲存失敗：${res.text || 'unknown'}`, 'error');
    } else {
      showMsg(`${name} 沒有異動`, 'info');
    }
  }

