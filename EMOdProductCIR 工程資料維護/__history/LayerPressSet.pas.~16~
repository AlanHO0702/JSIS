end;

procedure TdlgLayerPressSet.cboClassMatChange(Sender: TObject);
var i_JH:Integer;
begin
  inherited;
  //2011.09.28
  if cboClassMat.Text<>'' then
  begin
    sClassMat:= cboClassMat.Text;
    qryMatClass.Close;
    qryMatClass.Parameters.ParamByName('ClassMat').Value:=sClassMat;
    qryMatClass.Open;
    rdoMatClass.Refresh;

    //2016.07.22
    if sDefClass<>'' then
    begin
      if sClassMat<>sDefClass then
        pnlCond_JH.Visible:=False
      else
      begin
        pnlCond_JH.Visible:=True;
        i_JH:=1;
        while i_JH<=11 do
        begin
          TJSdLookupCombo(dlgLayerPressSet.FindComponent('JSdLookupCombo'
                    +IntToStr(i_JH))).Text:='';
          inc(i_JH);
        end;
      end;
    end;
    //2016.07.22 End
  end;
end;

procedure TdlgLayerPressSet.cboSupIdChange(Sender: TObject);
var tClass: String; //2011.12.02
begin
  inherited;
  tClass:= TRadioData(rdoMatClass.DataList[rdoMatClass.ItemIndex]^).Value;
  //CurrMatClass:= TRadioData(rdoMatClass.DataList[rdoMatClass.ItemIndex]^).Value;
  if tClass<>CurrMatClass then
  begin
    CurrMatClass:=tClass;
    DoChoice(CurrMatClass);
    msSelects.setup(slSource);
  end;
end;

