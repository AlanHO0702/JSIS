procedure TdlgLayerPressSet.btnOKClick(Sender: TObject);
var i: integer;
begin
  inherited;
         with qryLayerCheck do
         begin
            for i:= 0 to msSelects.TargetItems.Count-1 do
            begin
              Close;
              Parameters.ParamByName('PartNum').Value :=   pCurrPartNum  ;
              Parameters.ParamByName('Revision').Value :=  pCurrRevision ;
              Parameters.ParamByName('LayerId').Value :=   pCurrLayerId  ;
              Parameters.ParamByName('SerialNum').Value := i+1;
              Parameters.ParamByName('matcode').Value:= msSelects.TargetItems[i].Caption;
              Open;
              If FieldByName('sound').Asstring <> '' then
              Begin
                ShowMessage(FieldByName('sound').Asstring);
                abort;
              end;
            end;
         end;
  self.ModalResult := mrOk;
end;

