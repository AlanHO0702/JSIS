procedure TdlgLayerPressSet.DoChoice(sMatClass:String);
var sCond:String;
    i_JH:Integer;
begin
  if sDefClass<>'' then
  begin
    sCond:='';
    i_JH:=1;
    while i_JH<=11 do
    begin
      sCond:=sCond +
        TJSdLookupCombo(dlgLayerPressSet.FindComponent('JSdLookupCombo'
          +IntToStr(i_JH))).Text + ';';
      inc(i_JH);
    end;

    with qryPressMat_JH do
    begin
       close;
       Parameters.ParamByName('MatClass').Value:=sMatClass;
       Parameters.ParamByName('CondStr').Value:=sCond;
       open;
    end;
  end
  else
  begin
    with qryPressMat do
    begin
       close;
       Parameters.ParamByName('MatClass').Value:=sMatClass;
       open;
    end;
  end;
end;

