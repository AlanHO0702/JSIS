    tblAddData.FieldByName('DtlNumName_B').AswideString:=''
  else
  begin
    tblAddData.FieldByName('DtlNumName_B').AswideString
      := qrySetNumSubDtl.FieldByName('DtlNumName').AswideString;
  end;
end;

procedure TdlgLayerPressSet.btnSortClick(Sender: TObject);
var i, iSPId: integer;
begin
  inherited;
  //2016.07.26
  with qryPressTmp do
  begin
    qryPressTmp.Close;
    SQL.Clear;
    SQL.Add('select Value=@@SPId');
    Open;
    iSPId:=FieldByName('Value').AsInteger;

    for i:= 0 to msSelects.TargetItems.Count-1 do
    begin
      qryPressTmp.Close;
      SQL.Clear;
      SQL.Add('exec EMOdChoicePressSort 0, '''+pCurrPartNum+''','
        +''''+pCurrRevision+''','''+pCurrLayerId+''','+IntToStr(i+1)+','
        +''''+msSelects.TargetItems[i].Caption+''','+IntToStr(iSPId));
      ExecSql;
    end;

    qryPressTmp.Close;
    SQL.Clear;
    SQL.Add('exec EMOdChoicePressSort 1, '''+pCurrPartNum+''','
        +''''+pCurrRevision+''','''+pCurrLayerId+''',0,'''','
        +IntToStr(iSPId));
    ExecSql;

    qryLayerPress2.Close;
    qryLayerPress2.Parameters.ParamByName('SPId').Value:=iSPId;
    qryLayerPress2.Open;
    dsLayerPress.DataSet:=qryLayerPress2;
    msSelects.setup(slTarget);

    qryPressTmp.Close;
    SQL.Clear;
    SQL.Add('delete EMOdChoicePressTemp where SPId='+IntToStr(iSPId));
    ExecSql;
  end;

end;

