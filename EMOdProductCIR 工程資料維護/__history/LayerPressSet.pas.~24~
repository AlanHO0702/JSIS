 procedure TdlgLayerPressSet.tblAddDataAfterScroll(DataSet: TDataSet);
begin
  inherited;
  qrySetNumSubDtl.Close;
  qrySetNumSubDtl.SQL.Clear;
  qrySetNumSubDtl.SQL.Add('Select * From MGNdSetNumSubDtl (nolock) ');
  qrySetNumSubDtl.SQL.Add(' where SetClass = '''+  tblAddData.FieldByName('SetClass').AsString + '''');
  qrySetNumSubDtl.SQL.Add(' And NumId = ''' + tblAddData.FieldByName('NumId').AsString + '''');
  qrySetNumSubDtl.SQL.Add(' Order By SetClass ');
  qrySetNumSubDtl.Open;
end;

