    qrySetNumTable.Parameters.ParamByName('SetClass').Value := 11;
    qrySetNumTable.Parameters.ParamByName('PartNum').Value := '';//2008.12.26 add for RD
    qrySetNumTable.Parameters.ParamByName('Kind').Value := 1; //2008.12.26 add for RD
    qrySetNumTable.Open;

    Spid := qrySetNumTable.FieldByName('Spid').AsInteger;

    tblAddData.Close;
